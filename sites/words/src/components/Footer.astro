---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const labels: Record<string, { home: string; sister: string }> = {
  en: { home: 'Home', sister: 'Sister Site' },
  es: { home: 'Inicio', sister: 'Sitio Hermano' },
  'zh-tw': { home: '首頁', sister: '姊妹站' },
  th: { home: 'หน้าแรก', sister: 'เว็บไซต์พี่น้อง' },
};

const t = labels[locale] || labels.en;
---

<footer>
  <div class="footer-inner">
    <p>Nihongo Fun — <a href={`/${locale}/`}>{t.home}</a></p>
    <p class="sister">
      {t.sister}: <a href="https://japanmanners.com" target="_blank" rel="noopener">JapanManners.com</a>
    </p>
  </div>
</footer>

<style>
  footer {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 24px;
    text-align: center;
    font-size: 13px;
    color: var(--text-light);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sister {
    font-size: 12px;
    color: var(--text-light);
  }
  .sister a {
    color: var(--text-light);
    text-decoration-color: var(--border);
  }
  .sister a:hover {
    color: var(--accent);
  }
</style>

---
interface Props {
  japanese: string;
  romaji: string;
  category: string;
  collectionLabel: string;
  jlpt?: string;
}

const { japanese, romaji, category, collectionLabel, jlpt } = Astro.props;
---

<div class="hero-card">
  <div class="hero-inner">
    <div class="hero-top">
      <div class="hero-illustration">
        <slot name="hero-svg" />
      </div>
      <div class="hero-japanese">{japanese}</div>
      <div class="hero-reading">{romaji}</div>
      <div class="hero-badge-row">
        <div class="hero-badge">{collectionLabel} · {category}</div>
        {jlpt && <div class="hero-jlpt-badge">{jlpt}</div>}
      </div>
    </div>
    <div class="hero-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .hero-card {
    max-width: 720px;
    margin: 16px auto 0;
    padding: 0 24px;
  }
  .hero-inner {
    background: var(--card);
    border-radius: 16px;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .hero-top {
    background: linear-gradient(135deg, #e8f5e9 0%, #e0f2f1 100%);
    color: var(--text);
    padding: 40px 32px;
    text-align: center;
  }
  .hero-illustration {
    margin-bottom: 12px;
  }
  .hero-illustration:empty {
    display: none;
  }
  .hero-japanese {
    font-family: var(--jp-font);
    font-size: 48px;
    font-weight: 700;
    letter-spacing: 4px;
  }
  .hero-reading {
    font-size: 18px;
    color: var(--text-light);
    margin-top: 4px;
  }
  .hero-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(0,0,0,0.06);
    padding: 6px 20px;
    border-radius: 24px;
    font-size: 15px;
    backdrop-filter: blur(4px);
  }
  .hero-jlpt-badge {
    display: inline-block;
    background: rgba(0,0,0,0.06);
    padding: 6px 16px;
    border-radius: 24px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    backdrop-filter: blur(4px);
  }
  .hero-body {
    padding: 24px 32px;
  }
  @media (max-width: 600px) {
    .hero-japanese { font-size: 36px; }
    .hero-body { padding: 16px 20px; }
  }
</style>

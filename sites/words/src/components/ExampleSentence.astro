---
interface Props {
  japanese: string;
  reading: string;
  translation: string;
}

const { japanese, reading, translation } = Astro.props;
---

<div class="example">
  <div class="example-jp">{japanese}</div>
  <div class="example-reading">{reading}</div>
  <div class="example-translation">{translation}</div>
</div>

<style>
  .example {
    background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 100%);
    border-radius: 12px;
    padding: 16px 20px;
    margin: 12px 0;
  }
  .example-jp {
    font-family: var(--jp-font);
    font-size: 18px;
    font-weight: 500;
  }
  .example-reading {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 4px;
  }
  .example-translation {
    font-size: 14px;
    margin-top: 8px;
    color: var(--text-light);
  }
</style>

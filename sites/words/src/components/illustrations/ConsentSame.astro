<!-- Pattern A: Same object (electrical outlet) — called コンセント in JP, outlet in EN -->
<svg viewBox="0 0 180 140" width="180" height="140" xmlns="http://www.w3.org/2000/svg" style="margin: 0 auto; display: block;">
  <rect width="180" height="140" fill="#f0f7ff" rx="8"/>
  <!-- Wall -->
  <rect x="30" y="10" width="120" height="120" fill="#e8e0d4" rx="4"/>
  <!-- Outlet plate -->
  <rect x="50" y="25" width="80" height="90" fill="#f5f5f5" rx="10" stroke="#ccc" stroke-width="2"/>
  <!-- Screw top -->
  <circle cx="90" cy="36" r="3" fill="#bbb" stroke="#999" stroke-width="0.5"/>
  <!-- Top pair slots -->
  <rect x="73" y="47" width="8" height="20" fill="#333" rx="2"/>
  <rect x="99" y="47" width="8" height="20" fill="#333" rx="2"/>
  <!-- Bottom pair slots -->
  <rect x="73" y="80" width="8" height="20" fill="#333" rx="2"/>
  <rect x="99" y="80" width="8" height="20" fill="#333" rx="2"/>
  <!-- Screw bottom -->
  <circle cx="90" cy="108" r="3" fill="#bbb" stroke="#999" stroke-width="0.5"/>
</svg>

<!-- Fluffy round cat — モフモフ (mofumofu) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fef6f0" rx="8"/>
  <!-- Body — big fluffy round shape -->
  <ellipse cx="100" cy="105" rx="52" ry="40" fill="#f5e0d0"/>
  <!-- Fluffy fur tufts around body -->
  <circle cx="55" cy="90" r="12" fill="#faeade"/>
  <circle cx="145" cy="90" r="12" fill="#faeade"/>
  <circle cx="60" cy="110" r="10" fill="#faeade"/>
  <circle cx="140" cy="110" r="10" fill="#faeade"/>
  <circle cx="70" cy="125" r="9" fill="#faeade"/>
  <circle cx="130" cy="125" r="9" fill="#faeade"/>
  <circle cx="85" cy="132" r="8" fill="#faeade"/>
  <circle cx="115" cy="132" r="8" fill="#faeade"/>
  <!-- Head -->
  <circle cx="100" cy="65" r="30" fill="#f5e0d0"/>
  <!-- Ears -->
  <polygon points="78,42 70,18 90,35" fill="#f5e0d0"/>
  <polygon points="122,42 130,18 110,35" fill="#f5e0d0"/>
  <polygon points="80,40 74,24 88,36" fill="#f2c4b0"/>
  <polygon points="120,40 126,24 112,36" fill="#f2c4b0"/>
  <!-- Eyes -->
  <ellipse cx="88" cy="62" rx="4" ry="4.5" fill="#5d4037"/>
  <ellipse cx="112" cy="62" rx="4" ry="4.5" fill="#5d4037"/>
  <circle cx="86" cy="60" r="1.5" fill="white"/>
  <circle cx="110" cy="60" r="1.5" fill="white"/>
  <!-- Nose -->
  <ellipse cx="100" cy="72" rx="3" ry="2" fill="#e8a0a0"/>
  <!-- Mouth -->
  <path d="M97,74 Q100,78 103,74" fill="none" stroke="#c48080" stroke-width="1" stroke-linecap="round"/>
  <!-- Cheek blush -->
  <ellipse cx="80" cy="72" rx="6" ry="3.5" fill="#f8c0b0" opacity="0.5"/>
  <ellipse cx="120" cy="72" rx="6" ry="3.5" fill="#f8c0b0" opacity="0.5"/>
  <!-- Tail — fluffy -->
  <ellipse cx="155" cy="110" rx="18" ry="10" fill="#f5e0d0" transform="rotate(-30, 155, 110)"/>
  <circle cx="168" cy="100" r="7" fill="#faeade"/>
  <!-- Sparkles to show fluffiness -->
  <text x="38" y="50" font-size="14" fill="#ffb74d" opacity="0.7">✦</text>
  <text x="155" y="42" font-size="12" fill="#ffb74d" opacity="0.7">✦</text>
  <text x="165" y="72" font-size="10" fill="#ffb74d" opacity="0.5">✦</text>
</svg>

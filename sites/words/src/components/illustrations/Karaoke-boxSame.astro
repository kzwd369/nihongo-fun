<!-- カラオケボックス = private karaoke room -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#311b92" rx="8"/>
  <!-- Room walls gradient effect -->
  <rect x="10" y="20" width="180" height="110" fill="#512da8" rx="4"/>
  <!-- Disco floor pattern -->
  <rect x="10" y="115" width="180" height="15" fill="#4527a0"/>
  <!-- TV screen on wall -->
  <rect x="65" y="30" width="70" height="45" fill="#1a237e" stroke="#7c4dff" stroke-width="2" rx="3"/>
  <!-- Lyrics on screen -->
  <rect x="72" y="38" width="56" height="4" fill="#ffeb3b" rx="1"/>
  <rect x="75" y="46" width="50" height="4" fill="#ffeb3b" rx="1" opacity="0.7"/>
  <rect x="78" y="54" width="44" height="4" fill="#ffeb3b" rx="1" opacity="0.5"/>
  <!-- Video background on screen -->
  <circle cx="85" cy="65" r="4" fill="#f48fb1"/>
  <circle cx="115" cy="65" r="3" fill="#80deea"/>
  <!-- Sofa (curved shape, bottom) -->
  <rect x="25" y="95" width="60" height="25" fill="#c2185b" stroke="#880e4f" stroke-width="1" rx="6"/>
  <rect x="25" y="92" width="60" height="8" fill="#e91e63" rx="4"/>
  <rect x="115" y="95" width="60" height="25" fill="#c2185b" stroke="#880e4f" stroke-width="1" rx="6"/>
  <rect x="115" y="92" width="60" height="8" fill="#e91e63" rx="4"/>
  <!-- Table with drinks -->
  <ellipse cx="100" cy="118" rx="16" ry="4" fill="#4e342e"/>
  <rect x="90" y="110" width="5" height="8" fill="#6d4c41"/>
  <rect x="105" y="110" width="5" height="8" fill="#ffecb3"/>
  <!-- Microphone front and center -->
  <rect x="96" y="80" width="8" height="20" fill="#424242" rx="2"/>
  <circle cx="100" cy="80" r="8" fill="#616161" stroke="#212121" stroke-width="1"/>
  <circle cx="100" cy="80" r="5" fill="#424242"/>
  <line x1="97" y1="78" x2="103" y2="78" stroke="#9e9e9e" stroke-width="0.5"/>
  <line x1="97" y1="80" x2="103" y2="80" stroke="#9e9e9e" stroke-width="0.5"/>
  <line x1="97" y1="82" x2="103" y2="82" stroke="#9e9e9e" stroke-width="0.5"/>
  <!-- Music notes floating -->
  <text x="35" y="50" font-size="14" fill="#ffeb3b">♪</text>
  <text x="165" y="45" font-size="16" fill="#ff80ab">♫</text>
  <text x="30" y="80" font-size="12" fill="#80deea">♪</text>
  <text x="170" y="75" font-size="14" fill="#ffeb3b">♫</text>
  <!-- Disco lights -->
  <circle cx="40" cy="30" r="3" fill="#ff4081" opacity="0.8"/>
  <circle cx="160" cy="30" r="3" fill="#80deea" opacity="0.8"/>
  <circle cx="100" cy="18" r="4" fill="#ffeb3b" opacity="0.8"/>
  <!-- Label -->
  <text x="100" y="146" font-size="10" font-weight="bold" fill="#ffeb3b" text-anchor="middle">カラオケボックス = Private Karaoke Room</text>
  <text x="100" y="156" font-size="7" fill="#b39ddb" text-anchor="middle">貸切個室・時間制・ドリンクバー付き</text>
</svg>

<!-- Japanese サイン = signature/autograph written by hand on paper -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Paper/document -->
  <rect x="40" y="20" width="120" height="120" fill="white" rx="2" stroke="#d0d0d0" stroke-width="1"/>
  <!-- Lines on paper -->
  <line x1="55" y1="40" x2="145" y2="40" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="55" y1="52" x2="145" y2="52" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="55" y1="64" x2="145" y2="64" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="55" y1="76" x2="145" y2="76" stroke="#e0e0e0" stroke-width="0.8"/>
  <!-- Text lines (simulated) -->
  <rect x="55" y="36" width="60" height="3" fill="#bdbdbd" rx="1"/>
  <rect x="55" y="48" width="80" height="3" fill="#bdbdbd" rx="1"/>
  <rect x="55" y="60" width="50" height="3" fill="#bdbdbd" rx="1"/>
  <!-- Signature line -->
  <line x1="55" y1="105" x2="145" y2="105" stroke="#37474f" stroke-width="1"/>
  <text x="100" y="118" font-size="7" fill="#78909c" text-anchor="middle" font-family="sans-serif">サイン</text>
  <!-- Stylish signature scrawl -->
  <path d="M65 98 Q75 85 85 95 Q95 105 105 90 Q110 84 115 92 Q120 100 130 88" fill="none" stroke="#1565c0" stroke-width="2" stroke-linecap="round"/>
  <!-- Pen -->
  <line x1="130" y1="88" x2="155" y2="58" stroke="#37474f" stroke-width="3" stroke-linecap="round"/>
  <polygon points="155,58 158,50 152,54" fill="#37474f"/>
  <!-- Pen grip detail -->
  <rect x="139" y="70" width="8" height="4" fill="#78909c" rx="1" transform="rotate(-50 143 72)"/>
  <!-- Small stamp/hanko for cultural reference -->
  <circle cx="148" cy="125" r="8" fill="none" stroke="#e53935" stroke-width="1.5"/>
  <text x="148" y="128" font-size="7" fill="#e53935" text-anchor="middle" font-family="serif">印</text>
</svg>

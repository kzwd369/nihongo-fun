<!-- Japanese プラスアルファ = + α (an unspecified extra) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e1f5fe" rx="8"/>
  <!-- Job posting / salary slip -->
  <rect x="20" y="22" width="160" height="100" fill="#fff" stroke="#0277bd" stroke-width="2" rx="4"/>
  <!-- Header -->
  <rect x="20" y="22" width="160" height="20" fill="#0277bd" rx="4"/>
  <text x="100" y="36" font-size="11" font-weight="bold" fill="#fff" text-anchor="middle">求人募集 / 給与</text>
  <!-- "Base salary" line -->
  <text x="35" y="58" font-size="9" fill="#37474f">基本月給</text>
  <text x="170" y="58" font-size="11" font-weight="bold" fill="#37474f" text-anchor="end">¥250,000</text>
  <line x1="35" y1="64" x2="170" y2="64" stroke="#cfd8dc" stroke-width="0.5"/>
  <!-- Plus alpha line (highlighted) -->
  <text x="35" y="82" font-size="9" fill="#c62828" font-weight="bold">＋α</text>
  <text x="170" y="82" font-size="11" font-weight="bold" fill="#c62828" text-anchor="end">+ ?</text>
  <!-- The mystery alpha symbol big -->
  <circle cx="100" cy="100" r="14" fill="#fff9c4" stroke="#f57f17" stroke-width="1.5"/>
  <text x="100" y="106" font-size="20" font-weight="bold" fill="#f57f17" text-anchor="middle">α</text>
  <!-- Bonus arrows pointing in -->
  <path d="M50 100 L82 100" stroke="#f57f17" stroke-width="1.5"/>
  <polygon points="82,100 78,97 78,103" fill="#f57f17"/>
  <path d="M150 100 L118 100" stroke="#f57f17" stroke-width="1.5"/>
  <polygon points="118,100 122,97 122,103" fill="#f57f17"/>
  <!-- Bonus tags -->
  <rect x="22" y="93" width="28" height="14" fill="#ffd54f" stroke="#f57c00" stroke-width="0.5" rx="2"/>
  <text x="36" y="103" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">賞与</text>
  <rect x="150" y="93" width="28" height="14" fill="#ffd54f" stroke="#f57c00" stroke-width="0.5" rx="2"/>
  <text x="164" y="103" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">手当</text>
  <!-- "+more" text under alpha -->
  <text x="100" y="124" font-size="7" fill="#5d4037" text-anchor="middle">残業代・通勤費・etc</text>
  <!-- Sparkles -->
  <text x="80" y="85" font-size="8" fill="#ffd54f">✦</text>
  <text x="120" y="115" font-size="9" fill="#ffd54f">✦</text>
  <!-- Label -->
  <text x="100" y="20" font-size="9" font-weight="bold" fill="#0277bd" text-anchor="middle">月給25万円 ＋α (プラスアルファ)</text>
  <text x="100" y="148" font-size="10" font-weight="bold" fill="#0277bd" text-anchor="middle">プラスアルファ = +α (a little extra)</text>
  <text x="100" y="157" font-size="7" fill="#0288d1" text-anchor="middle">数値は曖昧、それが狙い</text>
</svg>

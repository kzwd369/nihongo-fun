<!-- Japanese ホットケーキ = thick, sweet, fluffy dessert-style pancake -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Warm sparkle background -->
  <text x="30" y="30" font-size="14" fill="#ffd54f" opacity="0.7">✦</text>
  <text x="165" y="40" font-size="12" fill="#ffd54f" opacity="0.7">✦</text>
  <text x="170" y="110" font-size="10" fill="#ffd54f" opacity="0.7">✦</text>
  <text x="25" y="115" font-size="12" fill="#ffd54f" opacity="0.7">✦</text>
  <!-- Plate -->
  <ellipse cx="100" cy="128" rx="70" ry="10" fill="#eceff1" stroke="#b0bec5" stroke-width="1.5"/>
  <ellipse cx="100" cy="127" rx="60" ry="7" fill="white"/>
  <!-- Hot cake stack (3 thick fluffy layers) -->
  <!-- Bottom cake -->
  <ellipse cx="100" cy="120" rx="48" ry="9" fill="#bf8141"/>
  <path d="M52,120 Q52,108 100,108 Q148,108 148,120 Z" fill="#d4a066"/>
  <ellipse cx="100" cy="108" rx="48" ry="9" fill="#e5b579"/>
  <!-- Middle cake -->
  <ellipse cx="100" cy="101" rx="45" ry="8" fill="#bf8141"/>
  <path d="M55,101 Q55,90 100,90 Q145,90 145,101 Z" fill="#d4a066"/>
  <ellipse cx="100" cy="90" rx="45" ry="8" fill="#e5b579"/>
  <!-- Top cake -->
  <ellipse cx="100" cy="83" rx="42" ry="7" fill="#bf8141"/>
  <path d="M58,83 Q58,72 100,72 Q142,72 142,83 Z" fill="#d4a066"/>
  <ellipse cx="100" cy="72" rx="42" ry="7" fill="#e5b579"/>
  <!-- Butter cube melting on top -->
  <rect x="88" y="62" width="18" height="10" fill="#fff59d" rx="1"/>
  <rect x="88" y="62" width="18" height="3" fill="#fff176"/>
  <!-- Melted butter dripping -->
  <path d="M90,72 Q88,78 89,83" fill="none" stroke="#fff176" stroke-width="2" stroke-linecap="round"/>
  <!-- Syrup dripping down sides -->
  <path d="M100,65 Q95,68 92,72 Q95,76 93,83 Q90,90 94,101 Q88,108 92,120" fill="none" stroke="#8d6e63" stroke-width="3" stroke-linecap="round"/>
  <path d="M110,68 Q115,72 112,83 Q118,90 114,101 Q120,108 116,120" fill="none" stroke="#8d6e63" stroke-width="3" stroke-linecap="round"/>
  <!-- Syrup pool on plate -->
  <ellipse cx="100" cy="127" rx="35" ry="4" fill="#a1887f" opacity="0.6"/>
  <!-- Steam rising -->
  <path d="M85,55 Q82,48 85,42 Q88,36 85,30" fill="none" stroke="#eceff1" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <path d="M115,55 Q118,48 115,42 Q112,36 115,30" fill="none" stroke="#eceff1" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <!-- Label -->
  <text x="100" y="150" font-size="10" font-weight="bold" fill="#6d4c41" text-anchor="middle">ホットケーキ（おやつ）</text>
</svg>

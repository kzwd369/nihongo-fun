<!-- ビジネスホテル = compact business hotel near a station -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Sky cloud -->
  <ellipse cx="40" cy="22" rx="18" ry="7" fill="white" opacity="0.7"/>
  <ellipse cx="160" cy="18" rx="16" ry="6" fill="white" opacity="0.7"/>
  <!-- Ground -->
  <rect x="0" y="143" width="200" height="17" fill="#cfd8dc"/>
  <!-- Sidewalk lines -->
  <line x1="0" y1="148" x2="200" y2="148" stroke="#b0bec5" stroke-width="0.5"/>
  <line x1="50" y1="143" x2="50" y2="160" stroke="#b0bec5" stroke-width="0.5"/>
  <line x1="120" y1="143" x2="120" y2="160" stroke="#b0bec5" stroke-width="0.5"/>
  <!-- Hotel building (tall narrow) -->
  <rect x="55" y="25" width="90" height="118" fill="#eceff1" stroke="#90a4ae" stroke-width="1.2"/>
  <!-- Roof slab -->
  <rect x="52" y="22" width="96" height="5" fill="#78909c"/>
  <!-- Ground floor entrance -->
  <rect x="60" y="120" width="80" height="23" fill="#37474f"/>
  <rect x="90" y="125" width="20" height="18" fill="#90caf9" rx="1"/>
  <line x1="100" y1="125" x2="100" y2="143" stroke="#37474f" stroke-width="0.8"/>
  <!-- Hotel sign -->
  <rect x="68" y="123" width="20" height="8" fill="#1565c0" rx="1"/>
  <text x="78" y="129" font-size="5" fill="white" text-anchor="middle" font-weight="bold" font-family="sans-serif">HOTEL</text>
  <rect x="112" y="123" width="20" height="8" fill="#1565c0" rx="1"/>
  <text x="122" y="129" font-size="4" fill="white" text-anchor="middle" font-family="sans-serif">24H Front</text>
  <!-- Tiny windows in a grid (many compact rooms) -->
  <g fill="#bbdefb" stroke="#78909c" stroke-width="0.4">
    <!-- floor 1 (top) -->
    <rect x="62" y="32" width="9" height="10" rx="0.5"/>
    <rect x="74" y="32" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="86" y="32" width="9" height="10" rx="0.5"/>
    <rect x="98" y="32" width="9" height="10" rx="0.5"/>
    <rect x="110" y="32" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="122" y="32" width="9" height="10" rx="0.5"/>
    <rect x="134" y="32" width="6" height="10" rx="0.5"/>
    <!-- floor 2 -->
    <rect x="62" y="46" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="74" y="46" width="9" height="10" rx="0.5"/>
    <rect x="86" y="46" width="9" height="10" rx="0.5"/>
    <rect x="98" y="46" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="110" y="46" width="9" height="10" rx="0.5"/>
    <rect x="122" y="46" width="9" height="10" rx="0.5"/>
    <rect x="134" y="46" width="6" height="10" rx="0.5" fill="#fff9c4"/>
    <!-- floor 3 -->
    <rect x="62" y="60" width="9" height="10" rx="0.5"/>
    <rect x="74" y="60" width="9" height="10" rx="0.5"/>
    <rect x="86" y="60" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="98" y="60" width="9" height="10" rx="0.5"/>
    <rect x="110" y="60" width="9" height="10" rx="0.5"/>
    <rect x="122" y="60" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="134" y="60" width="6" height="10" rx="0.5"/>
    <!-- floor 4 -->
    <rect x="62" y="74" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="74" y="74" width="9" height="10" rx="0.5"/>
    <rect x="86" y="74" width="9" height="10" rx="0.5"/>
    <rect x="98" y="74" width="9" height="10" rx="0.5"/>
    <rect x="110" y="74" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="122" y="74" width="9" height="10" rx="0.5"/>
    <rect x="134" y="74" width="6" height="10" rx="0.5"/>
    <!-- floor 5 -->
    <rect x="62" y="88" width="9" height="10" rx="0.5"/>
    <rect x="74" y="88" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="86" y="88" width="9" height="10" rx="0.5"/>
    <rect x="98" y="88" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="110" y="88" width="9" height="10" rx="0.5"/>
    <rect x="122" y="88" width="9" height="10" rx="0.5"/>
    <rect x="134" y="88" width="6" height="10" rx="0.5" fill="#fff9c4"/>
    <!-- floor 6 -->
    <rect x="62" y="102" width="9" height="10" rx="0.5"/>
    <rect x="74" y="102" width="9" height="10" rx="0.5"/>
    <rect x="86" y="102" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="98" y="102" width="9" height="10" rx="0.5"/>
    <rect x="110" y="102" width="9" height="10" rx="0.5"/>
    <rect x="122" y="102" width="9" height="10" rx="0.5" fill="#fff9c4"/>
    <rect x="134" y="102" width="6" height="10" rx="0.5"/>
  </g>
  <!-- Train track in foreground hint (station nearby) -->
  <rect x="0" y="153" width="200" height="2" fill="#90a4ae"/>
  <rect x="0" y="158" width="200" height="2" fill="#90a4ae"/>
  <!-- Briefcase in foreground -->
  <rect x="158" y="128" width="20" height="14" fill="#5d4037" rx="1.5"/>
  <rect x="158" y="128" width="20" height="3" fill="#3e2723"/>
  <rect x="166" y="123" width="4" height="6" fill="none" stroke="#3e2723" stroke-width="1.2"/>
  <circle cx="167" cy="135" r="0.8" fill="#ffd54f"/>
  <circle cx="170" cy="135" r="0.8" fill="#ffd54f"/>
</svg>

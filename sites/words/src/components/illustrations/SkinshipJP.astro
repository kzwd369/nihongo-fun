<!-- Japanese スキンシップ = physical bonding / affectionate touch (parent and child) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Warm background glow -->
  <circle cx="100" cy="80" r="55" fill="#ffecb3" opacity="0.4"/>
  <!-- Parent - head -->
  <circle cx="82" cy="48" r="16" fill="#ffe0b2"/>
  <!-- Parent - hair -->
  <path d="M66 44 Q66 30 82 28 Q98 30 98 44" fill="#5d4037" stroke="none"/>
  <!-- Parent - eyes -->
  <path d="M75 50 Q77 48 79 50" fill="none" stroke="#37474f" stroke-width="1.2" stroke-linecap="round"/>
  <path d="M85 50 Q87 48 89 50" fill="none" stroke="#37474f" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Parent - gentle smile -->
  <path d="M76 56 Q82 61 88 56" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Parent - body -->
  <path d="M66 64 L60 130 L104 130 L98 64 Z" fill="#81c784" rx="4"/>
  <!-- Parent - arms reaching to hold child -->
  <path d="M66 74 Q50 90 62 105" fill="none" stroke="#ffe0b2" stroke-width="6" stroke-linecap="round"/>
  <path d="M98 74 Q114 85 120 72" fill="none" stroke="#ffe0b2" stroke-width="6" stroke-linecap="round"/>
  <!-- Child - head -->
  <circle cx="122" cy="68" r="13" fill="#ffccbc"/>
  <!-- Child - hair -->
  <path d="M109 64 Q109 53 122 52 Q135 53 135 64" fill="#3e2723" stroke="none"/>
  <!-- Child - happy eyes -->
  <circle cx="117" cy="69" r="1.5" fill="#37474f"/>
  <circle cx="127" cy="69" r="1.5" fill="#37474f"/>
  <!-- Child - big happy smile -->
  <path d="M116 74 Q122 80 128 74" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Child - rosy cheeks -->
  <circle cx="113" cy="73" r="3" fill="#ffab91" opacity="0.5"/>
  <circle cx="131" cy="73" r="3" fill="#ffab91" opacity="0.5"/>
  <!-- Child - body -->
  <path d="M112 81 L108 130 L136 130 L132 81 Z" fill="#ffb74d"/>
  <!-- Child - arm reaching to parent -->
  <path d="M112 88 Q100 82 98 74" fill="none" stroke="#ffccbc" stroke-width="5" stroke-linecap="round"/>
  <!-- Holding hands detail -->
  <circle cx="98" cy="74" r="4" fill="#ffe0b2"/>
  <circle cx="99" cy="75" r="3.5" fill="#ffccbc"/>
  <!-- Small hearts -->
  <path d="M70 30 Q70 26 74 26 Q78 26 78 30 Q78 34 74 38 Q70 34 70 30" fill="#ef9a9a" opacity="0.6"/>
  <path d="M130 38 Q130 35 133 35 Q136 35 136 38 Q136 41 133 44 Q130 41 130 38" fill="#ef9a9a" opacity="0.5"/>
  <path d="M50 55 Q50 52 52.5 52 Q55 52 55 55 Q55 58 52.5 60 Q50 58 50 55" fill="#ef9a9a" opacity="0.4"/>
  <!-- Ground -->
  <rect x="20" y="130" width="160" height="4" fill="#ffe0b2" rx="2"/>
</svg>

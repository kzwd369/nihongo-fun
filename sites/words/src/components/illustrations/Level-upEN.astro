  <text x="30" y="128" font-size="9" font-weight="bold" fill="#ff5252" font-family="monospace">HP</text>
  <rect x="55" y="120" width="115" height="8" fill="#1a237e" stroke="#ff5252" stroke-width="1.5"/>
  <rect x="57" y="122" width="90" height="4" fill="#ff5252"/>

<!-- English "level up" = originated in video games, still informal slang -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#1a237e" rx="8"/>
  <!-- CRT scanlines effect -->
  <rect x="0" y="0" width="200" height="2" fill="#3949ab" opacity="0.3"/>
  <rect x="0" y="20" width="200" height="2" fill="#3949ab" opacity="0.3"/>
  <rect x="0" y="40" width="200" height="2" fill="#3949ab" opacity="0.3"/>
  <rect x="0" y="140" width="200" height="2" fill="#3949ab" opacity="0.3"/>
  <!-- "LEVEL UP!" retro game text -->
  <text x="100" y="35" font-size="20" font-weight="bold" fill="#ffeb3b" text-anchor="middle" font-family="monospace" stroke="#ff6f00" stroke-width="0.5">LEVEL UP!</text>
  <!-- Star burst behind text -->
  <polygon points="100,18 105,25 114,22 110,30 118,35 109,36 110,45 103,40 100,48 97,40 90,45 91,36 82,35 90,30 86,22 95,25" fill="#ffeb3b" opacity="0.2"/>
  <!-- Pixel-art RPG character -->
  <!-- Head pixels -->
  <rect x="90" y="55" width="4" height="4" fill="#ffccbc"/>
  <rect x="94" y="55" width="4" height="4" fill="#ffccbc"/>
  <rect x="98" y="55" width="4" height="4" fill="#ffccbc"/>
  <rect x="102" y="55" width="4" height="4" fill="#ffccbc"/>
  <rect x="86" y="59" width="4" height="4" fill="#5d4037"/>
  <rect x="90" y="59" width="4" height="4" fill="#ffccbc"/>
  <rect x="94" y="59" width="4" height="4" fill="#ffccbc"/>
  <rect x="98" y="59" width="4" height="4" fill="#ffccbc"/>
  <rect x="102" y="59" width="4" height="4" fill="#ffccbc"/>
  <rect x="106" y="59" width="4" height="4" fill="#5d4037"/>
  <rect x="86" y="63" width="4" height="4" fill="#5d4037"/>
  <rect x="90" y="63" width="4" height="4" fill="#3e2723"/>
  <rect x="94" y="63" width="4" height="4" fill="#ffccbc"/>
  <rect x="98" y="63" width="4" height="4" fill="#3e2723"/>
  <rect x="102" y="63" width="4" height="4" fill="#ffccbc"/>
  <rect x="106" y="63" width="4" height="4" fill="#5d4037"/>
  <rect x="90" y="67" width="4" height="4" fill="#ffccbc"/>
  <rect x="94" y="67" width="4" height="4" fill="#ffccbc"/>
  <rect x="98" y="67" width="4" height="4" fill="#ffccbc"/>
  <rect x="102" y="67" width="4" height="4" fill="#ffccbc"/>
  <!-- Body pixels (armor) -->
  <rect x="86" y="71" width="4" height="4" fill="#43a047"/>
  <rect x="90" y="71" width="4" height="4" fill="#43a047"/>
  <rect x="94" y="71" width="4" height="4" fill="#66bb6a"/>
  <rect x="98" y="71" width="4" height="4" fill="#66bb6a"/>
  <rect x="102" y="71" width="4" height="4" fill="#43a047"/>
  <rect x="106" y="71" width="4" height="4" fill="#43a047"/>
  <rect x="82" y="75" width="4" height="4" fill="#43a047"/>

  <text x="30" y="110" font-size="9" font-weight="bold" fill="#ffeb3b" font-family="monospace">EXP</text>
  <rect x="55" y="102" width="115" height="10" fill="#1a237e" stroke="#ffeb3b" stroke-width="1.5"/>
  <rect x="57" y="104" width="105" height="6" fill="#ffeb3b"/>

  <text x="25" y="150" font-size="9" font-weight="bold" fill="#4fc3f7" font-family="monospace">STR +2</text>
  <text x="85" y="150" font-size="9" font-weight="bold" fill="#4fc3f7" font-family="monospace">DEF +1</text>
  <text x="140" y="150" font-size="9" font-weight="bold" fill="#4fc3f7" font-family="monospace">MAG +3</text>

<!-- English "cost down" is not a noun — correct: "cost cutting" / "cost reduction" -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Speech bubble with "cost down?" crossed out -->
  <rect x="20" y="20" width="80" height="30" fill="white" stroke="#bdbdbd" stroke-width="1" rx="6"/>
  <polygon points="40,50 50,50 45,58" fill="white" stroke="#bdbdbd" stroke-width="1"/>
  <text x="60" y="40" font-size="11" fill="#424242" text-anchor="middle">"cost down"</text>
  <!-- Red X over phrase -->
  <line x1="25" y1="22" x2="95" y2="48" stroke="#e53935" stroke-width="3" stroke-linecap="round"/>
  <line x1="95" y1="22" x2="25" y2="48" stroke="#e53935" stroke-width="3" stroke-linecap="round"/>
  <!-- Confused English speaker -->
  <!-- Head -->
  <circle cx="45" cy="85" r="14" fill="#ffe0b2"/>
  <!-- Hair -->
  <path d="M32,82 Q32,70 45,68 Q58,70 58,82 L55,78 Q45,74 35,78 Z" fill="#8d6e63"/>
  <!-- Confused eyes -->
  <circle cx="40" cy="85" r="1.5" fill="#3e2723"/>
  <circle cx="50" cy="85" r="1.5" fill="#3e2723"/>
  <!-- Confused mouth (wavy) -->
  <path d="M40,92 Q43,90 46,92 Q49,94 52,92" fill="none" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Question marks -->
  <text x="28" y="65" font-size="14" font-weight="bold" fill="#ff7043">?</text>
  <text x="62" y="70" font-size="18" font-weight="bold" fill="#ff7043">?</text>
  <!-- Body -->
  <rect x="35" y="99" width="20" height="22" fill="#90caf9" rx="3"/>
  <!-- Shrugging arms -->
  <line x1="35" y1="102" x2="22" y2="94" stroke="#90caf9" stroke-width="5" stroke-linecap="round"/>
  <line x1="55" y1="102" x2="68" y2="94" stroke="#90caf9" stroke-width="5" stroke-linecap="round"/>
  <!-- Scissors cutting dollars (correct expression) -->
  <!-- Scissor blades -->
  <ellipse cx="135" cy="70" rx="4" ry="14" fill="#90a4ae" transform="rotate(-20 135 70)"/>
  <ellipse cx="145" cy="70" rx="4" ry="14" fill="#90a4ae" transform="rotate(20 145 70)"/>
  <!-- Scissor handle circles -->
  <circle cx="128" cy="86" r="5" fill="none" stroke="#546e7a" stroke-width="2"/>
  <circle cx="152" cy="86" r="5" fill="none" stroke="#546e7a" stroke-width="2"/>
  <!-- Dollar bill being cut -->
  <rect x="115" y="95" width="60" height="28" fill="#c8e6c9" stroke="#43a047" stroke-width="1.5" rx="2"/>
  <circle cx="145" cy="109" r="8" fill="none" stroke="#43a047" stroke-width="1"/>
  <text x="145" y="113" font-size="10" font-weight="bold" fill="#43a047" text-anchor="middle">$</text>
  <!-- Cut line -->
  <line x1="140" y1="95" x2="140" y2="123" stroke="#e53935" stroke-width="1" stroke-dasharray="2,2"/>
  <!-- "cost cutting" label -->
  <text x="145" y="140" font-size="10" font-weight="bold" fill="#2e7d32" text-anchor="middle">cost cutting ✓</text>
  <!-- Floor -->
  <rect x="0" y="145" width="200" height="15" fill="#ffccbc" rx="0"/>
</svg>

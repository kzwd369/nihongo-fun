<!-- Taiko drum with sound burst — ドンドン (heavy knocking / drum beat) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Sound burst rings -->
  <g fill="none" stroke="#ef6c00" stroke-linecap="round" opacity="0.6">
    <path d="M30 55 Q22 75 30 95" stroke-width="2.5"/>
    <path d="M18 45 Q5 75 18 105" stroke-width="2"/>
    <path d="M170 55 Q178 75 170 95" stroke-width="2.5"/>
    <path d="M182 45 Q195 75 182 105" stroke-width="2"/>
  </g>
  <!-- Drum stand legs -->
  <line x1="70" y1="135" x2="55" y2="155" stroke="#5d4037" stroke-width="4" stroke-linecap="round"/>
  <line x1="130" y1="135" x2="145" y2="155" stroke="#5d4037" stroke-width="4" stroke-linecap="round"/>
  <!-- Drum body (side) -->
  <rect x="60" y="65" width="80" height="70" fill="#8d6e63" rx="4"/>
  <!-- Drum horizontal bands -->
  <rect x="60" y="78" width="80" height="4" fill="#5d4037"/>
  <rect x="60" y="118" width="80" height="4" fill="#5d4037"/>
  <!-- Drum face (front ellipse) -->
  <ellipse cx="100" cy="75" rx="40" ry="12" fill="#efebe9" stroke="#5d4037" stroke-width="2"/>
  <!-- Tacks around drum face -->
  <circle cx="70" cy="75" r="1.8" fill="#5d4037"/>
  <circle cx="80" cy="71" r="1.8" fill="#5d4037"/>
  <circle cx="100" cy="69" r="1.8" fill="#5d4037"/>
  <circle cx="120" cy="71" r="1.8" fill="#5d4037"/>
  <circle cx="130" cy="75" r="1.8" fill="#5d4037"/>
  <!-- Impact star on drum face -->
  <polygon points="100,60 104,70 114,70 106,76 109,86 100,80 91,86 94,76 86,70 96,70" fill="#ffb74d" opacity="0.9"/>
  <!-- Drumstick -->
  <line x1="115" y1="30" x2="98" y2="65" stroke="#6d4c41" stroke-width="4" stroke-linecap="round"/>
  <circle cx="98" cy="65" r="5" fill="#6d4c41"/>
  <!-- ドン text -->
  <text x="40" y="35" font-family="sans-serif" font-size="20" font-weight="900" fill="#d84315" opacity="0.85">ドン!</text>
  <text x="140" y="40" font-family="sans-serif" font-size="18" font-weight="900" fill="#d84315" opacity="0.7">ドン!</text>
</svg>

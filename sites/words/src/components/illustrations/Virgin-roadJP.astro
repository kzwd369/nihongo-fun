<!-- Japanese バージンロード = chapel wedding aisle -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff" rx="8"/>
  <!-- Chapel interior background -->
  <rect x="0" y="0" width="200" height="130" fill="#fff9e6"/>
  <!-- Floor -->
  <rect x="0" y="130" width="200" height="30" fill="#d7ccc8"/>
  <!-- Stained glass window (back) -->
  <rect x="85" y="15" width="30" height="50" fill="#c5cae9" stroke="#1a237e" stroke-width="1" rx="15"/>
  <line x1="100" y1="20" x2="100" y2="60" stroke="#1a237e" stroke-width="0.5"/>
  <line x1="87" y1="40" x2="113" y2="40" stroke="#1a237e" stroke-width="0.5"/>
  <rect x="88" y="22" width="11" height="16" fill="#ef5350" opacity="0.6"/>
  <rect x="101" y="22" width="11" height="16" fill="#42a5f5" opacity="0.6"/>
  <rect x="88" y="42" width="11" height="16" fill="#ffb74d" opacity="0.6"/>
  <rect x="101" y="42" width="11" height="16" fill="#66bb6a" opacity="0.6"/>
  <!-- Cross above window -->
  <rect x="99" y="6" width="2" height="10" fill="#8d6e63"/>
  <rect x="96" y="9" width="8" height="2" fill="#8d6e63"/>
  <!-- Altar -->
  <rect x="80" y="70" width="40" height="15" fill="#fff" stroke="#bdbdbd" stroke-width="1"/>
  <rect x="85" y="72" width="30" height="2" fill="#ffd54f"/>
  <!-- Candles -->
  <rect x="85" y="62" width="2" height="10" fill="#fff9c4"/>
  <ellipse cx="86" cy="60" rx="1" ry="2" fill="#ff9800"/>
  <rect x="113" y="62" width="2" height="10" fill="#fff9c4"/>
  <ellipse cx="114" cy="60" rx="1" ry="2" fill="#ff9800"/>
  <!-- Groom at altar -->
  <circle cx="100" cy="80" r="4" fill="#ffcc80"/>
  <rect x="97" y="83" width="6" height="15" fill="#212121"/>
  <circle cx="100" cy="89" r="1.5" fill="#c62828"/>
  <!-- The aisle / "Virgin Road" — red carpet runner -->
  <path d="M75 85 L125 85 L180 130 L20 130 Z" fill="#d32f2f" stroke="#b71c1c" stroke-width="1.5"/>
  <!-- Aisle pattern -->
  <line x1="100" y1="90" x2="100" y2="130" stroke="#ffeb3b" stroke-width="0.5" stroke-dasharray="4,4"/>
  <!-- Pews on sides -->
  <rect x="5" y="95" width="20" height="6" fill="#6d4c41"/>
  <rect x="5" y="105" width="18" height="6" fill="#6d4c41"/>
  <rect x="5" y="115" width="15" height="6" fill="#6d4c41"/>
  <rect x="175" y="95" width="20" height="6" fill="#6d4c41"/>
  <rect x="177" y="105" width="18" height="6" fill="#6d4c41"/>
  <rect x="180" y="115" width="15" height="6" fill="#6d4c41"/>
  <!-- Bride walking down aisle with father -->
  <!-- Bride -->
  <circle cx="92" cy="113" r="5" fill="#ffcc80"/>
  <!-- Veil -->
  <path d="M85 110 Q92 103 99 110 L99 125 L85 125 Z" fill="#fff" opacity="0.7" stroke="#e0e0e0" stroke-width="0.3"/>
  <!-- Dress -->
  <path d="M88 118 L95 118 L102 140 L82 140 Z" fill="#fff" stroke="#e0e0e0" stroke-width="0.5"/>
  <!-- Bouquet -->
  <circle cx="96" cy="125" r="3" fill="#f8bbd0"/>
  <circle cx="94" cy="124" r="1.5" fill="#e91e63"/>
  <!-- Father -->
  <circle cx="108" cy="115" r="5" fill="#ffcc80"/>
  <rect x="103" y="120" width="10" height="18" fill="#212121"/>
  <!-- Bowtie -->
  <polygon points="106,122 110,124 106,126" fill="#c62828"/>
  <polygon points="110,122 106,124 110,126" fill="#c62828"/>
  <!-- Petals on the aisle -->
  <circle cx="60" cy="125" r="1" fill="#f8bbd0"/>
  <circle cx="130" cy="123" r="1" fill="#f8bbd0"/>
  <circle cx="70" cy="128" r="0.8" fill="#f48fb1"/>
  <circle cx="150" cy="127" r="1" fill="#f8bbd0"/>
  <!-- Label -->
  <text x="100" y="150" font-size="10" font-weight="bold" fill="#880e4f" text-anchor="middle">バージンロード = Wedding Aisle</text>
  <text x="100" y="158" font-size="7" fill="#c2185b" text-anchor="middle">チャペル挙式で花嫁が歩く赤いじゅうたん</text>
</svg>

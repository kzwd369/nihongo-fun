<!-- Japanese ペーパードライバー = person with license who never drives -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Road -->
  <rect x="0" y="120" width="200" height="40" fill="#e0e0e0" rx="0"/>
  <rect x="40" y="138" width="20" height="3" fill="#fff" rx="1"/>
  <rect x="80" y="138" width="20" height="3" fill="#fff" rx="1"/>
  <rect x="120" y="138" width="20" height="3" fill="#fff" rx="1"/>
  <rect x="160" y="138" width="20" height="3" fill="#fff" rx="1"/>
  <!-- Car -->
  <rect x="100" y="95" width="80" height="35" fill="#90caf9" rx="6"/>
  <rect x="110" y="80" width="60" height="20" fill="#bbdefb" rx="5"/>
  <!-- Car windows -->
  <rect x="115" y="83" width="22" height="14" fill="#e3f2fd" rx="2"/>
  <rect x="142" y="83" width="22" height="14" fill="#e3f2fd" rx="2"/>
  <!-- Wheels -->
  <circle cx="118" cy="130" r="8" fill="#546e7a"/>
  <circle cx="118" cy="130" r="4" fill="#78909c"/>
  <circle cx="162" cy="130" r="8" fill="#546e7a"/>
  <circle cx="162" cy="130" r="4" fill="#78909c"/>
  <!-- Headlight -->
  <rect x="176" y="102" width="6" height="8" fill="#ffee58" rx="2"/>
  <!-- Person standing nervously -->
  <!-- Head -->
  <circle cx="55" cy="60" r="12" fill="#ffe0b2"/>
  <!-- Hair -->
  <path d="M43 55 Q45 45 55 43 Q65 45 67 55" fill="#5d4037"/>
  <!-- Worried eyes -->
  <circle cx="50" cy="60" r="1.5" fill="#37474f"/>
  <circle cx="60" cy="60" r="1.5" fill="#37474f"/>
  <!-- Worried eyebrows -->
  <line x1="47" y1="56" x2="52" y2="57" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <line x1="63" y1="57" x2="58" y2="56" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- Worried mouth -->
  <path d="M50 66 Q55 63 60 66" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="45" y="72" width="20" height="24" fill="#81d4fa" rx="3"/>
  <!-- Arms holding license -->
  <line x1="45" y1="78" x2="32" y2="90" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <line x1="65" y1="78" x2="78" y2="90" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <!-- License card -->
  <rect x="30" y="88" width="50" height="30" fill="#fff9c4" rx="3" stroke="#f9a825" stroke-width="1"/>
  <rect x="34" y="92" width="12" height="14" fill="#e0e0e0" rx="1"/>
  <line x1="50" y1="95" x2="74" y2="95" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="50" y1="100" x2="74" y2="100" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="50" y1="105" x2="66" y2="105" stroke="#bdbdbd" stroke-width="1"/>
  <text x="37" y="113" font-size="5" fill="#f9a825" font-family="sans-serif">免許証</text>
  <!-- Legs -->
  <line x1="50" y1="96" x2="48" y2="118" stroke="#37474f" stroke-width="4" stroke-linecap="round"/>
  <line x1="60" y1="96" x2="62" y2="118" stroke="#37474f" stroke-width="4" stroke-linecap="round"/>
  <!-- Sweat drops -->
  <ellipse cx="70" cy="52" rx="2" ry="3" fill="#81d4fa"/>
  <ellipse cx="38" cy="56" rx="2" ry="3" fill="#81d4fa"/>
</svg>

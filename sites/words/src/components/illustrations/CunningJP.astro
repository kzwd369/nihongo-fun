<!-- Japanese カンニング = cheating on an exam -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Desk -->
  <rect x="30" y="90" width="140" height="8" fill="#bcaaa4" rx="2"/>
  <rect x="35" y="98" width="8" height="35" fill="#a1887f"/>
  <rect x="157" y="98" width="8" height="35" fill="#a1887f"/>
  <!-- Test paper on desk -->
  <rect x="55" y="65" width="50" height="25" fill="white" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="60" y1="72" x2="100" y2="72" stroke="#e0e0e0" stroke-width="1"/>
  <line x1="60" y1="77" x2="95" y2="77" stroke="#e0e0e0" stroke-width="1"/>
  <line x1="60" y1="82" x2="98" y2="82" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Student head -->
  <circle cx="80" cy="42" r="14" fill="#ffcc80"/>
  <!-- Hair -->
  <path d="M66,38 Q70,25 80,24 Q90,25 94,38" fill="#5d4037"/>
  <!-- Nervous eyes (looking sideways) -->
  <ellipse cx="74" cy="42" rx="3" ry="3" fill="white"/>
  <circle cx="72" cy="42" r="1.5" fill="#5d4037"/>
  <ellipse cx="86" cy="42" rx="3" ry="3" fill="white"/>
  <circle cx="84" cy="42" r="1.5" fill="#5d4037"/>
  <!-- Sweat drop -->
  <path d="M95,35 Q97,40 95,43 Q93,40 95,35" fill="#64b5f6"/>
  <!-- Nervous mouth -->
  <path d="M76,49 L84,49" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="70" y="56" width="20" height="24" fill="#fff9c4" rx="3"/>
  <!-- Arm sneaking to hidden note -->
  <line x1="70" y1="62" x2="50" y2="75" stroke="#ffcc80" stroke-width="4" stroke-linecap="round"/>
  <!-- Hidden cheat sheet (small paper) -->
  <rect x="38" y="70" width="18" height="14" fill="#ffecb3" rx="1" transform="rotate(-10 47 77)" stroke="#ffb74d" stroke-width="0.5"/>
  <line x1="41" y1="74" x2="53" y2="73" stroke="#ef6c00" stroke-width="0.5" transform="rotate(-10 47 77)"/>
  <line x1="41" y1="77" x2="52" y2="76" stroke="#ef6c00" stroke-width="0.5" transform="rotate(-10 47 77)"/>
  <line x1="41" y1="80" x2="50" y2="79" stroke="#ef6c00" stroke-width="0.5" transform="rotate(-10 47 77)"/>
  <!-- Teacher watching (small figure in background) -->
  <circle cx="160" cy="40" r="10" fill="#ffcc80"/>
  <rect x="153" y="50" width="14" height="18" fill="#78909c" rx="2"/>
  <!-- Teacher's glasses -->
  <circle cx="156" cy="39" r="3.5" fill="none" stroke="#5d4037" stroke-width="1"/>
  <circle cx="164" cy="39" r="3.5" fill="none" stroke="#5d4037" stroke-width="1"/>
  <line x1="159.5" y1="39" x2="160.5" y2="39" stroke="#5d4037" stroke-width="1"/>
  <!-- Teacher's stern look -->
  <line x1="155" y1="36" x2="158" y2="37" stroke="#5d4037" stroke-width="1"/>
  <line x1="163" y1="37" x2="166" y2="36" stroke="#5d4037" stroke-width="1"/>
  <!-- Exclamation mark above teacher -->
  <text x="160" y="24" font-size="14" fill="#e53935" text-anchor="middle" font-weight="bold">!</text>
  <!-- Floor -->
  <rect x="0" y="133" width="200" height="27" fill="#efebe9" rx="0"/>
</svg>

<!-- フライドポテト = french fries in a red carton -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Tray surface -->
  <ellipse cx="100" cy="148" rx="80" ry="6" fill="#e0e0e0" opacity="0.5"/>
  <!-- Carton (trapezoid, wider at top) -->
  <polygon points="60,70 140,70 130,145 70,145" fill="#e53935" stroke="#c62828" stroke-width="1.2"/>
  <!-- Carton white stripe pattern -->
  <polygon points="60,70 140,70 138,82 62,82" fill="#fff8e1"/>
  <rect x="65" y="86" width="6" height="55" fill="#fff8e1" opacity="0.85"/>
  <rect x="78" y="86" width="6" height="55" fill="#fff8e1" opacity="0.85"/>
  <rect x="91" y="86" width="6" height="55" fill="#fff8e1" opacity="0.85"/>
  <rect x="104" y="86" width="6" height="55" fill="#fff8e1" opacity="0.85"/>
  <rect x="117" y="86" width="6" height="55" fill="#fff8e1" opacity="0.85"/>
  <rect x="130" y="86" width="4" height="55" fill="#fff8e1" opacity="0.85"/>
  <!-- Front fold -->
  <polygon points="60,70 140,70 100,75" fill="#ef5350" opacity="0.5"/>
  <!-- Fries sticking out -->
  <rect x="74" y="35" width="6" height="42" fill="#ffd54f" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <rect x="83" y="28" width="6" height="48" fill="#ffca28" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <rect x="92" y="22" width="6" height="55" fill="#ffd54f" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <rect x="101" y="18" width="6" height="58" fill="#ffca28" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <rect x="110" y="25" width="6" height="52" fill="#ffd54f" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <rect x="119" y="32" width="6" height="44" fill="#ffca28" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  <!-- Tilted fry -->
  <g transform="rotate(15 130 50)">
    <rect x="127" y="38" width="6" height="40" fill="#ffd54f" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  </g>
  <g transform="rotate(-12 70 55)">
    <rect x="67" y="40" width="6" height="38" fill="#ffca28" stroke="#ffa000" stroke-width="0.6" rx="1.5"/>
  </g>
  <!-- Salt sparkle -->
  <circle cx="95" cy="32" r="0.8" fill="white" opacity="0.9"/>
  <circle cx="108" cy="38" r="0.8" fill="white" opacity="0.9"/>
  <circle cx="115" cy="28" r="0.8" fill="white" opacity="0.9"/>
  <!-- Steam -->
  <path d="M85 18 Q88 12 85 6" fill="none" stroke="#cfd8dc" stroke-width="1.4" stroke-linecap="round" opacity="0.7"/>
  <path d="M105 14 Q108 8 105 2" fill="none" stroke="#cfd8dc" stroke-width="1.4" stroke-linecap="round" opacity="0.7"/>
</svg>

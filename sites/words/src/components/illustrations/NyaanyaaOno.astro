<!-- Cat face meowing — ニャーニャー (cat meow) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Sound waves -->
  <g stroke="#f48fb1" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7">
    <path d="M155 60 Q165 70 155 80"/>
    <path d="M165 50 Q180 70 165 90"/>
  </g>
  <!-- Cat head -->
  <path d="M50 100 Q50 60 90 55 Q100 50 110 55 Q150 60 150 100 Q150 130 100 130 Q50 130 50 100Z" fill="#fafafa"/>
  <!-- Triangle ears -->
  <polygon points="58,60 50,28 78,55" fill="#fafafa"/>
  <polygon points="142,60 150,28 122,55" fill="#fafafa"/>
  <!-- Inner ears pink -->
  <polygon points="60,58 56,38 72,55" fill="#f8bbd0"/>
  <polygon points="140,58 144,38 128,55" fill="#f8bbd0"/>
  <!-- Eyes — alert green almond -->
  <ellipse cx="78" cy="88" rx="7" ry="9" fill="#aed581"/>
  <ellipse cx="122" cy="88" rx="7" ry="9" fill="#aed581"/>
  <!-- Pupils -->
  <ellipse cx="78" cy="88" rx="2" ry="8" fill="#33691e"/>
  <ellipse cx="122" cy="88" rx="2" ry="8" fill="#33691e"/>
  <!-- Eye highlights -->
  <circle cx="80" cy="84" r="1.5" fill="white"/>
  <circle cx="124" cy="84" r="1.5" fill="white"/>
  <!-- Pink nose -->
  <path d="M95 102 L105 102 L100 109 Z" fill="#f06292"/>
  <!-- Open mouth meowing -->
  <path d="M100 109 Q97 113 92 115" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M100 109 Q103 113 108 115" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <ellipse cx="100" cy="118" rx="8" ry="6" fill="#ad1457"/>
  <!-- Whiskers -->
  <line x1="55" y1="105" x2="40" y2="100" stroke="#9e9e9e" stroke-width="1"/>
  <line x1="55" y1="110" x2="40" y2="112" stroke="#9e9e9e" stroke-width="1"/>
  <line x1="145" y1="105" x2="160" y2="100" stroke="#9e9e9e" stroke-width="1"/>
  <line x1="145" y1="110" x2="160" y2="112" stroke="#9e9e9e" stroke-width="1"/>
  <!-- Meow bubble -->
  <ellipse cx="170" cy="35" rx="28" ry="14" fill="white" stroke="#f48fb1" stroke-width="1.5"/>
  <text x="170" y="40" text-anchor="middle" font-family="sans-serif" font-size="11" font-weight="800" fill="#c2185b">ニャー</text>
</svg>

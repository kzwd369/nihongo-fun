<!-- Waving hello / greeting: a simple figure waving hand with a sun in the corner -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#e0f2f1"/>

  <!-- Sun in top-right corner -->
  <circle cx="165" cy="30" r="16" fill="#ffecb3"/>
  <circle cx="165" cy="30" r="11" fill="#ffe082"/>
  <!-- Sun rays -->
  <line x1="165" y1="8" x2="165" y2="14" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="185" y1="30" x2="179" y2="30" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="180" y1="15" x2="175" y2="19" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="180" y1="45" x2="175" y2="41" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="150" y1="15" x2="155" y2="19" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>

  <!-- Simple figure - head -->
  <circle cx="90" cy="55" r="20" fill="#b2dfdb"/>
  <!-- Eyes - happy closed -->
  <path d="M82,52 Q85,56 88,52" stroke="#00695c" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <path d="M92,52 Q95,56 98,52" stroke="#00695c" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <!-- Smile -->
  <path d="M83,62 Q90,70 97,62" stroke="#00695c" stroke-width="1.5" fill="none" stroke-linecap="round"/>
  <!-- Blush -->
  <ellipse cx="80" cy="60" rx="4" ry="2.5" fill="#80cbc4" opacity="0.6"/>
  <ellipse cx="100" cy="60" rx="4" ry="2.5" fill="#80cbc4" opacity="0.6"/>

  <!-- Body -->
  <path d="M90,75 L90,115" stroke="#00897b" stroke-width="3" stroke-linecap="round"/>
  <!-- Legs -->
  <line x1="90" y1="115" x2="78" y2="140" stroke="#00897b" stroke-width="3" stroke-linecap="round"/>
  <line x1="90" y1="115" x2="102" y2="140" stroke="#00897b" stroke-width="3" stroke-linecap="round"/>
  <!-- Left arm (down) -->
  <line x1="90" y1="85" x2="70" y2="105" stroke="#00897b" stroke-width="3" stroke-linecap="round"/>
  <!-- Right arm (waving up) -->
  <path d="M90,85 Q115,65 125,45" stroke="#00897b" stroke-width="3" fill="none" stroke-linecap="round"/>
  <!-- Waving hand -->
  <circle cx="126" cy="43" r="5" fill="#b2dfdb"/>

  <!-- Motion lines near waving hand -->
  <line x1="135" y1="35" x2="140" y2="32" stroke="#00897b" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <line x1="136" y1="43" x2="142" y2="43" stroke="#00897b" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <line x1="135" y1="51" x2="140" y2="54" stroke="#00897b" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
</svg>

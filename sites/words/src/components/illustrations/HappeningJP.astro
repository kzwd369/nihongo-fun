<!-- Japanese ハプニング = comedic gaffe/mishap -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Ground -->
  <rect x="0" y="130" width="200" height="30" fill="#ffe0b2"/>
  <!-- Banana peel on floor -->
  <path d="M50 128 Q55 118 65 120 Q68 123 66 126 Q62 130 52 131 Z" fill="#fff176" stroke="#f57f17" stroke-width="1"/>
  <path d="M55 124 Q60 122 63 123" fill="none" stroke="#f9a825" stroke-width="0.7"/>
  <!-- Person slipping/falling -->
  <!-- Body at awkward angle -->
  <rect x="78" y="88" width="18" height="28" fill="#42a5f5" rx="3" transform="rotate(35 87 102)"/>
  <!-- Head -->
  <circle cx="112" cy="88" r="11" fill="#ffcc80"/>
  <!-- Surprised eyes (big O) -->
  <circle cx="108" cy="86" r="2.2" fill="white" stroke="#5d4037" stroke-width="1"/>
  <circle cx="108" cy="86" r="1" fill="#5d4037"/>
  <circle cx="116" cy="86" r="2.2" fill="white" stroke="#5d4037" stroke-width="1"/>
  <circle cx="116" cy="86" r="1" fill="#5d4037"/>
  <!-- Surprised mouth (O shape) -->
  <ellipse cx="112" cy="93" rx="3" ry="4" fill="#5d4037"/>
  <ellipse cx="112" cy="93" rx="2" ry="3" fill="#c62828"/>
  <!-- Hair flying -->
  <path d="M104 80 Q100 75 98 80" fill="#5d4037"/>
  <path d="M118 80 Q123 74 125 80" fill="#5d4037"/>
  <!-- Arms flailing -->
  <line x1="100" y1="95" x2="75" y2="80" stroke="#ffcc80" stroke-width="5" stroke-linecap="round"/>
  <line x1="122" y1="95" x2="140" y2="75" stroke="#ffcc80" stroke-width="5" stroke-linecap="round"/>
  <!-- Legs kicking up -->
  <line x1="90" y1="115" x2="75" y2="128" stroke="#263238" stroke-width="5" stroke-linecap="round"/>
  <line x1="95" y1="113" x2="110" y2="120" stroke="#263238" stroke-width="5" stroke-linecap="round"/>
  <!-- Shoe flying off -->
  <ellipse cx="115" cy="115" rx="5" ry="2" fill="#212121" transform="rotate(20 115 115)"/>
  <!-- Sweat droplets of distress -->
  <ellipse cx="100" cy="78" rx="1.5" ry="2.5" fill="#4fc3f7"/>
  <ellipse cx="125" cy="75" rx="1.5" ry="2.5" fill="#4fc3f7"/>
  <!-- Shocked stars/action lines -->
  <path d="M85 70 L87 73 L90 72 L88 75 L90 78 L87 77 L85 80 L85 76 L82 75 L84 73 Z" fill="#ffeb3b" stroke="#f57f17" stroke-width="0.5"/>
  <path d="M150 60 L152 63 L155 62 L153 65 L155 68 L152 67 L150 70 L150 66 L147 65 L149 63 Z" fill="#ff7043" stroke="#c62828" stroke-width="0.5"/>
  <!-- TV studio audience laughter "(笑)" annotation -->
  <rect x="145" y="100" width="50" height="22" fill="#fff" stroke="#c62828" stroke-width="1.5" rx="3"/>
  <text x="170" y="112" font-size="9" font-weight="bold" fill="#c62828" text-anchor="middle">あ！</text>
  <text x="170" y="120" font-size="8" fill="#5d4037" text-anchor="middle">(笑) LOL</text>
  <path d="M158 122 L152 128" stroke="#c62828" stroke-width="1.5"/>
  <!-- TV camera in corner -->
  <rect x="6" y="40" width="28" height="18" fill="#263238" rx="2"/>
  <rect x="32" y="45" width="6" height="8" fill="#263238"/>
  <circle cx="20" cy="49" r="4" fill="#616161"/>
  <circle cx="20" cy="49" r="2" fill="#212121"/>
  <circle cx="10" cy="43" r="1.5" fill="#f44336"/>
  <text x="20" y="68" font-size="6" fill="#5d4037" text-anchor="middle">ON AIR</text>
  <!-- Label -->
  <text x="100" y="22" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">ハプニング発生！</text>
  <text x="100" y="148" font-size="10" font-weight="bold" fill="#5d4037" text-anchor="middle">ハプニング = Unexpected gaffe</text>
  <text x="100" y="157" font-size="7" fill="#795548" text-anchor="middle">お笑い・失敗・トラブル的ニュアンス</text>
</svg>

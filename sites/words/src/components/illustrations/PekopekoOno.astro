<!-- Hungry stomach growling — ぺこぺこ (starving) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Head -->
  <circle cx="100" cy="55" r="28" fill="#fce4d6"/>
  <!-- Hair -->
  <path d="M75 50 Q78 28 100 26 Q122 28 125 50 Q120 38 100 36 Q80 38 75 50Z" fill="#5d4037"/>
  <!-- Eyes (><) -->
  <path d="M84 56 L90 52 L84 50 M86 54 L92 56" stroke="#3e2723" stroke-width="2" stroke-linecap="round" fill="none"/>
  <path d="M116 56 L110 52 L116 50 M114 54 L108 56" stroke="#3e2723" stroke-width="2" stroke-linecap="round" fill="none"/>
  <!-- Open mouth (waiting for food) -->
  <ellipse cx="100" cy="68" rx="5" ry="4" fill="#7c2d12"/>
  <!-- Body torso -->
  <path d="M70 90 Q70 85 80 82 L120 82 Q130 85 130 90 L130 145 L70 145 Z" fill="#90caf9"/>
  <!-- Empty stomach (sunken belly with growl swirl) -->
  <ellipse cx="100" cy="120" rx="22" ry="18" fill="#fff3e0"/>
  <ellipse cx="100" cy="120" rx="20" ry="16" fill="none" stroke="#f57c00" stroke-width="1.5" stroke-dasharray="3 2"/>
  <!-- Growl swirl in stomach -->
  <path d="M100 120 m -10 0 a 10 10 0 1 1 20 0 a 7 7 0 1 0 -14 0 a 4 4 0 1 1 8 0"
        fill="none" stroke="#e65100" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Sound effect "グー" lines -->
  <path d="M30 105 L48 105 M30 115 L46 115 M30 125 L44 125" stroke="#f57c00" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
  <path d="M170 105 L152 105 M170 115 L154 115 M170 125 L156 125" stroke="#f57c00" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
  <!-- Food thought bubble (rice ball) -->
  <circle cx="155" cy="40" r="14" fill="white" stroke="#bcaaa4" stroke-width="1"/>
  <path d="M148 38 L162 38 L160 48 L150 48 Z" fill="#fafafa" stroke="#5d4037" stroke-width="1"/>
  <rect x="153" y="44" width="4" height="3" fill="#212121"/>
  <circle cx="138" cy="48" r="3" fill="white" stroke="#bcaaa4" stroke-width="0.8"/>
  <circle cx="132" cy="55" r="2" fill="white" stroke="#bcaaa4" stroke-width="0.6"/>
</svg>

<!-- German origin: "Arbeit" — this wasei-eigo came from German, not English -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- German flag background stripe -->
  <rect x="20" y="12" width="160" height="14" fill="#000000" rx="4"/>
  <rect x="20" y="22" width="160" height="14" fill="#dd0000"/>
  <rect x="20" y="32" width="160" height="14" fill="#ffcc00" rx="0"/>
  <!-- Round bottom corners for flag -->
  <rect x="20" y="42" width="160" height="4" fill="#ffcc00" rx="0"/>
  <!-- Top corners -->
  <rect x="20" y="12" width="4" height="4" fill="#000000"/>
  <rect x="176" y="12" width="4" height="4" fill="#000000"/>
  <!-- "Arbeit" text on flag -->
  <text x="100" y="36" font-size="16" fill="white" text-anchor="middle" font-family="serif" font-weight="bold" stroke="#333" stroke-width="0.5">Arbeit</text>
  <!-- Arrow pointing down -->
  <polygon points="92,50 108,50 100,60" fill="#546e7a"/>
  <!-- Open book -->
  <rect x="55" y="65" width="40" height="50" fill="#fff8e1" rx="2" transform="rotate(-5, 75, 90)" stroke="#8d6e63" stroke-width="1"/>
  <rect x="105" y="65" width="40" height="50" fill="#fffde7" rx="2" transform="rotate(5, 125, 90)" stroke="#8d6e63" stroke-width="1"/>
  <rect x="93" y="63" width="14" height="54" fill="#8d6e63" rx="1"/>
  <!-- Book spine detail -->
  <line x1="100" y1="65" x2="100" y2="115" stroke="#6d4c41" stroke-width="1"/>
  <!-- Text lines on left page -->
  <line x1="62" y1="76" x2="85" y2="75" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="63" y1="82" x2="86" y2="81" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="64" y1="88" x2="87" y2="87" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="65" y1="94" x2="88" y2="93" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="66" y1="100" x2="88" y2="99" stroke="#bdbdbd" stroke-width="1"/>
  <!-- Text lines on right page -->
  <line x1="113" y1="75" x2="138" y2="76" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="113" y1="81" x2="137" y2="82" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="112" y1="87" x2="136" y2="88" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="112" y1="93" x2="135" y2="94" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="111" y1="99" x2="134" y2="100" stroke="#bdbdbd" stroke-width="1"/>
  <!-- Japanese text on right page -->
  <text x="124" y="82" font-size="6" fill="#37474f" text-anchor="middle" font-family="sans-serif">アルバイト</text>
  <!-- German text on left page -->
  <text x="75" y="82" font-size="6" fill="#37474f" text-anchor="middle" font-family="serif">Arbeit</text>
  <!-- Graduation cap / scholarly element -->
  <rect x="30" y="95" width="20" height="3" fill="#37474f"/>
  <polygon points="30,95 40,85 50,95" fill="#37474f"/>
  <line x1="40" y1="85" x2="40" y2="78" stroke="#37474f" stroke-width="1"/>
  <circle cx="40" cy="77" r="2" fill="#ffd54f"/>
  <!-- Meiji era label -->
  <rect x="40" y="125" width="120" height="24" fill="#fff3e0" rx="6" stroke="#ff9800" stroke-width="1"/>
  <text x="100" y="138" font-size="8" fill="#e65100" text-anchor="middle" font-family="serif" font-weight="bold">Meiji Era (1868-1912)</text>
  <text x="100" y="146" font-size="6" fill="#bf360c" text-anchor="middle" font-family="sans-serif">German &rarr; Japanese</text>
  <!-- Small DE and JP flags -->
  <rect x="22" y="128" width="14" height="3" fill="#000"/>
  <rect x="22" y="131" width="14" height="3" fill="#dd0000"/>
  <rect x="22" y="134" width="14" height="3" fill="#ffcc00"/>
  <rect x="164" y="128" width="14" height="10" fill="white" stroke="#bdbdbd" stroke-width="0.3"/>
  <circle cx="171" cy="133" r="3" fill="#bc002d"/>
</svg>

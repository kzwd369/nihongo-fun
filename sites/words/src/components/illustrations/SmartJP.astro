<!-- Japanese スマート = slim, slender, stylish appearance -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Sparkle effects -->
  <polygon points="30,25 32,20 34,25 32,30" fill="#ffd54f" opacity="0.6"/>
  <polygon points="170,35 172,30 174,35 172,40" fill="#ffd54f" opacity="0.6"/>
  <polygon points="45,70 47,65 49,70 47,75" fill="#ffd54f" opacity="0.6"/>
  <!-- Stylish slim person -->
  <!-- Head -->
  <circle cx="100" cy="30" r="14" fill="#ffcc80"/>
  <!-- Stylish hair -->
  <path d="M86,26 Q88,14 100,12 Q112,14 114,26" fill="#5d4037"/>
  <path d="M86,26 Q84,22 86,18" fill="#5d4037"/>
  <!-- Confident eyes -->
  <ellipse cx="94" cy="30" rx="2.5" ry="2" fill="#5d4037"/>
  <ellipse cx="106" cy="30" rx="2.5" ry="2" fill="#5d4037"/>
  <circle cx="93" cy="29" r="0.8" fill="white"/>
  <circle cx="105" cy="29" r="0.8" fill="white"/>
  <!-- Slight smile -->
  <path d="M95,36 Q100,40 105,36" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Slim body in fashionable clothes -->
  <!-- Jacket/blazer -->
  <path d="M90,44 L88,90 L100,92 L112,90 L110,44 Z" fill="#455a64"/>
  <!-- V-neck showing shirt -->
  <polygon points="95,44 100,58 105,44" fill="white"/>
  <!-- Slim waist emphasis -->
  <path d="M89,65 Q100,62 111,65" fill="none" stroke="#37474f" stroke-width="1"/>
  <!-- Slim legs -->
  <rect x="91" y="90" width="7" height="38" fill="#37474f" rx="1"/>
  <rect x="102" y="90" width="7" height="38" fill="#37474f" rx="1"/>
  <!-- Fashionable shoes -->
  <ellipse cx="94" cy="130" rx="7" ry="3" fill="#5d4037"/>
  <ellipse cx="106" cy="130" rx="7" ry="3" fill="#5d4037"/>
  <!-- Arms at sides (relaxed pose) -->
  <line x1="90" y1="50" x2="78" y2="80" stroke="#455a64" stroke-width="5" stroke-linecap="round"/>
  <line x1="110" y1="50" x2="122" y2="80" stroke="#455a64" stroke-width="5" stroke-linecap="round"/>
  <!-- Hands -->
  <circle cx="77" cy="82" r="3" fill="#ffcc80"/>
  <circle cx="123" cy="82" r="3" fill="#ffcc80"/>
  <!-- Fashion accessory - watch -->
  <rect x="119" y="73" width="6" height="4" fill="#90a4ae" rx="1"/>
  <!-- Mirror outline on right -->
  <ellipse cx="160" cy="70" rx="22" ry="40" fill="none" stroke="#ce93d8" stroke-width="2"/>
  <ellipse cx="160" cy="70" rx="20" ry="38" fill="#f3e5f5" opacity="0.3"/>
  <!-- Floor -->
  <rect x="0" y="135" width="200" height="25" fill="#f8bbd0" rx="0" opacity="0.4"/>
</svg>

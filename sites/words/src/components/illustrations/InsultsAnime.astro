<!-- Angry anime face with comic anger vein marks and steam puffs -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#fbe9e7"/>

  <!-- Face circle -->
  <circle cx="100" cy="85" r="40" fill="#ffccbc"/>
  <!-- Slight blush cheeks -->
  <ellipse cx="78" cy="95" rx="8" ry="4" fill="#ff8a65" opacity="0.4"/>
  <ellipse cx="122" cy="95" rx="8" ry="4" fill="#ff8a65" opacity="0.4"/>

  <!-- Angry eyebrows -->
  <line x1="80" y1="72" x2="94" y2="78" stroke="#bf360c" stroke-width="3" stroke-linecap="round"/>
  <line x1="120" y1="72" x2="106" y2="78" stroke="#bf360c" stroke-width="3" stroke-linecap="round"/>

  <!-- Angry eyes -->
  <ellipse cx="88" cy="84" rx="4" ry="5" fill="#bf360c"/>
  <ellipse cx="112" cy="84" rx="4" ry="5" fill="#bf360c"/>

  <!-- Angry mouth -->
  <path d="M88,102 Q100,96 112,102" stroke="#bf360c" stroke-width="2.5" fill="none" stroke-linecap="round"/>

  <!-- Anger vein mark (cross/# shape) top-right of head -->
  <g transform="translate(130,52)">
    <line x1="0" y1="2" x2="12" y2="2" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="0" y1="8" x2="12" y2="8" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="3" y1="0" x2="3" y2="10" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="9" y1="0" x2="9" y2="10" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
  </g>

  <!-- Second anger vein mark smaller -->
  <g transform="translate(58,50) scale(0.7)">
    <line x1="0" y1="2" x2="12" y2="2" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="0" y1="8" x2="12" y2="8" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="3" y1="0" x2="3" y2="10" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
    <line x1="9" y1="0" x2="9" y2="10" stroke="#ff5722" stroke-width="2.5" stroke-linecap="round"/>
  </g>

  <!-- Steam puff left -->
  <circle cx="48" cy="60" r="6" fill="#fff" opacity="0.7"/>
  <circle cx="42" cy="52" r="4.5" fill="#fff" opacity="0.5"/>
  <circle cx="38" cy="45" r="3" fill="#fff" opacity="0.3"/>

  <!-- Steam puff right -->
  <circle cx="152" cy="62" r="6" fill="#fff" opacity="0.7"/>
  <circle cx="158" cy="54" r="4.5" fill="#fff" opacity="0.5"/>
  <circle cx="162" cy="47" r="3" fill="#fff" opacity="0.3"/>
</svg>

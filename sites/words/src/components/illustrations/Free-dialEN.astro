<!-- English: "free dial" doesn't exist — natives say "toll-free" / "1-800" / "freephone" -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Old-school rotary dial phone (illustrating "dial" sounds antique) -->
  <ellipse cx="55" cy="125" rx="40" ry="6" fill="#bdbdbd" opacity="0.5"/>
  <!-- Phone body -->
  <rect x="20" y="80" width="70" height="40" fill="#37474f" stroke="#212121" stroke-width="1.5" rx="6"/>
  <!-- Rotary dial -->
  <circle cx="55" cy="100" r="18" fill="#212121" stroke="#000" stroke-width="1"/>
  <circle cx="55" cy="100" r="14" fill="#37474f"/>
  <!-- Dial holes -->
  <circle cx="55" cy="88" r="2" fill="#000"/>
  <circle cx="63" cy="91" r="2" fill="#000"/>
  <circle cx="68" cy="98" r="2" fill="#000"/>
  <circle cx="68" cy="106" r="2" fill="#000"/>
  <circle cx="63" cy="112" r="2" fill="#000"/>
  <circle cx="55" cy="115" r="2" fill="#000"/>
  <circle cx="47" cy="112" r="2" fill="#000"/>
  <circle cx="42" cy="106" r="2" fill="#000"/>
  <circle cx="42" cy="98" r="2" fill="#000"/>
  <circle cx="47" cy="91" r="2" fill="#000"/>
  <!-- Receiver / handset -->
  <path d="M28 70 Q26 65 32 64 L80 64 Q86 65 82 70 L75 75 L37 75 Z" fill="#37474f" stroke="#212121" stroke-width="1"/>
  <!-- Cobwebs (suggests "dial" is archaic) -->
  <path d="M15 75 L25 80 M15 75 L20 85 M25 80 L20 85" stroke="#9e9e9e" stroke-width="0.4"/>
  <!-- "Antique" tag on phone -->
  <rect x="92" y="70" width="22" height="10" fill="#fff9c4" stroke="#f57f17" stroke-width="0.5" rx="2" transform="rotate(-15 103 75)"/>
  <text x="103" y="77" font-size="5" fill="#5d4037" text-anchor="middle" transform="rotate(-15 103 75)">Antique!</text>
  <!-- Correct English terms list (right side) -->
  <rect x="110" y="20" width="80" height="100" fill="#fff" stroke="#0d47a1" stroke-width="1.5" rx="3"/>
  <text x="150" y="32" font-size="8" font-weight="bold" fill="#0d47a1" text-anchor="middle">English equivalents</text>
  <line x1="115" y1="36" x2="185" y2="36" stroke="#0d47a1" stroke-width="0.5"/>
  <!-- 1-800 button -->
  <rect x="118" y="42" width="64" height="14" fill="#43a047" rx="2"/>
  <text x="150" y="52" font-size="9" font-weight="bold" fill="#fff" text-anchor="middle">1-800-XXX-XXXX</text>
  <text x="150" y="64" font-size="6" fill="#1b5e20" text-anchor="middle">(US colloquial)</text>
  <!-- Toll-free -->
  <text x="150" y="78" font-size="9" font-weight="bold" fill="#1565c0" text-anchor="middle">"toll-free"</text>
  <text x="150" y="86" font-size="6" fill="#1565c0" text-anchor="middle">(US standard)</text>
  <!-- Freephone -->
  <text x="150" y="100" font-size="9" font-weight="bold" fill="#6a1b9a" text-anchor="middle">"freephone"</text>
  <text x="150" y="108" font-size="6" fill="#6a1b9a" text-anchor="middle">(British English)</text>
  <!-- Strike-out free dial -->
  <text x="150" y="118" font-size="7" fill="#c62828" text-anchor="middle">✗ "free dial"</text>
  <!-- Label -->
  <text x="100" y="146" font-size="9" font-weight="bold" fill="#5d4037" text-anchor="middle">"Free dial" sounds antique to English ears</text>
  <text x="100" y="156" font-size="7" fill="#795548" text-anchor="middle">"Dial" itself is from the rotary-phone era</text>
</svg>

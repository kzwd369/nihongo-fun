<!-- Dead silence — シーン (shīn) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Empty room — floor and walls in muted tones -->
  <rect x="20" y="30" width="160" height="110" fill="#f5f5f5" rx="2"/>
  <!-- Back wall -->
  <rect x="20" y="30" width="160" height="70" fill="#eceff1"/>
  <!-- Window on back wall -->
  <rect x="75" y="42" width="50" height="40" fill="#c5cae9" rx="1" stroke="#b0bec5" stroke-width="1"/>
  <line x1="100" y1="42" x2="100" y2="82" stroke="#b0bec5" stroke-width="0.8"/>
  <line x1="75" y1="62" x2="125" y2="62" stroke="#b0bec5" stroke-width="0.8"/>
  <!-- Moonlight glow through window -->
  <ellipse cx="100" cy="55" rx="12" ry="10" fill="white" opacity="0.3"/>
  <!-- Floor line -->
  <line x1="20" y1="100" x2="180" y2="100" stroke="#cfd8dc" stroke-width="1"/>
  <!-- Empty chair -->
  <rect x="125" y="88" width="22" height="3" fill="#a1887f" rx="1"/>
  <rect x="127" y="91" width="2" height="18" fill="#8d6e63"/>
  <rect x="143" y="91" width="2" height="18" fill="#8d6e63"/>
  <rect x="125" y="78" width="2" height="13" fill="#8d6e63"/>
  <rect x="145" y="78" width="2" height="13" fill="#8d6e63"/>
  <rect x="124" y="76" width="24" height="3" fill="#a1887f" rx="1"/>
  <!-- Silence marks (manga-style) — small lines radiating -->
  <line x1="90" y1="110" x2="90" y2="118" stroke="#9e9e9e" stroke-width="0.8" opacity="0.5"/>
  <line x1="100" y1="108" x2="100" y2="120" stroke="#9e9e9e" stroke-width="0.8" opacity="0.5"/>
  <line x1="110" y1="110" x2="110" y2="118" stroke="#9e9e9e" stroke-width="0.8" opacity="0.5"/>
  <!-- Manga-style "..." -->
  <circle cx="55" cy="55" r="2" fill="#78909c" opacity="0.4"/>
  <circle cx="62" cy="55" r="2" fill="#78909c" opacity="0.35"/>
  <circle cx="69" cy="55" r="2" fill="#78909c" opacity="0.3"/>
  <!-- Dust motes in moonlight -->
  <circle cx="95" cy="70" r="1" fill="#b0bec5" opacity="0.4"/>
  <circle cx="105" cy="65" r="0.8" fill="#b0bec5" opacity="0.3"/>
  <circle cx="98" cy="78" r="0.6" fill="#b0bec5" opacity="0.35"/>
  <!-- Subtle cold atmosphere lines -->
  <line x1="30" y1="35" x2="35" y2="35" stroke="#b0bec5" stroke-width="0.5" opacity="0.3"/>
  <line x1="160" y1="38" x2="168" y2="38" stroke="#b0bec5" stroke-width="0.5" opacity="0.3"/>
  <line x1="40" y1="125" x2="48" y2="125" stroke="#b0bec5" stroke-width="0.5" opacity="0.3"/>
  <line x1="150" y1="128" x2="155" y2="128" stroke="#b0bec5" stroke-width="0.5" opacity="0.3"/>
</svg>

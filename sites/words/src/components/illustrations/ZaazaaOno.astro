<!-- Heavy rain pouring from cloud — ザーザー (heavy rain sound) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#cfd8dc" rx="8"/>
  <!-- Background dark sky tone -->
  <rect width="200" height="60" fill="#90a4ae" rx="8" opacity="0.5"/>
  <!-- Dark cloud -->
  <ellipse cx="100" cy="40" rx="65" ry="22" fill="#546e7a"/>
  <circle cx="60" cy="38" r="20" fill="#546e7a"/>
  <circle cx="140" cy="38" r="22" fill="#546e7a"/>
  <circle cx="80" cy="28" r="18" fill="#546e7a"/>
  <circle cx="120" cy="28" r="20" fill="#546e7a"/>
  <!-- Cloud highlight -->
  <ellipse cx="80" cy="30" rx="20" ry="6" fill="#78909c" opacity="0.8"/>
  <!-- Heavy rain lines -->
  <g stroke="#42a5f5" stroke-width="2.5" stroke-linecap="round" opacity="0.85">
    <line x1="40" y1="65" x2="32" y2="95"/>
    <line x1="55" y1="65" x2="47" y2="100"/>
    <line x1="70" y1="65" x2="62" y2="105"/>
    <line x1="85" y1="65" x2="77" y2="110"/>
    <line x1="100" y1="65" x2="92" y2="115"/>
    <line x1="115" y1="65" x2="107" y2="110"/>
    <line x1="130" y1="65" x2="122" y2="105"/>
    <line x1="145" y1="65" x2="137" y2="100"/>
    <line x1="160" y1="65" x2="152" y2="95"/>
  </g>
  <g stroke="#64b5f6" stroke-width="2" stroke-linecap="round" opacity="0.7">
    <line x1="48" y1="70" x2="42" y2="100"/>
    <line x1="63" y1="70" x2="57" y2="105"/>
    <line x1="78" y1="70" x2="72" y2="110"/>
    <line x1="93" y1="70" x2="87" y2="115"/>
    <line x1="108" y1="70" x2="102" y2="115"/>
    <line x1="123" y1="70" x2="117" y2="110"/>
    <line x1="138" y1="70" x2="132" y2="105"/>
    <line x1="153" y1="70" x2="147" y2="100"/>
  </g>
  <!-- Splash droplets at bottom -->
  <g fill="#42a5f5" opacity="0.7">
    <circle cx="35" cy="125" r="2"/>
    <circle cx="55" cy="130" r="2.5"/>
    <circle cx="80" cy="128" r="2"/>
    <circle cx="105" cy="132" r="2.5"/>
    <circle cx="130" cy="128" r="2"/>
    <circle cx="155" cy="130" r="2.5"/>
    <circle cx="175" cy="126" r="2"/>
  </g>
  <!-- Puddle -->
  <ellipse cx="100" cy="148" rx="80" ry="6" fill="#1976d2" opacity="0.4"/>
  <ellipse cx="100" cy="148" rx="60" ry="3" fill="#42a5f5" opacity="0.5"/>
  <!-- Splash ripples -->
  <path d="M55 145 Q60 140 65 145" fill="none" stroke="#1976d2" stroke-width="1" opacity="0.6"/>
  <path d="M130 145 Q135 140 140 145" fill="none" stroke="#1976d2" stroke-width="1" opacity="0.6"/>
</svg>

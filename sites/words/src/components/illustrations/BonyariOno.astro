<!-- Hazy spaced-out face with floating clouds — ぼんやり (absent-minded) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#eceff1" rx="8"/>
  <!-- Background haze clouds -->
  <ellipse cx="50" cy="40" rx="30" ry="12" fill="#cfd8dc" opacity="0.6"/>
  <ellipse cx="150" cy="35" rx="28" ry="10" fill="#cfd8dc" opacity="0.5"/>
  <ellipse cx="160" cy="120" rx="32" ry="11" fill="#cfd8dc" opacity="0.55"/>
  <ellipse cx="40" cy="125" rx="26" ry="9" fill="#cfd8dc" opacity="0.5"/>
  <!-- Outer head glow (haze) -->
  <circle cx="100" cy="80" r="50" fill="#b0bec5" opacity="0.25"/>
  <circle cx="100" cy="80" r="42" fill="#b0bec5" opacity="0.3"/>
  <!-- Head -->
  <circle cx="100" cy="80" r="36" fill="#fce4d6"/>
  <!-- Hair -->
  <path d="M65 70 Q70 45 100 42 Q130 45 135 70 Q130 55 100 52 Q70 55 65 70Z" fill="#6d4c41" opacity="0.85"/>
  <!-- Half-closed eyes (dots) -->
  <line x1="82" y1="82" x2="92" y2="82" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <line x1="108" y1="82" x2="118" y2="82" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Slightly open mouth -->
  <ellipse cx="100" cy="100" rx="5" ry="3" fill="#c48080"/>
  <!-- Cheek blush soft -->
  <ellipse cx="78" cy="92" rx="6" ry="3" fill="#f8c0b0" opacity="0.5"/>
  <ellipse cx="122" cy="92" rx="6" ry="3" fill="#f8c0b0" opacity="0.5"/>
  <!-- Floating thought bubbles fading away -->
  <circle cx="155" cy="60" r="6" fill="white" opacity="0.7" stroke="#90a4ae" stroke-width="1"/>
  <circle cx="170" cy="48" r="4" fill="white" opacity="0.6" stroke="#90a4ae" stroke-width="0.8"/>
  <circle cx="180" cy="38" r="2.5" fill="white" opacity="0.5" stroke="#90a4ae" stroke-width="0.6"/>
  <!-- Fog overlay -->
  <ellipse cx="100" cy="85" rx="55" ry="20" fill="white" opacity="0.18"/>
</svg>

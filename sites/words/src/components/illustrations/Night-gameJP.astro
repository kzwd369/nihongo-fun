<!-- Japanese ナイター = night baseball game under lights -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#0d1b2a" rx="8"/>
  <!-- Night sky stars -->
  <circle cx="25" cy="20" r="0.8" fill="#fff"/>
  <circle cx="50" cy="15" r="0.6" fill="#fff"/>
  <circle cx="170" cy="18" r="0.8" fill="#fff"/>
  <circle cx="180" cy="25" r="0.5" fill="#fff"/>
  <circle cx="40" cy="30" r="0.5" fill="#fff"/>
  <!-- Moon -->
  <circle cx="175" cy="28" r="6" fill="#fff9c4"/>
  <circle cx="172" cy="26" r="5" fill="#fff59d"/>
  <!-- Stadium lights / towers -->
  <!-- Left light tower -->
  <line x1="30" y1="50" x2="30" y2="90" stroke="#424242" stroke-width="1.5"/>
  <rect x="20" y="42" width="22" height="10" fill="#616161" stroke="#424242" stroke-width="0.8"/>
  <circle cx="25" cy="47" r="2" fill="#fffde7"/>
  <circle cx="31" cy="47" r="2" fill="#fffde7"/>
  <circle cx="37" cy="47" r="2" fill="#fffde7"/>
  <!-- Light beam -->
  <path d="M42 44 L120 85 L42 52 Z" fill="#fff9c4" opacity="0.25"/>
  <!-- Right light tower -->
  <line x1="170" y1="50" x2="170" y2="90" stroke="#424242" stroke-width="1.5"/>
  <rect x="158" y="42" width="22" height="10" fill="#616161" stroke="#424242" stroke-width="0.8"/>
  <circle cx="163" cy="47" r="2" fill="#fffde7"/>
  <circle cx="169" cy="47" r="2" fill="#fffde7"/>
  <circle cx="175" cy="47" r="2" fill="#fffde7"/>
  <path d="M158 44 L80 85 L158 52 Z" fill="#fff9c4" opacity="0.25"/>
  <!-- Baseball field (diamond) -->
  <ellipse cx="100" cy="125" rx="95" ry="25" fill="#2e7d32"/>
  <path d="M100 95 L75 115 L100 135 L125 115 Z" fill="#a1887f" stroke="#6d4c41" stroke-width="1"/>
  <circle cx="100" cy="115" r="3" fill="#fff" stroke="#8d6e63" stroke-width="0.5"/>
  <!-- Bases -->
  <rect x="97" y="93" width="6" height="6" fill="#fff" transform="rotate(45 100 96)"/>
  <rect x="72" y="112" width="6" height="6" fill="#fff" transform="rotate(45 75 115)"/>
  <rect x="97" y="132" width="6" height="6" fill="#fff" transform="rotate(45 100 135)"/>
  <rect x="122" y="112" width="6" height="6" fill="#fff" transform="rotate(45 125 115)"/>
  <!-- Pitcher -->
  <circle cx="100" cy="109" r="3" fill="#1976d2"/>
  <rect x="99" y="112" width="2" height="5" fill="#1976d2"/>
  <!-- Batter at home plate -->
  <circle cx="100" cy="132" r="3" fill="#c62828"/>
  <rect x="99" y="135" width="2" height="5" fill="#c62828"/>
  <line x1="96" y1="132" x2="93" y2="127" stroke="#8d6e63" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Stadium seating -->
  <path d="M5 125 L5 140 L195 140 L195 125 L170 115 L30 115 Z" fill="#37474f" opacity="0.4"/>
  <!-- Scoreboard -->
  <rect x="65" y="55" width="70" height="28" fill="#212121" stroke="#ef5350" stroke-width="1.5" rx="2"/>
  <text x="100" y="66" font-size="6" font-weight="bold" fill="#ef5350" text-anchor="middle">★ NIGHT GAME ★</text>
  <line x1="70" y1="70" x2="130" y2="70" stroke="#ef5350" stroke-width="0.3"/>
  <text x="80" y="78" font-size="8" font-weight="bold" fill="white" text-anchor="middle">巨人</text>
  <text x="100" y="78" font-size="9" font-weight="bold" fill="#ffeb3b" text-anchor="middle">3-2</text>
  <text x="120" y="78" font-size="8" font-weight="bold" fill="white" text-anchor="middle">阪神</text>
  <!-- Label -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#ffeb3b" text-anchor="middle">ナイター (wasei-eigo)</text>
  <text x="100" y="152" font-size="9" font-weight="bold" fill="#ffeb3b" text-anchor="middle">ナイター = Night baseball game</text>
</svg>

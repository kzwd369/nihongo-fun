<!-- English Cunning = sly, crafty, cleverly deceptive -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Forest background -->
  <circle cx="30" cy="110" r="25" fill="#66bb6a" opacity="0.5"/>
  <circle cx="170" cy="105" r="28" fill="#66bb6a" opacity="0.5"/>
  <circle cx="100" cy="115" r="20" fill="#81c784" opacity="0.4"/>
  <!-- Ground -->
  <rect x="0" y="130" width="200" height="30" fill="#a5d6a7" rx="0"/>
  <!-- Sly fox body -->
  <ellipse cx="100" cy="110" rx="30" ry="15" fill="#ff8a65"/>
  <!-- Fox tail (big and fluffy) -->
  <path d="M130,108 Q155,90 160,105 Q155,115 135,112" fill="#ff8a65"/>
  <path d="M155,100 Q162,105 160,108" fill="white" opacity="0.6"/>
  <!-- Fox legs -->
  <rect x="78" y="120" width="6" height="12" fill="#e65100" rx="1"/>
  <rect x="90" y="120" width="6" height="12" fill="#e65100" rx="1"/>
  <rect x="105" y="120" width="6" height="12" fill="#e65100" rx="1"/>
  <rect x="115" y="120" width="6" height="12" fill="#e65100" rx="1"/>
  <!-- Fox head -->
  <ellipse cx="75" cy="95" rx="18" ry="14" fill="#ff8a65"/>
  <!-- Fox ears -->
  <polygon points="62,85 58,65 70,80" fill="#ff8a65"/>
  <polygon points="63,82 60,68 69,79" fill="#ffccbc" opacity="0.6"/>
  <polygon points="85,82 88,62 78,78" fill="#ff8a65"/>
  <polygon points="84,80 87,66 79,78" fill="#ffccbc" opacity="0.6"/>
  <!-- Fox face - white -->
  <ellipse cx="75" cy="100" rx="12" ry="8" fill="white"/>
  <!-- Fox eyes (sly, narrowed) -->
  <path d="M66,93 Q70,90 74,93" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M78,93 Q82,90 86,93" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Fox nose -->
  <ellipse cx="75" cy="98" rx="2.5" ry="1.5" fill="#5d4037"/>
  <!-- Sly smirk -->
  <path d="M70,102 Q75,106 82,101" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Thought bubble with cunning plan -->
  <circle cx="55" cy="68" r="2" fill="#e0e0e0"/>
  <circle cx="48" cy="58" r="3" fill="#e0e0e0"/>
  <ellipse cx="38" cy="42" rx="18" ry="12" fill="white" stroke="#bdbdbd" stroke-width="0.8"/>
  <!-- Light bulb in thought bubble -->
  <path d="M35,38 L35,46 M38,46 L38,38" fill="none" stroke="#ffd54f" stroke-width="1"/>
  <circle cx="36.5" cy="36" r="5" fill="#fff9c4" stroke="#ffd54f" stroke-width="1"/>
  <!-- Sparkle lines around bulb -->
  <line x1="28" y1="36" x2="25" y2="36" stroke="#ffd54f" stroke-width="1"/>
  <line x1="45" y1="36" x2="48" y2="36" stroke="#ffd54f" stroke-width="1"/>
  <line x1="36" y1="28" x2="36" y2="25" stroke="#ffd54f" stroke-width="1"/>
</svg>

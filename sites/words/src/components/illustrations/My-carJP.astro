<!-- マイカー = personally owned family car (concept) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Sun -->
  <circle cx="170" cy="25" r="10" fill="#ffd54f" opacity="0.8"/>
  <!-- Cloud -->
  <ellipse cx="40" cy="22" rx="18" ry="6" fill="white" opacity="0.7"/>
  <!-- House (one's own home) in background -->
  <rect x="22" y="80" width="38" height="40" fill="#ffe0b2" stroke="#a1887f" stroke-width="0.8"/>
  <polygon points="20,80 41,62 62,80" fill="#a1887f"/>
  <rect x="35" y="100" width="12" height="20" fill="#6d4c41"/>
  <rect x="26" y="88" width="8" height="8" fill="#bbdefb" stroke="#a1887f" stroke-width="0.5"/>
  <rect x="48" y="88" width="8" height="8" fill="#bbdefb" stroke="#a1887f" stroke-width="0.5"/>
  <!-- Driveway -->
  <rect x="60" y="115" width="115" height="20" fill="#cfd8dc"/>
  <!-- Ground/grass -->
  <rect x="0" y="135" width="200" height="25" fill="#c8e6c9"/>
  <!-- Family car (compact sedan) -->
  <!-- Body lower -->
  <path d="M75 110 Q78 100 88 100 L160 100 Q170 100 173 110 L173 130 L75 130 Z" fill="#42a5f5" stroke="#1565c0" stroke-width="1.2"/>
  <!-- Roof / cabin -->
  <path d="M90 100 Q95 78 110 78 L150 78 Q160 78 158 100 Z" fill="#64b5f6" stroke="#1565c0" stroke-width="1.2"/>
  <!-- Windshield -->
  <path d="M95 98 Q100 82 112 82 L130 82 L130 98 Z" fill="#bbdefb" stroke="#1565c0" stroke-width="0.8"/>
  <!-- Rear window -->
  <path d="M133 98 L133 82 L150 82 Q156 82 154 98 Z" fill="#bbdefb" stroke="#1565c0" stroke-width="0.8"/>
  <!-- Door line -->
  <line x1="125" y1="100" x2="125" y2="125" stroke="#1565c0" stroke-width="0.8"/>
  <!-- Door handle -->
  <rect x="115" y="110" width="6" height="2" fill="#1565c0" rx="0.5"/>
  <rect x="135" y="110" width="6" height="2" fill="#1565c0" rx="0.5"/>
  <!-- Headlight -->
  <ellipse cx="170" cy="112" rx="4" ry="3" fill="#fff9c4" stroke="#1565c0" stroke-width="0.8"/>
  <!-- Tail light -->
  <rect x="76" y="108" width="5" height="6" fill="#ef5350" rx="1"/>
  <!-- Bumper -->
  <rect x="76" y="125" width="97" height="5" fill="#1565c0"/>
  <!-- Wheels -->
  <circle cx="95" cy="130" r="11" fill="#263238"/>
  <circle cx="95" cy="130" r="6" fill="#90a4ae"/>
  <circle cx="95" cy="130" r="2.5" fill="#37474f"/>
  <circle cx="153" cy="130" r="11" fill="#263238"/>
  <circle cx="153" cy="130" r="6" fill="#90a4ae"/>
  <circle cx="153" cy="130" r="2.5" fill="#37474f"/>
  <!-- License plate -->
  <rect x="158" y="118" width="14" height="6" fill="white" stroke="#37474f" stroke-width="0.5" rx="0.5"/>
  <text x="165" y="123" font-size="3.5" fill="#37474f" text-anchor="middle" font-family="sans-serif">品川</text>
  <!-- "MY" tag/heart on car -->
  <path d="M120 60 C 120 56, 117 54, 115 56 C 113 54, 110 56, 110 60 C 110 64, 115 68, 115 68 C 115 68, 120 64, 120 60 Z" fill="#ef5350" stroke="#c62828" stroke-width="0.6"/>
  <text x="115" y="62" font-size="4" fill="white" text-anchor="middle" font-weight="bold" font-family="sans-serif">MY</text>
  <!-- Stick figure family near car -->
  <circle cx="180" cy="118" r="3" fill="#ffe0b2" stroke="#5d4037" stroke-width="0.4"/>
  <rect x="178" y="121" width="4" height="9" fill="#7986cb"/>
  <circle cx="186" cy="120" r="2.4" fill="#ffe0b2" stroke="#5d4037" stroke-width="0.4"/>
  <rect x="184" y="122" width="4" height="8" fill="#f48fb1"/>
  <!-- Sparkle on car -->
  <text x="100" y="92" font-size="9" fill="white" opacity="0.9">✦</text>
</svg>

<!-- コスパ = cost performance / value for money -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fffde7" rx="8"/>
  <!-- Balance scale -->
  <!-- Base -->
  <rect x="92" y="130" width="16" height="8" fill="#795548" rx="1"/>
  <rect x="80" y="138" width="40" height="4" fill="#5d4037" rx="2"/>
  <!-- Pillar -->
  <rect x="98" y="70" width="4" height="60" fill="#8d6e63"/>
  <!-- Pivot -->
  <circle cx="100" cy="70" r="4" fill="#5d4037"/>
  <!-- Beam (tilted to indicate good value - right side heavier = more value) -->
  <line x1="50" y1="66" x2="150" y2="74" stroke="#5d4037" stroke-width="3" stroke-linecap="round"/>
  <!-- Left pan chains -->
  <line x1="55" y1="67" x2="45" y2="85" stroke="#8d6e63" stroke-width="1"/>
  <line x1="68" y1="68" x2="75" y2="85" stroke="#8d6e63" stroke-width="1"/>
  <!-- Left pan - COST (coins) -->
  <path d="M38 85 Q60 88 82 85 Q75 95 60 97 Q45 95 38 85 Z" fill="#cfd8dc" stroke="#78909c" stroke-width="1"/>
  <!-- Coins on left pan -->
  <circle cx="52" cy="82" r="6" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
  <text x="52" y="85" font-size="6" font-weight="bold" fill="#5d4037" text-anchor="middle">¥</text>
  <circle cx="65" cy="78" r="6" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
  <text x="65" y="81" font-size="6" font-weight="bold" fill="#5d4037" text-anchor="middle">¥</text>
  <text x="60" y="110" font-size="9" font-weight="bold" fill="#5d4037" text-anchor="middle">COST</text>
  <text x="60" y="120" font-size="8" fill="#795548" text-anchor="middle">価格</text>
  <!-- Right pan chains -->
  <line x1="132" y1="72" x2="125" y2="90" stroke="#8d6e63" stroke-width="1"/>
  <line x1="145" y1="73" x2="155" y2="90" stroke="#8d6e63" stroke-width="1"/>
  <!-- Right pan - VALUE -->
  <path d="M118 90 Q140 93 162 90 Q155 100 140 102 Q125 100 118 90 Z" fill="#cfd8dc" stroke="#78909c" stroke-width="1"/>
  <!-- Stars/value items -->
  <text x="130" y="90" font-size="12" fill="#ffb300">★</text>
  <text x="140" y="86" font-size="14" fill="#ffb300">★</text>
  <text x="150" y="90" font-size="12" fill="#ffb300">★</text>
  <text x="140" y="115" font-size="9" font-weight="bold" fill="#5d4037" text-anchor="middle">VALUE</text>
  <text x="140" y="125" font-size="8" fill="#795548" text-anchor="middle">価値</text>
  <!-- Thumbs up -->
  <text x="100" y="38" font-size="18" text-anchor="middle">👍</text>
  <!-- Label -->
  <text x="100" y="22" font-size="11" font-weight="bold" fill="#f57f17" text-anchor="middle">コスパがいい！</text>
  <text x="100" y="150" font-size="9" font-weight="bold" fill="#5d4037" text-anchor="middle">コスパ = Value for Money</text>
  <text x="100" y="158" font-size="7" fill="#795548" text-anchor="middle">"bang for your buck" / 価格に対する価値</text>
</svg>

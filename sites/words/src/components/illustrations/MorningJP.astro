<!-- Japanese モーニング = morning set / breakfast deal at a kissaten cafe -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Tray -->
  <ellipse cx="100" cy="110" rx="80" ry="22" fill="#d7ccc8"/>
  <ellipse cx="100" cy="108" rx="80" ry="22" fill="#efebe9"/>
  <!-- Coffee cup - saucer -->
  <ellipse cx="55" cy="95" rx="22" ry="8" fill="#bcaaa4"/>
  <ellipse cx="55" cy="93" rx="22" ry="8" fill="white"/>
  <!-- Coffee cup - body -->
  <rect x="40" y="68" width="30" height="26" fill="white" rx="3"/>
  <rect x="40" y="68" width="30" height="26" fill="white" rx="3" stroke="#d7ccc8" stroke-width="1"/>
  <!-- Coffee -->
  <rect x="42" y="70" width="26" height="15" fill="#5d4037" rx="2"/>
  <ellipse cx="55" cy="70" rx="13" ry="4" fill="#6d4c41"/>
  <!-- Cup handle -->
  <path d="M70 74 Q80 74 80 82 Q80 90 70 90" fill="none" stroke="#d7ccc8" stroke-width="2.5"/>
  <!-- Steam -->
  <path d="M48 60 Q46 52 50 46" fill="none" stroke="#bdbdbd" stroke-width="1" opacity="0.5"/>
  <path d="M55 58 Q53 50 57 44" fill="none" stroke="#bdbdbd" stroke-width="1" opacity="0.5"/>
  <path d="M62 60 Q60 52 64 46" fill="none" stroke="#bdbdbd" stroke-width="1" opacity="0.5"/>
  <!-- Toast plate -->
  <ellipse cx="115" cy="85" rx="24" ry="9" fill="#d7ccc8"/>
  <ellipse cx="115" cy="83" rx="24" ry="9" fill="white"/>
  <!-- Thick toast -->
  <rect x="100" y="62" width="30" height="22" fill="#ffcc80" rx="2"/>
  <rect x="100" y="62" width="30" height="22" fill="none" stroke="#ffb74d" stroke-width="1" rx="2"/>
  <!-- Toast crust (darker edges) -->
  <rect x="100" y="62" width="30" height="3" fill="#ffa726" rx="2"/>
  <!-- Butter pat on toast -->
  <rect x="108" y="67" width="14" height="6" fill="#fff9c4" rx="1" stroke="#fff176" stroke-width="0.5"/>
  <!-- Egg cup -->
  <ellipse cx="152" cy="95" rx="14" ry="6" fill="#bcaaa4"/>
  <ellipse cx="152" cy="93" rx="14" ry="6" fill="white"/>
  <!-- Boiled egg -->
  <ellipse cx="152" cy="82" rx="10" ry="13" fill="#fafafa" stroke="#e0e0e0" stroke-width="0.5"/>
  <!-- Egg top cracked off -->
  <path d="M143 78 Q145 75 148 77 Q150 74 152 76 Q155 73 157 76 Q160 74 161 78" fill="#fafafa" stroke="#e0e0e0" stroke-width="0.5"/>
  <!-- Egg yolk visible -->
  <ellipse cx="152" cy="78" rx="6" ry="4" fill="#ffb74d"/>
  <!-- Small salad bowl -->
  <ellipse cx="148" cy="118" rx="15" ry="6" fill="#a5d6a7"/>
  <ellipse cx="148" cy="116" rx="15" ry="6" fill="#c8e6c9"/>
  <!-- Lettuce leaves -->
  <ellipse cx="145" cy="114" rx="6" ry="4" fill="#66bb6a" opacity="0.7"/>
  <ellipse cx="152" cy="113" rx="5" ry="3.5" fill="#81c784" opacity="0.7"/>
  <!-- Cherry tomato -->
  <circle cx="156" cy="114" r="3" fill="#ef5350"/>
  <circle cx="155" cy="113" r="1" fill="#ef9a9a" opacity="0.5"/>
  <!-- Napkin -->
  <rect x="30" y="115" width="20" height="14" fill="white" rx="1" stroke="#e0e0e0" stroke-width="0.5"/>
  <rect x="31" y="116" width="18" height="12" fill="white" rx="1"/>
</svg>

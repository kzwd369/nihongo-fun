<!-- Flowing silky hair — サラサラ (smooth & silky) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f7fa" rx="8"/>
  <!-- Soft breeze lines in background -->
  <g fill="none" stroke="#4dd0e1" stroke-width="1.5" stroke-linecap="round" opacity="0.45">
    <path d="M15 35 Q40 30 65 35"/>
    <path d="M130 25 Q160 22 185 30"/>
    <path d="M15 130 Q45 135 75 130"/>
  </g>
  <!-- Tiny sparkles -->
  <g fill="#80deea" opacity="0.8">
    <circle cx="35" cy="70" r="1.5"/>
    <circle cx="175" cy="85" r="1.5"/>
    <circle cx="170" cy="130" r="1.5"/>
  </g>

  <!-- Face (profile-ish) -->
  <circle cx="95" cy="75" r="32" fill="#ffe0b2"/>
  <!-- Closed peaceful eye (side view suggestion) -->
  <path d="M82 72 Q88 75 94 72" fill="none" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Smile -->
  <path d="M92 90 Q96 93 100 90" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Blush -->
  <ellipse cx="75" cy="85" rx="5" ry="3" fill="#ffab91" opacity="0.6"/>

  <!-- Long flowing silky hair cascading right -->
  <g fill="#3e2723">
    <!-- Main mass behind head -->
    <path d="M68 55 Q60 45 70 38 Q95 30 115 38 Q130 50 125 65 Q120 80 125 95 L95 115 Q80 105 72 90 Q65 75 68 55Z"/>
  </g>
  <!-- Flowing strands streaming to the right -->
  <g fill="none" stroke="#3e2723" stroke-width="4" stroke-linecap="round">
    <path d="M120 65 Q150 60 185 75"/>
    <path d="M122 78 Q155 80 188 95"/>
    <path d="M118 92 Q148 100 180 115"/>
    <path d="M112 105 Q140 120 170 130"/>
  </g>
  <!-- Highlights on strands (silky sheen) -->
  <g fill="none" stroke="#795548" stroke-width="1.5" stroke-linecap="round" opacity="0.9">
    <path d="M130 65 Q155 62 180 75"/>
    <path d="M130 80 Q158 85 183 98"/>
    <path d="M124 94 Q150 103 172 117"/>
  </g>

  <!-- サラサラ text -->
  <text x="55" y="25" font-family="sans-serif" font-size="14" font-weight="800" fill="#00838f">サラサラ♪</text>
  <text x="130" y="152" font-family="sans-serif" font-size="11" font-weight="700" fill="#00838f" opacity="0.8">…サラサラ</text>
</svg>

<!-- English "back number" = jersey number on back of sports uniform / has-been slang -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Field grass -->
  <rect x="0" y="130" width="200" height="30" fill="#c8e6c9"/>
  <line x1="0" y1="140" x2="200" y2="140" stroke="#a5d6a7" stroke-width="0.5" stroke-dasharray="3,2"/>
  <!-- Jersey/uniform -->
  <!-- Shirt body -->
  <path d="M60 40 L60 35 Q70 28 100 28 Q130 28 140 35 L140 40 L150 50 L145 65 L140 60 L140 130 L60 130 L60 60 L55 65 L50 50 Z" fill="#0d47a1" stroke="#0d47a1" stroke-width="1.5"/>
  <!-- Shoulders/collar -->
  <path d="M85 28 Q100 38 115 28" fill="none" stroke="#fff" stroke-width="1.5"/>
  <!-- Big jersey number on back -->
  <text x="100" y="95" font-size="46" font-weight="bold" fill="white" text-anchor="middle" font-family="Arial Black, sans-serif">23</text>
  <!-- Player name above number -->
  <text x="100" y="55" font-size="9" font-weight="bold" fill="white" text-anchor="middle" letter-spacing="2">JORDAN</text>
  <line x1="75" y1="58" x2="125" y2="58" stroke="white" stroke-width="0.5"/>
  <!-- Arrow pointing to number with annotation -->
  <path d="M160 95 Q170 90 168 85" fill="none" stroke="#c62828" stroke-width="1.5"/>
  <polygon points="168,85 165,88 172,88" fill="#c62828"/>
  <rect x="152" y="70" width="44" height="16" fill="#ffecb3" stroke="#f57c00" stroke-width="1" rx="2"/>
  <text x="174" y="77" font-size="6" font-weight="bold" fill="#c62828" text-anchor="middle">the number</text>
  <text x="174" y="84" font-size="6" font-weight="bold" fill="#c62828" text-anchor="middle">on the back</text>
  <!-- Arrow from label -->
  <!-- Label -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#0d47a1" text-anchor="middle">"Back Number" ≠ magazine</text>
  <text x="100" y="146" font-size="9" font-weight="bold" fill="#0d47a1" text-anchor="middle">= Jersey / Uniform Number</text>
  <text x="100" y="156" font-size="7" fill="#3949ab" text-anchor="middle">(old slang: "a has-been")</text>
</svg>

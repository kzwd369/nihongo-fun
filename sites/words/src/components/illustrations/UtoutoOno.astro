<!-- Dozing head with floating Z's — うとうと (dozing off) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f3e5f5" rx="8"/>
  <!-- Head tilted -->
  <g transform="rotate(-15, 100, 90)">
    <!-- Head -->
    <circle cx="100" cy="90" r="38" fill="#fce4d6"/>
    <!-- Hair -->
    <path d="M64 82 Q68 55 100 52 Q132 55 136 82 Q130 65 100 62 Q70 65 64 82Z" fill="#5d4037"/>
    <!-- Closed eyes (sleeping curves) -->
    <path d="M78 92 Q85 88 92 92" fill="none" stroke="#3e2723" stroke-width="2.2" stroke-linecap="round"/>
    <path d="M108 92 Q115 88 122 92" fill="none" stroke="#3e2723" stroke-width="2.2" stroke-linecap="round"/>
    <!-- Eyelashes -->
    <line x1="80" y1="93" x2="78" y2="96" stroke="#3e2723" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="120" y1="93" x2="122" y2="96" stroke="#3e2723" stroke-width="1.2" stroke-linecap="round"/>
    <!-- Soft mouth -->
    <ellipse cx="100" cy="110" rx="4" ry="2.5" fill="#c48080"/>
    <!-- Cheek blush -->
    <ellipse cx="76" cy="103" rx="6" ry="3.5" fill="#f8c0b0" opacity="0.6"/>
    <ellipse cx="124" cy="103" rx="6" ry="3.5" fill="#f8c0b0" opacity="0.6"/>
  </g>
  <!-- Pillow / arm support -->
  <ellipse cx="100" cy="145" rx="60" ry="10" fill="#ce93d8"/>
  <!-- Floating Z's (sleep) -->
  <g fill="#7b1fa2">
    <text x="140" y="55" font-size="22" font-weight="bold" font-family="Arial">Z</text>
    <text x="158" y="38" font-size="16" font-weight="bold" font-family="Arial" opacity="0.7">Z</text>
    <text x="172" y="22" font-size="11" font-weight="bold" font-family="Arial" opacity="0.5">z</text>
  </g>
  <!-- Drowsy bubble -->
  <circle cx="60" cy="40" r="5" fill="white" stroke="#ce93d8" stroke-width="1" opacity="0.8"/>
  <circle cx="48" cy="32" r="3" fill="white" stroke="#ce93d8" stroke-width="0.8" opacity="0.7"/>
  <circle cx="40" cy="25" r="2" fill="white" stroke="#ce93d8" stroke-width="0.6" opacity="0.6"/>
  <!-- Moon crescent -->
  <path d="M30 55 a 8 8 0 1 0 4 14 a 6 6 0 1 1 -4 -14 Z" fill="#ffd54f"/>
</svg>

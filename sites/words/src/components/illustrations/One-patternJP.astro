<!-- Japanese ワンパターン = predictable, repetitive -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Sequence of 3 identical scenes (same dad joke, 3 days in a row) -->
  <!-- Frame 1 -->
  <rect x="10" y="35" width="55" height="55" fill="#fff" stroke="#5d4037" stroke-width="1.5" rx="3"/>
  <text x="37" y="46" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">月曜日</text>
  <!-- Dad face -->
  <circle cx="37" cy="62" r="9" fill="#ffcc80"/>
  <path d="M30 56 Q37 50 44 56" fill="#5d4037"/>
  <circle cx="34" cy="62" r="1" fill="#5d4037"/>
  <circle cx="40" cy="62" r="1" fill="#5d4037"/>
  <path d="M33 67 Q37 70 41 67" fill="none" stroke="#5d4037" stroke-width="0.8"/>
  <!-- Speech bubble -->
  <rect x="14" y="76" width="46" height="11" fill="#fff9c4" stroke="#f57f17" stroke-width="0.8" rx="2"/>
  <text x="37" y="84" font-size="6" fill="#5d4037" text-anchor="middle">布団がふっとんだ</text>
  <!-- Frame 2 -->
  <rect x="73" y="35" width="55" height="55" fill="#fff" stroke="#5d4037" stroke-width="1.5" rx="3"/>
  <text x="100" y="46" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">火曜日</text>
  <circle cx="100" cy="62" r="9" fill="#ffcc80"/>
  <path d="M93 56 Q100 50 107 56" fill="#5d4037"/>
  <circle cx="97" cy="62" r="1" fill="#5d4037"/>
  <circle cx="103" cy="62" r="1" fill="#5d4037"/>
  <path d="M96 67 Q100 70 104 67" fill="none" stroke="#5d4037" stroke-width="0.8"/>
  <rect x="77" y="76" width="46" height="11" fill="#fff9c4" stroke="#f57f17" stroke-width="0.8" rx="2"/>
  <text x="100" y="84" font-size="6" fill="#5d4037" text-anchor="middle">布団がふっとんだ</text>
  <!-- Frame 3 -->
  <rect x="136" y="35" width="55" height="55" fill="#fff" stroke="#5d4037" stroke-width="1.5" rx="3"/>
  <text x="163" y="46" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">水曜日</text>
  <circle cx="163" cy="62" r="9" fill="#ffcc80"/>
  <path d="M156 56 Q163 50 170 56" fill="#5d4037"/>
  <circle cx="160" cy="62" r="1" fill="#5d4037"/>
  <circle cx="166" cy="62" r="1" fill="#5d4037"/>
  <path d="M159 67 Q163 70 167 67" fill="none" stroke="#5d4037" stroke-width="0.8"/>
  <rect x="140" y="76" width="46" height="11" fill="#fff9c4" stroke="#f57f17" stroke-width="0.8" rx="2"/>
  <text x="163" y="84" font-size="6" fill="#5d4037" text-anchor="middle">布団がふっとんだ</text>
  <!-- Reaction face below (annoyed family) -->
  <circle cx="60" cy="115" r="10" fill="#ffcc80"/>
  <path d="M52 113 Q56 110 60 113" fill="none" stroke="#5d4037" stroke-width="1"/>
  <path d="M60 113 Q64 110 68 113" fill="none" stroke="#5d4037" stroke-width="1"/>
  <line x1="55" y1="116" x2="58" y2="118" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="65" y1="116" x2="62" y2="118" stroke="#5d4037" stroke-width="1.5"/>
  <path d="M55 122 L65 122" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Speech (annoyed) -->
  <path d="M75 110 L85 105 L90 115 L80 120 Z" fill="#fff" stroke="#5d4037" stroke-width="0.8"/>
  <text x="120" y="115" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">またそれ？</text>
  <text x="120" y="128" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">ワンパターン！</text>
  <!-- Repeating arrows -->
  <path d="M65 60 L73 60" stroke="#9e9e9e" stroke-width="1.5"/>
  <polygon points="73,60 70,58 70,62" fill="#9e9e9e"/>
  <path d="M128 60 L136 60" stroke="#9e9e9e" stroke-width="1.5"/>
  <polygon points="136,60 133,58 133,62" fill="#9e9e9e"/>
  <!-- Label -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#5d4037" text-anchor="middle">ワンパターン = Predictable / Same old</text>
  <text x="100" y="148" font-size="8" fill="#795548" text-anchor="middle">毎回同じギャグ・展開・選択</text>
  <text x="100" y="157" font-size="7" fill="#9e9e9e" text-anchor="middle">軽いネガティブだが愛情ある使い方も</text>
</svg>

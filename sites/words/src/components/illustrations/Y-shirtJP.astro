<!-- Japanese ワイシャツ = dress shirt (from mishearing "white shirt") -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hanger -->
  <path d="M100 18 L100 28" stroke="#90a4ae" stroke-width="2" stroke-linecap="round"/>
  <circle cx="100" cy="16" r="4" fill="none" stroke="#90a4ae" stroke-width="2"/>
  <path d="M72 50 Q100 28 128 50" fill="none" stroke="#90a4ae" stroke-width="3" stroke-linecap="round"/>
  <!-- Shirt body -->
  <path d="M60 50 L60 140 L140 140 L140 50 L128 50 Q100 38 72 50 Z" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
  <!-- Collar left -->
  <path d="M80 50 L92 48 L88 64 L76 58 Z" fill="white" stroke="#90caf9" stroke-width="1"/>
  <!-- Collar right -->
  <path d="M120 50 L108 48 L112 64 L124 58 Z" fill="white" stroke="#90caf9" stroke-width="1"/>
  <!-- Collar V opening -->
  <path d="M92 48 L100 70 L108 48" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
  <!-- Buttons -->
  <circle cx="100" cy="75" r="2.5" fill="#bbdefb" stroke="#90caf9" stroke-width="0.5"/>
  <circle cx="100" cy="90" r="2.5" fill="#bbdefb" stroke="#90caf9" stroke-width="0.5"/>
  <circle cx="100" cy="105" r="2.5" fill="#bbdefb" stroke="#90caf9" stroke-width="0.5"/>
  <circle cx="100" cy="120" r="2.5" fill="#bbdefb" stroke="#90caf9" stroke-width="0.5"/>
  <!-- Button line -->
  <line x1="100" y1="70" x2="100" y2="140" stroke="#bbdefb" stroke-width="0.5"/>
  <!-- Left sleeve fold -->
  <path d="M60 50 L42 65 L48 80 L60 72" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
  <!-- Right sleeve fold -->
  <path d="M140 50 L158 65 L152 80 L140 72" fill="#e3f2fd" stroke="#90caf9" stroke-width="1"/>
  <!-- Pocket -->
  <rect x="108" y="72" width="16" height="14" fill="none" stroke="#bbdefb" stroke-width="1" rx="1"/>
  <!-- Subtle fabric texture lines -->
  <line x1="75" y1="80" x2="75" y2="135" stroke="#bbdefb" stroke-width="0.3" opacity="0.5"/>
  <line x1="85" y1="75" x2="85" y2="135" stroke="#bbdefb" stroke-width="0.3" opacity="0.5"/>
  <line x1="115" y1="75" x2="115" y2="135" stroke="#bbdefb" stroke-width="0.3" opacity="0.5"/>
  <line x1="125" y1="80" x2="125" y2="135" stroke="#bbdefb" stroke-width="0.3" opacity="0.5"/>
</svg>

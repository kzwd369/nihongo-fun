<!-- Slurping noodles (smooth/slippery) — つるつる (slippery/smooth) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f2f1" rx="8"/>
  <!-- Steam wisps in background -->
  <path d="M50 25 Q55 15 50 8" fill="none" stroke="#b2dfdb" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
  <path d="M65 25 Q70 15 65 8" fill="none" stroke="#b2dfdb" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <path d="M150 25 Q155 15 150 8" fill="none" stroke="#b2dfdb" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
  <!-- Bowl (ramen/udon bowl) -->
  <path d="M35 95 Q35 140 100 142 Q165 140 165 95 Z" fill="#37474f"/>
  <path d="M35 95 Q35 140 100 142 Q165 140 165 95 Z" fill="url(#bowlGrad)"/>
  <!-- Bowl rim -->
  <ellipse cx="100" cy="95" rx="65" ry="12" fill="#455a64"/>
  <ellipse cx="100" cy="92" rx="62" ry="9" fill="#90a4ae"/>
  <!-- Broth surface -->
  <ellipse cx="100" cy="93" rx="58" ry="7" fill="#fff8e1"/>
  <!-- Noodles rising/being slurped -->
  <path d="M90 93 Q88 75 95 60 Q102 45 100 25" fill="none" stroke="#ffeb3b" stroke-width="3" stroke-linecap="round"/>
  <path d="M95 93 Q95 75 102 60 Q110 45 108 25" fill="none" stroke="#fdd835" stroke-width="3" stroke-linecap="round"/>
  <path d="M100 93 Q102 75 110 60 Q118 45 116 30" fill="none" stroke="#ffeb3b" stroke-width="3" stroke-linecap="round"/>
  <path d="M105 93 Q110 80 118 65 Q128 50 130 35" fill="none" stroke="#fdd835" stroke-width="3" stroke-linecap="round"/>
  <!-- Noodle tips -->
  <circle cx="100" cy="25" r="2.5" fill="#fff59d"/>
  <circle cx="108" cy="25" r="2.5" fill="#fff59d"/>
  <circle cx="116" cy="30" r="2.5" fill="#fff59d"/>
  <circle cx="130" cy="35" r="2.5" fill="#fff59d"/>
  <!-- Chopsticks holding noodles -->
  <line x1="130" y1="20" x2="85" y2="85" stroke="#8d6e63" stroke-width="3" stroke-linecap="round"/>
  <line x1="140" y1="22" x2="95" y2="87" stroke="#6d4c41" stroke-width="3" stroke-linecap="round"/>
  <!-- Green onion slices floating -->
  <circle cx="60" cy="92" r="3" fill="#66bb6a"/>
  <circle cx="60" cy="92" r="1.5" fill="#a5d6a7"/>
  <circle cx="140" cy="94" r="3" fill="#66bb6a"/>
  <circle cx="140" cy="94" r="1.5" fill="#a5d6a7"/>
  <circle cx="80" cy="95" r="2.5" fill="#66bb6a"/>
  <!-- Shine/slippery highlights -->
  <path d="M94 50 Q92 52 93 54" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.9" fill="none"/>
  <path d="M106 55 Q104 57 105 59" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.9" fill="none"/>
  <path d="M115 45 Q113 47 114 49" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.9" fill="none"/>
  <!-- Slurp motion lines -->
  <path d="M150 60 Q158 58 160 52" fill="none" stroke="#80cbc4" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
  <path d="M155 70 Q162 68 165 62" fill="none" stroke="#80cbc4" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
  <defs>
    <linearGradient id="bowlGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="white" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="black" stop-opacity="0.15"/>
    </linearGradient>
  </defs>
</svg>

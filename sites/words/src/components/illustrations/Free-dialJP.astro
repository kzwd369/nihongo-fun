<!-- Japanese フリーダイヤル = toll-free 0120 number -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- TV ad / product box backdrop -->
  <rect x="15" y="20" width="170" height="100" fill="#fff" stroke="#1565c0" stroke-width="2" rx="4"/>
  <!-- Banner header -->
  <rect x="15" y="20" width="170" height="20" fill="#1565c0" rx="4"/>
  <text x="100" y="34" font-size="11" font-weight="bold" fill="#fff" text-anchor="middle">お問い合わせはこちら</text>
  <!-- Free dial mark -->
  <rect x="30" y="50" width="50" height="38" fill="#ef5350" stroke="#b71c1c" stroke-width="1.5" rx="6"/>
  <text x="55" y="62" font-size="6" font-weight="bold" fill="#fff" text-anchor="middle">FREE</text>
  <text x="55" y="72" font-size="9" font-weight="bold" fill="#fff" text-anchor="middle">DIAL</text>
  <text x="55" y="84" font-size="6" fill="#fff" text-anchor="middle">無料</text>
  <!-- Phone number -->
  <text x="135" y="65" font-size="13" font-weight="bold" fill="#1565c0" text-anchor="middle">0120-</text>
  <text x="135" y="80" font-size="13" font-weight="bold" fill="#1565c0" text-anchor="middle">123-456</text>
  <!-- Sub-message -->
  <text x="100" y="100" font-size="7" fill="#37474f" text-anchor="middle">通話料無料・24時間受付</text>
  <text x="100" y="110" font-size="6" fill="#78909c" text-anchor="middle">※携帯電話・PHSからもご利用いただけます</text>
  <!-- Phone receiver icon (bottom-left) -->
  <g transform="translate(25,128)">
    <path d="M0 5 Q3 0 8 2 L14 6 Q16 8 14 11 L11 14 Q14 18 18 21 Q22 24 25 21 L28 24 Q30 26 28 29 L23 33 Q20 35 16 33 Q5 27 0 16 Q-2 10 0 5 Z" fill="#1976d2"/>
  </g>
  <!-- "TV CM example" frame indicator -->
  <text x="100" y="14" font-size="8" fill="#0d47a1" text-anchor="middle">📺 TV広告イメージ</text>
  <!-- Label -->
  <text x="100" y="148" font-size="10" font-weight="bold" fill="#0d47a1" text-anchor="middle">フリーダイヤル = 0120 / 0800</text>
  <text x="100" y="157" font-size="7" fill="#1976d2" text-anchor="middle">通話料は企業負担（顧客は無料）</text>
</svg>

<!-- Japanese コンセント = electrical wall outlet -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Wall background -->
  <rect x="20" y="15" width="160" height="130" fill="#e8e0d4" rx="4"/>
  <!-- Outlet plate -->
  <rect x="55" y="35" width="90" height="100" fill="#f5f5f5" rx="10" stroke="#ccc" stroke-width="2"/>
  <!-- Screw top -->
  <circle cx="100" cy="48" r="3" fill="#bbb" stroke="#999" stroke-width="0.5"/>
  <!-- Left slot -->
  <rect x="78" y="62" width="8" height="22" fill="#333" rx="2"/>
  <!-- Right slot -->
  <rect x="114" y="62" width="8" height="22" fill="#333" rx="2"/>
  <!-- Lower left slot -->
  <rect x="78" y="98" width="8" height="22" fill="#333" rx="2"/>
  <!-- Lower right slot -->
  <rect x="114" y="98" width="8" height="22" fill="#333" rx="2"/>
  <!-- Screw bottom -->
  <circle cx="100" cy="128" r="3" fill="#bbb" stroke="#999" stroke-width="0.5"/>
  <!-- Label -->
  <text x="100" y="155" text-anchor="middle" font-size="11" fill="#555" font-family="sans-serif">コンセント</text>
</svg>

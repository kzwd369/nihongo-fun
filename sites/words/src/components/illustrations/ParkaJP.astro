<!-- Japanese パーカー = casual hoodie / hooded sweatshirt -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hoodie body -->
  <path d="M60 50 L60 130 Q60 138 68 138 L132 138 Q140 138 140 130 L140 50" fill="#7986cb" stroke="#5c6bc0" stroke-width="1"/>
  <!-- Hood -->
  <path d="M60 50 Q60 20 100 18 Q140 20 140 50" fill="#7986cb" stroke="#5c6bc0" stroke-width="1"/>
  <!-- Hood opening/face area -->
  <ellipse cx="100" cy="42" rx="22" ry="18" fill="#e8eaf6"/>
  <!-- Hood inner shadow -->
  <path d="M80 38 Q100 28 120 38" fill="none" stroke="#9fa8da" stroke-width="1"/>
  <!-- Hood strings -->
  <line x1="90" y1="52" x2="88" y2="72" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="110" y1="52" x2="112" y2="72" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  <!-- String tips -->
  <rect x="85" y="70" width="6" height="4" fill="white" rx="1"/>
  <rect x="109" y="70" width="6" height="4" fill="white" rx="1"/>
  <!-- Kangaroo pocket -->
  <path d="M72 95 L72 120 Q72 125 77 125 L123 125 Q128 125 128 120 L128 95" fill="#6573c3" stroke="#5c6bc0" stroke-width="0.8"/>
  <path d="M72 95 Q100 100 128 95" fill="none" stroke="#5c6bc0" stroke-width="0.8"/>
  <!-- Sleeves -->
  <path d="M60 50 L38 55 L30 95 Q28 102 35 103 L50 100 L60 70" fill="#7986cb" stroke="#5c6bc0" stroke-width="1"/>
  <path d="M140 50 L162 55 L170 95 Q172 102 165 103 L150 100 L140 70" fill="#7986cb" stroke="#5c6bc0" stroke-width="1"/>
  <!-- Sleeve cuffs -->
  <path d="M30 95 Q28 102 35 103 L50 100 L48 93" fill="#5c6bc0"/>
  <path d="M170 95 Q172 102 165 103 L150 100 L152 93" fill="#5c6bc0"/>
  <!-- Bottom ribbing -->
  <rect x="60" y="132" width="80" height="6" fill="#5c6bc0" rx="2"/>
  <!-- Casual/relaxed wrinkle lines -->
  <path d="M75 80 Q80 82 75 85" fill="none" stroke="#5c6bc0" stroke-width="0.5"/>
  <path d="M125 78 Q120 81 125 84" fill="none" stroke="#5c6bc0" stroke-width="0.5"/>
</svg>

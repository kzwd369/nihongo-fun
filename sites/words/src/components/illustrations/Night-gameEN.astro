<!-- English "night game" = correct English — two words, any sport -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#1a237e" rx="8"/>
  <!-- Sky -->
  <circle cx="30" cy="15" r="0.7" fill="#fff"/>
  <circle cx="165" cy="18" r="0.6" fill="#fff"/>
  <!-- Stadium ring structure -->
  <ellipse cx="100" cy="90" rx="90" ry="30" fill="#0d47a1"/>
  <!-- Field -->
  <ellipse cx="100" cy="90" rx="75" ry="20" fill="#1b5e20"/>
  <!-- American football field markings -->
  <line x1="35" y1="90" x2="165" y2="90" stroke="#fff" stroke-width="0.4" opacity="0.6"/>
  <line x1="55" y1="80" x2="55" y2="100" stroke="#fff" stroke-width="0.5"/>
  <line x1="75" y1="76" x2="75" y2="104" stroke="#fff" stroke-width="0.5"/>
  <line x1="100" y1="72" x2="100" y2="108" stroke="#fff" stroke-width="0.8"/>
  <line x1="125" y1="76" x2="125" y2="104" stroke="#fff" stroke-width="0.5"/>
  <line x1="145" y1="80" x2="145" y2="100" stroke="#fff" stroke-width="0.5"/>
  <!-- Yard number at 50 -->
  <text x="100" y="93" font-size="5" fill="#fff" text-anchor="middle" opacity="0.7">50</text>
  <!-- Light pylons around the top -->
  <!-- Top-left -->
  <line x1="35" y1="65" x2="35" y2="40" stroke="#757575" stroke-width="1.5"/>
  <rect x="28" y="35" width="16" height="7" fill="#bdbdbd"/>
  <circle cx="31" cy="38" r="1.3" fill="#fffde7"/>
  <circle cx="35" cy="38" r="1.3" fill="#fffde7"/>
  <circle cx="39" cy="38" r="1.3" fill="#fffde7"/>
  <!-- Light glow -->
  <circle cx="35" cy="38" r="10" fill="#fff9c4" opacity="0.3"/>
  <!-- Top-center -->
  <line x1="100" y1="58" x2="100" y2="30" stroke="#757575" stroke-width="1.5"/>
  <rect x="88" y="25" width="24" height="8" fill="#bdbdbd"/>
  <circle cx="93" cy="29" r="1.3" fill="#fffde7"/>
  <circle cx="99" cy="29" r="1.3" fill="#fffde7"/>
  <circle cx="105" cy="29" r="1.3" fill="#fffde7"/>
  <circle cx="100" cy="30" r="14" fill="#fff9c4" opacity="0.3"/>
  <!-- Top-right -->
  <line x1="165" y1="65" x2="165" y2="40" stroke="#757575" stroke-width="1.5"/>
  <rect x="156" y="35" width="16" height="7" fill="#bdbdbd"/>
  <circle cx="159" cy="38" r="1.3" fill="#fffde7"/>
  <circle cx="165" cy="38" r="1.3" fill="#fffde7"/>
  <circle cx="171" cy="38" r="1.3" fill="#fffde7"/>
  <circle cx="165" cy="38" r="10" fill="#fff9c4" opacity="0.3"/>
  <!-- Players on field (silhouettes) -->
  <circle cx="85" cy="88" r="2.5" fill="#ef5350"/>
  <rect x="83.5" y="90" width="3" height="6" fill="#ef5350"/>
  <circle cx="115" cy="88" r="2.5" fill="#42a5f5"/>
  <rect x="113.5" y="90" width="3" height="6" fill="#42a5f5"/>
  <circle cx="100" cy="85" r="2.5" fill="#ef5350"/>
  <rect x="98.5" y="87" width="3" height="6" fill="#ef5350"/>
  <!-- Football -->
  <ellipse cx="102" cy="82" rx="2" ry="1" fill="#8d6e63"/>
  <!-- Scoreboard -->
  <rect x="60" y="120" width="80" height="30" fill="#000" stroke="#ffeb3b" stroke-width="1.5" rx="2"/>
  <text x="100" y="131" font-size="7" font-weight="bold" fill="#ffeb3b" text-anchor="middle">NIGHT GAME</text>
  <text x="100" y="137" font-size="4" fill="#bdbdbd" text-anchor="middle">(two words — correct English)</text>
  <text x="78" y="147" font-size="7" font-weight="bold" fill="white" text-anchor="middle">HOME 21</text>
  <text x="122" y="147" font-size="7" font-weight="bold" fill="white" text-anchor="middle">14 AWAY</text>
  <!-- "Under the Lights" poetic label -->
  <rect x="5" y="5" width="80" height="14" fill="#ffeb3b" rx="2"/>
  <text x="45" y="15" font-size="8" font-weight="bold" fill="#1a237e" text-anchor="middle">"Under the Lights"</text>
  <!-- Label -->
  <text x="100" y="158" font-size="7" fill="#bdbdbd" text-anchor="middle">English: "night game" — Japanese ナイター doesn't exist here</text>
</svg>

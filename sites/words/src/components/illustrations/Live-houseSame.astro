<!-- ライブハウス = small live music venue -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#212121" rx="8"/>
  <!-- Stage platform -->
  <rect x="20" y="85" width="160" height="10" fill="#5d4037"/>
  <rect x="20" y="95" width="160" height="35" fill="#3e2723"/>
  <!-- Stage backdrop -->
  <rect x="30" y="30" width="140" height="55" fill="#c62828" opacity="0.2"/>
  <!-- Spotlights -->
  <path d="M40,20 L20,90 L60,90 Z" fill="#ffeb3b" opacity="0.15"/>
  <path d="M160,20 L140,90 L180,90 Z" fill="#ff6e40" opacity="0.15"/>
  <path d="M100,15 L85,90 L115,90 Z" fill="#80deea" opacity="0.15"/>
  <!-- Band members (silhouettes) -->
  <!-- Guitarist -->
  <circle cx="60" cy="60" r="6" fill="#212121"/>
  <rect x="55" y="65" width="10" height="22" fill="#212121" rx="1"/>
  <!-- Guitar -->
  <ellipse cx="72" cy="80" rx="7" ry="5" fill="#424242" stroke="#fff" stroke-width="0.3"/>
  <rect x="65" y="77" width="10" height="2" fill="#8d6e63"/>
  <!-- Vocalist with mic -->
  <circle cx="100" cy="55" r="7" fill="#212121"/>
  <rect x="95" y="60" width="10" height="25" fill="#212121" rx="1"/>
  <!-- Mic stand -->
  <line x1="93" y1="62" x2="88" y2="85" stroke="#424242" stroke-width="1.5"/>
  <circle cx="88" cy="60" r="3" fill="#616161"/>
  <!-- Drummer -->
  <circle cx="140" cy="58" r="6" fill="#212121"/>
  <rect x="135" y="63" width="10" height="18" fill="#212121" rx="1"/>
  <!-- Drum kit -->
  <ellipse cx="145" cy="82" rx="10" ry="4" fill="#757575" stroke="#424242" stroke-width="0.5"/>
  <rect x="142" y="75" width="6" height="10" fill="#616161"/>
  <!-- Speakers -->
  <rect x="25" y="65" width="16" height="28" fill="#424242" stroke="#616161" stroke-width="0.5"/>
  <circle cx="33" cy="73" r="3" fill="#212121"/>
  <circle cx="33" cy="85" r="4" fill="#212121"/>
  <rect x="159" y="65" width="16" height="28" fill="#424242" stroke="#616161" stroke-width="0.5"/>
  <circle cx="167" cy="73" r="3" fill="#212121"/>
  <circle cx="167" cy="85" r="4" fill="#212121"/>
  <!-- Audience silhouettes (heads and raised hands) -->
  <circle cx="40" cy="125" r="4" fill="#000"/>
  <circle cx="55" cy="122" r="4" fill="#000"/>
  <path d="M55 115 L53 105" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="70" cy="125" r="4" fill="#000"/>
  <circle cx="85" cy="122" r="4" fill="#000"/>
  <path d="M85 115 L87 102" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="100" cy="125" r="4" fill="#000"/>
  <circle cx="115" cy="122" r="4" fill="#000"/>
  <path d="M115 115 L113 105" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="130" cy="125" r="4" fill="#000"/>
  <circle cx="145" cy="122" r="4" fill="#000"/>
  <path d="M145 115 L147 102" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="160" cy="125" r="4" fill="#000"/>
  <!-- Music notes -->
  <text x="20" y="35" font-size="12" fill="#ff6e40">♪</text>
  <text x="180" y="40" font-size="12" fill="#ffeb3b">♫</text>
  <!-- Label -->
  <text x="100" y="20" font-size="10" font-weight="bold" fill="#ff6e40" text-anchor="middle">LIVE TONIGHT</text>
  <text x="100" y="146" font-size="10" font-weight="bold" fill="#ffeb3b" text-anchor="middle">ライブハウス = Small Music Venue</text>
  <text x="100" y="156" font-size="7" fill="#bdbdbd" text-anchor="middle">地下の小さなステージ・ドリンク代別</text>
</svg>

<!-- Japanese レベルアップ = general improvement in any skill/product/service -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Ascending staircase -->
  <rect x="20" y="110" width="30" height="20" fill="#90caf9"/>
  <rect x="50" y="95" width="30" height="35" fill="#64b5f6"/>
  <rect x="80" y="80" width="30" height="50" fill="#42a5f5"/>
  <rect x="110" y="65" width="30" height="65" fill="#1e88e5"/>
  <rect x="140" y="50" width="30" height="80" fill="#1565c0"/>
  <!-- Upward arrow -->
  <path d="M30,108 L160,48" stroke="#ef5350" stroke-width="3" stroke-linecap="round" fill="none"/>
  <polygon points="160,48 155,55 163,56" fill="#ef5350"/>
  <!-- Person climbing on top -->
  <!-- Head -->
  <circle cx="155" cy="32" r="10" fill="#ffcc80"/>
  <!-- Hair -->
  <path d="M146,30 Q146,22 155,22 Q164,22 164,30 L162,27 Q155,23 148,27 Z" fill="#5d4037"/>
  <!-- Happy eyes -->
  <path d="M150,32 Q151,30 153,32" fill="none" stroke="#3e2723" stroke-width="1.3" stroke-linecap="round"/>
  <path d="M157,32 Q158,30 160,32" fill="none" stroke="#3e2723" stroke-width="1.3" stroke-linecap="round"/>
  <!-- Smile -->
  <path d="M151,37 Q155,40 159,37" fill="none" stroke="#3e2723" stroke-width="1.3" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="148" y="42" width="14" height="15" fill="#ff7043" rx="2"/>
  <!-- Arm raised in triumph -->
  <line x1="162" y1="45" x2="170" y2="25" stroke="#ff7043" stroke-width="3.5" stroke-linecap="round"/>
  <circle cx="171" cy="23" r="2.5" fill="#ffcc80"/>
  <!-- Other arm -->
  <line x1="148" y1="45" x2="142" y2="55" stroke="#ff7043" stroke-width="3.5" stroke-linecap="round"/>
  <!-- Legs -->
  <rect x="151" y="57" width="4" height="12" fill="#42a5f5"/>
  <rect x="157" y="57" width="4" height="12" fill="#42a5f5"/>
  <!-- Skill icons on each step -->
  <!-- Step 1: book (study) -->
  <rect x="28" y="100" width="14" height="10" fill="#fff59d" stroke="#f9a825" stroke-width="1"/>
  <line x1="35" y1="100" x2="35" y2="110" stroke="#f9a825" stroke-width="0.8"/>
  <!-- Step 2: document (work) -->
  <rect x="58" y="83" width="14" height="12" fill="white" stroke="#757575" stroke-width="1"/>
  <line x1="61" y1="87" x2="69" y2="87" stroke="#757575" stroke-width="0.8"/>
  <line x1="61" y1="90" x2="69" y2="90" stroke="#757575" stroke-width="0.8"/>
  <!-- Step 3: star (achievement) -->
  <polygon points="95,70 97,76 103,76 98,80 100,86 95,82 90,86 92,80 87,76 93,76" fill="#ffca28"/>
  <!-- Step 4: trophy -->
  <rect x="122" y="55" width="6" height="8" fill="#ffca28"/>
  <rect x="118" y="52" width="14" height="4" fill="#ffb300"/>
  <rect x="120" y="63" width="10" height="2" fill="#f57f17"/>
  <!-- "UP!" label -->
  <text x="100" y="25" font-size="16" font-weight="bold" fill="#1565c0" text-anchor="middle">レベルアップ ↑</text>
  <!-- Floor -->
  <rect x="0" y="130" width="200" height="30" fill="#bbdefb" rx="0"/>
  <text x="100" y="148" font-size="10" fill="#0d47a6" text-anchor="middle">スキル・成長・向上</text>
</svg>

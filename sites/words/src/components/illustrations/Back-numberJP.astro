<!-- Japanese バックナンバー = past magazine issues -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Shelf -->
  <rect x="10" y="125" width="180" height="5" fill="#8d6e63"/>
  <rect x="10" y="130" width="180" height="3" fill="#5d4037"/>
  <!-- Stack of magazines (back issues) -->
  <!-- Magazine 1 (bottom, tilted) -->
  <rect x="20" y="110" width="60" height="16" fill="#4fc3f7" stroke="#01579b" stroke-width="1" transform="rotate(-3 50 118)"/>
  <text x="32" y="121" font-size="6" font-weight="bold" fill="white" transform="rotate(-3 50 118)">2024年1月号</text>
  <!-- Magazine 2 -->
  <rect x="25" y="95" width="60" height="16" fill="#ef5350" stroke="#b71c1c" stroke-width="1" transform="rotate(2 55 103)"/>
  <text x="37" y="106" font-size="6" font-weight="bold" fill="white" transform="rotate(2 55 103)">2024年2月号</text>
  <!-- Magazine 3 -->
  <rect x="22" y="80" width="60" height="16" fill="#66bb6a" stroke="#1b5e20" stroke-width="1" transform="rotate(-2 52 88)"/>
  <text x="34" y="91" font-size="6" font-weight="bold" fill="white" transform="rotate(-2 52 88)">2024年3月号</text>
  <!-- Magazine 4 (top with visible cover) -->
  <rect x="25" y="65" width="60" height="16" fill="#ab47bc" stroke="#4a148c" stroke-width="1"/>
  <text x="55" y="76" font-size="6" font-weight="bold" fill="white" text-anchor="middle">2024年4月号</text>
  <!-- Big magazine on right (standing, featured back issue) -->
  <rect x="110" y="45" width="70" height="80" fill="#fff" stroke="#5d4037" stroke-width="1.5" rx="1"/>
  <!-- Magazine cover image area -->
  <rect x="115" y="50" width="60" height="45" fill="#ff9800"/>
  <circle cx="145" cy="72" r="15" fill="#fff9c4"/>
  <path d="M138 75 Q145 82 152 75" fill="none" stroke="#5d4037" stroke-width="1.5"/>
  <circle cx="140" cy="70" r="1.2" fill="#5d4037"/>
  <circle cx="150" cy="70" r="1.2" fill="#5d4037"/>
  <!-- Magazine title -->
  <rect x="115" y="97" width="60" height="8" fill="#c62828"/>
  <text x="145" y="103" font-size="6" font-weight="bold" fill="white" text-anchor="middle">月刊マガジン</text>
  <text x="145" y="113" font-size="5" fill="#5d4037" text-anchor="middle">特集：昭和の喫茶店</text>
  <text x="145" y="121" font-size="7" font-weight="bold" fill="#c62828" text-anchor="middle">2023年12月号</text>
  <!-- "BACK ISSUE" label -->
  <rect x="105" y="38" width="75" height="10" fill="#ffd54f" stroke="#f57f17" stroke-width="0.8" rx="2"/>
  <text x="142" y="45" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">過去の号（バックナンバー）</text>
  <!-- Label -->
  <text x="100" y="145" font-size="10" font-weight="bold" fill="#5d4037" text-anchor="middle">バックナンバー（雑誌）</text>
  <text x="100" y="156" font-size="8" fill="#795548" text-anchor="middle">= Past magazine issues</text>
</svg>

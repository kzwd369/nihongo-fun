<!-- Japanese ショートケーキ = sponge cake with strawberries and cream -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Plate -->
  <ellipse cx="100" cy="128" rx="65" ry="12" fill="#eceff1" stroke="#cfd8dc" stroke-width="1"/>
  <!-- Triangular cake slice -->
  <!-- Back face -->
  <polygon points="55,125 100,40 145,125" fill="#fff9c4"/>
  <!-- Sponge layers -->
  <rect x="62" y="90" width="76" height="35" fill="#fff9c4" rx="1"/>
  <!-- Cream layer middle -->
  <rect x="62" y="85" width="76" height="8" fill="#fff" rx="1"/>
  <!-- Top sponge -->
  <polygon points="62,85 100,40 138,85" fill="#fff9c4"/>
  <!-- Whipped cream on top (fluffy edges) -->
  <path d="M62 85 Q70 78 80 82 Q90 76 100 80 Q110 76 120 82 Q130 78 138 85" fill="#fff"/>
  <!-- Side cream drips -->
  <path d="M55 125 Q58 115 62 85" fill="none" stroke="#fff" stroke-width="3"/>
  <path d="M145 125 Q142 115 138 85" fill="none" stroke="#fff" stroke-width="3"/>
  <!-- Strawberry on top -->
  <g transform="translate(95, 32)">
    <path d="M5,0 Q12,3 12,12 Q10,18 5,20 Q0,18 -2,12 Q-2,3 5,0" fill="#e53935"/>
    <ellipse cx="5" cy="0" rx="5" ry="2" fill="#43a047"/>
    <!-- Seeds -->
    <circle cx="3" cy="8" r="0.8" fill="#ffcdd2"/>
    <circle cx="7" cy="6" r="0.8" fill="#ffcdd2"/>
    <circle cx="5" cy="12" r="0.8" fill="#ffcdd2"/>
    <circle cx="2" cy="14" r="0.8" fill="#ffcdd2"/>
    <circle cx="8" cy="10" r="0.8" fill="#ffcdd2"/>
  </g>
  <!-- Strawberry slices in cream layer -->
  <circle cx="75" cy="89" r="4" fill="#ef5350"/>
  <circle cx="75" cy="89" r="1.5" fill="#ffcdd2"/>
  <circle cx="95" cy="89" r="4" fill="#ef5350"/>
  <circle cx="95" cy="89" r="1.5" fill="#ffcdd2"/>
  <circle cx="115" cy="89" r="4" fill="#ef5350"/>
  <circle cx="115" cy="89" r="1.5" fill="#ffcdd2"/>
  <!-- Sparkle -->
  <circle cx="55" cy="25" r="2" fill="#f48fb1" opacity="0.5"/>
  <circle cx="150" cy="35" r="1.5" fill="#f48fb1" opacity="0.4"/>
  <!-- Label -->
  <text x="100" y="152" text-anchor="middle" font-size="10" fill="#c62828" font-family="sans-serif">ショートケーキ = strawberry sponge cake</text>
</svg>

<!-- Japanese マイペース = going at one's own pace, unhurried -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Sky with clouds -->
  <ellipse cx="45" cy="25" rx="22" ry="10" fill="white" opacity="0.7"/>
  <ellipse cx="155" cy="20" rx="18" ry="8" fill="white" opacity="0.6"/>
  <!-- Ground / path -->
  <rect x="0" y="125" width="200" height="35" fill="#c8e6c9" rx="0"/>
  <path d="M0 130 Q50 125 100 130 Q150 135 200 128" fill="none" stroke="#a5d6a7" stroke-width="1"/>
  <!-- Rushing person 1 (left, blurred/leaning forward) -->
  <g opacity="0.4">
    <circle cx="28" cy="88" r="7" fill="#ffccbc"/>
    <rect x="22" y="95" width="12" height="18" fill="#78909c" rx="2"/>
    <line x1="22" y1="100" x2="16" y2="108" stroke="#ffccbc" stroke-width="3" stroke-linecap="round"/>
    <line x1="34" y1="100" x2="40" y2="108" stroke="#ffccbc" stroke-width="3" stroke-linecap="round"/>
    <line x1="25" y1="113" x2="20" y2="125" stroke="#546e7a" stroke-width="3" stroke-linecap="round"/>
    <line x1="31" y1="113" x2="38" y2="125" stroke="#546e7a" stroke-width="3" stroke-linecap="round"/>
    <!-- Speed lines -->
    <line x1="8" y1="95" x2="16" y2="95" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
    <line x1="5" y1="102" x2="14" y2="102" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
    <line x1="10" y1="109" x2="17" y2="109" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
  </g>
  <!-- Rushing person 2 (right, also hurrying) -->
  <g opacity="0.4">
    <circle cx="172" cy="90" r="7" fill="#ffe0b2"/>
    <rect x="166" y="97" width="12" height="18" fill="#7986cb" rx="2"/>
    <line x1="166" y1="102" x2="160" y2="110" stroke="#ffe0b2" stroke-width="3" stroke-linecap="round"/>
    <line x1="178" y1="102" x2="184" y2="110" stroke="#ffe0b2" stroke-width="3" stroke-linecap="round"/>
    <line x1="169" y1="115" x2="164" y2="125" stroke="#5c6bc0" stroke-width="3" stroke-linecap="round"/>
    <line x1="175" y1="115" x2="182" y2="125" stroke="#5c6bc0" stroke-width="3" stroke-linecap="round"/>
    <!-- Speed lines -->
    <line x1="190" y1="97" x2="183" y2="97" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
    <line x1="193" y1="104" x2="184" y2="104" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
    <line x1="191" y1="111" x2="183" y2="111" stroke="#90a4ae" stroke-width="1" opacity="0.6"/>
  </g>
  <!-- Main character - relaxed and walking slowly (center) -->
  <!-- Head -->
  <circle cx="100" cy="68" r="14" fill="#ffe0b2"/>
  <!-- Hair -->
  <path d="M86 64 Q86 52 100 50 Q114 52 114 64" fill="#4e342e" stroke="none"/>
  <!-- Relaxed eyes (closed, happy) -->
  <path d="M93 70 Q96 68 99 70" fill="none" stroke="#37474f" stroke-width="1.2" stroke-linecap="round"/>
  <path d="M103 70 Q106 68 109 70" fill="none" stroke="#37474f" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Content smile -->
  <path d="M94 76 Q100 81 106 76" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Body - casual clothes -->
  <rect x="88" y="82" width="24" height="26" fill="#66bb6a" rx="4"/>
  <!-- Arms relaxed at sides -->
  <line x1="88" y1="88" x2="76" y2="102" stroke="#ffe0b2" stroke-width="5" stroke-linecap="round"/>
  <line x1="112" y1="88" x2="124" y2="102" stroke="#ffe0b2" stroke-width="5" stroke-linecap="round"/>
  <!-- Legs walking slowly -->
  <line x1="94" y1="108" x2="90" y2="125" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <line x1="106" y1="108" x2="110" y2="125" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <!-- Musical notes (carefree vibe) -->
  <text x="128" y="58" font-size="14" fill="#66bb6a" opacity="0.7" font-family="serif">&#9834;</text>
  <text x="68" y="52" font-size="11" fill="#66bb6a" opacity="0.5" font-family="serif">&#9835;</text>
  <!-- Small flower on ground -->
  <circle cx="140" cy="128" r="3" fill="#fff176"/>
  <circle cx="140" cy="128" r="1.2" fill="#ffb74d"/>
  <circle cx="60" cy="132" r="3" fill="#f48fb1" opacity="0.6"/>
  <circle cx="60" cy="132" r="1.2" fill="#e91e63" opacity="0.5"/>
</svg>

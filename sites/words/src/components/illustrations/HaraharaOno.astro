<!-- Nervous face with pounding heart and sweat drops — ハラハラ (suspense/anxiety) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Tension lines in background -->
  <line x1="20" y1="20" x2="30" y2="30" stroke="#ffb74d" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="175" y1="25" x2="185" y2="15" stroke="#ffb74d" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="25" y1="130" x2="35" y2="138" stroke="#ffb74d" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="175" y1="135" x2="185" y2="125" stroke="#ffb74d" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <!-- Head -->
  <circle cx="100" cy="82" r="38" fill="#fce4d6"/>
  <!-- Hair -->
  <path d="M65 72 Q72 42 100 40 Q128 42 135 72 Q128 55 100 52 Q72 55 65 72Z" fill="#5d4037"/>
  <!-- Wide worried eyes -->
  <ellipse cx="86" cy="82" rx="5" ry="6" fill="white" stroke="#3e2723" stroke-width="1.5"/>
  <ellipse cx="114" cy="82" rx="5" ry="6" fill="white" stroke="#3e2723" stroke-width="1.5"/>
  <circle cx="86" cy="83" r="2.5" fill="#3e2723"/>
  <circle cx="114" cy="83" r="2.5" fill="#3e2723"/>
  <!-- Raised worried eyebrows -->
  <path d="M78 70 Q86 66 94 72" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M106 72 Q114 66 122 70" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <!-- Small open nervous mouth -->
  <ellipse cx="100" cy="100" rx="4" ry="5" fill="#5d4037"/>
  <!-- Sweat drops -->
  <path d="M138 60 Q138 70 142 74 Q146 70 146 60 Q142 65 138 60Z" fill="#4fc3f7"/>
  <path d="M148 80 Q148 88 151 91 Q154 88 154 80 Q151 84 148 80Z" fill="#4fc3f7" opacity="0.8"/>
  <!-- Pounding heart beside head -->
  <g transform="translate(38,70)">
    <path d="M10 8 C10 2 2 2 2 10 C2 16 10 22 14 26 C18 22 26 16 26 10 C26 2 18 2 14 8 Z" fill="#e53935"/>
    <path d="M10 8 C10 2 2 2 2 10 C2 16 10 22 14 26 C18 22 26 16 26 10 C26 2 18 2 14 8 Z" fill="url(#heartGrad)"/>
  </g>
  <!-- Heart beat lines -->
  <path d="M28 70 Q22 65 26 58" fill="none" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <path d="M20 78 Q12 75 14 68" fill="none" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
  <!-- Falling petals/leaves to evoke ハラハラ falling -->
  <path d="M160 100 Q166 98 170 104 Q166 110 160 108 Z" fill="#ffb74d" opacity="0.7"/>
  <path d="M170 125 Q176 123 180 129 Q176 135 170 133 Z" fill="#ffcc80" opacity="0.6"/>
  <path d="M30 110 Q36 108 40 114 Q36 120 30 118 Z" fill="#ffb74d" opacity="0.6"/>
  <defs>
    <linearGradient id="heartGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="white" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="black" stop-opacity="0.1"/>
    </linearGradient>
  </defs>
</svg>

<!-- Japanese オーダーメイド = custom-made, made-to-order -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#efebe9" rx="8"/>
  <!-- Tailor shop vibe: wooden wall -->
  <rect x="0" y="0" width="200" height="125" fill="#d7ccc8"/>
  <line x1="0" y1="30" x2="200" y2="30" stroke="#a1887f" stroke-width="0.5" opacity="0.5"/>
  <line x1="0" y1="65" x2="200" y2="65" stroke="#a1887f" stroke-width="0.5" opacity="0.5"/>
  <line x1="0" y1="100" x2="200" y2="100" stroke="#a1887f" stroke-width="0.5" opacity="0.5"/>
  <!-- Mannequin with custom suit -->
  <!-- Stand pole -->
  <rect x="99" y="115" width="4" height="10" fill="#5d4037"/>
  <ellipse cx="101" cy="128" rx="15" ry="3" fill="#3e2723"/>
  <!-- Mannequin head (no face) -->
  <circle cx="101" cy="35" r="10" fill="#d7ccc8" stroke="#8d6e63" stroke-width="0.8"/>
  <!-- Neck -->
  <rect x="97" y="42" width="8" height="6" fill="#d7ccc8" stroke="#8d6e63" stroke-width="0.5"/>
  <!-- Suit jacket body -->
  <path d="M75,50 L85,45 L117,45 L127,50 L130,115 L72,115 Z" fill="#263238" stroke="#000" stroke-width="0.8"/>
  <!-- White shirt collar V -->
  <polygon points="101,48 93,55 101,70 109,55" fill="white"/>
  <!-- Tie -->
  <polygon points="98,55 104,55 106,75 96,75 97,70" fill="#b71c1c"/>
  <polygon points="96,75 106,75 101,85" fill="#b71c1c"/>
  <!-- Lapels -->
  <polygon points="85,45 85,75 95,55" fill="#1c2429" stroke="#000" stroke-width="0.3"/>
  <polygon points="117,45 117,75 107,55" fill="#1c2429" stroke="#000" stroke-width="0.3"/>
  <!-- Buttons -->
  <circle cx="101" cy="88" r="1.3" fill="#ffd54f"/>
  <circle cx="101" cy="98" r="1.3" fill="#ffd54f"/>
  <!-- Measuring tape around jacket -->
  <path d="M72,80 Q101,85 130,80" fill="none" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <rect x="65" y="77" width="10" height="5" fill="#ffca28" stroke="#f57f17" stroke-width="0.5" rx="0.5"/>
  <text x="70" y="81" font-size="4" fill="#3e2723" text-anchor="middle">cm</text>
  <!-- Tick marks on tape -->
  <line x1="82" y1="81" x2="82" y2="83" stroke="#3e2723" stroke-width="0.4"/>
  <line x1="92" y1="82" x2="92" y2="84" stroke="#3e2723" stroke-width="0.4"/>
  <line x1="110" y1="82" x2="110" y2="84" stroke="#3e2723" stroke-width="0.4"/>
  <line x1="120" y1="81" x2="120" y2="83" stroke="#3e2723" stroke-width="0.4"/>
  <!-- Pins on shoulder -->
  <circle cx="86" cy="50" r="1.5" fill="#e53935"/>
  <line x1="86" y1="50" x2="86" y2="47" stroke="#9e9e9e" stroke-width="0.5"/>
  <circle cx="116" cy="50" r="1.5" fill="#e53935"/>
  <line x1="116" y1="50" x2="116" y2="47" stroke="#9e9e9e" stroke-width="0.5"/>
  <!-- Scissors on side -->
  <ellipse cx="35" cy="80" rx="3" ry="9" fill="#90a4ae" transform="rotate(-15 35 80)"/>
  <ellipse cx="42" cy="80" rx="3" ry="9" fill="#90a4ae" transform="rotate(15 42 80)"/>
  <circle cx="31" cy="89" r="3.5" fill="none" stroke="#546e7a" stroke-width="1.5"/>
  <circle cx="46" cy="89" r="3.5" fill="none" stroke="#546e7a" stroke-width="1.5"/>
  <!-- Fabric swatches -->
  <rect x="155" y="50" width="20" height="16" fill="#1a237e" stroke="#424242" stroke-width="0.5"/>
  <rect x="160" y="55" width="20" height="16" fill="#4a148c" stroke="#424242" stroke-width="0.5"/>
  <rect x="165" y="60" width="20" height="16" fill="#3e2723" stroke="#424242" stroke-width="0.5"/>
  <!-- Floor -->
  <rect x="0" y="125" width="200" height="35" fill="#bcaaa4" rx="0"/>
  <!-- Label -->
  <text x="100" y="145" font-size="10" font-weight="bold" fill="#3e2723" text-anchor="middle">オーダーメイドのスーツ</text>
  <text x="100" y="156" font-size="8" fill="#5d4037" text-anchor="middle">一人ひとりに合わせて仕立てる</text>
</svg>

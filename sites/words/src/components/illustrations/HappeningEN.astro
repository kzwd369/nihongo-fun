<!-- English "a happening" = neutral event / 1960s avant-garde art happening -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#ede7f6" rx="8"/>
  <!-- Gallery wall -->
  <rect x="0" y="0" width="200" height="125" fill="#f3e5f5"/>
  <rect x="0" y="125" width="200" height="35" fill="#d1c4e9"/>
  <!-- Abstract art canvas on wall -->
  <rect x="110" y="25" width="70" height="60" fill="#fff" stroke="#6a1b9a" stroke-width="2"/>
  <!-- Abstract shapes on canvas -->
  <circle cx="130" cy="45" r="10" fill="#ef5350"/>
  <rect x="145" y="40" width="20" height="20" fill="#ffeb3b" transform="rotate(20 155 50)"/>
  <circle cx="155" cy="70" r="8" fill="#42a5f5"/>
  <path d="M120 70 L135 75 L125 80 Z" fill="#66bb6a"/>
  <!-- Abstract line -->
  <line x1="115" y1="55" x2="175" y2="62" stroke="#6a1b9a" stroke-width="3"/>
  <!-- Art piece label -->
  <text x="145" y="95" font-size="6" fill="#4a148c" text-anchor="middle">"Happening #3"</text>
  <text x="145" y="102" font-size="5" fill="#6a1b9a" text-anchor="middle">Kaprow, 1962</text>
  <!-- Performance artist (center-left) -->
  <circle cx="55" cy="60" r="10" fill="#ffcc80"/>
  <!-- Beret -->
  <ellipse cx="55" cy="52" rx="9" ry="4" fill="#000"/>
  <rect x="50" y="48" width="2" height="3" fill="#000"/>
  <!-- Neutral face -->
  <circle cx="51" cy="60" r="1.2" fill="#5d4037"/>
  <circle cx="59" cy="60" r="1.2" fill="#5d4037"/>
  <line x1="52" y1="65" x2="58" y2="65" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- Turtleneck body -->
  <rect x="48" y="70" width="14" height="30" fill="#212121" rx="2"/>
  <!-- Arms doing performance gesture -->
  <line x1="48" y1="75" x2="38" y2="60" stroke="#212121" stroke-width="4" stroke-linecap="round"/>
  <line x1="62" y1="75" x2="72" y2="60" stroke="#212121" stroke-width="4" stroke-linecap="round"/>
  <!-- Hands holding paint/color -->
  <circle cx="36" cy="58" r="4" fill="#ffcc80"/>
  <circle cx="74" cy="58" r="4" fill="#ffcc80"/>
  <!-- Paint splash coming from hand -->
  <circle cx="30" cy="50" r="3" fill="#e91e63"/>
  <circle cx="25" cy="45" r="2" fill="#ff9800"/>
  <circle cx="20" cy="40" r="1.5" fill="#42a5f5"/>
  <circle cx="80" cy="50" r="3" fill="#66bb6a"/>
  <circle cx="85" cy="45" r="2" fill="#ffc107"/>
  <!-- Pants -->
  <rect x="48" y="100" width="6" height="25" fill="#3e2723"/>
  <rect x="56" y="100" width="6" height="25" fill="#3e2723"/>
  <!-- Museum visitor observing -->
  <circle cx="90" cy="75" r="6" fill="#ffcc80"/>
  <rect x="86" y="80" width="8" height="20" fill="#795548" rx="1"/>
  <!-- Stroking chin pose -->
  <line x1="94" y1="82" x2="92" y2="76" stroke="#ffcc80" stroke-width="2" stroke-linecap="round"/>
  <circle cx="90" cy="72" r="1" fill="#5d4037"/>
  <circle cx="88" cy="74" r="0.5" fill="#5d4037"/>
  <!-- Info plaque -->
  <rect x="105" y="90" width="20" height="12" fill="#fff9c4" stroke="#6a1b9a" stroke-width="0.5"/>
  <text x="115" y="96" font-size="4" fill="#4a148c" text-anchor="middle">HAPPENING</text>
  <text x="115" y="100" font-size="3" fill="#6a1b9a" text-anchor="middle">Art performance</text>
  <!-- Alternative meaning: "happening" as a generic event -->
  <rect x="8" y="105" width="38" height="15" fill="#b39ddb" stroke="#4a148c" stroke-width="0.8" rx="2"/>
  <text x="27" y="113" font-size="6" fill="white" text-anchor="middle">a happening</text>
  <text x="27" y="119" font-size="5" fill="white" text-anchor="middle">= an event</text>
  <!-- Label -->
  <text x="100" y="20" font-size="10" font-weight="bold" fill="#4a148c" text-anchor="middle">"A Happening" = Art event / occurrence</text>
  <text x="100" y="146" font-size="9" font-weight="bold" fill="#4a148c" text-anchor="middle">Neutral — no "gaffe" nuance</text>
  <text x="100" y="156" font-size="7" fill="#6a1b9a" text-anchor="middle">1960s avant-garde art performances</text>
</svg>

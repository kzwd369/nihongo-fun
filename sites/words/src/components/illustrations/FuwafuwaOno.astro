<!-- Floating fluffy clouds — ふわふわ (soft and fluffy) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Background big soft cloud -->
  <ellipse cx="60" cy="50" rx="30" ry="16" fill="#ffffff" opacity="0.7"/>
  <circle cx="50" cy="48" r="14" fill="#ffffff" opacity="0.7"/>
  <circle cx="72" cy="46" r="13" fill="#ffffff" opacity="0.7"/>
  <!-- Small upper cloud -->
  <ellipse cx="160" cy="35" rx="22" ry="12" fill="#ffffff" opacity="0.85"/>
  <circle cx="152" cy="32" r="10" fill="#ffffff" opacity="0.85"/>
  <circle cx="168" cy="32" r="11" fill="#ffffff" opacity="0.85"/>
  <!-- Main fluffy cloud center -->
  <ellipse cx="100" cy="95" rx="55" ry="28" fill="#ffffff"/>
  <circle cx="68" cy="90" r="20" fill="#ffffff"/>
  <circle cx="132" cy="90" r="20" fill="#ffffff"/>
  <circle cx="85" cy="78" r="18" fill="#ffffff"/>
  <circle cx="115" cy="78" r="18" fill="#ffffff"/>
  <circle cx="100" cy="72" r="16" fill="#ffffff"/>
  <!-- Soft shadow underneath -->
  <ellipse cx="100" cy="125" rx="48" ry="6" fill="#bbdefb" opacity="0.5"/>
  <!-- Tiny floating fluff -->
  <circle cx="30" cy="100" r="6" fill="#ffffff" opacity="0.8"/>
  <circle cx="35" cy="105" r="4" fill="#ffffff" opacity="0.8"/>
  <circle cx="170" cy="110" r="6" fill="#ffffff" opacity="0.8"/>
  <circle cx="175" cy="115" r="4" fill="#ffffff" opacity="0.8"/>
  <!-- Sparkles to show softness -->
  <text x="40" y="135" font-size="12" fill="#90caf9" opacity="0.7">✦</text>
  <text x="155" y="140" font-size="14" fill="#90caf9" opacity="0.7">✦</text>
  <text x="100" y="148" font-size="10" fill="#64b5f6" opacity="0.6">✦</text>
</svg>

<!-- Japanese アメリカンコーヒー = weak/light drip coffee, Shōwa kissaten style -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Kissaten wall wood panel -->
  <rect x="0" y="0" width="200" height="115" fill="#d7ccc8"/>
  <line x1="0" y1="28" x2="200" y2="28" stroke="#a1887f" stroke-width="0.5" opacity="0.6"/>
  <line x1="0" y1="56" x2="200" y2="56" stroke="#a1887f" stroke-width="0.5" opacity="0.6"/>
  <line x1="0" y1="84" x2="200" y2="84" stroke="#a1887f" stroke-width="0.5" opacity="0.6"/>
  <!-- Vintage wall clock -->
  <circle cx="160" cy="30" r="12" fill="#fff8e1" stroke="#5d4037" stroke-width="1.5"/>
  <circle cx="160" cy="30" r="1.5" fill="#5d4037"/>
  <line x1="160" y1="30" x2="160" y2="22" stroke="#5d4037" stroke-width="1.2"/>
  <line x1="160" y1="30" x2="166" y2="30" stroke="#5d4037" stroke-width="1"/>
  <text x="160" y="25" font-size="4" fill="#5d4037" text-anchor="middle">12</text>
  <!-- Saucer -->
  <ellipse cx="100" cy="110" rx="55" ry="8" fill="#fafafa" stroke="#bdbdbd" stroke-width="1"/>
  <ellipse cx="100" cy="108" rx="40" ry="5" fill="#f5f5f5"/>
  <!-- Cup (tall, kissaten style) -->
  <path d="M65,65 L70,105 L130,105 L135,65 Z" fill="#fafafa" stroke="#8d6e63" stroke-width="1.5"/>
  <!-- Cup rim -->
  <ellipse cx="100" cy="65" rx="35" ry="5" fill="#fafafa" stroke="#8d6e63" stroke-width="1.5"/>
  <!-- Handle -->
  <path d="M135,75 Q150,80 148,92 Q145,100 132,98" fill="none" stroke="#8d6e63" stroke-width="2"/>
  <!-- Light coffee (amber/tea-like tone vs dark espresso) -->
  <ellipse cx="100" cy="66" rx="32" ry="4" fill="#b08d5e"/>
  <ellipse cx="100" cy="66" rx="28" ry="3" fill="#c9a87a"/>
  <!-- Steam -->
  <path d="M85,55 Q83,45 85,37 Q87,30 84,22" fill="none" stroke="#eceff1" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <path d="M100,55 Q102,45 100,37 Q98,30 101,22" fill="none" stroke="#eceff1" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <path d="M115,55 Q117,45 115,37 Q113,30 116,22" fill="none" stroke="#eceff1" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <!-- Retro pattern on saucer -->
  <circle cx="60" cy="115" r="2" fill="none" stroke="#8d6e63" stroke-width="0.5" opacity="0.5"/>
  <circle cx="140" cy="115" r="2" fill="none" stroke="#8d6e63" stroke-width="0.5" opacity="0.5"/>
  <!-- Sugar cube -->
  <rect x="45" y="113" width="8" height="6" fill="white" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Floor -->
  <rect x="0" y="115" width="200" height="45" fill="#a1887f" rx="0"/>
  <!-- Label -->
  <text x="100" y="135" font-size="11" font-weight="bold" fill="#3e2723" text-anchor="middle">アメリカンコーヒー</text>
  <text x="100" y="148" font-size="8" fill="#5d4037" text-anchor="middle">薄めの ドリップコーヒー（喫茶店）</text>
  <text x="100" y="157" font-size="7" fill="#8d6e63" text-anchor="middle">Shōwa kissaten classic</text>
</svg>

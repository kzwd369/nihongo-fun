<!-- Japanese バイキング = all-you-can-eat buffet -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Buffet table -->
  <rect x="20" y="85" width="160" height="12" fill="#8d6e63" rx="2"/>
  <rect x="25" y="97" width="6" height="40" fill="#6d4c41"/>
  <rect x="169" y="97" width="6" height="40" fill="#6d4c41"/>
  <!-- Table cloth -->
  <rect x="18" y="82" width="164" height="6" fill="#ffffff" rx="1"/>
  <!-- Food plate 1 - salad -->
  <ellipse cx="50" cy="75" rx="18" ry="8" fill="#e0e0e0"/>
  <ellipse cx="50" cy="73" rx="14" ry="6" fill="#81c784"/>
  <circle cx="46" cy="71" r="3" fill="#ef5350"/>
  <circle cx="54" cy="72" r="2" fill="#ff8a65"/>
  <!-- Food plate 2 - meat/main -->
  <ellipse cx="100" cy="75" rx="18" ry="8" fill="#e0e0e0"/>
  <rect x="88" y="68" width="24" height="8" fill="#a1887f" rx="3"/>
  <rect x="90" y="66" width="6" height="4" fill="#d7ccc8" rx="1"/>
  <!-- Food plate 3 - sushi/rice -->
  <ellipse cx="150" cy="75" rx="18" ry="8" fill="#e0e0e0"/>
  <rect x="140" y="68" width="8" height="5" fill="#fff9c4" rx="1"/>
  <rect x="140" y="67" width="8" height="3" fill="#ef5350" rx="1"/>
  <rect x="152" y="68" width="8" height="5" fill="#fff9c4" rx="1"/>
  <rect x="152" y="67" width="8" height="3" fill="#ff8a65" rx="1"/>
  <!-- Stack of plates -->
  <ellipse cx="30" cy="68" rx="8" ry="3" fill="#eceff1"/>
  <ellipse cx="30" cy="66" rx="8" ry="3" fill="#f5f5f5"/>
  <ellipse cx="30" cy="64" rx="8" ry="3" fill="#ffffff"/>
  <!-- Person with plate (happy) -->
  <circle cx="100" cy="30" r="12" fill="#ffcc80"/>
  <!-- Eyes (happy) -->
  <path d="M94,28 Q96,32 98,28" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M102,28 Q104,32 106,28" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Smile -->
  <path d="M94,34 Q100,40 106,34" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="92" y="42" width="16" height="20" fill="#42a5f5" rx="3"/>
  <!-- Arms holding plate -->
  <line x1="92" y1="48" x2="78" y2="58" stroke="#42a5f5" stroke-width="4" stroke-linecap="round"/>
  <line x1="108" y1="48" x2="122" y2="58" stroke="#42a5f5" stroke-width="4" stroke-linecap="round"/>
  <!-- Plate in hands -->
  <ellipse cx="100" cy="60" rx="22" ry="5" fill="#f5f5f5"/>
  <!-- Food piled on plate -->
  <circle cx="93" cy="56" r="4" fill="#81c784"/>
  <circle cx="100" cy="55" r="4" fill="#a1887f"/>
  <circle cx="107" cy="56" r="4" fill="#ef5350"/>
  <!-- "食べ放題" sign -->
  <rect x="140" y="10" width="52" height="20" fill="#ff7043" rx="4"/>
  <text x="166" y="24" font-size="8" fill="white" text-anchor="middle" font-family="sans-serif">食べ放題</text>
  <!-- Floor -->
  <rect x="0" y="137" width="200" height="23" fill="#efebe9" rx="0"/>
</svg>

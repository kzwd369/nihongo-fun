<!-- English "virgin road" = not a thing / only "the aisle" -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e1f5fe" rx="8"/>
  <!-- Confused English speaker -->
  <!-- Head -->
  <circle cx="60" cy="60" r="18" fill="#ffcc80"/>
  <!-- Hair -->
  <path d="M45 50 Q55 38 75 45 L75 55 Q65 50 48 55 Z" fill="#6d4c41"/>
  <!-- Confused eyes (one squinting) -->
  <path d="M51 58 Q54 56 57 58" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <circle cx="66" cy="58" r="1.5" fill="#5d4037"/>
  <!-- Raised eyebrow -->
  <path d="M50 52 Q54 50 58 52" fill="none" stroke="#5d4037" stroke-width="1.3"/>
  <path d="M62 51 Q66 48 70 51" fill="none" stroke="#5d4037" stroke-width="1.3"/>
  <!-- Scrunched confused mouth -->
  <path d="M55 70 Q60 68 65 70" fill="none" stroke="#5d4037" stroke-width="1.3" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="50" y="78" width="20" height="30" fill="#42a5f5" rx="3"/>
  <!-- Arm scratching head -->
  <line x1="52" y1="82" x2="45" y2="65" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <circle cx="44" cy="62" r="3" fill="#ffcc80"/>
  <!-- Other arm -->
  <line x1="70" y1="82" x2="80" y2="100" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <!-- Legs -->
  <rect x="52" y="108" width="6" height="25" fill="#1565c0"/>
  <rect x="62" y="108" width="6" height="25" fill="#1565c0"/>
  <!-- "???" thought bubble -->
  <path d="M90 35 Q100 25 125 30 Q140 35 140 50 Q135 60 120 58 L115 68 L112 58 Q95 55 90 45 Z" fill="#fff" stroke="#1565c0" stroke-width="1.5"/>
  <text x="115" y="48" font-size="18" font-weight="bold" fill="#1565c0" text-anchor="middle">???</text>
  <!-- Small thought circles -->
  <circle cx="85" cy="45" r="3" fill="#fff" stroke="#1565c0" stroke-width="1"/>
  <circle cx="80" cy="52" r="1.5" fill="#fff" stroke="#1565c0" stroke-width="1"/>
  <!-- Dictionary / bridal magazine with X -->
  <rect x="145" y="40" width="45" height="55" fill="#fce4ec" stroke="#880e4f" stroke-width="1.5" rx="2"/>
  <text x="167" y="52" font-size="7" font-weight="bold" fill="#880e4f" text-anchor="middle">BRIDE</text>
  <text x="167" y="60" font-size="5" fill="#880e4f" text-anchor="middle">Magazine</text>
  <line x1="150" y1="64" x2="185" y2="64" stroke="#880e4f" stroke-width="0.3"/>
  <text x="167" y="72" font-size="4" fill="#880e4f" text-anchor="middle">The Aisle ✓</text>
  <text x="167" y="78" font-size="4" fill="#880e4f" text-anchor="middle">Walk down ✓</text>
  <text x="167" y="84" font-size="4" fill="#c62828" text-anchor="middle">Virgin Road ✗</text>
  <text x="167" y="90" font-size="3" fill="#757575" text-anchor="middle">(not in index)</text>
  <!-- Large red X over "Virgin Road" term -->
  <rect x="30" y="115" width="140" height="22" fill="#ffebee" stroke="#c62828" stroke-width="1.5" rx="3"/>
  <text x="100" y="129" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">"Virgin Road" — not an English term</text>
  <line x1="35" y1="118" x2="167" y2="134" stroke="#c62828" stroke-width="1.8" opacity="0.6"/>
  <!-- English correct term -->
  <rect x="40" y="142" width="120" height="14" fill="#c8e6c9" stroke="#2e7d32" stroke-width="1" rx="2"/>
  <text x="100" y="152" font-size="8" font-weight="bold" fill="#1b5e20" text-anchor="middle">✓ Say "the aisle" instead</text>
  <!-- Label -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#0d47a1" text-anchor="middle">English speakers: "Huh?"</text>
</svg>

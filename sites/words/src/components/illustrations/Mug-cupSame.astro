<!-- マグカップ = mug (English: just "mug", but same object) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f7fa" rx="8"/>
  <!-- Warm sparkle background -->
  <text x="30" y="30" font-size="12" fill="#80deea" opacity="0.7">✦</text>
  <text x="165" y="35" font-size="10" fill="#80deea" opacity="0.7">✦</text>
  <text x="25" y="125" font-size="10" fill="#80deea" opacity="0.7">✦</text>
  <!-- Table surface -->
  <ellipse cx="100" cy="130" rx="75" ry="8" fill="#bcaaa4" opacity="0.4"/>
  <!-- Coaster -->
  <ellipse cx="100" cy="128" rx="50" ry="6" fill="#8d6e63"/>
  <ellipse cx="100" cy="127" rx="45" ry="4" fill="#a1887f"/>
  <!-- Mug body -->
  <rect x="65" y="50" width="60" height="75" fill="white" stroke="#00838f" stroke-width="2.5" rx="3"/>
  <!-- Mug top opening (ellipse for 3D) -->
  <ellipse cx="95" cy="50" rx="30" ry="6" fill="white" stroke="#00838f" stroke-width="2.5"/>
  <!-- Inside rim shadow -->
  <ellipse cx="95" cy="50" rx="26" ry="4" fill="#546e7a" opacity="0.8"/>
  <!-- Coffee inside -->
  <ellipse cx="95" cy="50" rx="24" ry="3" fill="#4e342e"/>
  <!-- Handle (big round handle - defining feature of a mug) -->
  <path d="M125,65 Q155,70 155,90 Q155,110 125,110" fill="none" stroke="#00838f" stroke-width="5" stroke-linecap="round"/>
  <path d="M125,70 Q148,74 148,90 Q148,106 125,105" fill="white"/>
  <path d="M125,70 Q148,74 148,90 Q148,106 125,105" fill="none" stroke="#00838f" stroke-width="2"/>
  <!-- Cute design on mug -->
  <!-- Heart -->
  <path d="M95,82 L90,77 Q85,72 90,70 Q93,70 95,74 Q97,70 100,70 Q105,72 100,77 Z" fill="#ef5350"/>
  <!-- Subtitle text on mug -->
  <text x="95" y="100" font-size="8" font-weight="bold" fill="#546e7a" text-anchor="middle">COFFEE</text>
  <text x="95" y="112" font-size="6" fill="#78909c" text-anchor="middle">time</text>
  <!-- Steam rising -->
  <path d="M80,42 Q78,32 82,22 Q85,14 80,8" fill="none" stroke="#b2ebf2" stroke-width="2.5" stroke-linecap="round" opacity="0.8"/>
  <path d="M95,42 Q97,32 93,22 Q90,14 95,8" fill="none" stroke="#b2ebf2" stroke-width="2.5" stroke-linecap="round" opacity="0.8"/>
  <path d="M110,42 Q108,32 112,22 Q115,14 110,8" fill="none" stroke="#b2ebf2" stroke-width="2.5" stroke-linecap="round" opacity="0.8"/>
  <!-- Labels -->
  <text x="100" y="145" font-size="10" font-weight="bold" fill="#006064" text-anchor="middle">マグカップ = Mug</text>
  <text x="100" y="156" font-size="8" fill="#00838f" text-anchor="middle">同じ物 (English uses just "mug" — no "cup")</text>
</svg>

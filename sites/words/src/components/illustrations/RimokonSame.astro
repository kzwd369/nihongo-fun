<!-- Japanese リモコン = remote control (abbreviated from リモートコントロール) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Remote control body -->
  <rect x="70" y="10" width="60" height="140" fill="#455a64" rx="10"/>
  <rect x="73" y="13" width="54" height="134" fill="#546e7a" rx="8"/>
  <!-- Power button (red) -->
  <circle cx="100" cy="28" r="6" fill="#ef5350"/>
  <circle cx="100" cy="28" r="4.5" fill="#e53935"/>
  <!-- Power icon -->
  <path d="M100 24 L100 26" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
  <path d="M96 25 Q96 30 100 32 Q104 30 104 25" fill="none" stroke="white" stroke-width="1" stroke-linecap="round"/>
  <!-- Screen / display area -->
  <rect x="82" y="40" width="36" height="14" fill="#263238" rx="2"/>
  <text x="100" y="51" font-size="7" fill="#4fc3f7" text-anchor="middle" font-family="monospace">CH 08</text>
  <!-- Volume / Channel buttons -->
  <!-- Volume -->
  <rect x="78" y="60" width="18" height="12" fill="#37474f" rx="3"/>
  <text x="87" y="69" font-size="7" fill="#b0bec5" text-anchor="middle" font-family="sans-serif">VOL</text>
  <!-- Channel -->
  <rect x="104" y="60" width="18" height="12" fill="#37474f" rx="3"/>
  <text x="113" y="69" font-size="7" fill="#b0bec5" text-anchor="middle" font-family="sans-serif">CH</text>
  <!-- Plus/minus indicators -->
  <text x="87" y="58" font-size="6" fill="#90a4ae" text-anchor="middle">+</text>
  <text x="87" y="78" font-size="6" fill="#90a4ae" text-anchor="middle">-</text>
  <text x="113" y="58" font-size="6" fill="#90a4ae" text-anchor="middle">&#9650;</text>
  <text x="113" y="78" font-size="6" fill="#90a4ae" text-anchor="middle">&#9660;</text>
  <!-- Number pad -->
  <!-- Row 1 -->
  <rect x="78" y="84" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="84" y="92" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">1</text>
  <rect x="94" y="84" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="100" y="92" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">2</text>
  <rect x="110" y="84" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="116" y="92" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">3</text>
  <!-- Row 2 -->
  <rect x="78" y="98" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="84" y="106" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">4</text>
  <rect x="94" y="98" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="100" y="106" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">5</text>
  <rect x="110" y="98" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="116" y="106" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">6</text>
  <!-- Row 3 -->
  <rect x="78" y="112" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="84" y="120" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">7</text>
  <rect x="94" y="112" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="100" y="120" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">8</text>
  <rect x="110" y="112" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="116" y="120" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">9</text>
  <!-- Bottom row -->
  <rect x="94" y="126" width="12" height="10" fill="#37474f" rx="2"/>
  <text x="100" y="134" font-size="7" fill="#cfd8dc" text-anchor="middle" font-family="sans-serif">0</text>
  <!-- Color buttons -->
  <circle cx="82" y="126" cx="82" cy="131" r="3.5" fill="#ef5350" opacity="0.8"/>
  <circle cx="118" cy="131" r="3.5" fill="#42a5f5" opacity="0.8"/>
  <!-- IR sensor -->
  <rect x="95" y="14" width="10" height="3" fill="#263238" rx="1"/>
  <!-- Signal waves -->
  <path d="M100 5 Q95 0 100 -3" fill="none" stroke="#7986cb" stroke-width="1" opacity="0.4"/>
  <path d="M100 5 Q106 0 100 -3" fill="none" stroke="#7986cb" stroke-width="1" opacity="0.4"/>
</svg>

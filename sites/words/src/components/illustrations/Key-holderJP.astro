  <!-- Label -->
  <text x="100" y="148" font-size="10" font-weight="bold" fill="#880e4f" text-anchor="middle">キーホルダー = Charm on a ring</text>
  <text x="100" y="157" font-size="7" fill="#ad1457" text-anchor="middle">アクリル・ぬい・ご当地・グッズの定番</text>

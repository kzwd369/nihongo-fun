  <line x1="155" y1="40" x2="155" y2="55" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="155" cy="40" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <ellipse cx="155" cy="65" rx="14" ry="9" fill="#bcaaa4" stroke="#6d4c41" stroke-width="1.5"/>

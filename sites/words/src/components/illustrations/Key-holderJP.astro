  <ellipse cx="56" cy="95" rx="2" ry="3" fill="#fff"/>
  <ellipse cx="56" cy="95" rx="1.5" ry="2.5" fill="#1976d2"/>
  <circle cx="56" cy="95" r="0.8" fill="#000"/>
  <ellipse cx="64" cy="95" rx="2" ry="3" fill="#fff"/>
  <ellipse cx="64" cy="95" rx="1.5" ry="2.5" fill="#1976d2"/>

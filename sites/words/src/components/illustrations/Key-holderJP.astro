  <circle cx="125" cy="72" r="9" fill="#a5d6a7" stroke="#388e3c" stroke-width="1"/>
  <circle cx="121" cy="70" r="1" fill="#000"/>
  <circle cx="129" cy="70" r="1" fill="#000"/>
  <path d="M122 75 Q125 77 128 75" fill="none" stroke="#000" stroke-width="0.6"/>

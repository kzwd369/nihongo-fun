  <ellipse cx="60" cy="62" rx="2.5" ry="1.5" fill="none" stroke="#757575" stroke-width="1"/>
  <ellipse cx="60" cy="66" rx="2.5" ry="1.5" fill="none" stroke="#757575" stroke-width="1"/>

  <rect x="55" y="106" width="10" height="14" fill="#f06292" rx="2"/>
  <!-- Sparkles around charm -->
  <text x="35" y="65" font-size="10" fill="#ffd54f">✦</text>
  <text x="85" y="78" font-size="8" fill="#ec407a">♥</text>
  <text x="83" y="115" font-size="9" fill="#ffd54f">✦</text>
  <!-- Smaller key holders dangling -->
  <!-- Acrylic small -->
  <line x1="100" y1="50" x2="100" y2="65" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="100" cy="50" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <rect x="92" y="65" width="16" height="20" fill="#fff9c4" stroke="#f9a825" stroke-width="1" rx="2"/>
  <text x="100" y="78" font-size="11" text-anchor="middle">🐱</text>
  <!-- Plush key holder -->
  <line x1="125" y1="50" x2="125" y2="62" stroke="#9e9e9e" stroke-width="1"/>

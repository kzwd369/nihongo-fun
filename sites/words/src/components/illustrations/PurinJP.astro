<!-- Japanese プリン = caramel custard pudding (crème caramel) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Plate -->
  <ellipse cx="100" cy="128" rx="60" ry="10" fill="#eceff1" stroke="#cfd8dc" stroke-width="1"/>
  <!-- Caramel sauce pool on plate -->
  <ellipse cx="100" cy="125" rx="40" ry="6" fill="#6d4c41" opacity="0.6"/>
  <!-- Pudding body (trapezoid shape) -->
  <path d="M70 125 L75 60 Q100 55 125 60 L130 125 Z" fill="#ffd54f"/>
  <!-- Top surface -->
  <ellipse cx="100" cy="60" rx="25" ry="6" fill="#ffca28"/>
  <!-- Caramel on top dripping -->
  <ellipse cx="100" cy="60" rx="22" ry="5" fill="#8d6e63"/>
  <path d="M82 62 Q80 72 82 78" stroke="#8d6e63" stroke-width="3" fill="none" stroke-linecap="round"/>
  <path d="M118 62 Q120 70 118 75" stroke="#8d6e63" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <path d="M95 64 Q94 68 95 70" stroke="#8d6e63" stroke-width="2" fill="none" stroke-linecap="round"/>
  <!-- Shine/highlight on pudding -->
  <ellipse cx="90" cy="80" rx="6" ry="15" fill="#ffe082" opacity="0.5" transform="rotate(-10, 90, 80)"/>
  <!-- Caramel drip on plate -->
  <path d="M75 125 Q72 128 78 130" stroke="#6d4c41" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.5"/>
  <!-- Cherry on top -->
  <circle cx="100" cy="54" r="5" fill="#e53935"/>
  <line x1="100" y1="49" x2="102" y2="44" stroke="#43a047" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M102 44 Q105 42 107 44" fill="none" stroke="#43a047" stroke-width="1"/>
  <!-- Sparkle -->
  <circle cx="60" cy="40" r="2" fill="#ffd54f" opacity="0.5"/>
  <circle cx="145" cy="50" r="1.5" fill="#ffd54f" opacity="0.4"/>
  <!-- Label -->
  <text x="100" y="152" text-anchor="middle" font-size="11" fill="#795548" font-family="sans-serif">プリン = caramel custard pudding</text>
</svg>

<!-- メルマガ = email newsletter (same concept in English: "email newsletter") -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Background dotted lines (emails flying) -->
  <path d="M20,130 Q40,100 60,120 Q80,140 100,110" fill="none" stroke="#9fa8da" stroke-width="1" stroke-dasharray="2,3"/>
  <path d="M140,120 Q160,100 180,130" fill="none" stroke="#9fa8da" stroke-width="1" stroke-dasharray="2,3"/>
  <!-- Main envelope -->
  <rect x="55" y="45" width="90" height="60" fill="white" stroke="#3949ab" stroke-width="2" rx="3"/>
  <!-- Envelope flap -->
  <polygon points="55,45 100,78 145,45" fill="#c5cae9" stroke="#3949ab" stroke-width="2"/>
  <!-- @ symbol watermark -->
  <text x="100" y="92" font-size="28" font-weight="bold" fill="#3949ab" text-anchor="middle" opacity="0.7">@</text>
  <!-- "NEWSLETTER" banner -->
  <rect x="35" y="68" width="30" height="12" fill="#ef5350" rx="2"/>
  <text x="50" y="76" font-size="7" font-weight="bold" fill="white" text-anchor="middle">NEW!</text>
  <!-- Small flying emails -->
  <g transform="translate(15,25)">
    <rect x="0" y="0" width="20" height="14" fill="white" stroke="#5c6bc0" stroke-width="1" rx="1"/>
    <polygon points="0,0 10,7 20,0" fill="#c5cae9" stroke="#5c6bc0" stroke-width="1"/>
  </g>
  <g transform="translate(165,30)">
    <rect x="0" y="0" width="20" height="14" fill="white" stroke="#5c6bc0" stroke-width="1" rx="1"/>
    <polygon points="0,0 10,7 20,0" fill="#c5cae9" stroke="#5c6bc0" stroke-width="1"/>
  </g>
  <g transform="translate(10,108)">
    <rect x="0" y="0" width="18" height="12" fill="white" stroke="#5c6bc0" stroke-width="1" rx="1"/>
    <polygon points="0,0 9,6 18,0" fill="#c5cae9" stroke="#5c6bc0" stroke-width="1"/>
  </g>
  <g transform="translate(170,105)">
    <rect x="0" y="0" width="18" height="12" fill="white" stroke="#5c6bc0" stroke-width="1" rx="1"/>
    <polygon points="0,0 9,6 18,0" fill="#c5cae9" stroke="#5c6bc0" stroke-width="1"/>
  </g>
  <!-- Subscribe button below -->
  <rect x="65" y="115" width="70" height="18" fill="#3949ab" stroke="#1a237e" stroke-width="1" rx="4"/>
  <text x="100" y="127" font-size="9" font-weight="bold" fill="white" text-anchor="middle">✉ SUBSCRIBE</text>
  <!-- Labels -->
  <text x="100" y="25" font-size="11" font-weight="bold" fill="#1a237e" text-anchor="middle">メルマガ = Email Newsletter</text>
  <text x="100" y="148" font-size="9" fill="#3949ab" text-anchor="middle">同じ概念 (Same meaning in English)</text>
  <text x="100" y="157" font-size="7" fill="#5c6bc0" text-anchor="middle">日本語: メールマガジン／メルマガ</text>
</svg>

<!-- Japanese クリームソーダ = bright green melon soda float with vanilla ice cream and cherry -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Retro dots pattern (Shōwa kissaten) -->
  <circle cx="25" cy="25" r="2" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="175" cy="30" r="2" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="30" cy="130" r="2" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="170" cy="135" r="2" fill="#f8bbd0" opacity="0.6"/>
  <!-- Footed soda glass -->
  <!-- Base foot -->
  <ellipse cx="100" cy="135" rx="22" ry="4" fill="#eceff1" stroke="#90a4ae" stroke-width="1"/>
  <rect x="97" y="115" width="6" height="20" fill="#e3f2fd" stroke="#90a4ae" stroke-width="0.8"/>
  <!-- Glass bowl (flared) -->
  <path d="M72,45 L82,115 L118,115 L128,45 Z" fill="#c8e6c9" opacity="0.4" stroke="#81c784" stroke-width="1.2"/>
  <!-- Green melon soda -->
  <path d="M75,55 L84,113 L116,113 L125,55 Z" fill="#66bb6a" opacity="0.85"/>
  <!-- Bubbles -->
  <circle cx="90" cy="75" r="2" fill="white" opacity="0.7"/>
  <circle cx="105" cy="85" r="1.5" fill="white" opacity="0.7"/>
  <circle cx="95" cy="95" r="1.8" fill="white" opacity="0.7"/>
  <circle cx="110" cy="100" r="1.2" fill="white" opacity="0.7"/>
  <circle cx="88" cy="105" r="1.5" fill="white" opacity="0.7"/>
  <circle cx="102" cy="65" r="1.8" fill="white" opacity="0.7"/>
  <!-- Glass rim -->
  <ellipse cx="100" cy="45" rx="28" ry="4" fill="#a5d6a7" opacity="0.4" stroke="#81c784" stroke-width="1.2"/>
  <!-- Vanilla ice cream scoop -->
  <circle cx="100" cy="40" r="16" fill="#fffde7" stroke="#f9a825" stroke-width="1"/>
  <circle cx="100" cy="40" r="14" fill="#fff9c4"/>
  <!-- Ice cream texture -->
  <path d="M92,38 Q94,35 96,38" fill="none" stroke="#fff59d" stroke-width="1" opacity="0.7"/>
  <path d="M104,40 Q106,37 108,40" fill="none" stroke="#fff59d" stroke-width="1" opacity="0.7"/>
  <!-- Cherry on top -->
  <circle cx="100" cy="22" r="5" fill="#e53935" stroke="#b71c1c" stroke-width="0.8"/>
  <circle cx="98" cy="20" r="1.5" fill="#ef5350"/>
  <!-- Cherry stem -->
  <path d="M100,17 Q103,12 108,14" fill="none" stroke="#2e7d32" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Leaf -->
  <ellipse cx="110" cy="13" rx="3" ry="1.5" fill="#43a047" transform="rotate(30 110 13)"/>
  <!-- Straw -->
  <rect x="115" y="25" width="3" height="40" fill="#e91e63" transform="rotate(15 115 25)"/>
  <rect x="115" y="25" width="3" height="40" fill="#f06292" transform="rotate(15 115 25)" opacity="0.5"/>
  <!-- Straw stripes -->
  <line x1="117" y1="30" x2="125" y2="33" stroke="white" stroke-width="0.8"/>
  <line x1="119" y1="42" x2="127" y2="45" stroke="white" stroke-width="0.8"/>
  <!-- Label -->
  <text x="100" y="152" font-size="10" font-weight="bold" fill="#880e4f" text-anchor="middle">クリームソーダ（昭和の喫茶店）</text>
</svg>

    <ellipse cx="255" cy="282" rx="7" ry="3.5" fill="#e53935"/>
  </g>

  <!-- Character 2 (right, reading a book) -->
  <g>
    <!-- Body -->
    <rect x="370" y="238" width="26" height="28" rx="9" fill="#ec407a"/>

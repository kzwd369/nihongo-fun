<!-- Nihongo Fun hero: vibrant Japan scene with kawaii characters, torii, sakura, and floating Japanese words -->
<svg viewBox="0 0 520 320" width="100%" xmlns="http://www.w3.org/2000/svg" style="margin: 0 auto; display: block; max-width: 680px;">
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#e1f5fe"/>
      <stop offset="60%" stop-color="#fff8e1"/>
      <stop offset="100%" stop-color="#fce4ec"/>
    </linearGradient>
    <linearGradient id="hill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#a5d6a7"/>
      <stop offset="100%" stop-color="#81c784"/>
    </linearGradient>
    <linearGradient id="hill2" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#c8e6c9"/>
      <stop offset="100%" stop-color="#a5d6a7"/>
    </linearGradient>
    <radialGradient id="sun" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0%" stop-color="#fff9c4"/>
      <stop offset="100%" stop-color="#fff176" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <!-- Background -->
  <rect width="520" height="320" rx="20" fill="url(#sky)"/>

  <!-- Sun glow -->
  <circle cx="420" cy="60" r="60" fill="url(#sun)" opacity="0.6"/>
  <circle cx="420" cy="60" r="22" fill="#ffee58" opacity="0.4"/>

  <!-- Clouds -->
  <g opacity="0.35">
    <ellipse cx="80" cy="40" rx="40" ry="14" fill="white"/>
    <ellipse cx="60" cy="38" rx="22" ry="10" fill="white"/>
    <ellipse cx="100" cy="36" rx="20" ry="10" fill="white"/>
  </g>
  <g opacity="0.25">
    <ellipse cx="340" cy="30" rx="30" ry="10" fill="white"/>
    <ellipse cx="325" cy="28" rx="16" ry="8" fill="white"/>
    <ellipse cx="355" cy="27" rx="14" ry="7" fill="white"/>
  </g>

  <!-- Mt. Fuji (background) -->
  <path d="M370 240 L420 100 L470 240 Z" fill="#b0bec5" opacity="0.25"/>
  <path d="M390 180 L420 120 L450 180 Z" fill="white" opacity="0.3"/>

  <!-- Hills -->
  <ellipse cx="130" cy="300" rx="200" ry="70" fill="url(#hill2)" opacity="0.5"/>
  <ellipse cx="400" cy="310" rx="180" ry="60" fill="url(#hill2)" opacity="0.4"/>
  <ellipse cx="260" cy="310" rx="300" ry="55" fill="url(#hill)" opacity="0.6"/>

  <!-- Path -->
  <path d="M220 310 Q240 270 260 310" fill="none" stroke="#e8e5e1" stroke-width="12" stroke-linecap="round" opacity="0.4"/>

  <!-- Torii gate -->
  <rect x="210" y="155" width="10" height="105" rx="3" fill="#e53935"/>
  <rect x="300" y="155" width="10" height="105" rx="3" fill="#e53935"/>
  <rect x="200" y="148" width="120" height="12" rx="4" fill="#c62828"/>
  <rect x="204" y="164" width="112" height="7" rx="3" fill="#e53935" opacity="0.85"/>
  <!-- Torii roof overhang -->
  <path d="M195 148 L260 140 L325 148" fill="none" stroke="#c62828" stroke-width="3" stroke-linecap="round"/>

  <!-- Sakura tree (left) -->
  <rect x="60" y="180" width="8" height="80" rx="3" fill="#8d6e63"/>
  <rect x="55" y="210" width="5" height="40" rx="2" fill="#8d6e63" transform="rotate(-25 57 210)"/>
  <rect x="72" y="200" width="4" height="35" rx="2" fill="#8d6e63" transform="rotate(20 74 200)"/>
  <!-- Blossom clusters -->
  <g>
    <circle cx="45" cy="165" r="14" fill="#f48fb1" opacity="0.7"/>
    <circle cx="65" cy="155" r="16" fill="#f8bbd0" opacity="0.6"/>
    <circle cx="80" cy="168" r="12" fill="#f48fb1" opacity="0.7"/>
    <circle cx="55" cy="180" r="10" fill="#fce4ec" opacity="0.6"/>
    <circle cx="35" cy="175" r="8" fill="#f48fb1" opacity="0.5"/>
    <circle cx="75" cy="150" r="10" fill="#fce4ec" opacity="0.5"/>
    <circle cx="48" cy="150" r="9" fill="#f48fb1" opacity="0.6"/>
    <circle cx="88" cy="158" r="8" fill="#f8bbd0" opacity="0.5"/>
    <circle cx="30" cy="165" r="7" fill="#f8bbd0" opacity="0.4"/>
  </g>

  <!-- Falling petals -->
  <ellipse cx="120" cy="100" rx="4" ry="2.5" fill="#f48fb1" opacity="0.6" transform="rotate(30 120 100)"/>
  <ellipse cx="170" cy="130" rx="3" ry="2" fill="#f8bbd0" opacity="0.5" transform="rotate(-20 170 130)"/>
  <ellipse cx="95" cy="140" rx="3.5" ry="2" fill="#f48fb1" opacity="0.4" transform="rotate(45 95 140)"/>
  <ellipse cx="380" cy="90" rx="3" ry="2" fill="#f48fb1" opacity="0.5" transform="rotate(15 380 90)"/>
  <ellipse cx="450" cy="130" rx="3.5" ry="2" fill="#f8bbd0" opacity="0.4" transform="rotate(-30 450 130)"/>
  <ellipse cx="310" cy="80" rx="2.5" ry="1.5" fill="#f48fb1" opacity="0.5" transform="rotate(60 310 80)"/>
  <ellipse cx="150" cy="80" rx="3" ry="2" fill="#fce4ec" opacity="0.4" transform="rotate(-10 150 80)"/>
  <ellipse cx="470" cy="180" rx="3" ry="2" fill="#f48fb1" opacity="0.35" transform="rotate(25 470 180)"/>

  <!-- Character 1 (center-left, waving) -->
  <g>
    <!-- Body -->
    <rect x="230" y="232" width="30" height="32" rx="10" fill="#42a5f5"/>
    <!-- Head -->
    <circle cx="245" cy="215" r="20" fill="#ffcc80"/>
    <!-- Hair -->
    <path d="M225 210 C225 195 235 186 245 186 C255 186 265 195 265 210" fill="#5d4037" opacity="0.85"/>
    <path d="M225 210 L222 200 L230 208" fill="#5d4037" opacity="0.85"/>
    <path d="M265 210 L268 200 L260 208" fill="#5d4037" opacity="0.85"/>
    <!-- Eyes -->
    <ellipse cx="238" cy="213" rx="4" ry="4.5" fill="white"/>
    <ellipse cx="252" cy="213" rx="4" ry="4.5" fill="white"/>
    <circle cx="239" cy="214" r="3" fill="#1a237e"/>
    <circle cx="253" cy="214" r="3" fill="#1a237e"/>
    <circle cx="238" cy="212.5" r="1.3" fill="white"/>
    <circle cx="252" cy="212.5" r="1.3" fill="white"/>
    <!-- Blush -->
    <ellipse cx="232" cy="220" rx="5" ry="3" fill="#ffab91" opacity="0.45"/>
    <ellipse cx="258" cy="220" rx="5" ry="3" fill="#ffab91" opacity="0.45"/>
    <!-- Smile -->
    <path d="M240 222 Q245 228 250 222" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Arms -->
    <line x1="230" y1="240" x2="212" y2="225" stroke="#ffcc80" stroke-width="6" stroke-linecap="round"/>
    <line x1="260" y1="240" x2="278" y2="225" stroke="#ffcc80" stroke-width="6" stroke-linecap="round"/>
    <!-- Hand wave lines -->
    <path d="M206 218 Q202 214 206 210" fill="none" stroke="#ffd54f" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
    <path d="M200 220 Q196 215 200 210" fill="none" stroke="#ffd54f" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    <!-- Legs -->
    <line x1="240" y1="264" x2="237" y2="280" stroke="#42a5f5" stroke-width="6" stroke-linecap="round"/>
    <line x1="250" y1="264" x2="253" y2="280" stroke="#42a5f5" stroke-width="6" stroke-linecap="round"/>

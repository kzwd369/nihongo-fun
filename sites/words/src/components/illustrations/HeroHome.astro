    <circle cx="383" cy="222" r="17" fill="#ffe0b2"/>
    <!-- Hair (long) -->
    <path d="M366 218 C366 204 373 196 383 196 C393 196 400 204 400 218" fill="#37474f" opacity="0.85"/>
    <rect x="364" y="216" width="5" height="30" rx="2" fill="#37474f" opacity="0.7"/>
    <rect x="398" y="216" width="5" height="30" rx="2" fill="#37474f" opacity="0.7"/>
    <!-- Eyes -->
    <ellipse cx="377" cy="220" rx="3.5" ry="4" fill="white"/>
    <ellipse cx="389" cy="220" rx="3.5" ry="4" fill="white"/>
    <circle cx="378" cy="221" r="2.5" fill="#4a148c"/>
    <circle cx="390" cy="221" r="2.5" fill="#4a148c"/>
    <circle cx="377" cy="219.5" r="1" fill="white"/>
    <circle cx="389" cy="219.5" r="1" fill="white"/>
    <!-- Blush -->
    <ellipse cx="372" cy="226" rx="4" ry="2.5" fill="#ffab91" opacity="0.4"/>
    <ellipse cx="394" cy="226" rx="4" ry="2.5" fill="#ffab91" opacity="0.4"/>
    <!-- Smile -->
    <path d="M379 228 Q383 233 387 228" fill="none" stroke="#5d4037" stroke-width="1.3" stroke-linecap="round"/>
    <!-- Arms holding book -->
    <line x1="370" y1="245" x2="355" y2="250" stroke="#ffe0b2" stroke-width="5" stroke-linecap="round"/>
    <line x1="396" y1="245" x2="410" y2="250" stroke="#ffe0b2" stroke-width="5" stroke-linecap="round"/>
    <!-- Book -->
    <rect x="348" y="246" width="28" height="20" rx="3" fill="#81c784"/>
    <rect x="376" y="246" width="28" height="20" rx="3" fill="#a5d6a7"/>
    <line x1="376" y1="246" x2="376" y2="266" stroke="#66bb6a" stroke-width="1.5"/>
    <!-- Legs -->
    <line x1="378" y1="266" x2="376" y2="280" stroke="#ec407a" stroke-width="5" stroke-linecap="round"/>
    <line x1="388" y1="266" x2="390" y2="280" stroke="#ec407a" stroke-width="5" stroke-linecap="round"/>
    <ellipse cx="374" cy="282" rx="6" ry="3" fill="#7b1fa2"/>
    <ellipse cx="392" cy="282" rx="6" ry="3" fill="#7b1fa2"/>
  </g>

  <!-- Floating word bubbles -->
  <!-- Bubble: ドキドキ (top-left) -->
  <g>
    <rect x="18" y="58" width="96" height="40" rx="16" fill="white"/>
    <polygon points="78,98 88,98 72,110" fill="white"/>
    <text x="66" y="83" text-anchor="middle" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="16" font-weight="800" fill="#e91e63">ドキドキ</text>
  </g>

  <!-- Bubble: すごい！ (top-right) -->
  <g>
    <rect x="410" y="140" width="90" height="38" rx="14" fill="white"/>
    <polygon points="420,178 430,178 415,190" fill="white"/>
    <text x="455" y="164" text-anchor="middle" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="15" font-weight="800" fill="#5c6bc0">すごい！</text>
  </g>

  <!-- Bubble: 楽しい (center-top) -->
  <g>
    <rect x="185" y="60" width="84" height="36" rx="14" fill="white"/>
    <polygon points="215,96 225,96 210,106" fill="white"/>
    <text x="227" y="83" text-anchor="middle" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="15" font-weight="800" fill="#00897b">楽しい！</text>
  </g>

  <!-- Bubble: かわいい (right) -->
  <g>
    <rect x="420" y="220" width="84" height="34" rx="13" fill="white" opacity="0.9"/>
    <polygon points="428,254 436,254 422,264" fill="white" opacity="0.9"/>
    <text x="462" y="242" text-anchor="middle" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="13" font-weight="700" fill="#ec407a">かわいい</text>
  </g>

  <!-- Floating kana particles -->
  <text x="140" y="55" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="14" fill="#7e57c2" opacity="0.3" font-weight="700">あ</text>
  <text x="480" y="85" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="12" fill="#e91e63" opacity="0.25" font-weight="700">は</text>
  <text x="20" y="140" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="16" fill="#ff9800" opacity="0.2" font-weight="700">の</text>
  <text x="490" y="290" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="13" fill="#43a047" opacity="0.25" font-weight="700">ん</text>
  <text x="340" y="55" font-family="'Hiragino Kaku Gothic ProN',sans-serif" font-size="11" fill="#5c6bc0" opacity="0.2" font-weight="700">き</text>

  <!-- Stars & sparkles -->
  <polygon points="155,35 157,28 159,35 166,37 159,39 157,46 155,39 148,37" fill="#ffd54f" opacity="0.7"/>
  <polygon points="470,110 472,104 474,110 480,112 474,114 472,120 470,114 464,112" fill="#ffd54f" opacity="0.6"/>
  <polygon points="15,200 16.5,195 18,200 23,201.5 18,203 16.5,208 15,203 10,201.5" fill="#ffd54f" opacity="0.5"/>
  <polygon points="500,200 501.5,195 503,200 508,201.5 503,203 501.5,208 500,203 495,201.5" fill="#ffd54f" opacity="0.4"/>
  <polygon points="295,40 296.5,35 298,40 303,41.5 298,43 296.5,48 295,43 290,41.5" fill="#ffd54f" opacity="0.5"/>

  <!-- Small hearts near characters -->
  <path d="M282 210 C282 210 279 207 279 204 C279 202 280 201 282 203 C284 201 285 202 285 204 C285 207 282 210 282 210Z" fill="#e91e63" opacity="0.6"/>
  <path d="M290 200 C290 200 288 198 288 196 C288 194.5 289 194 290 195.5 C291 194 292 194.5 292 196 C292 198 290 200 290 200Z" fill="#f48fb1" opacity="0.5"/>

  <!-- Musical notes near character 2 -->
  <g opacity="0.5">
    <circle cx="350" cy="200" r="3" fill="#7b1fa2"/>
    <line x1="353" y1="200" x2="353" y2="186" stroke="#7b1fa2" stroke-width="1.5"/>
    <path d="M353 186 Q358 184 356 189" fill="#7b1fa2"/>
  </g>
  <g opacity="0.4">
    <circle cx="340" cy="210" r="2.5" fill="#9c27b0"/>
    <line x1="342.5" y1="210" x2="342.5" y2="198" stroke="#9c27b0" stroke-width="1.2"/>
    <path d="M342.5 198 Q347 196 345.5 200" fill="#9c27b0"/>
  </g>

  <!-- Lanterns hanging from torii -->
  <g>
    <rect x="232" y="165" width="12" height="16" rx="4" fill="#ffb74d" opacity="0.8"/>
    <rect x="232" y="162" width="12" height="4" rx="1" fill="#e65100" opacity="0.6"/>
    <line x1="238" y1="162" x2="238" y2="158" stroke="#8d6e63" stroke-width="1"/>
  </g>
  <g>
    <rect x="276" y="165" width="12" height="16" rx="4" fill="#ffb74d" opacity="0.8"/>
    <rect x="276" y="162" width="12" height="4" rx="1" fill="#e65100" opacity="0.6"/>
    <line x1="282" y1="162" x2="282" y2="158" stroke="#8d6e63" stroke-width="1"/>
  </g>
</svg>

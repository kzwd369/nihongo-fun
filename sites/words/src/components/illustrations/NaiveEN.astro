<!-- English naive = gullible, easily tricked (negative) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Confused/gullible person -->
  <circle cx="80" cy="55" r="22" fill="#ffccbc"/>
  <!-- Confused expression -->
  <ellipse cx="72" cy="52" rx="2.5" ry="3" fill="#5d4037"/>
  <ellipse cx="88" cy="52" rx="2.5" ry="3" fill="#5d4037"/>
  <path d="M73 62 Q80 58 87 62" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Sweat drop -->
  <path d="M62 42 Q60 48 62 52 Q64 48 62 42" fill="#81d4fa"/>
  <!-- Hair -->
  <path d="M58 48 Q60 30 80 28 Q100 30 102 48" fill="#8d6e63"/>
  <!-- Body -->
  <path d="M62 75 Q80 80 98 75 L100 120 H60 Z" fill="#90caf9"/>
  <!-- Question marks -->
  <text x="50" y="30" font-size="14" fill="#ef6c00" font-family="sans-serif" opacity="0.7">?</text>
  <text x="98" y="38" font-size="11" fill="#ef6c00" font-family="sans-serif" opacity="0.5">?</text>
  <!-- Trickster person behind -->
  <g transform="translate(140, 45)">
    <circle cx="0" cy="0" r="16" fill="#d7ccc8"/>
    <!-- Sly grin -->
    <ellipse cx="-5" cy="-2" rx="2" ry="1.5" fill="#5d4037"/>
    <ellipse cx="5" cy="-2" rx="2" ry="1.5" fill="#5d4037"/>
    <path d="M-6 4 Q0 9 6 4" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
    <!-- Hair -->
    <path d="M-16 -5 Q-14 -18 0 -20 Q14 -18 16 -5" fill="#424242"/>
  </g>
  <!-- Trickster body -->
  <path d="M126 60 Q140 65 154 60 L156 120 H124 Z" fill="#78909c"/>
  <!-- Trickster hand with crossed fingers -->
  <circle cx="120" cy="90" r="5" fill="#d7ccc8"/>
  <line x1="118" y1="85" x2="116" y2="80" stroke="#d7ccc8" stroke-width="2.5" stroke-linecap="round"/>
  <line x1="121" y1="85" x2="120" y2="79" stroke="#d7ccc8" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Deception indicator -->
  <text x="135" y="30" font-size="10" fill="#e65100" font-family="sans-serif">heh heh</text>
  <!-- Label -->
  <text x="100" y="148" text-anchor="middle" font-size="11" fill="#795548" font-family="sans-serif">naive = gullible, foolish</text>
</svg>

<!-- English Tension = stress, anxiety, strain -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#eceff1" rx="8"/>
  <!-- Dark clouds -->
  <ellipse cx="60" cy="20" rx="35" ry="14" fill="#90a4ae" opacity="0.6"/>
  <ellipse cx="140" cy="18" rx="30" ry="12" fill="#90a4ae" opacity="0.5"/>
  <ellipse cx="100" cy="15" rx="25" ry="10" fill="#78909c" opacity="0.5"/>
  <!-- Stressed person sitting at desk -->
  <!-- Desk -->
  <rect x="40" y="100" width="120" height="6" fill="#8d6e63" rx="1"/>
  <rect x="45" y="106" width="6" height="30" fill="#6d4c41"/>
  <rect x="149" y="106" width="6" height="30" fill="#6d4c41"/>
  <!-- Stack of papers on desk -->
  <rect x="120" y="85" width="30" height="15" fill="white" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <rect x="122" y="83" width="30" height="15" fill="#f5f5f5" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <rect x="124" y="81" width="30" height="15" fill="#fafafa" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Person's head (hands on head = stressed) -->
  <circle cx="85" cy="60" r="15" fill="#ffcc80"/>
  <!-- Messy stressed hair -->
  <path d="M70,55 Q72,40 78,42 Q75,38 82,38 Q80,33 88,35 Q86,30 93,35 Q95,32 98,38 Q100,40 100,45" fill="#5d4037"/>
  <!-- Stressed eyes (X shaped or squinted) -->
  <line x1="78" y1="58" x2="82" y2="62" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="82" y1="58" x2="78" y2="62" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="88" y1="58" x2="92" y2="62" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="92" y1="58" x2="88" y2="62" stroke="#5d4037" stroke-width="1.5"/>
  <!-- Frown -->
  <path d="M79,70 Q85,66 91,70" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Stress lines around head -->
  <line x1="65" y1="48" x2="58" y2="42" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="63" y1="55" x2="55" y2="53" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="105" y1="48" x2="112" y2="42" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="107" y1="55" x2="115" y2="53" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Body hunched over -->
  <rect x="76" y="75" width="18" height="20" fill="#78909c" rx="3"/>
  <!-- Arms on head (stressed pose) -->
  <path d="M76,80 Q65,70 70,55" fill="none" stroke="#ffcc80" stroke-width="4" stroke-linecap="round"/>
  <path d="M94,80 Q105,70 100,55" fill="none" stroke="#ffcc80" stroke-width="4" stroke-linecap="round"/>
  <!-- Sweat drops -->
  <path d="M108,50 Q110,55 108,58 Q106,55 108,50" fill="#64b5f6"/>
  <path d="M62,62 Q64,66 62,69 Q60,66 62,62" fill="#64b5f6"/>
  <!-- Spiral (stress symbol) -->
  <path d="M42,45 Q42,38 48,38 Q54,38 54,44 Q54,50 46,50 Q40,50 40,44" fill="none" stroke="#ef5350" stroke-width="1.5"/>
  <!-- Floor -->
  <rect x="0" y="136" width="200" height="24" fill="#cfd8dc" rx="0"/>
</svg>

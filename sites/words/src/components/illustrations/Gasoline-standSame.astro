<!-- ガソリンスタンド = gas station / petrol station -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Ground -->
  <rect x="0" y="130" width="200" height="30" fill="#e0e0e0" rx="0"/>
  <!-- Station canopy -->
  <rect x="20" y="25" width="160" height="8" fill="#ef5350" rx="2"/>
  <rect x="20" y="30" width="160" height="4" fill="#c62828"/>
  <!-- Canopy supports -->
  <rect x="25" y="34" width="5" height="96" fill="#bdbdbd" rx="1"/>
  <rect x="170" y="34" width="5" height="96" fill="#bdbdbd" rx="1"/>
  <!-- Station building (back) -->
  <rect x="130" y="50" width="50" height="80" fill="#fafafa" rx="3" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Window -->
  <rect x="140" y="58" width="30" height="20" fill="#bbdefb" rx="2"/>
  <line x1="155" y1="58" x2="155" y2="78" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Door -->
  <rect x="148" y="95" width="18" height="35" fill="#90a4ae" rx="2"/>
  <circle cx="163" cy="112" r="1.5" fill="#ffd54f"/>
  <!-- Sign -->
  <rect x="138" y="82" width="34" height="10" fill="#fff9c4" rx="2"/>
  <text x="155" y="90" font-size="6" fill="#f9a825" text-anchor="middle" font-family="sans-serif" font-weight="bold">OPEN</text>
  <!-- Fuel pump 1 -->
  <rect x="50" y="70" width="25" height="55" fill="#78909c" rx="3"/>
  <rect x="53" y="75" width="19" height="14" fill="#37474f" rx="2"/>
  <!-- Pump display -->
  <rect x="55" y="78" width="15" height="8" fill="#c8e6c9" rx="1"/>
  <text x="62.5" y="84" font-size="5" fill="#2e7d32" text-anchor="middle" font-family="monospace">¥170</text>
  <!-- Pump nozzle holder -->
  <rect x="53" y="94" width="8" height="4" fill="#546e7a" rx="1"/>
  <rect x="65" y="94" width="8" height="4" fill="#546e7a" rx="1"/>
  <!-- Nozzle (regular) -->
  <circle cx="57" cy="96" r="3" fill="#ef5350"/>
  <!-- Nozzle (premium) -->
  <circle cx="69" cy="96" r="3" fill="#ffd54f"/>
  <!-- Hose -->
  <path d="M57 99 Q50 108 45 105" fill="none" stroke="#37474f" stroke-width="2" stroke-linecap="round"/>
  <!-- Pump handle -->
  <rect x="40" y="102" width="8" height="4" fill="#37474f" rx="1"/>
  <!-- Fuel pump 2 -->
  <rect x="90" y="70" width="25" height="55" fill="#78909c" rx="3"/>
  <rect x="93" y="75" width="19" height="14" fill="#37474f" rx="2"/>
  <rect x="95" y="78" width="15" height="8" fill="#c8e6c9" rx="1"/>
  <text x="102.5" y="84" font-size="5" fill="#2e7d32" text-anchor="middle" font-family="monospace">¥180</text>
  <rect x="93" y="94" width="8" height="4" fill="#546e7a" rx="1"/>
  <rect x="105" y="94" width="8" height="4" fill="#546e7a" rx="1"/>
  <circle cx="97" cy="96" r="3" fill="#ef5350"/>
  <circle cx="109" cy="96" r="3" fill="#ffd54f"/>
  <!-- Price sign -->
  <rect x="40" y="40" width="70" height="22" fill="white" rx="3" stroke="#e0e0e0" stroke-width="1"/>
  <text x="47" y="50" font-size="5" fill="#ef5350" font-family="sans-serif">レギュラー</text>
  <text x="90" y="50" font-size="7" fill="#37474f" font-family="sans-serif" font-weight="bold">170</text>
  <text x="47" y="58" font-size="5" fill="#ffd54f" font-family="sans-serif">ハイオク</text>
  <text x="90" y="58" font-size="7" fill="#37474f" font-family="sans-serif" font-weight="bold">180</text>
  <!-- Traffic cones -->
  <polygon points="30,130 33,118 36,130" fill="#ff7043"/>
  <rect x="29" y="128" width="8" height="3" fill="#ff7043" rx="1"/>
  <line x1="31" y1="124" x2="35" y2="124" stroke="white" stroke-width="1"/>
</svg>

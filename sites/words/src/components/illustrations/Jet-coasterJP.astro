<!-- Japanese ジェットコースター = roller coaster (theme park ride) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#bbdefb" rx="8"/>
  <!-- Sky clouds -->
  <ellipse cx="160" cy="25" rx="14" ry="6" fill="#fff"/>
  <ellipse cx="170" cy="22" rx="10" ry="5" fill="#fff"/>
  <ellipse cx="30" cy="30" rx="12" ry="5" fill="#fff"/>
  <!-- Coaster track loop -->
  <path d="M10 130 L30 130 L40 60 L70 30 L100 60 L130 30 L160 50 Q175 60 175 80 Q175 110 145 110 Q115 110 115 90 Q115 75 130 75 Q145 75 145 95 Q145 115 165 115 L190 115 L190 130 L10 130 Z" fill="none" stroke="#c62828" stroke-width="3"/>
  <!-- Track support ties -->
  <line x1="40" y1="60" x2="40" y2="130" stroke="#5d4037" stroke-width="1.5" stroke-dasharray="2,3"/>
  <line x1="70" y1="30" x2="70" y2="130" stroke="#5d4037" stroke-width="1.5" stroke-dasharray="2,3"/>
  <line x1="100" y1="60" x2="100" y2="130" stroke="#5d4037" stroke-width="1.5" stroke-dasharray="2,3"/>
  <line x1="130" y1="30" x2="130" y2="130" stroke="#5d4037" stroke-width="1.5" stroke-dasharray="2,3"/>
  <line x1="160" y1="50" x2="160" y2="130" stroke="#5d4037" stroke-width="1.5" stroke-dasharray="2,3"/>
  <!-- Coaster cart at top of first hill (going down) -->
  <g transform="translate(72,28)">
    <!-- First car -->
    <rect x="-8" y="-2" width="14" height="10" fill="#1976d2" stroke="#0d47a1" stroke-width="1" rx="2"/>
    <circle cx="-5" cy="9" r="2" fill="#212121"/>
    <circle cx="3" cy="9" r="2" fill="#212121"/>
    <!-- Passenger heads -->
    <circle cx="-3" cy="-3" r="2.5" fill="#ffcc80"/>
    <circle cx="3" cy="-3" r="2.5" fill="#ffcc80"/>
    <!-- Arms up -->
    <line x1="-3" y1="-5" x2="-5" y2="-10" stroke="#ffcc80" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="3" y1="-5" x2="5" y2="-10" stroke="#ffcc80" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Mouths open (screaming) -->
    <ellipse cx="-3" cy="-2" rx="0.8" ry="1" fill="#c62828"/>
    <ellipse cx="3" cy="-2" rx="0.8" ry="1" fill="#c62828"/>
  </g>
  <!-- Speed lines -->
  <line x1="55" y1="40" x2="48" y2="42" stroke="#fff" stroke-width="1.5"/>
  <line x1="58" y1="48" x2="50" y2="51" stroke="#fff" stroke-width="1.5"/>
  <!-- Loop highlight -->
  <text x="148" y="93" font-size="14" fill="#ffd54f">⚡</text>
  <!-- Screams -->
  <text x="65" y="20" font-size="9" font-weight="bold" fill="#c62828">きゃー!</text>
  <text x="105" y="80" font-size="9" font-weight="bold" fill="#c62828">うわー!</text>
  <!-- Park entrance/ground -->
  <rect x="0" y="130" width="200" height="30" fill="#a5d6a7"/>
  <!-- Small people in line -->
  <circle cx="20" cy="138" r="3" fill="#ffcc80"/>
  <rect x="18.5" y="140" width="3" height="6" fill="#e91e63"/>
  <circle cx="28" cy="138" r="3" fill="#ffcc80"/>
  <rect x="26.5" y="140" width="3" height="6" fill="#1976d2"/>
  <!-- Label -->
  <text x="100" y="151" font-size="10" font-weight="bold" fill="#0d47a1" text-anchor="middle">ジェットコースター = Roller Coaster</text>
  <text x="100" y="158" font-size="6" fill="#1565c0" text-anchor="middle">遊園地の絶叫マシン／比喩でも多用</text>
</svg>

<!-- Japanese サラリーマン = male office worker in a suit -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- sky and buildings in background -->
  <rect x="10" y="40" width="30" height="105" fill="#cfd8dc" rx="2"/>
  <rect x="15" y="50" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="27" y="50" width="8" height="8" fill="#bbdefb" rx="1"/>
  <rect x="15" y="62" width="8" height="8" fill="#bbdefb" rx="1"/>
  <rect x="27" y="62" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="15" y="74" width="8" height="8" fill="#fff9c4" rx="1"/>
  <rect x="27" y="74" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="160" y="30" width="30" height="115" fill="#b0bec5" rx="2"/>
  <rect x="165" y="40" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="177" y="40" width="8" height="8" fill="#fff9c4" rx="1"/>
  <rect x="165" y="52" width="8" height="8" fill="#bbdefb" rx="1"/>
  <rect x="177" y="52" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="165" y="64" width="8" height="8" fill="#e3f2fd" rx="1"/>
  <rect x="177" y="64" width="8" height="8" fill="#bbdefb" rx="1"/>
  <!-- ground -->
  <rect x="0" y="145" width="200" height="15" fill="#e0e0e0" rx="0"/>
  <!-- salaryman body - dark suit -->
  <rect x="80" y="75" width="40" height="55" fill="#37474f" rx="3"/>
  <!-- white shirt / tie area -->
  <line x1="100" y1="78" x2="100" y2="130" stroke="#546e7a" stroke-width="1"/>
  <rect x="96" y="78" width="8" height="5" fill="white" rx="1"/>
  <!-- tie -->
  <polygon points="100,83 96,95 100,92 104,95" fill="#c62828"/>
  <!-- head -->
  <circle cx="100" cy="60" r="16" fill="#ffcc80"/>
  <!-- hair -->
  <ellipse cx="100" cy="50" rx="16" ry="8" fill="#3e2723"/>
  <!-- tired eyes (half-closed) -->
  <line x1="92" y1="60" x2="96" y2="60" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="104" y1="60" x2="108" y2="60" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <!-- small frown - tired but determined -->
  <path d="M95 68 Q100 66 105 68" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- sweat drop -->
  <ellipse cx="115" cy="55" rx="2" ry="3" fill="#90caf9"/>
  <!-- arms -->
  <line x1="80" y1="80" x2="65" y2="110" stroke="#37474f" stroke-width="8" stroke-linecap="round"/>
  <line x1="120" y1="80" x2="135" y2="110" stroke="#37474f" stroke-width="8" stroke-linecap="round"/>
  <!-- hands -->
  <circle cx="65" cy="112" r="4" fill="#ffcc80"/>
  <circle cx="135" cy="112" r="4" fill="#ffcc80"/>
  <!-- briefcase -->
  <rect x="128" y="108" width="22" height="16" fill="#5d4037" rx="2"/>
  <rect x="135" y="105" width="8" height="5" fill="none" stroke="#5d4037" stroke-width="1.5" rx="2"/>
  <!-- legs -->
  <line x1="90" y1="130" x2="88" y2="143" stroke="#37474f" stroke-width="7" stroke-linecap="round"/>
  <line x1="110" y1="130" x2="112" y2="143" stroke="#37474f" stroke-width="7" stroke-linecap="round"/>
  <!-- shoes -->
  <ellipse cx="86" cy="145" rx="7" ry="3" fill="#212121"/>
  <ellipse cx="114" cy="145" rx="7" ry="3" fill="#212121"/>
</svg>

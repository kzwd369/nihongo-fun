<!-- English parka = heavy winter jacket with fur-lined hood -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Jacket body - dark heavy material -->
  <path d="M58 48 L55 138 Q55 145 63 145 L137 145 Q145 145 145 138 L142 48" fill="#37474f" stroke="#263238" stroke-width="1"/>
  <!-- Hood - large and puffy -->
  <path d="M58 48 Q55 15 100 12 Q145 15 142 48" fill="#37474f" stroke="#263238" stroke-width="1"/>
  <!-- Fur trim around hood -->
  <path d="M68 46 Q68 22 100 20 Q132 22 132 46" fill="none" stroke="#bcaaa4" stroke-width="6" stroke-linecap="round"/>
  <!-- Individual fur tufts -->
  <path d="M70 42 L68 36 L72 38" fill="#d7ccc8" stroke="none"/>
  <path d="M80 34 L78 28 L82 30" fill="#d7ccc8" stroke="none"/>
  <path d="M90 30 L89 24 L93 26" fill="#d7ccc8" stroke="none"/>
  <path d="M100 28 L99 22 L103 24" fill="#d7ccc8" stroke="none"/>
  <path d="M110 30 L109 24 L113 26" fill="#d7ccc8" stroke="none"/>
  <path d="M120 34 L118 28 L122 30" fill="#d7ccc8" stroke="none"/>
  <path d="M130 42 L128 36 L132 38" fill="#d7ccc8" stroke="none"/>
  <!-- Hood opening -->
  <ellipse cx="100" cy="40" rx="18" ry="14" fill="#455a64"/>
  <!-- Center zipper -->
  <line x1="100" y1="48" x2="100" y2="142" stroke="#78909c" stroke-width="2"/>
  <!-- Zipper teeth -->
  <line x1="98" y1="55" x2="102" y2="55" stroke="#90a4ae" stroke-width="1"/>
  <line x1="98" y1="65" x2="102" y2="65" stroke="#90a4ae" stroke-width="1"/>
  <line x1="98" y1="75" x2="102" y2="75" stroke="#90a4ae" stroke-width="1"/>
  <line x1="98" y1="85" x2="102" y2="85" stroke="#90a4ae" stroke-width="1"/>
  <line x1="98" y1="95" x2="102" y2="95" stroke="#90a4ae" stroke-width="1"/>
  <line x1="98" y1="105" x2="102" y2="105" stroke="#90a4ae" stroke-width="1"/>
  <!-- Zipper pull -->
  <rect x="97" y="48" width="6" height="4" fill="#90a4ae" rx="1"/>
  <!-- Sleeves - puffy/insulated -->
  <path d="M58 48 L32 55 L25 100 Q22 110 30 112 L50 108 L58 72" fill="#37474f" stroke="#263238" stroke-width="1"/>
  <path d="M142 48 L168 55 L175 100 Q178 110 170 112 L150 108 L142 72" fill="#37474f" stroke="#263238" stroke-width="1"/>
  <!-- Puffy quilted lines on sleeves -->
  <path d="M35 65 Q45 68 55 62" fill="none" stroke="#455a64" stroke-width="0.8"/>
  <path d="M30 80 Q42 83 52 77" fill="none" stroke="#455a64" stroke-width="0.8"/>
  <path d="M145 62 Q155 68 165 65" fill="none" stroke="#455a64" stroke-width="0.8"/>
  <path d="M148 77 Q158 83 170 80" fill="none" stroke="#455a64" stroke-width="0.8"/>
  <!-- Pockets with flaps -->
  <rect x="63" y="95" width="30" height="22" fill="#455a64" rx="2" stroke="#263238" stroke-width="0.5"/>
  <rect x="63" y="93" width="30" height="5" fill="#455a64" rx="1" stroke="#263238" stroke-width="0.5"/>
  <rect x="107" y="95" width="30" height="22" fill="#455a64" rx="2" stroke="#263238" stroke-width="0.5"/>
  <rect x="107" y="93" width="30" height="5" fill="#455a64" rx="1" stroke="#263238" stroke-width="0.5"/>
  <!-- Pocket snap buttons -->
  <circle cx="78" cy="95" r="1.5" fill="#90a4ae"/>
  <circle cx="122" cy="95" r="1.5" fill="#90a4ae"/>
  <!-- Snowflakes around to suggest cold weather -->
  <text x="18" y="25" font-size="10" fill="#90caf9" opacity="0.4">❄</text>
  <text x="170" y="20" font-size="8" fill="#90caf9" opacity="0.3">❄</text>
  <text x="15" y="140" font-size="8" fill="#90caf9" opacity="0.3">❄</text>
  <text x="175" y="145" font-size="10" fill="#90caf9" opacity="0.4">❄</text>
</svg>

<!-- English equivalent = "studio apartment" (not "one-room") -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f2f1" rx="8"/>
  <!-- Big apartment building with door -->
  <rect x="50" y="30" width="100" height="90" fill="#b2dfdb" stroke="#00695c" stroke-width="2" rx="2"/>
  <!-- Roof -->
  <polygon points="45,30 155,30 140,18 60,18" fill="#00897b"/>
  <!-- Windows -->
  <rect x="60" y="40" width="18" height="18" fill="#fff9c4" stroke="#f9a825" stroke-width="1"/>
  <line x1="69" y1="40" x2="69" y2="58" stroke="#f9a825" stroke-width="0.5"/>
  <line x1="60" y1="49" x2="78" y2="49" stroke="#f9a825" stroke-width="0.5"/>
  <rect x="122" y="40" width="18" height="18" fill="#fff9c4" stroke="#f9a825" stroke-width="1"/>
  <line x1="131" y1="40" x2="131" y2="58" stroke="#f9a825" stroke-width="0.5"/>
  <line x1="122" y1="49" x2="140" y2="49" stroke="#f9a825" stroke-width="0.5"/>
  <!-- Door with sign -->
  <rect x="85" y="75" width="30" height="45" fill="#5d4037" stroke="#3e2723" stroke-width="1.5" rx="1"/>
  <circle cx="110" cy="97" r="1.5" fill="#ffd54f"/>
  <!-- Sign on door -->
  <rect x="80" y="62" width="40" height="15" fill="white" stroke="#00695c" stroke-width="1.5" rx="2"/>
  <text x="100" y="73" font-size="10" font-weight="bold" fill="#00695c" text-anchor="middle">STUDIO</text>
  <!-- Apartment number -->
  <rect x="92" y="80" width="16" height="8" fill="#fff8e1" stroke="#8d6e63" stroke-width="0.8"/>
  <text x="100" y="86" font-size="6" fill="#3e2723" text-anchor="middle">APT 2B</text>
  <!-- "one-room" crossed out -->
  <rect x="12" y="62" width="35" height="16" fill="#ffebee" stroke="#e53935" stroke-width="1" rx="2"/>
  <text x="29" y="73" font-size="8" fill="#424242" text-anchor="middle">one-room</text>
  <line x1="14" y1="64" x2="45" y2="76" stroke="#e53935" stroke-width="2"/>
  <line x1="45" y1="64" x2="14" y2="76" stroke="#e53935" stroke-width="2"/>
  <!-- Correct terms list -->
  <rect x="152" y="55" width="42" height="50" fill="white" stroke="#00695c" stroke-width="1" rx="2"/>
  <text x="173" y="67" font-size="8" font-weight="bold" fill="#00695c" text-anchor="middle">Correct:</text>
  <text x="173" y="78" font-size="7" fill="#2e7d32" text-anchor="middle">• studio</text>
  <text x="173" y="88" font-size="7" fill="#2e7d32" text-anchor="middle">• bedsit (UK)</text>
  <text x="173" y="98" font-size="7" fill="#2e7d32" text-anchor="middle">• efficiency</text>
  <!-- Arrow pointing to door -->
  <path d="M152,105 Q140,112 122,105" fill="none" stroke="#2e7d32" stroke-width="1.5" stroke-linecap="round"/>
  <polygon points="122,105 127,102 127,108" fill="#2e7d32"/>
  <!-- Ground -->
  <rect x="0" y="120" width="200" height="40" fill="#80cbc4" rx="0"/>
  <!-- Path -->
  <rect x="85" y="120" width="30" height="25" fill="#a1887f"/>
  <!-- Label -->
  <text x="100" y="154" font-size="10" font-weight="bold" fill="#004d40" text-anchor="middle">"studio apartment"</text>
</svg>

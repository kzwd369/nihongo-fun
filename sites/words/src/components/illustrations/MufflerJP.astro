<!-- Japanese マフラー = winter knit scarf -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Snowflakes background -->
  <text x="25" y="30" font-size="11" fill="#bbdefb">❄</text>
  <text x="170" y="35" font-size="9" fill="#bbdefb">❄</text>
  <text x="160" y="120" font-size="8" fill="#bbdefb">❄</text>
  <text x="20" y="120" font-size="9" fill="#bbdefb">❄</text>
  <!-- Scarf draped in shape of an arc with hanging ends -->
  <!-- Top loop / collar curve -->
  <path d="M70 50 Q100 30 130 50 L130 70 Q100 50 70 70 Z" fill="#e57373" stroke="#c62828" stroke-width="1"/>
  <!-- Left hanging end -->
  <path d="M70 50 L60 75 L55 130 L75 132 L80 75 Z" fill="#e57373" stroke="#c62828" stroke-width="1"/>
  <!-- Right hanging end -->
  <path d="M130 50 L140 75 L145 130 L125 132 L120 75 Z" fill="#e57373" stroke="#c62828" stroke-width="1"/>
  <!-- Cross fold in middle -->
  <path d="M75 70 Q100 60 125 70 L125 88 Q100 78 75 88 Z" fill="#ef5350" stroke="#c62828" stroke-width="0.8" opacity="0.85"/>
  <!-- Knit ribbing texture (horizontal lines) -->
  <g stroke="#c62828" stroke-width="0.4" opacity="0.6">
    <line x1="60" y1="85" x2="80" y2="85"/>
    <line x1="60" y1="95" x2="80" y2="95"/>
    <line x1="60" y1="105" x2="78" y2="105"/>
    <line x1="58" y1="115" x2="78" y2="115"/>
    <line x1="55" y1="125" x2="76" y2="125"/>
    <line x1="120" y1="85" x2="140" y2="85"/>
    <line x1="120" y1="95" x2="140" y2="95"/>
    <line x1="122" y1="105" x2="142" y2="105"/>
    <line x1="122" y1="115" x2="143" y2="115"/>
    <line x1="124" y1="125" x2="145" y2="125"/>
  </g>
  <!-- Knit V-pattern on body -->
  <g stroke="#c62828" stroke-width="0.4" opacity="0.5">
    <path d="M85 60 L88 64 L91 60" fill="none"/>
    <path d="M95 60 L98 64 L101 60" fill="none"/>
    <path d="M105 60 L108 64 L111 60" fill="none"/>
    <path d="M115 60 L118 64 L121 60" fill="none"/>
  </g>
  <!-- Fringe (tassels) at bottom of each end -->
  <line x1="58" y1="130" x2="56" y2="140" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="62" y1="131" x2="61" y2="142" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="66" y1="131" x2="66" y2="143" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="70" y1="132" x2="71" y2="143" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="74" y1="132" x2="75" y2="142" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="126" y1="132" x2="125" y2="142" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="130" y1="132" x2="130" y2="143" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="134" y1="131" x2="135" y2="143" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="138" y1="131" x2="139" y2="142" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
  <line x1="142" y1="130" x2="144" y2="140" stroke="#c62828" stroke-width="1.2" stroke-linecap="round"/>
</svg>

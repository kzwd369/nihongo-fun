<!-- English shortcake = crumbly biscuit with strawberries (American style) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Plate -->
  <ellipse cx="100" cy="125" rx="65" ry="12" fill="#eceff1" stroke="#cfd8dc" stroke-width="1"/>
  <!-- Bottom biscuit -->
  <ellipse cx="100" cy="110" rx="42" ry="8" fill="#d7a86e"/>
  <rect x="58" y="95" width="84" height="15" fill="#deb078" rx="3"/>
  <ellipse cx="100" cy="95" rx="42" ry="8" fill="#e6be8a"/>
  <!-- Crumbly texture on biscuit -->
  <circle cx="72" cy="100" r="1.5" fill="#c4955a" opacity="0.5"/>
  <circle cx="85" cy="103" r="1" fill="#c4955a" opacity="0.5"/>
  <circle cx="110" cy="98" r="1.2" fill="#c4955a" opacity="0.5"/>
  <circle cx="125" cy="102" r="1" fill="#c4955a" opacity="0.5"/>
  <!-- Whipped cream blob on top -->
  <ellipse cx="100" cy="85" rx="30" ry="12" fill="#fff"/>
  <ellipse cx="90" cy="82" rx="15" ry="8" fill="#fff"/>
  <ellipse cx="112" cy="83" rx="14" ry="7" fill="#fff"/>
  <ellipse cx="100" cy="78" rx="12" ry="6" fill="#fff"/>
  <!-- Strawberry halves on top -->
  <g transform="translate(82, 60)">
    <path d="M5,0 Q11,2 11,10 Q9,16 5,18 Q1,16 -1,10 Q-1,2 5,0" fill="#e53935"/>
    <ellipse cx="5" cy="0" rx="4" ry="1.5" fill="#43a047"/>
    <circle cx="3" cy="6" r="0.7" fill="#ffcdd2"/>
    <circle cx="7" cy="5" r="0.7" fill="#ffcdd2"/>
    <circle cx="5" cy="10" r="0.7" fill="#ffcdd2"/>
  </g>
  <g transform="translate(103, 58)">
    <path d="M5,0 Q11,2 11,10 Q9,16 5,18 Q1,16 -1,10 Q-1,2 5,0" fill="#e53935"/>
    <ellipse cx="5" cy="0" rx="4" ry="1.5" fill="#43a047"/>
    <circle cx="3" cy="6" r="0.7" fill="#ffcdd2"/>
    <circle cx="7" cy="5" r="0.7" fill="#ffcdd2"/>
    <circle cx="5" cy="10" r="0.7" fill="#ffcdd2"/>
  </g>
  <!-- Small strawberry slice -->
  <g transform="translate(92, 72)">
    <path d="M4,0 Q8,2 8,7 Q6,10 4,11 Q2,10 0,7 Q0,2 4,0" fill="#ef5350"/>
    <circle cx="3" cy="4" r="0.5" fill="#ffcdd2"/>
    <circle cx="5" cy="6" r="0.5" fill="#ffcdd2"/>
  </g>
  <!-- Top biscuit lid (slightly tilted) -->
  <g transform="translate(68, 48) rotate(-5)">
    <ellipse cx="32" cy="5" rx="30" ry="6" fill="#e6be8a"/>
    <rect x="2" y="0" width="60" height="5" fill="#deb078" rx="2"/>
    <ellipse cx="32" cy="0" rx="30" ry="5" fill="#ecc99a"/>
  </g>
  <!-- Label -->
  <text x="100" y="150" text-anchor="middle" font-size="11" fill="#e65100" font-family="sans-serif">shortcake = crumbly biscuit pastry</text>
</svg>

<!-- English muffler = car exhaust silencer -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Garage floor -->
  <rect x="0" y="125" width="200" height="35" fill="#cfd8dc"/>
  <line x1="0" y1="135" x2="200" y2="135" stroke="#b0bec5" stroke-width="0.5"/>
  <!-- Car silhouette (rear, suggested) -->
  <path d="M30 90 Q35 75 50 75 L75 75 L75 110 L30 110 Z" fill="#546e7a" stroke="#37474f" stroke-width="1"/>
  <rect x="40" y="80" width="25" height="14" fill="#90a4ae" stroke="#37474f" stroke-width="0.6"/>
  <circle cx="40" cy="115" r="9" fill="#263238"/>
  <circle cx="40" cy="115" r="4" fill="#546e7a"/>
  <circle cx="68" cy="115" r="9" fill="#263238"/>
  <circle cx="68" cy="115" r="4" fill="#546e7a"/>
  <!-- Exhaust pipe coming out from under car -->
  <rect x="70" y="105" width="40" height="6" fill="#90a4ae" stroke="#546e7a" stroke-width="0.8"/>
  <!-- Muffler box (cylindrical silencer) -->
  <ellipse cx="115" cy="108" rx="6" ry="14"/>
  <rect x="110" y="94" width="40" height="28" fill="#b0bec5" stroke="#546e7a" stroke-width="1.2" rx="4"/>
  <ellipse cx="110" cy="108" rx="4" ry="14" fill="#90a4ae" stroke="#546e7a" stroke-width="1"/>
  <ellipse cx="150" cy="108" rx="4" ry="14" fill="#cfd8dc" stroke="#546e7a" stroke-width="1"/>
  <!-- Heat shield ridge -->
  <line x1="115" y1="98" x2="148" y2="98" stroke="#78909c" stroke-width="0.6"/>
  <line x1="115" y1="118" x2="148" y2="118" stroke="#78909c" stroke-width="0.6"/>
  <!-- Exhaust tip pipe -->
  <rect x="150" y="104" width="20" height="8" fill="#37474f" rx="1"/>
  <ellipse cx="170" cy="108" rx="2.5" ry="4" fill="#212121"/>
  <!-- Mounting strap to chassis -->
  <line x1="125" y1="94" x2="125" y2="80" stroke="#37474f" stroke-width="1.5"/>
  <line x1="140" y1="94" x2="140" y2="80" stroke="#37474f" stroke-width="1.5"/>
  <line x1="118" y1="80" x2="148" y2="80" stroke="#37474f" stroke-width="2"/>
  <!-- Exhaust smoke puffs -->
  <ellipse cx="178" cy="108" rx="6" ry="4" fill="#cfd8dc" opacity="0.7"/>
  <ellipse cx="186" cy="105" rx="5" ry="3.5" fill="#cfd8dc" opacity="0.55"/>
  <ellipse cx="190" cy="111" rx="4" ry="3" fill="#cfd8dc" opacity="0.45"/>
  <ellipse cx="183" cy="114" rx="3" ry="2.5" fill="#cfd8dc" opacity="0.4"/>
  <!-- Brand label on muffler -->
  <rect x="120" y="105" width="22" height="6" fill="#37474f" rx="0.8"/>
  <text x="131" y="109.5" font-size="4" fill="#ffeb3b" text-anchor="middle" font-family="sans-serif" font-weight="bold">MUFFLER</text>
  <!-- Heat waves -->
  <path d="M158 90 Q162 86 158 82" fill="none" stroke="#ef9a9a" stroke-width="1" opacity="0.6" stroke-linecap="round"/>
  <path d="M168 92 Q172 88 168 84" fill="none" stroke="#ef9a9a" stroke-width="1" opacity="0.6" stroke-linecap="round"/>
</svg>

<!-- Japanese ピアス = pierced earrings (noun) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Jewelry display velvet -->
  <rect x="15" y="95" width="170" height="50" fill="#880e4f" rx="4"/>
  <rect x="15" y="95" width="170" height="5" fill="#ad1457"/>
  <!-- Ear (upper left, modeling the earring) -->
  <!-- Face profile -->
  <path d="M40 25 Q70 20 85 40 Q90 55 78 70 Q70 82 65 90 L45 90 Z" fill="#ffcc80"/>
  <!-- Ear -->
  <path d="M75 45 Q90 45 88 60 Q86 72 75 70 Q73 60 72 55 Q73 48 75 45 Z" fill="#ffb74d" stroke="#5d4037" stroke-width="0.8"/>
  <path d="M78 52 Q82 55 80 62" fill="none" stroke="#5d4037" stroke-width="0.5"/>
  <!-- Hair -->
  <path d="M35 25 Q50 10 75 18 Q85 25 82 40 L78 40 Q65 30 40 35 Z" fill="#3e2723"/>
  <!-- Pierced earring on ear -->
  <circle cx="82" cy="68" r="3" fill="#ffd700" stroke="#f57c00" stroke-width="0.5"/>
  <circle cx="82" cy="68" r="1.5" fill="#fff59d"/>
  <!-- Sparkle -->
  <text x="87" y="65" font-size="10" fill="#ffd700">✦</text>
  <!-- Eye -->
  <circle cx="65" cy="45" r="1.5" fill="#3e2723"/>
  <!-- Lips -->
  <path d="M55 65 Q60 68 65 65" fill="none" stroke="#d81b60" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Earring display stand showing various pierce jewelry -->
  <!-- Stud 1 -->
  <circle cx="110" cy="110" r="6" fill="#e0e0e0" stroke="#424242" stroke-width="0.5"/>
  <circle cx="110" cy="110" r="4" fill="#fff" stroke="#9e9e9e" stroke-width="0.5"/>
  <circle cx="110" cy="110" r="2" fill="#90caf9"/>
  <text x="110" y="128" font-size="6" fill="white" text-anchor="middle">スタッド</text>
  <!-- Hoop -->
  <circle cx="135" cy="110" r="7" fill="none" stroke="#ffd700" stroke-width="2.5"/>
  <circle cx="135" cy="103" r="1" fill="#f57c00"/>
  <text x="135" y="128" font-size="6" fill="white" text-anchor="middle">フープ</text>
  <!-- Dangle earring -->
  <circle cx="160" cy="103" r="2" fill="#ffd700"/>
  <path d="M160 105 L158 115 L162 115 Z" fill="#e91e63"/>
  <circle cx="160" cy="118" r="2.5" fill="#e91e63" stroke="#880e4f" stroke-width="0.5"/>
  <text x="160" y="128" font-size="6" fill="white" text-anchor="middle">ダングル</text>
  <!-- Large featured earring on velvet -->
  <!-- Small card -->
  <rect x="25" y="105" width="70" height="30" fill="#fff" stroke="#880e4f" stroke-width="1" rx="2"/>
  <!-- Pair of earrings -->
  <circle cx="45" cy="118" r="5" fill="none" stroke="#ffd700" stroke-width="1.5"/>
  <circle cx="45" cy="114" r="0.8" fill="#e91e63"/>
  <circle cx="75" cy="118" r="5" fill="none" stroke="#ffd700" stroke-width="1.5"/>
  <circle cx="75" cy="114" r="0.8" fill="#e91e63"/>
  <text x="60" y="132" font-size="5" fill="#880e4f" text-anchor="middle">ピアス (ペア)</text>
  <!-- Label -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#880e4f" text-anchor="middle">ピアス = Pierced Earrings (noun!)</text>
  <text x="100" y="155" font-size="7" fill="#ad1457" text-anchor="middle">穴を開ける「アクセサリー」／イヤリング(クリップ式)とは別</text>
</svg>

<!-- English "jumbo" = only for physical oversized things: jumbo jet, jumbo shrimp -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e1f5fe" rx="8"/>
  <!-- Sky gradient effect -->
  <ellipse cx="100" cy="30" rx="150" ry="15" fill="#b3e5fc" opacity="0.6"/>
  <!-- Clouds -->
  <ellipse cx="30" cy="20" rx="15" ry="5" fill="white" opacity="0.8"/>
  <ellipse cx="170" cy="25" rx="12" ry="4" fill="white" opacity="0.8"/>
  <!-- JUMBO JET (large airplane) -->
  <!-- Fuselage -->
  <ellipse cx="100" cy="55" rx="65" ry="10" fill="white" stroke="#546e7a" stroke-width="1.5"/>
  <!-- Tail -->
  <polygon points="30,55 15,40 22,58" fill="white" stroke="#546e7a" stroke-width="1.5"/>
  <!-- Top fin -->
  <polygon points="40,48 35,30 50,48" fill="#1976d2" stroke="#0d47a6" stroke-width="1"/>
  <!-- Wings -->
  <polygon points="80,55 55,75 72,55" fill="#90caf9" stroke="#1976d2" stroke-width="1"/>
  <polygon points="115,55 140,75 125,55" fill="#90caf9" stroke="#1976d2" stroke-width="1"/>
  <!-- Windows row -->
  <circle cx="50" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="60" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="70" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="80" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="90" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="100" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="110" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="120" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="130" cy="55" r="1.5" fill="#1976d2"/>
  <circle cx="140" cy="55" r="1.5" fill="#1976d2"/>
  <!-- Nose cone -->
  <ellipse cx="160" cy="55" rx="6" ry="4" fill="#90a4ae"/>
  <!-- Engines -->
  <ellipse cx="82" cy="70" rx="5" ry="3" fill="#455a64"/>
  <ellipse cx="118" cy="70" rx="5" ry="3" fill="#455a64"/>
  <!-- Label "jumbo jet" -->
  <text x="100" y="85" font-size="10" font-weight="bold" fill="#0d47a6" text-anchor="middle">"jumbo jet" ✓</text>
  <!-- JUMBO SHRIMP on plate -->
  <ellipse cx="100" cy="125" rx="55" ry="8" fill="white" stroke="#90a4ae" stroke-width="1.2"/>
  <ellipse cx="100" cy="123" rx="45" ry="5" fill="#fafafa"/>
  <!-- Big shrimp curled -->
  <path d="M70,120 Q75,108 95,110 Q115,112 125,120 Q130,125 128,130 Q120,132 115,125 Q105,120 95,122 Q80,125 72,128 Q68,125 70,120 Z" fill="#ff8a65" stroke="#d84315" stroke-width="1"/>
  <!-- Shrimp segments -->
  <path d="M80,115 Q82,120 85,118" fill="none" stroke="#d84315" stroke-width="0.5"/>
  <path d="M90,112 Q92,117 95,115" fill="none" stroke="#d84315" stroke-width="0.5"/>
  <path d="M100,111 Q102,116 105,114" fill="none" stroke="#d84315" stroke-width="0.5"/>
  <path d="M110,114 Q112,119 115,117" fill="none" stroke="#d84315" stroke-width="0.5"/>
  <!-- Tail -->
  <polygon points="68,125 60,120 62,130" fill="#ff7043" stroke="#d84315" stroke-width="0.8"/>
  <!-- Lemon slice -->
  <circle cx="145" cy="123" r="6" fill="#fff59d" stroke="#f9a825" stroke-width="0.8"/>
  <line x1="139" y1="123" x2="151" y2="123" stroke="#f9a825" stroke-width="0.5"/>
  <line x1="145" y1="117" x2="145" y2="129" stroke="#f9a825" stroke-width="0.5"/>
  <!-- Label "jumbo shrimp" -->
  <text x="100" y="148" font-size="10" font-weight="bold" fill="#bf360c" text-anchor="middle">"jumbo shrimp" ✓</text>
  <text x="100" y="158" font-size="7" fill="#5d4037" text-anchor="middle">only for physically oversized things</text>
</svg>

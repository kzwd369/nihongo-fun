<!-- Japanese ファイト! = cheering encouragement -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Track/ground -->
  <rect x="0" y="130" width="200" height="30" fill="#ffcc80"/>
  <line x1="0" y1="135" x2="200" y2="135" stroke="white" stroke-width="1" stroke-dasharray="6,4"/>
  <!-- Runner (center) -->
  <!-- Head -->
  <circle cx="100" cy="55" r="10" fill="#ffcc80"/>
  <!-- Headband -->
  <rect x="90" y="48" width="20" height="4" fill="#c62828"/>
  <circle cx="100" cy="50" r="2" fill="white"/>
  <!-- Determined eyes -->
  <line x1="94" y1="54" x2="98" y2="56" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <line x1="106" y1="54" x2="102" y2="56" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Grimace/determined mouth -->
  <path d="M96 62 Q100 60 104 62" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- Sweat drop -->
  <path d="M112 52 Q114 56 112 58 Q110 56 112 52" fill="#64b5f6"/>
  <!-- Running body -->
  <rect x="93" y="65" width="14" height="22" fill="#ef5350" rx="2"/>
  <!-- Number bib -->
  <rect x="95" y="70" width="10" height="10" fill="white" rx="1"/>
  <text x="100" y="77" font-size="6" font-weight="bold" fill="#c62828" text-anchor="middle">42</text>
  <!-- Arms pumping -->
  <line x1="93" y1="70" x2="80" y2="78" stroke="#ef5350" stroke-width="5" stroke-linecap="round"/>
  <line x1="107" y1="72" x2="120" y2="62" stroke="#ef5350" stroke-width="5" stroke-linecap="round"/>
  <!-- Legs running -->
  <line x1="95" y1="87" x2="85" y2="110" stroke="#1976d2" stroke-width="6" stroke-linecap="round"/>
  <line x1="105" y1="87" x2="115" y2="105" stroke="#1976d2" stroke-width="6" stroke-linecap="round"/>
  <!-- Shoes -->
  <ellipse cx="83" cy="115" rx="6" ry="3" fill="#212121"/>
  <ellipse cx="117" cy="110" rx="6" ry="3" fill="#212121"/>
  <!-- Motion lines behind runner -->
  <line x1="75" y1="75" x2="65" y2="72" stroke="#ffa726" stroke-width="2" stroke-linecap="round"/>
  <line x1="75" y1="85" x2="62" y2="85" stroke="#ffa726" stroke-width="2" stroke-linecap="round"/>
  <line x1="75" y1="95" x2="65" y2="98" stroke="#ffa726" stroke-width="2" stroke-linecap="round"/>
  <!-- Cheering person (left) -->
  <circle cx="28" cy="90" r="7" fill="#ffcc80"/>
  <rect x="23" y="96" width="10" height="15" fill="#ffeb3b" rx="1"/>
  <!-- Raised arms -->
  <line x1="23" y1="98" x2="18" y2="85" stroke="#ffcc80" stroke-width="3" stroke-linecap="round"/>
  <line x1="33" y1="98" x2="38" y2="85" stroke="#ffcc80" stroke-width="3" stroke-linecap="round"/>
  <!-- Smile -->
  <path d="M25 92 Q28 94 31 92" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <circle cx="26" cy="89" r="1" fill="#5d4037"/>
  <circle cx="30" cy="89" r="1" fill="#5d4037"/>
  <!-- Cheer banner from left person -->
  <rect x="8" y="58" width="50" height="20" fill="#fff" stroke="#c62828" stroke-width="2" rx="3"/>
  <text x="33" y="73" font-size="13" font-weight="bold" fill="#c62828" text-anchor="middle">ファイト!</text>
  <path d="M28 78 L26 85" stroke="#c62828" stroke-width="1"/>
  <!-- Right cheerer -->
  <circle cx="172" cy="90" r="7" fill="#ffcc80"/>
  <rect x="167" y="96" width="10" height="15" fill="#4fc3f7" rx="1"/>
  <line x1="167" y1="98" x2="160" y2="85" stroke="#ffcc80" stroke-width="3" stroke-linecap="round"/>
  <line x1="177" y1="98" x2="182" y2="85" stroke="#ffcc80" stroke-width="3" stroke-linecap="round"/>
  <circle cx="170" cy="89" r="1" fill="#5d4037"/>
  <circle cx="174" cy="89" r="1" fill="#5d4037"/>
  <path d="M169 92 Q172 94 175 92" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- Cheer banner from right -->
  <rect x="140" y="58" width="52" height="20" fill="#fff" stroke="#1976d2" stroke-width="2" rx="3"/>
  <text x="166" y="73" font-size="11" font-weight="bold" fill="#1976d2" text-anchor="middle">がんばれ!</text>
  <!-- Label -->
  <text x="100" y="25" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">"ファイト!" = Go for it!</text>
  <text x="100" y="155" font-size="8" fill="#5d4037" text-anchor="middle">応援のかけ声（殴り合いではない）</text>
</svg>

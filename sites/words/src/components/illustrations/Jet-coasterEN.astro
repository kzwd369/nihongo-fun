<!-- English: "jet coaster" = imagined rocket-powered sled (not a real thing) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Thought bubble background showing what English speakers imagine -->
  <ellipse cx="100" cy="65" rx="85" ry="40" fill="#fff" stroke="#5c6bc0" stroke-width="2" stroke-dasharray="4,3"/>
  <!-- Imagined rocket-sled with question marks -->
  <!-- Rocket body -->
  <path d="M40 70 L130 70 L150 80 L130 90 L40 90 Z" fill="#90a4ae" stroke="#37474f" stroke-width="1.5"/>
  <!-- Nose cone -->
  <polygon points="130,70 150,80 130,90" fill="#cfd8dc" stroke="#37474f" stroke-width="1.5"/>
  <!-- Cockpit window -->
  <ellipse cx="100" cy="78" rx="10" ry="5" fill="#42a5f5" stroke="#0d47a1" stroke-width="1"/>
  <!-- Confused passenger inside -->
  <circle cx="100" cy="76" r="3" fill="#ffcc80"/>
  <text x="100" y="79" font-size="6" fill="#0d47a1" text-anchor="middle">?</text>
  <!-- Wing/fin -->
  <polygon points="60,70 50,55 70,70" fill="#78909c" stroke="#37474f" stroke-width="1"/>
  <polygon points="60,90 50,105 70,90" fill="#78909c" stroke="#37474f" stroke-width="1"/>
  <!-- Rocket flames at back -->
  <polygon points="40,72 25,80 40,88" fill="#ffeb3b"/>
  <polygon points="40,75 18,80 40,85" fill="#ff7043"/>
  <polygon points="40,78 12,80 40,82" fill="#c62828"/>
  <!-- Track/rail underneath -->
  <line x1="20" y1="92" x2="180" y2="92" stroke="#5d4037" stroke-width="3"/>
  <line x1="20" y1="95" x2="180" y2="95" stroke="#5d4037" stroke-width="1"/>
  <!-- Question marks around it -->
  <text x="30" y="50" font-size="22" font-weight="bold" fill="#5c6bc0">?</text>
  <text x="160" y="55" font-size="22" font-weight="bold" fill="#5c6bc0">?</text>
  <text x="170" y="100" font-size="18" font-weight="bold" fill="#5c6bc0">?</text>
  <!-- "What I picture..." caption -->
  <text x="100" y="40" font-size="8" font-style="italic" fill="#3949ab" text-anchor="middle">"some kind of jet-powered sled..?"</text>
  <!-- English speaker thinking -->
  <circle cx="35" cy="135" r="9" fill="#ffcc80"/>
  <path d="M27 130 Q35 122 43 130" fill="#6d4c41"/>
  <circle cx="32" cy="135" r="1" fill="#5d4037"/>
  <circle cx="38" cy="135" r="1" fill="#5d4037"/>
  <path d="M32 140 Q35 138 38 140" fill="none" stroke="#5d4037" stroke-width="0.8"/>
  <!-- Small thought bubbles connecting -->
  <circle cx="48" cy="120" r="2" fill="#fff" stroke="#5c6bc0" stroke-width="1"/>
  <circle cx="55" cy="113" r="3" fill="#fff" stroke="#5c6bc0" stroke-width="1"/>
  <!-- Correct term box -->
  <rect x="100" y="118" width="95" height="20" fill="#c8e6c9" stroke="#1b5e20" stroke-width="1.5" rx="3"/>
  <text x="147" y="127" font-size="8" font-weight="bold" fill="#1b5e20" text-anchor="middle">✓ Say "roller coaster"</text>
  <text x="147" y="135" font-size="6" fill="#33691e" text-anchor="middle">universal in English worldwide</text>
  <!-- Label -->
  <text x="100" y="20" font-size="10" font-weight="bold" fill="#1a237e" text-anchor="middle">"Jet coaster" → ???</text>
  <text x="100" y="155" font-size="7" fill="#3949ab" text-anchor="middle">Sounds like a rocket-powered sled concept that never got built</text>
</svg>

<!-- Cat lying lazily on cushion with thunder cloud above — ゴロゴロ (rumbling/lazing) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Thunder cloud -->
  <ellipse cx="100" cy="28" rx="35" ry="16" fill="#b0bec5"/>
  <ellipse cx="78" cy="30" rx="22" ry="14" fill="#90a4ae"/>
  <ellipse cx="122" cy="30" rx="22" ry="14" fill="#90a4ae"/>
  <ellipse cx="100" cy="24" rx="28" ry="14" fill="#b0bec5"/>
  <!-- Lightning bolt -->
  <polygon points="98,42 104,42 100,52 106,52 94,66 98,55 92,55" fill="#ffd54f"/>
  <polygon points="99,43 103,43 100,50 105,50 96,62 99,54 94,54" fill="#ffea00" opacity="0.7"/>
  <!-- Cushion -->
  <ellipse cx="105" cy="130" rx="55" ry="14" fill="#ce93d8" opacity="0.6"/>
  <ellipse cx="105" cy="126" rx="52" ry="12" fill="#e1bee7"/>
  <ellipse cx="105" cy="124" rx="48" ry="10" fill="#f3e5f5"/>

  <ellipse cx="105" cy="110" rx="38" ry="16" fill="#ffcc80"/>
  <!-- Cat body highlight -->
  <ellipse cx="100" cy="106" rx="28" ry="10" fill="#ffe0b2" opacity="0.6"/>
  <!-- Cat head -->
  <ellipse cx="145" cy="100" rx="18" ry="15" fill="#ffcc80"/>
  <!-- Cat ears -->
  <polygon points="133,88 138,75 143,88" fill="#ffcc80"/>
  <polygon points="147,88 152,75 157,88" fill="#ffcc80"/>
  <polygon points="135,88 138,79 141,88" fill="#ffab91" opacity="0.6"/>
  <polygon points="149,88 152,79 155,88" fill="#ffab91" opacity="0.6"/>
  <!-- Cat face — sleeping/content -->
  <path d="M137 100 Q140 97 143 100" fill="none" stroke="#795548" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M147 100 Q150 97 153 100" fill="none" stroke="#795548" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Cat nose -->
  <ellipse cx="145" cy="104" rx="2" ry="1.5" fill="#f48fb1"/>
  <!-- Cat smile -->
  <path d="M141 107 Q145 110 149 107" fill="none" stroke="#795548" stroke-width="1" stroke-linecap="round"/>

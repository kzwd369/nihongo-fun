  <line x1="125" y1="102" x2="136" y2="104" stroke="#bdbdbd" stroke-width="0.8"/>
  <line x1="125" y1="106" x2="136" y2="106" stroke="#bdbdbd" stroke-width="0.8"/>
  <line x1="154" y1="104" x2="168" y2="102" stroke="#bdbdbd" stroke-width="0.8"/>
  <line x1="154" y1="106" x2="168" y2="106" stroke="#bdbdbd" stroke-width="0.8"/>
  <!-- Cat tail (curled) -->
  <path d="M67 110 Q50 105 48 95 Q46 85 55 82" fill="none" stroke="#ffcc80" stroke-width="6" stroke-linecap="round"/>
  <path d="M67 110 Q50 105 48 95 Q46 85 55 82" fill="none" stroke="#ffe0b2" stroke-width="3" stroke-linecap="round"/>
  <!-- Cat front paw -->
  <ellipse cx="130" cy="118" rx="6" ry="4" fill="#ffcc80"/>
  <!-- Zzz (sleeping/relaxed) -->
  <text x="165" y="82" font-family="sans-serif" font-size="10" fill="#90a4ae" opacity="0.6">z</text>
  <text x="172" y="74" font-family="sans-serif" font-size="12" fill="#90a4ae" opacity="0.5">z</text>
  <text x="180" y="64" font-family="sans-serif" font-size="14" fill="#90a4ae" opacity="0.4">z</text>
  <!-- Purr vibration lines -->
  <path d="M88 105 Q86 103 84 105" fill="none" stroke="#ffab91" stroke-width="0.8" opacity="0.5"/>
  <path d="M82 102 Q80 100 78 102" fill="none" stroke="#ffab91" stroke-width="0.8" opacity="0.4"/>
  <path d="M120 105 Q122 103 124 105" fill="none" stroke="#ffab91" stroke-width="0.8" opacity="0.5"/>
</svg>

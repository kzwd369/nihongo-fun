<!-- シャープペンシル = mechanical pencil -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Notebook page -->
  <rect x="20" y="105" width="160" height="48" fill="white" rx="3" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="30" y1="118" x2="170" y2="118" stroke="#e1f5fe" stroke-width="0.8"/>
  <line x1="30" y1="128" x2="170" y2="128" stroke="#e1f5fe" stroke-width="0.8"/>
  <line x1="30" y1="138" x2="170" y2="138" stroke="#e1f5fe" stroke-width="0.8"/>
  <!-- Pencil-drawn math equation -->
  <text x="40" y="125" font-size="9" fill="#616161" font-family="serif">2x + 3 = 11</text>
  <!-- Mechanical pencil (rotated) -->
  <g transform="rotate(-22 100 60)">
    <!-- Push button cap -->
    <rect x="30" y="56" width="6" height="8" fill="#fb8c00" rx="1"/>
    <!-- Eraser holder -->
    <rect x="36" y="55" width="8" height="10" fill="#bf360c" rx="1"/>
    <!-- Top barrel -->
    <rect x="44" y="54" width="60" height="12" fill="#5d4037" rx="1"/>
    <rect x="44" y="55" width="60" height="2" fill="#8d6e63"/>
    <!-- Mid section (knurled grip area) -->
    <rect x="104" y="55" width="20" height="10" fill="#3e2723" rx="1"/>
    <line x1="106" y1="55" x2="106" y2="65" stroke="#5d4037" stroke-width="0.5"/>
    <line x1="110" y1="55" x2="110" y2="65" stroke="#5d4037" stroke-width="0.5"/>
    <line x1="114" y1="55" x2="114" y2="65" stroke="#5d4037" stroke-width="0.5"/>
    <line x1="118" y1="55" x2="118" y2="65" stroke="#5d4037" stroke-width="0.5"/>
    <line x1="122" y1="55" x2="122" y2="65" stroke="#5d4037" stroke-width="0.5"/>
    <!-- Tip cone -->
    <polygon points="124,55 124,65 145,62 145,58" fill="#90a4ae"/>
    <!-- Lead pipe -->
    <rect x="145" y="59" width="8" height="2" fill="#546e7a"/>
    <!-- Lead -->
    <line x1="153" y1="60" x2="160" y2="60" stroke="#212121" stroke-width="1.2"/>
    <!-- Clip -->
    <path d="M65 66 L65 80 L70 80 L70 66 Z" fill="#fb8c00"/>
    <!-- Brand stripe -->
    <rect x="55" y="58" width="40" height="2" fill="#fff3e0" opacity="0.9"/>
    <text x="75" y="63.5" font-size="3.5" fill="#5d4037" text-anchor="middle" font-family="sans-serif">0.5mm</text>
  </g>
  <!-- Lead refills floating -->
  <g transform="translate(155 35) rotate(15)">
    <rect x="0" y="0" width="20" height="1.2" fill="#212121"/>
  </g>
  <g transform="translate(160 45) rotate(15)">
    <rect x="0" y="0" width="18" height="1.2" fill="#212121"/>
  </g>
  <!-- Sparkle -->
  <text x="40" y="40" font-size="10" fill="#ffcc80" opacity="0.7">✦</text>
</svg>

<!-- English "key holder" = wall-mounted rack by the door -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#efebe9" rx="8"/>
  <!-- Wall background -->
  <rect x="0" y="0" width="200" height="120" fill="#f5f5f5"/>
  <!-- Wall texture lines -->
  <line x1="0" y1="40" x2="200" y2="40" stroke="#e0e0e0" stroke-width="0.3"/>
  <line x1="0" y1="80" x2="200" y2="80" stroke="#e0e0e0" stroke-width="0.3"/>
  <!-- Floor -->
  <rect x="0" y="120" width="200" height="40" fill="#a1887f"/>
  <!-- Door on left edge -->
  <rect x="0" y="20" width="35" height="100" fill="#8d6e63" stroke="#5d4037" stroke-width="1.5"/>
  <circle cx="28" cy="75" r="2" fill="#ffd54f"/>
  <!-- Wall-mounted key holder rack -->
  <!-- Wood plaque -->
  <rect x="60" y="35" width="120" height="40" fill="#a1887f" stroke="#5d4037" stroke-width="2" rx="3"/>
  <!-- Decorative wood grain -->
  <line x1="65" y1="42" x2="175" y2="42" stroke="#795548" stroke-width="0.4"/>
  <line x1="65" y1="50" x2="175" y2="50" stroke="#795548" stroke-width="0.4"/>
  <line x1="65" y1="58" x2="175" y2="58" stroke="#795548" stroke-width="0.4"/>
  <!-- "KEYS" engraved -->
  <text x="120" y="55" font-size="12" font-weight="bold" fill="#3e2723" text-anchor="middle" letter-spacing="3">KEYS</text>
  <!-- Mounting screws -->
  <circle cx="68" cy="40" r="1.5" fill="#616161"/>
  <circle cx="172" cy="40" r="1.5" fill="#616161"/>
  <!-- Hooks underneath -->
  <path d="M75 75 Q75 85 80 85" fill="none" stroke="#616161" stroke-width="2.5"/>
  <path d="M105 75 Q105 85 110 85" fill="none" stroke="#616161" stroke-width="2.5"/>
  <path d="M135 75 Q135 85 140 85" fill="none" stroke="#616161" stroke-width="2.5"/>
  <path d="M165 75 Q165 85 170 85" fill="none" stroke="#616161" stroke-width="2.5"/>
  <!-- Keys hanging on hooks -->
  <!-- Key 1 (house key) -->
  <line x1="80" y1="85" x2="80" y2="92" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="80" cy="95" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <rect x="79" y="98" width="2" height="14" fill="#ffd54f"/>
  <rect x="78" y="108" width="3" height="2" fill="#ffd54f"/>
  <rect x="78" y="111" width="4" height="2" fill="#ffd54f"/>
  <!-- Key 2 (car key) -->
  <line x1="110" y1="85" x2="110" y2="92" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="110" cy="95" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <rect x="106" y="98" width="8" height="12" fill="#212121" rx="1"/>
  <text x="110" y="106" font-size="5" fill="#ffeb3b" text-anchor="middle">CAR</text>
  <!-- Key 3 (mailbox) -->
  <line x1="140" y1="85" x2="140" y2="92" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="140" cy="95" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <rect x="139" y="98" width="2" height="10" fill="#bdbdbd"/>
  <rect x="138" y="106" width="3" height="2" fill="#bdbdbd"/>
  <!-- Key 4 (bike lock) -->
  <line x1="170" y1="85" x2="170" y2="92" stroke="#9e9e9e" stroke-width="1"/>
  <circle cx="170" cy="95" r="4" fill="none" stroke="#9e9e9e" stroke-width="1.5"/>
  <rect x="169" y="98" width="2" height="13" fill="#a1887f"/>
  <rect x="168" y="108" width="3" height="2" fill="#a1887f"/>
  <!-- Wall pictures next to it -->
  <rect x="42" y="20" width="14" height="14" fill="#fff" stroke="#5d4037" stroke-width="0.8"/>
  <circle cx="49" cy="27" r="3" fill="#ffd54f"/>
  <!-- Note: NOT a charm -->
  <rect x="65" y="92" width="50" height="26" fill="#ffebee" stroke="#c62828" stroke-width="1" rx="2"/>
  <text x="90" y="102" font-size="6" fill="#c62828" text-anchor="middle">NOT a small</text>
  <text x="90" y="109" font-size="6" fill="#c62828" text-anchor="middle">charm/keychain.</text>
  <text x="90" y="116" font-size="6" fill="#c62828" text-anchor="middle">That = "key chain"</text>
  <!-- Label -->
  <text x="100" y="20" font-size="10" font-weight="bold" fill="#3e2723" text-anchor="middle">English "key holder" = wall rack by the door</text>
  <text x="100" y="138" font-size="9" font-weight="bold" fill="#3e2723" text-anchor="middle">Or: a leather key organizer / a person with the key</text>
  <text x="100" y="148" font-size="7" fill="#5d4037" text-anchor="middle">For the Japanese charm meaning, say "key chain" / "key ring"</text>
  <text x="100" y="157" font-size="6" fill="#795548" text-anchor="middle">⚠ "Acrylic key holder" sounds odd in English</text>
</svg>

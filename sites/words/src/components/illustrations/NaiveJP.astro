<!-- Japanese ナイーブ = sensitive, delicate, gentle (positive) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Gentle person -->
  <circle cx="100" cy="52" r="22" fill="#ffccbc"/>
  <!-- Soft smile -->
  <ellipse cx="92" cy="50" rx="2.5" ry="3" fill="#5d4037"/>
  <ellipse cx="108" cy="50" rx="2.5" ry="3" fill="#5d4037"/>
  <path d="M93 58 Q100 63 107 58" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Slight blush -->
  <ellipse cx="86" cy="56" rx="5" ry="3" fill="#f48fb1" opacity="0.4"/>
  <ellipse cx="114" cy="56" rx="5" ry="3" fill="#f48fb1" opacity="0.4"/>
  <!-- Hair -->
  <path d="M78 45 Q80 28 100 25 Q120 28 122 45" fill="#5d4037"/>
  <!-- Body -->
  <path d="M82 72 Q100 78 118 72 L122 120 H78 Z" fill="#ce93d8"/>
  <!-- Flowers around -->
  <g transform="translate(40, 35)">
    <circle cx="0" cy="0" r="5" fill="#f8bbd0"/>
    <circle cx="5" cy="-4" r="5" fill="#f8bbd0"/>
    <circle cx="-5" cy="-4" r="5" fill="#f8bbd0"/>
    <circle cx="0" cy="-3" r="3" fill="#fff59d"/>
  </g>
  <g transform="translate(155, 50)">
    <circle cx="0" cy="0" r="4.5" fill="#c5e1a5"/>
    <circle cx="4.5" cy="-3.5" r="4.5" fill="#c5e1a5"/>
    <circle cx="-4.5" cy="-3.5" r="4.5" fill="#c5e1a5"/>
    <circle cx="0" cy="-2.5" r="2.5" fill="#fff59d"/>
  </g>
  <g transform="translate(50, 95)">
    <circle cx="0" cy="0" r="4" fill="#b3e5fc"/>
    <circle cx="4" cy="-3" r="4" fill="#b3e5fc"/>
    <circle cx="-4" cy="-3" r="4" fill="#b3e5fc"/>
    <circle cx="0" cy="-2" r="2.2" fill="#fff59d"/>
  </g>
  <g transform="translate(148, 100)">
    <circle cx="0" cy="0" r="4" fill="#f8bbd0"/>
    <circle cx="4" cy="-3" r="4" fill="#f8bbd0"/>
    <circle cx="-4" cy="-3" r="4" fill="#f8bbd0"/>
    <circle cx="0" cy="-2" r="2.2" fill="#fff59d"/>
  </g>
  <!-- Soft sparkles -->
  <circle cx="70" cy="25" r="1.5" fill="#f48fb1" opacity="0.5"/>
  <circle cx="130" cy="30" r="1.5" fill="#ce93d8" opacity="0.5"/>
  <!-- Label -->
  <text x="100" y="148" text-anchor="middle" font-size="11" fill="#7b1fa2" font-family="sans-serif">ナイーブ = sensitive, gentle</text>
</svg>

<!-- Angry/nauseated face with churning stomach — ムカムカ (nausea / simmering anger) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>

  <!-- Steam puffs rising from head (anger steam) -->
  <g fill="#ffab91" opacity="0.85">
    <ellipse cx="65" cy="22" rx="8" ry="5"/>
    <ellipse cx="80" cy="14" rx="7" ry="4"/>
    <ellipse cx="120" cy="14" rx="7" ry="4"/>
    <ellipse cx="135" cy="22" rx="8" ry="5"/>
  </g>
  <g fill="#ef9a9a" opacity="0.7">
    <ellipse cx="70" cy="10" rx="5" ry="3"/>
    <ellipse cx="130" cy="10" rx="5" ry="3"/>
  </g>

  <!-- Head -->
  <circle cx="100" cy="70" r="40" fill="#ffccbc"/>
  <!-- Hair (short messy) -->
  <path d="M60 60 Q65 28 100 28 Q135 28 140 60 Q130 45 100 45 Q70 45 60 60Z" fill="#4e342e"/>

  <!-- Angry slanted eyebrows -->
  <line x1="72" y1="58" x2="88" y2="64" stroke="#3e2723" stroke-width="3" stroke-linecap="round"/>
  <line x1="128" y1="58" x2="112" y2="64" stroke="#3e2723" stroke-width="3" stroke-linecap="round"/>

  <!-- Eyes - squinting angry -->
  <path d="M75 72 Q82 78 89 72" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M111 72 Q118 78 125 72" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>

  <!-- Downturned grimace mouth -->
  <path d="M85 92 Q100 85 115 92" fill="none" stroke="#3e2723" stroke-width="2.2" stroke-linecap="round"/>
  <!-- Teeth hint -->
  <line x1="93" y1="89" x2="93" y2="93" stroke="#3e2723" stroke-width="1"/>
  <line x1="100" y1="88" x2="100" y2="93" stroke="#3e2723" stroke-width="1"/>
  <line x1="107" y1="89" x2="107" y2="93" stroke="#3e2723" stroke-width="1"/>

  <!-- Red flushed cheeks -->
  <ellipse cx="75" cy="85" rx="6" ry="4" fill="#e57373" opacity="0.75"/>
  <ellipse cx="125" cy="85" rx="6" ry="4" fill="#e57373" opacity="0.75"/>

  <!-- Anger mark (popular veins symbol) -->
  <g transform="translate(145 45)" stroke="#d32f2f" stroke-width="2" fill="none" stroke-linecap="round">
    <path d="M0 0 L4 -4 L2 0 L6 -3"/>
    <path d="M2 2 L8 2"/>
    <path d="M0 4 L6 6"/>
  </g>

  <!-- Churning stomach area below -->
  <ellipse cx="100" cy="135" rx="38" ry="16" fill="#ffab91" opacity="0.55"/>
  <g fill="none" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.85">
    <path d="M78 135 Q85 128 92 135 Q99 142 106 135 Q113 128 120 135"/>
  </g>

  <!-- ムカムカ text -->
  <text x="20" y="150" font-family="sans-serif" font-size="14" font-weight="900" fill="#bf360c">ムカムカ!</text>
  <text x="150" y="110" font-family="sans-serif" font-size="11" font-weight="700" fill="#bf360c" opacity="0.8">ムカッ</text>
</svg>

<!-- Japanese クレーム = customer complaint -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Store counter -->
  <rect x="0" y="95" width="200" height="15" fill="#8d6e63" rx="0"/>
  <rect x="0" y="110" width="200" height="50" fill="#6d4c41" rx="0"/>
  <!-- Angry customer (left) -->
  <!-- Head -->
  <circle cx="65" cy="45" r="15" fill="#ffcc80"/>
  <!-- Angry eyebrows -->
  <line x1="55" y1="38" x2="62" y2="42" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <line x1="75" y1="38" x2="68" y2="42" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Angry eyes -->
  <circle cx="59" cy="44" r="2" fill="#5d4037"/>
  <circle cx="71" cy="44" r="2" fill="#5d4037"/>
  <!-- Open angry mouth -->
  <ellipse cx="65" cy="54" rx="6" ry="4" fill="#c62828"/>
  <path d="M60,53 L70,53" stroke="#ffcc80" stroke-width="1"/>
  <!-- Anger veins -->
  <path d="M80,32 L83,35 L86,32 L83,29 Z" fill="#ef5350"/>
  <!-- Body -->
  <rect x="55" y="60" width="20" height="25" fill="#ef5350" rx="3"/>
  <!-- Arm pointing/gesturing angrily -->
  <line x1="75" y1="66" x2="95" y2="78" stroke="#ef5350" stroke-width="5" stroke-linecap="round"/>
  <circle cx="97" cy="79" r="3" fill="#ffcc80"/>
  <!-- Speech lines (yelling) -->
  <line x1="82" y1="48" x2="90" y2="45" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="82" y1="52" x2="92" y2="52" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="82" y1="56" x2="90" y2="59" stroke="#ef5350" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Store employee (right, behind counter) -->
  <!-- Head -->
  <circle cx="145" cy="55" r="13" fill="#ffcc80"/>
  <!-- Employee hat/cap -->
  <rect x="132" y="42" width="26" height="6" fill="#1565c0" rx="2"/>
  <rect x="134" y="38" width="22" height="8" fill="#1976d2" rx="3"/>
  <!-- Worried eyes -->
  <circle cx="140" cy="55" r="2" fill="#5d4037"/>
  <circle cx="150" cy="55" r="2" fill="#5d4037"/>
  <!-- Worried eyebrows -->
  <path d="M136,51 Q140,49 143,51" fill="none" stroke="#5d4037" stroke-width="1.2"/>
  <path d="M147,51 Q150,49 154,51" fill="none" stroke="#5d4037" stroke-width="1.2"/>
  <!-- Apologetic mouth -->
  <path d="M141,62 Q145,59 149,62" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Sweat drop -->
  <path d="M160,48 Q162,53 160,56 Q158,53 160,48" fill="#64b5f6"/>
  <!-- Body (bowing slightly) -->
  <rect x="137" y="68" width="16" height="22" fill="#1976d2" rx="3"/>
  <!-- Arms (apologetic gesture) -->
  <line x1="137" y1="74" x2="125" y2="85" stroke="#1976d2" stroke-width="4" stroke-linecap="round"/>
  <line x1="153" y1="74" x2="165" y2="85" stroke="#1976d2" stroke-width="4" stroke-linecap="round"/>
  <!-- Defective product on counter -->
  <rect x="95" y="82" width="16" height="12" fill="#e0e0e0" rx="2" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="97" y1="84" x2="109" y2="92" stroke="#ef5350" stroke-width="1.5"/>
  <line x1="109" y1="84" x2="97" y2="92" stroke="#ef5350" stroke-width="1.5"/>
</svg>

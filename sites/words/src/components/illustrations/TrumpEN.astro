<!-- English trump = a powerful winning card (trump card) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Glow effect behind the card -->
  <ellipse cx="100" cy="75" rx="50" ry="55" fill="#fff176" opacity="0.3"/>
  <ellipse cx="100" cy="75" rx="35" ry="40" fill="#ffee58" opacity="0.2"/>
  <!-- Single powerful trump card -->
  <g transform="translate(62, 15)">
    <rect width="76" height="110" fill="#fff" rx="5" stroke="#ffd54f" stroke-width="2"/>
    <!-- Crown at top -->
    <polygon points="38,18 28,32 33,28 38,35 43,28 48,32" fill="#ffd54f" stroke="#f9a825" stroke-width="0.8"/>
    <circle cx="38" cy="16" r="2" fill="#f9a825"/>
    <circle cx="30" cy="22" r="1.5" fill="#f9a825"/>
    <circle cx="46" cy="22" r="1.5" fill="#f9a825"/>
    <!-- Star in center -->
    <polygon points="38,45 41,55 52,55 43,61 46,72 38,65 30,72 33,61 24,55 35,55" fill="#ffc107" stroke="#f57f17" stroke-width="0.5"/>
    <!-- TRUMP text -->
    <text x="38" y="90" text-anchor="middle" font-size="11" fill="#e65100" font-weight="bold" font-family="sans-serif">TRUMP</text>
    <!-- Corner symbols -->
    <text x="10" y="15" font-size="9" fill="#f57f17" font-family="serif">&#9733;</text>
    <text x="60" y="108" font-size="9" fill="#f57f17" font-family="serif" transform="rotate(180, 64, 104)">&#9733;</text>
  </g>
  <!-- Sparkle effects -->
  <circle cx="45" cy="30" r="2" fill="#ffeb3b" opacity="0.7"/>
  <circle cx="155" cy="45" r="1.5" fill="#ffeb3b" opacity="0.6"/>
  <circle cx="50" cy="100" r="1.8" fill="#ffeb3b" opacity="0.5"/>
  <circle cx="152" cy="95" r="2" fill="#ffeb3b" opacity="0.7"/>
  <!-- Label -->
  <text x="100" y="148" text-anchor="middle" font-size="11" fill="#795548" font-family="sans-serif">trump = winning card</text>
</svg>

<!-- English "American coffee" is not a term — it's just "coffee" or "drip coffee". NOT an Americano -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#efebe9" rx="8"/>
  <!-- "American coffee" crossed out -->
  <rect x="15" y="12" width="170" height="20" fill="#ffebee" stroke="#e53935" stroke-width="1" rx="3"/>
  <text x="100" y="25" font-size="10" fill="#424242" text-anchor="middle">"American coffee" (not a real English term)</text>
  <line x1="17" y1="14" x2="183" y2="30" stroke="#e53935" stroke-width="2.5"/>
  <line x1="183" y1="14" x2="17" y2="30" stroke="#e53935" stroke-width="2.5"/>
  <!-- Two cups side by side: Coffee vs Americano -->
  <!-- LEFT: Regular American "coffee" -->
  <text x="55" y="50" font-size="9" font-weight="bold" fill="#2e7d32" text-anchor="middle">✓ "coffee"</text>
  <text x="55" y="60" font-size="7" fill="#558b2f" text-anchor="middle">(drip / black)</text>
  <!-- Paper takeaway cup -->
  <path d="M35,70 L40,125 L70,125 L75,70 Z" fill="white" stroke="#6d4c41" stroke-width="1.5"/>
  <rect x="35" y="70" width="40" height="14" fill="#d7ccc8" stroke="#6d4c41" stroke-width="1.5"/>
  <!-- Cardboard sleeve -->
  <rect x="37" y="95" width="36" height="12" fill="#8d6e63" stroke="#5d4037" stroke-width="1"/>
  <!-- Lid -->
  <ellipse cx="55" cy="68" rx="20" ry="3" fill="#3e2723" stroke="#212121" stroke-width="1"/>
  <rect x="51" y="62" width="8" height="6" fill="#3e2723"/>
  <!-- Steam -->
  <path d="M50,58 Q48,52 51,47" fill="none" stroke="#bdbdbd" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M60,58 Q62,52 59,47" fill="none" stroke="#bdbdbd" stroke-width="1.5" stroke-linecap="round"/>
  <!-- RIGHT: Americano (for contrast) -->
  <text x="145" y="50" font-size="9" font-weight="bold" fill="#5d4037" text-anchor="middle">≠ Americano</text>
  <text x="145" y="60" font-size="7" fill="#8d6e63" text-anchor="middle">(espresso + hot water)</text>
  <!-- Ceramic espresso cup -->
  <path d="M125,75 L130,115 L160,115 L165,75 Z" fill="#fafafa" stroke="#6d4c41" stroke-width="1.5"/>
  <ellipse cx="145" cy="75" rx="20" ry="3" fill="#fafafa" stroke="#6d4c41" stroke-width="1.5"/>
  <!-- Handle -->
  <path d="M165,85 Q175,92 170,102" fill="none" stroke="#6d4c41" stroke-width="1.5"/>
  <!-- Dark espresso with crema -->
  <ellipse cx="145" cy="76" rx="18" ry="2" fill="#8d6e63"/>
  <ellipse cx="145" cy="76" rx="16" ry="1.5" fill="#4e342e"/>
  <!-- Saucer -->
  <ellipse cx="145" cy="117" rx="28" ry="4" fill="#eceff1" stroke="#90a4ae" stroke-width="1"/>
  <!-- VS divider -->
  <text x="100" y="95" font-size="14" font-weight="bold" fill="#e53935" text-anchor="middle">≠</text>
  <!-- Floor -->
  <rect x="0" y="125" width="200" height="35" fill="#bcaaa4" rx="0"/>
  <!-- Label -->
  <text x="100" y="143" font-size="10" font-weight="bold" fill="#3e2723" text-anchor="middle">Americans just say "coffee"</text>
  <text x="100" y="155" font-size="8" fill="#5d4037" text-anchor="middle">— and Americano is a totally different drink</text>
</svg>

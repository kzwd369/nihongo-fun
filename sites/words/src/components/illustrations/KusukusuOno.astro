<!-- Two figures giggling with hand over mouth — クスクス (soft giggle) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Tiny sparkles / hearts in air -->
  <g fill="#f06292" opacity="0.6">
    <circle cx="30" cy="30" r="2"/>
    <circle cx="170" cy="35" r="2"/>
    <circle cx="100" cy="20" r="1.5"/>
    <circle cx="45" cy="120" r="1.5"/>
    <circle cx="160" cy="125" r="1.5"/>
  </g>
  <!-- Left face -->
  <circle cx="70" cy="85" r="38" fill="#ffe0b2"/>
  <!-- Hair left (short bob) -->
  <path d="M35 80 Q40 50 70 48 Q100 50 105 80 Q100 60 70 58 Q40 60 35 80Z" fill="#5d4037"/>
  <!-- Closed smiling eyes left -->
  <path d="M55 82 Q60 78 65 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M77 82 Q82 78 87 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <!-- Hand covering mouth left -->
  <ellipse cx="73" cy="102" rx="15" ry="10" fill="#ffccbc"/>
  <path d="M60 98 Q73 95 86 98" fill="none" stroke="#d7a990" stroke-width="1"/>
  <!-- Blush left -->
  <circle cx="52" cy="95" r="4" fill="#f48fb1" opacity="0.6"/>
  <circle cx="92" cy="95" r="4" fill="#f48fb1" opacity="0.6"/>

  <!-- Right face -->
  <circle cx="135" cy="85" r="38" fill="#ffe0b2"/>
  <!-- Hair right (long) -->
  <path d="M100 80 Q105 48 135 48 Q165 48 170 80 L170 100 Q160 85 155 90 Q135 60 115 90 Q110 85 100 100Z" fill="#6d4c41"/>
  <!-- Closed smiling eyes right -->
  <path d="M120 82 Q125 78 130 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M142 82 Q147 78 152 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <!-- Hand covering mouth right -->
  <ellipse cx="138" cy="102" rx="15" ry="10" fill="#ffccbc"/>
  <path d="M125 98 Q138 95 151 98" fill="none" stroke="#d7a990" stroke-width="1"/>
  <!-- Blush right -->
  <circle cx="117" cy="95" r="4" fill="#f48fb1" opacity="0.6"/>
  <circle cx="157" cy="95" r="4" fill="#f48fb1" opacity="0.6"/>

  <!-- クス text floating -->
  <text x="100" y="40" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="800" fill="#c2185b" opacity="0.85">クスクス</text>
  <text x="28" y="150" font-family="sans-serif" font-size="10" font-weight="700" fill="#c2185b" opacity="0.6">クス♪</text>
  <text x="145" y="150" font-family="sans-serif" font-size="10" font-weight="700" fill="#c2185b" opacity="0.6">クス♪</text>
</svg>

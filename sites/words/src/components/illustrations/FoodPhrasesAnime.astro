<!-- A bowl of rice with chopsticks and steam lines, representing Japanese food phrases -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#fff3e0" />
  <!-- Bowl -->
  <ellipse cx="100" cy="105" rx="48" ry="12" fill="#e65100" />
  <path d="M 52 105 Q 56 140 100 140 Q 144 140 148 105" fill="#ff9800" />
  <ellipse cx="100" cy="105" rx="48" ry="12" fill="#ffb74d" />
  <!-- Rice dome -->
  <path d="M 56 105 Q 58 78 100 75 Q 142 78 144 105" fill="white" />
  <ellipse cx="100" cy="105" rx="44" ry="8" fill="#fff8e1" />
  <!-- Rice grain details -->
  <ellipse cx="85" cy="95" rx="4" ry="2" fill="#f5f5f5" transform="rotate(-15 85 95)" />
  <ellipse cx="105" cy="90" rx="4" ry="2" fill="#f5f5f5" transform="rotate(10 105 90)" />
  <ellipse cx="95" cy="88" rx="3.5" ry="1.8" fill="#f5f5f5" transform="rotate(-5 95 88)" />
  <ellipse cx="115" cy="96" rx="3.5" ry="1.8" fill="#f5f5f5" transform="rotate(20 115 96)" />
  <!-- Chopsticks -->
  <line x1="120" y1="50" x2="85" y2="98" stroke="#8d6e63" stroke-width="3" stroke-linecap="round" />
  <line x1="130" y1="48" x2="105" y2="96" stroke="#8d6e63" stroke-width="3" stroke-linecap="round" />
  <!-- Steam lines -->
  <path d="M 78 68 Q 74 58 78 48" fill="none" stroke="#ffcc80" stroke-width="2" stroke-linecap="round" />
  <path d="M 100 62 Q 96 50 100 40" fill="none" stroke="#ffcc80" stroke-width="2" stroke-linecap="round" />
  <path d="M 90 65 Q 86 54 90 44" fill="none" stroke="#ffcc80" stroke-width="1.5" stroke-linecap="round" />
  <!-- Bowl decorative line -->
  <path d="M 60 118 Q 80 124 100 124 Q 120 124 140 118" fill="none" stroke="#e65100" stroke-width="1" stroke-linecap="round" />
</svg>

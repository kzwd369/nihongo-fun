<!-- Japanese アルバイト = part-time worker at a convenience store -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Store background -->
  <rect x="20" y="20" width="160" height="120" fill="#e8f5e9" rx="4"/>
  <rect x="20" y="20" width="160" height="18" fill="#43a047" rx="4"/>
  <rect x="20" y="34" width="160" height="4" fill="#43a047"/>
  <!-- Store sign -->
  <text x="100" y="34" font-size="10" fill="white" text-anchor="middle" font-family="sans-serif" font-weight="bold">KONBINI</text>
  <!-- Shelves -->
  <rect x="30" y="50" width="50" height="4" fill="#a1887f"/>
  <rect x="30" y="72" width="50" height="4" fill="#a1887f"/>
  <!-- Products on shelves -->
  <rect x="34" y="42" width="8" height="8" fill="#ef5350" rx="1"/>
  <rect x="45" y="42" width="8" height="8" fill="#42a5f5" rx="1"/>
  <rect x="56" y="42" width="8" height="8" fill="#ffca28" rx="1"/>
  <rect x="67" y="42" width="8" height="8" fill="#66bb6a" rx="1"/>
  <rect x="34" y="62" width="8" height="10" fill="#ff7043" rx="1"/>
  <rect x="45" y="64" width="8" height="8" fill="#ab47bc" rx="1"/>
  <rect x="56" y="62" width="8" height="10" fill="#26c6da" rx="1"/>
  <rect x="67" y="64" width="8" height="8" fill="#ffa726" rx="1"/>
  <!-- Counter -->
  <rect x="95" y="90" width="75" height="40" fill="#bcaaa4" rx="2"/>
  <rect x="95" y="87" width="75" height="6" fill="#8d6e63" rx="2"/>
  <!-- Cash register -->
  <rect x="140" y="76" width="20" height="14" fill="#78909c" rx="2"/>
  <rect x="143" y="79" width="14" height="5" fill="#b0bec5" rx="1"/>
  <rect x="148" y="86" width="4" height="4" fill="#546e7a"/>
  <!-- Worker - head -->
  <circle cx="120" cy="62" r="12" fill="#ffe0b2"/>
  <!-- Worker - cap -->
  <rect x="108" y="52" width="24" height="8" fill="#43a047" rx="2"/>
  <rect x="105" y="58" width="30" height="3" fill="#2e7d32" rx="1"/>
  <!-- Worker - eyes and smile -->
  <circle cx="116" cy="63" r="1.5" fill="#37474f"/>
  <circle cx="124" cy="63" r="1.5" fill="#37474f"/>
  <path d="M115 68 Q120 72 125 68" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Worker - body/apron -->
  <rect x="110" y="74" width="20" height="20" fill="#43a047" rx="2"/>
  <!-- Apron -->
  <rect x="112" y="78" width="16" height="16" fill="#c8e6c9" rx="1"/>
  <rect x="116" y="76" width="8" height="3" fill="#c8e6c9"/>
  <!-- Name tag -->
  <rect x="115" y="82" width="10" height="6" fill="white" rx="1" stroke="#43a047" stroke-width="0.5"/>
  <line x1="117" y1="84" x2="123" y2="84" stroke="#43a047" stroke-width="0.5"/>
  <line x1="117" y1="86" x2="121" y2="86" stroke="#43a047" stroke-width="0.5"/>
  <!-- Worker - arms -->
  <line x1="110" y1="78" x2="102" y2="88" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <line x1="130" y1="78" x2="138" y2="88" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <!-- Bag being handed -->
  <rect x="96" y="82" width="10" height="12" fill="white" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Floor -->
  <rect x="20" y="136" width="160" height="4" fill="#e0e0e0"/>
</svg>

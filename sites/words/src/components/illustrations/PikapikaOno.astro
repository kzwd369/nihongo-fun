<!-- Shiny diamond gem with sparkles — ピカピカ (sparkling/shiny) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e1f5fe" rx="8"/>
  <!-- Light rays from gem -->
  <g stroke="#fff59d" stroke-width="1" opacity="0.5">
    <line x1="100" y1="80" x2="100" y2="10"/>
    <line x1="100" y1="80" x2="100" y2="150"/>
    <line x1="100" y1="80" x2="20" y2="80"/>
    <line x1="100" y1="80" x2="180" y2="80"/>
    <line x1="100" y1="80" x2="40" y2="20"/>
    <line x1="100" y1="80" x2="160" y2="20"/>
    <line x1="100" y1="80" x2="40" y2="140"/>
    <line x1="100" y1="80" x2="160" y2="140"/>
  </g>
  <!-- Diamond/gem outer glow -->
  <polygon points="100,30 145,75 100,135 55,75" fill="#81d4fa" opacity="0.4"/>
  <!-- Diamond main -->
  <polygon points="100,40 138,75 100,128 62,75" fill="#4fc3f7"/>
  <!-- Diamond facets -->
  <polygon points="100,40 122,60 100,75 78,60" fill="#81d4fa"/>
  <polygon points="100,40 78,60 62,75 100,40" fill="#b3e5fc"/>
  <polygon points="100,40 122,60 138,75 100,40" fill="#29b6f6"/>
  <polygon points="62,75 100,75 100,128" fill="#039be5"/>
  <polygon points="138,75 100,75 100,128" fill="#0288d1"/>
  <!-- Highlight -->
  <polygon points="85,52 95,48 90,68 80,62" fill="white" opacity="0.8"/>
  <!-- Sparkle stars -->
  <g fill="#fff176">
    <polygon points="40,35 43,42 50,45 43,48 40,55 37,48 30,45 37,42"/>
    <polygon points="160,40 163,47 170,50 163,53 160,60 157,53 150,50 157,47"/>
    <polygon points="35,115 38,121 44,123 38,125 35,131 32,125 26,123 32,121"/>
    <polygon points="165,120 167,125 172,127 167,129 165,134 163,129 158,127 163,125"/>
  </g>
  <circle cx="40" cy="45" r="1.5" fill="white"/>
  <circle cx="160" cy="50" r="1.5" fill="white"/>
  <!-- Tiny sparkle dots -->
  <circle cx="65" cy="25" r="2" fill="#fff176" opacity="0.8"/>
  <circle cx="135" cy="25" r="2" fill="#fff176" opacity="0.8"/>
  <circle cx="60" cy="140" r="2" fill="#fff176" opacity="0.7"/>
  <circle cx="140" cy="140" r="2" fill="#fff176" opacity="0.7"/>
  <text x="15" y="78" font-size="10" fill="#fbc02d" opacity="0.7">✦</text>
  <text x="178" y="78" font-size="10" fill="#fbc02d" opacity="0.7">✦</text>
</svg>

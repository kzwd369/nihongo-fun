<!-- Angry face with vein mark — イライラ (irritated) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#ffebee" rx="8"/>
  <!-- Heat/anger lines top -->
  <path d="M50 18 L48 30 M55 14 L55 28 M62 18 L64 30" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <path d="M138 18 L140 30 M145 14 L145 28 M152 18 L150 30" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <!-- Head -->
  <circle cx="100" cy="85" r="42" fill="#fce4d6"/>
  <!-- Hair -->
  <path d="M60 75 Q65 42 100 40 Q135 42 140 75 Q135 58 100 55 Q65 58 60 75Z" fill="#5d4037"/>
  <!-- Anger vein mark (popping vein symbol — 怒りマーク) -->
  <g transform="translate(140, 55)">
    <path d="M0 0 L8 -6 L4 0 L10 0 L2 8 L6 0 L0 0Z M-8 -2 L-2 -8 L-4 -2 L2 -10 L-4 -4 L-10 -2 L-8 -2Z"
          fill="#d32f2f" stroke="#b71c1c" stroke-width="0.5"/>
    <circle cx="0" cy="0" r="3" fill="#d32f2f"/>
  </g>
  <!-- Angled angry eyebrows -->
  <path d="M75 73 L92 78" stroke="#3e2723" stroke-width="4" stroke-linecap="round"/>
  <path d="M125 73 L108 78" stroke="#3e2723" stroke-width="4" stroke-linecap="round"/>
  <!-- Eyes (sharp) -->
  <ellipse cx="85" cy="88" rx="4" ry="3" fill="#3e2723"/>
  <ellipse cx="115" cy="88" rx="4" ry="3" fill="#3e2723"/>
  <!-- Frown mouth -->
  <path d="M85 110 Q100 100 115 110" fill="none" stroke="#5d4037" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Red cheeks -->
  <ellipse cx="78" cy="100" rx="7" ry="4" fill="#ef5350" opacity="0.5"/>
  <ellipse cx="122" cy="100" rx="7" ry="4" fill="#ef5350" opacity="0.5"/>
  <!-- Sharp side action lines -->
  <line x1="20" y1="80" x2="35" y2="80" stroke="#e53935" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
  <line x1="22" y1="95" x2="34" y2="95" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="165" y1="80" x2="180" y2="80" stroke="#e53935" stroke-width="3" stroke-linecap="round" opacity="0.7"/>
  <line x1="166" y1="95" x2="178" y2="95" stroke="#e53935" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <!-- Spark zigzags -->
  <polyline points="30,135 35,128 40,135 45,128 50,135" fill="none" stroke="#ff5252" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <polyline points="150,135 155,128 160,135 165,128 170,135" fill="none" stroke="#ff5252" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
</svg>

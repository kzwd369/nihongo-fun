<!-- フリーター = young person working various part-time jobs (convenience store, cafe) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Background: split scene showing different jobs -->
  <!-- Left side: convenience store -->
  <rect x="10" y="15" width="85" height="105" fill="#e8f5e9" rx="4"/>
  <rect x="10" y="15" width="85" height="15" fill="#43a047" rx="4"/>
  <rect x="10" y="26" width="85" height="4" fill="#43a047"/>
  <text x="52" y="27" font-size="7" fill="white" text-anchor="middle" font-family="sans-serif" font-weight="bold">KONBINI</text>
  <!-- Store shelves -->
  <rect x="16" y="38" width="35" height="3" fill="#a1887f"/>
  <rect x="18" y="30" width="7" height="8" fill="#ef5350" rx="1"/>
  <rect x="27" y="30" width="7" height="8" fill="#42a5f5" rx="1"/>
  <rect x="36" y="30" width="7" height="8" fill="#ffca28" rx="1"/>
  <!-- Cash register -->
  <rect x="60" y="55" width="18" height="12" fill="#78909c" rx="2"/>
  <rect x="63" y="57" width="12" height="5" fill="#b0bec5" rx="1"/>
  <!-- Counter -->
  <rect x="55" y="67" width="35" height="30" fill="#bcaaa4" rx="2"/>
  <rect x="55" y="65" width="35" height="4" fill="#8d6e63" rx="1"/>
  <!-- Right side: cafe -->
  <rect x="105" y="15" width="85" height="105" fill="#fff3e0" rx="4"/>
  <rect x="105" y="15" width="85" height="15" fill="#e65100" rx="4"/>
  <rect x="105" y="26" width="85" height="4" fill="#e65100"/>
  <text x="147" y="27" font-size="7" fill="white" text-anchor="middle" font-family="sans-serif" font-weight="bold">CAFE</text>
  <!-- Coffee machine -->
  <rect x="155" y="40" width="20" height="25" fill="#795548" rx="2"/>
  <circle cx="165" cy="48" r="4" fill="#5d4037"/>
  <rect x="158" y="60" width="14" height="3" fill="#6d4c41"/>
  <!-- Coffee cup -->
  <rect x="160" y="63" width="10" height="8" fill="white" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <path d="M170 65 Q174 67 170 71" fill="none" stroke="#bdbdbd" stroke-width="0.8"/>
  <!-- Center: the freeter person -->
  <!-- Head -->
  <circle cx="100" cy="62" r="14" fill="#ffe0b2"/>
  <!-- Messy casual hair -->
  <path d="M86 58 Q88 44 100 42 Q112 44 114 58" fill="#5d4037"/>
  <path d="M88 52 Q85 48 88 46" fill="#5d4037"/>
  <path d="M112 52 Q115 48 112 46" fill="#5d4037"/>
  <!-- Eyes -->
  <circle cx="95" cy="63" r="1.5" fill="#37474f"/>
  <circle cx="105" cy="63" r="1.5" fill="#37474f"/>
  <!-- Slight uncertain smile -->
  <path d="M95 70 Q100 73 105 70" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Body with apron (convenience store side) -->
  <rect x="88" y="76" width="24" height="28" fill="#66bb6a" rx="2"/>
  <!-- Apron -->
  <rect x="90" y="80" width="20" height="24" fill="#c8e6c9" rx="1"/>
  <rect x="95" y="77" width="10" height="4" fill="#c8e6c9"/>
  <!-- Name tag -->
  <rect x="94" y="85" width="12" height="7" fill="white" rx="1" stroke="#66bb6a" stroke-width="0.5"/>
  <line x1="96" y1="87" x2="104" y2="87" stroke="#66bb6a" stroke-width="0.5"/>
  <line x1="96" y1="89.5" x2="101" y2="89.5" stroke="#66bb6a" stroke-width="0.5"/>
  <!-- Arms -->
  <line x1="88" y1="82" x2="76" y2="92" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <line x1="112" y1="82" x2="124" y2="92" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <!-- Arrows suggesting job hopping -->
  <path d="M35 125 Q50 135 65 125" fill="none" stroke="#78909c" stroke-width="1.5" stroke-linecap="round" marker-end="url(#arrowhead)"/>
  <path d="M135 125 Q150 135 165 125" fill="none" stroke="#78909c" stroke-width="1.5" stroke-linecap="round" marker-end="url(#arrowhead)"/>
  <defs>
    <marker id="arrowhead" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
      <polygon points="0 0, 6 2, 0 4" fill="#78909c"/>
    </marker>
  </defs>
  <!-- Job labels -->
  <text x="52" y="145" font-size="6" fill="#43a047" text-anchor="middle" font-family="sans-serif">コンビニ</text>
  <text x="147" y="145" font-size="6" fill="#e65100" text-anchor="middle" font-family="sans-serif">カフェ</text>
  <text x="100" y="152" font-size="7" fill="#5d4037" text-anchor="middle" font-family="sans-serif" font-weight="bold">フリーター</text>
</svg>

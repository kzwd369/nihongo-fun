<!-- エアコン = wall-mounted air conditioning unit with cool air flowing -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Wall background -->
  <rect x="10" y="10" width="180" height="140" fill="#fafafa" rx="4"/>
  <!-- Wall texture lines -->
  <line x1="10" y1="50" x2="190" y2="50" stroke="#f5f5f5" stroke-width="0.5"/>
  <line x1="10" y1="90" x2="190" y2="90" stroke="#f5f5f5" stroke-width="0.5"/>
  <!-- AC Unit body -->
  <rect x="35" y="25" width="130" height="40" fill="white" rx="6" stroke="#e0e0e0" stroke-width="1.5"/>
  <!-- AC Unit top detail -->
  <rect x="40" y="27" width="120" height="6" fill="#f5f5f5" rx="2"/>
  <!-- AC vent slats -->
  <rect x="42" y="45" width="116" height="2" fill="#e0e0e0" rx="1"/>
  <rect x="42" y="50" width="116" height="2" fill="#e0e0e0" rx="1"/>
  <rect x="42" y="55" width="116" height="2" fill="#e0e0e0" rx="1"/>
  <!-- AC display/indicator -->
  <circle cx="155" cy="36" r="3" fill="#4caf50"/>
  <rect x="48" y="34" width="18" height="8" fill="#e3f2fd" rx="2"/>
  <text x="57" y="41" font-size="6" fill="#1565c0" text-anchor="middle" font-family="monospace">24°</text>
  <!-- Brand logo area -->
  <rect x="80" y="34" width="30" height="6" fill="#f5f5f5" rx="2"/>
  <!-- Cool air flowing down - wave lines -->
  <path d="M55 70 Q65 76 75 70 Q85 64 95 70" fill="none" stroke="#90caf9" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
  <path d="M65 80 Q75 86 85 80 Q95 74 105 80" fill="none" stroke="#90caf9" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <path d="M75 90 Q85 96 95 90 Q105 84 115 90" fill="none" stroke="#90caf9" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
  <path d="M105 70 Q115 76 125 70 Q135 64 145 70" fill="none" stroke="#90caf9" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
  <path d="M115 80 Q125 86 135 80 Q145 74 155 80" fill="none" stroke="#90caf9" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <!-- Snowflake symbols for cold air -->
  <text x="60" y="100" font-size="10" fill="#90caf9" opacity="0.5">❄</text>
  <text x="95" y="108" font-size="8" fill="#90caf9" opacity="0.4">❄</text>
  <text x="130" y="100" font-size="10" fill="#90caf9" opacity="0.5">❄</text>
  <!-- Remote control -->
  <rect x="150" y="110" width="22" height="36" fill="#eceff1" rx="3" stroke="#bdbdbd" stroke-width="0.8"/>
  <circle cx="161" cy="120" r="4" fill="#e0e0e0" stroke="#bdbdbd" stroke-width="0.5"/>
  <rect x="155" y="128" width="12" height="4" fill="#e0e0e0" rx="1"/>
  <rect x="155" y="134" width="5" height="4" fill="#bbdefb" rx="1"/>
  <rect x="162" y="134" width="5" height="4" fill="#ffcdd2" rx="1"/>
  <!-- リモコン label -->
  <text x="161" y="150" font-size="5" fill="#78909c" text-anchor="middle" font-family="sans-serif">リモコン</text>
</svg>

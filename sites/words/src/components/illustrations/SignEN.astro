<!-- English sign = road sign / shop signboard -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Sky gradient background -->
  <rect x="10" y="10" width="180" height="140" fill="#e3f2fd" rx="4"/>
  <!-- Ground -->
  <rect x="10" y="120" width="180" height="30" fill="#c8e6c9" rx="0"/>
  <!-- Road sign post -->
  <rect x="55" y="40" width="4" height="110" fill="#78909c"/>
  <!-- Road sign - stop sign shape -->
  <polygon points="57,15 42,22 35,37 42,52 57,58 72,52 78,37 72,22" fill="#e53935" stroke="#c62828" stroke-width="1"/>
  <text x="57" y="40" font-size="10" fill="white" text-anchor="middle" font-family="sans-serif" font-weight="bold">STOP</text>
  <!-- Shop signboard -->
  <rect x="110" y="25" width="70" height="35" fill="#fff9c4" rx="3" stroke="#f9a825" stroke-width="1.5"/>
  <!-- Sign hanging chains -->
  <line x1="120" y1="15" x2="120" y2="25" stroke="#78909c" stroke-width="1.5"/>
  <line x1="170" y1="15" x2="170" y2="25" stroke="#78909c" stroke-width="1.5"/>
  <!-- Bracket on wall -->
  <rect x="118" y="12" width="54" height="4" fill="#78909c" rx="1"/>
  <!-- Shop sign text -->
  <text x="145" y="40" font-size="9" fill="#e65100" text-anchor="middle" font-family="sans-serif" font-weight="bold">CAFE</text>
  <text x="145" y="52" font-size="7" fill="#bf360c" text-anchor="middle" font-family="sans-serif">OPEN</text>
  <!-- Arrow direction sign -->
  <polygon points="20,85 85,85 95,92 85,99 20,99" fill="#1565c0"/>
  <rect x="20" y="85" width="4" height="14" fill="#0d47a1"/>
  <text x="50" y="95" font-size="8" fill="white" font-family="sans-serif" font-weight="bold">STATION →</text>
  <!-- Sign post for arrow -->
  <rect x="18" y="85" width="4" height="65" fill="#78909c"/>
  <!-- Small flowers on ground -->
  <circle cx="100" cy="130" r="3" fill="#f48fb1"/>
  <circle cx="140" cy="135" r="2.5" fill="#f48fb1"/>
  <circle cx="160" cy="128" r="3" fill="#ce93d8"/>
  <!-- Grass tufts -->
  <path d="M30 120 L33 112 L36 120" fill="#66bb6a"/>
  <path d="M80 120 L83 113 L86 120" fill="#66bb6a"/>
  <path d="M130 120 L132 114 L135 120" fill="#66bb6a"/>
</svg>

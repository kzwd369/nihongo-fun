<!-- Face with puffed cheeks chewing food — もぐもぐ (munching) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Little food sparkles -->
  <circle cx="30" cy="30" r="2" fill="#ffb74d" opacity="0.7"/>
  <circle cx="170" cy="25" r="2.5" fill="#ff9800" opacity="0.6"/>
  <circle cx="25" cy="130" r="2" fill="#ffb74d" opacity="0.6"/>
  <!-- Head -->
  <circle cx="100" cy="82" r="42" fill="#ffe0b2"/>
  <!-- Puffed cheeks (slightly bigger bumps on sides) -->
  <ellipse cx="64" cy="92" rx="10" ry="12" fill="#ffe0b2"/>
  <ellipse cx="136" cy="92" rx="10" ry="12" fill="#ffe0b2"/>
  <!-- Hair -->
  <path d="M62 70 Q70 40 100 38 Q130 40 138 70 Q130 54 100 52 Q70 54 62 70Z" fill="#6d4c41"/>
  <!-- Happy closed curved eyes -->
  <path d="M78 82 Q86 76 94 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M106 82 Q114 76 122 82" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <!-- Closed mouth chewing -->
  <path d="M90 102 Q100 108 110 102" fill="none" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Blush -->
  <ellipse cx="72" cy="100" rx="6" ry="3" fill="#f8bbd0" opacity="0.7"/>
  <ellipse cx="128" cy="100" rx="6" ry="3" fill="#f8bbd0" opacity="0.7"/>
  <!-- Motion wiggle around cheeks -->
  <path d="M46 92 Q40 88 44 82" fill="none" stroke="#ff9800" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
  <path d="M46 100 Q40 104 44 110" fill="none" stroke="#ff9800" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <path d="M154 92 Q160 88 156 82" fill="none" stroke="#ff9800" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
  <path d="M154 100 Q160 104 156 110" fill="none" stroke="#ff9800" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <!-- Rice ball at side -->
  <g transform="translate(150,110)">
    <path d="M0 20 L15 0 L30 20 Z" fill="#ffffff" stroke="#e0e0e0" stroke-width="1"/>
    <rect x="4" y="16" width="22" height="6" fill="#424242"/>
  </g>
  <!-- Crumb sparkles near mouth -->
  <circle cx="118" cy="110" r="1.5" fill="#ff9800" opacity="0.7"/>
  <circle cx="82" cy="110" r="1.5" fill="#ff9800" opacity="0.7"/>
</svg>

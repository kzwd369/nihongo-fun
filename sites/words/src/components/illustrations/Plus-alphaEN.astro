<!-- English: α only lives in math/physics — never in everyday business idiom -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f3e5f5" rx="8"/>
  <!-- Blackboard / chalkboard with math equations -->
  <rect x="15" y="20" width="170" height="80" fill="#1b5e20" stroke="#3e2723" stroke-width="3" rx="2"/>
  <!-- Chalk equations (alpha is here in math context) -->
  <text x="30" y="40" font-size="14" fill="#fff" font-family="serif">α = ½v²</text>
  <text x="100" y="40" font-size="11" fill="#fff" font-family="serif">F = mα</text>
  <text x="155" y="40" font-size="13" fill="#fffde7" font-family="serif">α + β</text>
  <text x="30" y="62" font-size="11" fill="#fff" font-family="serif">∫α dx = αx + C</text>
  <text x="120" y="62" font-size="11" fill="#fffde7" font-family="serif">α-particle</text>
  <text x="30" y="84" font-size="10" fill="#fffde7" font-family="serif">alpha returns (finance)</text>
  <text x="135" y="84" font-size="10" fill="#fff" font-family="serif">α decay</text>
  <!-- Chalk drawn arrow -->
  <path d="M50 92 L80 92" stroke="#fff" stroke-width="1" stroke-dasharray="2,2"/>
  <text x="65" y="98" font-size="6" fill="#fff" text-anchor="middle">math/physics ONLY</text>
  <!-- Confused businessman in suit -->
  <circle cx="40" cy="125" r="9" fill="#ffcc80"/>
  <path d="M32 121 Q40 114 48 121" fill="#5d4037"/>
  <line x1="36" y1="125" x2="39" y2="127" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="44" y1="125" x2="41" y2="127" stroke="#5d4037" stroke-width="1.5"/>
  <path d="M37 130 Q40 132 43 130" fill="none" stroke="#5d4037" stroke-width="0.8"/>
  <!-- Suit -->
  <path d="M30 134 L50 134 L52 155 L28 155 Z" fill="#37474f"/>
  <polygon points="36,134 40,140 44,134" fill="#fff"/>
  <line x1="40" y1="140" x2="40" y2="155" stroke="#c62828" stroke-width="1"/>
  <!-- Speech bubble: confused -->
  <path d="M55 115 L65 110 Q140 110 140 130 Q140 145 65 145 L60 150 Z" fill="#fff" stroke="#5d4037" stroke-width="1.5"/>
  <text x="100" y="124" font-size="7" fill="#5d4037" text-anchor="middle">"$25,000 plus alpha"?</text>
  <text x="100" y="133" font-size="6" font-style="italic" fill="#5d4037" text-anchor="middle">— sounds like half a physics equation</text>
  <!-- Native equivalents -->
  <rect x="145" y="115" width="50" height="40" fill="#c8e6c9" stroke="#2e7d32" stroke-width="1" rx="2"/>
  <text x="170" y="123" font-size="6" font-weight="bold" fill="#1b5e20" text-anchor="middle">Say instead:</text>
  <text x="170" y="131" font-size="5" fill="#1b5e20" text-anchor="middle">"plus a little extra"</text>
  <text x="170" y="138" font-size="5" fill="#1b5e20" text-anchor="middle">"plus bonuses"</text>
  <text x="170" y="145" font-size="5" fill="#1b5e20" text-anchor="middle">"and then some"</text>
  <text x="170" y="152" font-size="5" fill="#1b5e20" text-anchor="middle">"the X factor"</text>
  <!-- Label -->
  <text x="100" y="14" font-size="10" font-weight="bold" fill="#4a148c" text-anchor="middle">English: α stays in the lab</text>
</svg>

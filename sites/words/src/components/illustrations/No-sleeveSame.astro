<!-- ノースリーブ = sleeveless top -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hanger hook -->
  <path d="M100 18 Q100 10 105 10 Q110 10 110 16" fill="none" stroke="#90a4ae" stroke-width="2" stroke-linecap="round"/>
  <!-- Hanger bar -->
  <path d="M65 35 L100 18 L135 35" fill="none" stroke="#90a4ae" stroke-width="2.5" stroke-linejoin="round"/>
  <line x1="65" y1="35" x2="135" y2="35" stroke="#90a4ae" stroke-width="2"/>
  <!-- Tank top body -->
  <!-- Strap left -->
  <path d="M75 38 L70 50 L70 60 L78 58 Z" fill="#f48fb1" stroke="#c2185b" stroke-width="0.8"/>
  <!-- Strap right -->
  <path d="M125 38 L130 50 L130 60 L122 58 Z" fill="#f48fb1" stroke="#c2185b" stroke-width="0.8"/>
  <!-- Body main -->
  <path d="M70 60 L130 60 L138 140 L62 140 Z" fill="#f48fb1" stroke="#c2185b" stroke-width="1.2"/>
  <!-- Neckline (V-cut) -->
  <path d="M78 58 Q100 78 122 58 L122 60 Q100 80 78 60 Z" fill="#f0f7ff"/>
  <!-- Shoulder cutouts (where sleeves would be) -->
  <path d="M70 60 Q60 70 62 90 L70 75 Z" fill="#f0f7ff"/>
  <path d="M130 60 Q140 70 138 90 L130 75 Z" fill="#f0f7ff"/>
  <!-- Trim along armhole -->
  <path d="M70 60 Q60 70 62 90" fill="none" stroke="#c2185b" stroke-width="1.2"/>
  <path d="M130 60 Q140 70 138 90" fill="none" stroke="#c2185b" stroke-width="1.2"/>
  <!-- Subtle fabric folds -->
  <path d="M85 95 Q90 115 88 138" fill="none" stroke="#ec407a" stroke-width="0.8" opacity="0.6"/>
  <path d="M100 95 Q102 118 100 138" fill="none" stroke="#ec407a" stroke-width="0.8" opacity="0.6"/>
  <path d="M115 95 Q110 115 112 138" fill="none" stroke="#ec407a" stroke-width="0.8" opacity="0.6"/>
  <!-- Hem stitching -->
  <line x1="62" y1="138" x2="138" y2="138" stroke="#fce4ec" stroke-width="0.8" stroke-dasharray="2 2"/>
  <!-- Decorative bow at neckline -->
  <circle cx="100" cy="68" r="2.5" fill="#fce4ec"/>
  <path d="M97 68 L93 64 L93 72 Z" fill="#fce4ec"/>
  <path d="M103 68 L107 64 L107 72 Z" fill="#fce4ec"/>
  <!-- Sparkle -->
  <text x="40" y="55" font-size="9" fill="#f8bbd0" opacity="0.7">✦</text>
  <text x="160" y="80" font-size="8" fill="#f8bbd0" opacity="0.6">✦</text>
</svg>

<!-- ソフトクリーム = soft-serve ice cream cone -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Soft serve swirl (vanilla) - stacked ellipses going up to a point -->
  <!-- Cone (waffle) -->
  <polygon points="80,90 120,90 100,148" fill="#d7a86e" stroke="#8d6e63" stroke-width="1.2"/>
  <!-- Cone waffle pattern -->
  <line x1="86" y1="100" x2="114" y2="100" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="89" y1="110" x2="111" y2="110" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="92" y1="120" x2="108" y2="120" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="95" y1="130" x2="105" y2="130" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="89" y1="92" x2="95" y2="142" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="100" y1="92" x2="100" y2="148" stroke="#8d6e63" stroke-width="0.6"/>
  <line x1="111" y1="92" x2="105" y2="142" stroke="#8d6e63" stroke-width="0.6"/>
  <!-- Soft serve base layer -->
  <ellipse cx="100" cy="90" rx="28" ry="8" fill="#fffde7" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Layer 2 -->
  <ellipse cx="100" cy="80" rx="26" ry="7" fill="#fffde7" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Layer 3 -->
  <ellipse cx="100" cy="71" rx="22" ry="6" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Layer 4 -->
  <ellipse cx="100" cy="62" rx="18" ry="5" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Layer 5 -->
  <ellipse cx="100" cy="54" rx="14" ry="4" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Layer 6 -->
  <ellipse cx="100" cy="47" rx="10" ry="3" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Tip -->
  <ellipse cx="100" cy="42" rx="6" ry="2.5" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <path d="M100 35 Q103 38 100 42 Q97 38 100 35 Z" fill="white" stroke="#fff59d" stroke-width="0.8"/>
  <!-- Drip down side -->
  <path d="M125 90 Q130 100 127 110 Q124 105 122 95 Z" fill="white" stroke="#fff59d" stroke-width="0.6"/>
  <path d="M75 88 Q72 96 75 102 Q78 95 78 90 Z" fill="white" stroke="#fff59d" stroke-width="0.6"/>
  <!-- Highlight on swirl -->
  <ellipse cx="92" cy="60" rx="2.5" ry="6" fill="#fffde7" opacity="0.8"/>
  <!-- Sparkle -->
  <text x="40" y="50" font-size="11" fill="#ffd54f" opacity="0.7">✦</text>
  <text x="155" y="40" font-size="9" fill="#ffd54f" opacity="0.6">✦</text>
  <text x="160" y="70" font-size="7" fill="#ffd54f" opacity="0.5">✦</text>
</svg>

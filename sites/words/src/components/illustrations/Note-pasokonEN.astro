<!-- English literal meaning: "note" (notepad) + "personal computer" (desktop PC) = nonsense! -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Left side: Notepad / paper notebook -->
  <rect x="15" y="30" width="60" height="80" fill="#fff9c4" rx="2" stroke="#f9a825" stroke-width="1"/>
  <!-- Notepad spiral binding -->
  <circle cx="20" cy="35" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="45" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="55" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="65" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="75" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="85" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="95" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <circle cx="20" cy="105" r="2.5" fill="none" stroke="#bdbdbd" stroke-width="1"/>
  <!-- Notepad lines -->
  <line x1="28" y1="42" x2="70" y2="42" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="50" x2="70" y2="50" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="58" x2="70" y2="58" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="66" x2="70" y2="66" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="74" x2="70" y2="74" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="82" x2="70" y2="82" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="90" x2="70" y2="90" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="28" y1="98" x2="70" y2="98" stroke="#e0e0e0" stroke-width="0.5"/>
  <!-- Handwriting scribbles on notepad -->
  <rect x="30" y="44" width="25" height="3" fill="#42a5f5" rx="1" opacity="0.6"/>
  <rect x="30" y="52" width="35" height="3" fill="#42a5f5" rx="1" opacity="0.6"/>
  <rect x="30" y="60" width="20" height="3" fill="#42a5f5" rx="1" opacity="0.6"/>
  <!-- Label: NOTE -->
  <text x="45" y="125" text-anchor="middle" font-size="11" font-family="sans-serif" fill="#f57f17" font-weight="bold">NOTE</text>
  <!-- Plus sign -->
  <text x="100" y="78" text-anchor="middle" font-size="24" font-family="sans-serif" fill="#90a4ae" font-weight="bold">+</text>
  <!-- Right side: Desktop PC tower -->
  <rect x="120" y="30" width="35" height="70" fill="#78909c" rx="3" stroke="#546e7a" stroke-width="1"/>
  <!-- PC front panel -->
  <rect x="125" y="36" width="25" height="8" fill="#546e7a" rx="1"/>
  <rect x="125" y="48" width="25" height="4" fill="#455a64" rx="1"/>
  <!-- Power button -->
  <circle cx="137" cy="58" r="3" fill="#455a64" stroke="#37474f" stroke-width="0.5"/>
  <circle cx="137" cy="58" r="1.5" fill="#66bb6a"/>
  <!-- Drive bays -->
  <line x1="125" y1="65" x2="150" y2="65" stroke="#546e7a" stroke-width="0.5"/>
  <line x1="125" y1="72" x2="150" y2="72" stroke="#546e7a" stroke-width="0.5"/>
  <!-- USB ports -->
  <rect x="128" y="85" width="6" height="3" fill="#455a64" rx="0.5"/>
  <rect x="138" y="85" width="6" height="3" fill="#455a64" rx="0.5"/>
  <!-- Ventilation grille -->
  <line x1="125" y1="92" x2="150" y2="92" stroke="#546e7a" stroke-width="0.5"/>
  <line x1="125" y1="94" x2="150" y2="94" stroke="#546e7a" stroke-width="0.5"/>
  <line x1="125" y1="96" x2="150" y2="96" stroke="#546e7a" stroke-width="0.5"/>
  <!-- Label: PASOKON -->
  <text x="137" y="125" text-anchor="middle" font-size="9" font-family="sans-serif" fill="#455a64" font-weight="bold">PASOKON</text>
  <!-- Question mark / confusion -->
  <text x="100" y="148" text-anchor="middle" font-size="13" font-family="sans-serif" fill="#e53935" font-weight="bold">= laptop ???</text>
</svg>

<!-- English Consent = permission / agreement document -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Document / form -->
  <rect x="45" y="10" width="110" height="140" fill="white" rx="3" stroke="#ccc" stroke-width="1.5"/>
  <!-- Header line -->
  <rect x="65" y="20" width="70" height="6" fill="#555" rx="2"/>
  <!-- Body text lines -->
  <rect x="55" y="35" width="90" height="3" fill="#bbb" rx="1"/>
  <rect x="55" y="43" width="85" height="3" fill="#bbb" rx="1"/>
  <rect x="55" y="51" width="90" height="3" fill="#bbb" rx="1"/>
  <rect x="55" y="59" width="70" height="3" fill="#bbb" rx="1"/>
  <!-- More text lines -->
  <rect x="55" y="72" width="90" height="3" fill="#bbb" rx="1"/>
  <rect x="55" y="80" width="80" height="3" fill="#bbb" rx="1"/>
  <!-- Checkbox -->
  <rect x="58" y="92" width="12" height="12" fill="white" rx="2" stroke="#555" stroke-width="1.5"/>
  <!-- Checkmark -->
  <polyline points="61,98 64,102 68,95" fill="none" stroke="#4caf50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Checkbox label -->
  <rect x="75" y="96" width="65" height="3" fill="#888" rx="1"/>
  <!-- Signature line -->
  <line x1="58" y1="125" x2="140" y2="125" stroke="#555" stroke-width="1"/>
  <!-- Signature scribble -->
  <path d="M65,122 Q72,112 80,120 Q88,128 95,118 Q100,113 108,120" fill="none" stroke="#1a237e" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Signature label -->
  <text x="99" y="135" text-anchor="middle" font-size="7" fill="#888" font-family="sans-serif">Signature</text>
  <!-- Label -->
  <text x="100" y="155" text-anchor="middle" font-size="11" fill="#555" font-family="sans-serif">Consent</text>
</svg>

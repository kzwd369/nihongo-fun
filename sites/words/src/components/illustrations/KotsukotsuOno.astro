<!-- Stack of coins growing — コツコツ (steady persistent effort) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f2f1" rx="8"/>
  <!-- Calendar/checkmark grid in background -->
  <g opacity="0.25">
    <rect x="20" y="20" width="14" height="14" fill="#80cbc4" rx="2"/>
    <rect x="38" y="20" width="14" height="14" fill="#80cbc4" rx="2"/>
    <rect x="56" y="20" width="14" height="14" fill="#80cbc4" rx="2"/>
    <rect x="20" y="38" width="14" height="14" fill="#80cbc4" rx="2"/>
    <rect x="38" y="38" width="14" height="14" fill="#80cbc4" rx="2"/>
  </g>
  <!-- Ground line -->
  <line x1="20" y1="140" x2="180" y2="140" stroke="#26a69a" stroke-width="2"/>
  <!-- Coin stack rising left to right -->
  <g>
    <!-- Stack 1 - 1 coin -->
    <ellipse cx="55" cy="135" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <!-- Stack 2 - 2 coins -->
    <ellipse cx="90" cy="135" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="90" cy="128" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <!-- Stack 3 - 4 coins -->
    <ellipse cx="125" cy="135" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="125" cy="128" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="125" cy="121" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="125" cy="114" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <!-- Stack 4 - 7 coins -->
    <ellipse cx="160" cy="135" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="128" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="121" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="114" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="107" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="100" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
    <ellipse cx="160" cy="93" rx="14" ry="4" fill="#ffd54f" stroke="#f57f17" stroke-width="1"/>
  </g>
  <!-- Upward trend arrow -->
  <path d="M50 110 L100 95 L155 70" fill="none" stroke="#00897b" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="4 3"/>
  <polygon points="155,70 148,68 152,77" fill="#00897b"/>
</svg>

<!-- Silent snow falling at night — しんしん (silently, snow falling quietly) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <!-- Night gradient sky -->
  <rect width="200" height="160" fill="url(#skyGrad)" rx="8"/>
  <!-- Moon -->
  <circle cx="155" cy="35" r="14" fill="#fffde7" opacity="0.9"/>
  <circle cx="151" cy="33" r="10" fill="#fff9c4" opacity="0.5"/>
  <!-- Snow-covered ground -->
  <path d="M0 130 Q50 120 100 125 Q150 128 200 120 L200 160 L0 160 Z" fill="#ffffff" opacity="0.95"/>
  <path d="M0 130 Q50 120 100 125 Q150 128 200 120" fill="none" stroke="#e1f5fe" stroke-width="1.5"/>
  <!-- Bare tree silhouette -->
  <g stroke="#3e2723" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.85">
    <line x1="40" y1="130" x2="40" y2="85"/>
    <line x1="40" y1="105" x2="28" y2="92"/>
    <line x1="40" y1="100" x2="52" y2="88"/>
    <line x1="40" y1="95" x2="30" y2="82"/>
    <line x1="40" y1="90" x2="50" y2="78"/>
    <line x1="28" y1="92" x2="22" y2="85"/>
    <line x1="52" y1="88" x2="58" y2="80"/>
  </g>
  <!-- Snow caps on branches -->
  <circle cx="28" cy="92" r="2" fill="white"/>
  <circle cx="52" cy="88" r="2" fill="white"/>
  <circle cx="40" cy="85" r="2.5" fill="white"/>
  <!-- Snowflakes falling (large/small, various opacities) -->
  <circle cx="25" cy="25" r="3" fill="white" opacity="0.95"/>
  <circle cx="60" cy="40" r="2" fill="white" opacity="0.85"/>
  <circle cx="90" cy="20" r="2.5" fill="white" opacity="0.9"/>
  <circle cx="115" cy="55" r="3" fill="white" opacity="0.95"/>
  <circle cx="75" cy="70" r="2" fill="white" opacity="0.8"/>
  <circle cx="100" cy="85" r="2.5" fill="white" opacity="0.85"/>
  <circle cx="130" cy="75" r="2" fill="white" opacity="0.8"/>
  <circle cx="170" cy="70" r="2.5" fill="white" opacity="0.9"/>
  <circle cx="185" cy="95" r="2" fill="white" opacity="0.8"/>
  <circle cx="15" cy="65" r="2" fill="white" opacity="0.8"/>
  <circle cx="45" cy="110" r="1.8" fill="white" opacity="0.7"/>
  <circle cx="80" cy="108" r="1.5" fill="white" opacity="0.7"/>
  <circle cx="125" cy="105" r="1.8" fill="white" opacity="0.7"/>
  <circle cx="160" cy="110" r="1.5" fill="white" opacity="0.7"/>
  <circle cx="50" cy="50" r="1.5" fill="white" opacity="0.6"/>
  <circle cx="145" cy="40" r="1.5" fill="white" opacity="0.6"/>
  <!-- Snowflake shapes (a couple) -->
  <g stroke="white" stroke-width="1" opacity="0.85">
    <line x1="65" y1="85" x2="65" y2="95"/>
    <line x1="60" y1="90" x2="70" y2="90"/>
    <line x1="62" y1="87" x2="68" y2="93"/>
    <line x1="62" y1="93" x2="68" y2="87"/>
  </g>
  <g stroke="white" stroke-width="1" opacity="0.85">
    <line x1="150" y1="100" x2="150" y2="110"/>
    <line x1="145" y1="105" x2="155" y2="105"/>
  </g>
  <defs>
    <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#283593"/>
      <stop offset="100%" stop-color="#5c6bc0"/>
    </linearGradient>
  </defs>
</svg>

<!-- ホッチキス = desktop stapler -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Desk shadow -->
  <ellipse cx="100" cy="135" rx="80" ry="6" fill="#cfd8dc" opacity="0.4"/>
  <!-- Paper sheets underneath -->
  <rect x="40" y="118" width="120" height="14" fill="white" stroke="#bdbdbd" stroke-width="0.6" rx="1"/>
  <rect x="44" y="115" width="120" height="14" fill="white" stroke="#bdbdbd" stroke-width="0.6" rx="1"/>
  <!-- Stapler base -->
  <path d="M30 110 L170 110 L165 125 L35 125 Z" fill="#37474f" rx="3"/>
  <!-- Anvil plate (silver strip on base) -->
  <rect x="80" y="112" width="40" height="3" fill="#b0bec5" rx="1"/>
  <!-- Hinge -->
  <circle cx="35" cy="100" r="5" fill="#546e7a"/>
  <circle cx="35" cy="100" r="2" fill="#263238"/>
  <!-- Stapler arm (top) - tilted slightly up -->
  <g transform="rotate(-8 35 100)">
    <path d="M30 92 L168 86 L168 102 L30 108 Z" fill="#e53935" stroke="#b71c1c" stroke-width="1"/>
    <!-- Top highlight -->
    <rect x="40" y="89" width="120" height="3" fill="#ef5350" opacity="0.7" rx="1"/>
    <!-- Brand label -->
    <rect x="100" y="92" width="30" height="5" fill="#fff3e0" rx="1"/>
    <text x="115" y="96.2" font-size="4" fill="#b71c1c" text-anchor="middle" font-family="sans-serif" font-weight="bold">HD-10</text>
    <!-- Front lip -->
    <rect x="160" y="86" width="9" height="16" fill="#c62828" rx="1"/>
  </g>
  <!-- Staple flying down (animation hint) -->
  <rect x="98" y="105" width="10" height="2" fill="#90a4ae"/>
  <rect x="98" y="105" width="2" height="5" fill="#90a4ae"/>
  <rect x="106" y="105" width="2" height="5" fill="#90a4ae"/>
  <!-- Already stapled mark on paper -->
  <line x1="92" y1="123" x2="100" y2="123" stroke="#546e7a" stroke-width="1.5"/>
  <!-- Paper text lines -->
  <line x1="50" y1="121" x2="80" y2="121" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="120" y1="121" x2="155" y2="121" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="50" y1="126" x2="155" y2="126" stroke="#e0e0e0" stroke-width="0.8"/>
  <!-- Action lines -->
  <line x1="60" y1="60" x2="65" y2="70" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <line x1="80" y1="55" x2="80" y2="68" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <line x1="100" y1="58" x2="98" y2="70" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
</svg>

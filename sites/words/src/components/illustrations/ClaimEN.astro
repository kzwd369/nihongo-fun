<!-- English Claim = legal/insurance claim, formal assertion -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Office/legal setting background -->
  <rect x="15" y="20" width="170" height="120" fill="#f5f5f5" rx="4"/>
  <rect x="15" y="20" width="170" height="8" fill="#5c6bc0" rx="4 4 0 0"/>
  <!-- Desk -->
  <rect x="30" y="95" width="140" height="8" fill="#8d6e63" rx="2"/>
  <!-- Person sitting at desk -->
  <!-- Head -->
  <circle cx="75" cy="60" r="13" fill="#ffcc80"/>
  <!-- Hair -->
  <path d="M62,56 Q64,45 75,44 Q86,45 88,56" fill="#5d4037"/>
  <!-- Normal calm eyes -->
  <circle cx="70" cy="60" r="1.5" fill="#5d4037"/>
  <circle cx="80" cy="60" r="1.5" fill="#5d4037"/>
  <!-- Neutral/focused mouth -->
  <line x1="72" y1="66" x2="78" y2="66" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Body (business attire) -->
  <rect x="66" y="73" width="18" height="18" fill="#455a64" rx="3"/>
  <!-- Tie -->
  <polygon points="75,73 72,80 75,85 78,80" fill="#e53935"/>
  <!-- Arms writing -->
  <line x1="66" y1="78" x2="55" y2="88" stroke="#455a64" stroke-width="4" stroke-linecap="round"/>
  <line x1="84" y1="78" x2="95" y2="88" stroke="#455a64" stroke-width="4" stroke-linecap="round"/>
  <!-- Pen in hand -->
  <line x1="93" y1="86" x2="100" y2="78" stroke="#1565c0" stroke-width="2" stroke-linecap="round"/>
  <!-- Claim form / document -->
  <rect x="90" y="75" width="55" height="18" fill="white" rx="2" stroke="#bdbdbd" stroke-width="0.8"/>
  <text x="117" y="83" font-size="5.5" fill="#5c6bc0" text-anchor="middle" font-family="sans-serif" font-weight="bold">CLAIM FORM</text>
  <line x1="95" y1="87" x2="140" y2="87" stroke="#e0e0e0" stroke-width="0.8"/>
  <line x1="95" y1="90" x2="135" y2="90" stroke="#e0e0e0" stroke-width="0.8"/>
  <!-- Insurance/legal stamps -->
  <circle cx="155" cy="52" r="12" fill="none" stroke="#1565c0" stroke-width="1.5" stroke-dasharray="2,1"/>
  <text x="155" y="54" font-size="5" fill="#1565c0" text-anchor="middle" font-family="sans-serif">APPROVED</text>
  <!-- Filing cabinet -->
  <rect x="155" y="70" width="20" height="25" fill="#78909c" rx="2"/>
  <rect x="157" y="73" width="16" height="5" fill="#90a4ae" rx="1"/>
  <rect x="157" y="80" width="16" height="5" fill="#90a4ae" rx="1"/>
  <rect x="157" y="87" width="16" height="5" fill="#90a4ae" rx="1"/>
  <circle cx="165" cy="75.5" r="1" fill="#546e7a"/>
  <circle cx="165" cy="82.5" r="1" fill="#546e7a"/>
  <circle cx="165" cy="89.5" r="1" fill="#546e7a"/>
  <!-- Scale of justice (legal symbol) -->
  <line x1="38" y1="35" x2="38" y2="55" stroke="#ffd54f" stroke-width="2"/>
  <line x1="25" y1="42" x2="51" y2="42" stroke="#ffd54f" stroke-width="2"/>
  <path d="M25,42 L22,50 L28,50 Z" fill="#ffd54f"/>
  <path d="M51,42 L48,50 L54,50 Z" fill="#ffd54f"/>
  <circle cx="38" cy="34" r="3" fill="#ffd54f"/>
  <!-- Floor -->
  <rect x="0" y="140" width="200" height="20" fill="#c5cae9" rx="0"/>
</svg>

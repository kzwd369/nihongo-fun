<!-- Sparkly gift box with stars — ワクワク (excitement/anticipation) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Background sparkles -->
  <circle cx="30" cy="25" r="2" fill="#ffd54f" opacity="0.7"/>
  <circle cx="170" cy="20" r="2.5" fill="#ffab40" opacity="0.6"/>
  <circle cx="25" cy="100" r="1.5" fill="#ffd54f" opacity="0.5"/>
  <circle cx="175" cy="95" r="2" fill="#ffab40" opacity="0.5"/>
  <!-- Star sparkles -->
  <polygon points="45,18 47,24 53,24 48,28 50,34 45,30 40,34 42,28 37,24 43,24" fill="#ffc107" opacity="0.7"/>
  <polygon points="160,30 162,35 167,35 163,38 165,43 160,40 155,43 157,38 153,35 158,35" fill="#ff9800" opacity="0.6"/>
  <polygon points="20,70 21,73 24,73 22,75 23,78 20,76 17,78 18,75 16,73 19,73" fill="#ffd54f" opacity="0.5"/>
  <polygon points="180,65 181,68 184,68 182,70 183,73 180,71 177,73 178,70 176,68 179,68" fill="#ffc107" opacity="0.5"/>
  <!-- Gift box body -->
  <rect x="60" y="70" width="80" height="60" fill="#ff7043" rx="4"/>
  <rect x="60" y="70" width="80" height="60" fill="url(#giftGrad)" rx="4"/>
  <!-- Gift box lid -->
  <rect x="55" y="58" width="90" height="16" fill="#ff5722" rx="3"/>
  <rect x="55" y="58" width="90" height="16" fill="url(#lidGrad)" rx="3"/>
  <!-- Ribbon vertical -->
  <rect x="94" y="58" width="12" height="72" fill="#ffc107" rx="1"/>
  <!-- Ribbon horizontal -->
  <rect x="55" y="62" width="90" height="8" fill="#ffc107" rx="1"/>
  <!-- Ribbon bow -->
  <ellipse cx="92" cy="52" rx="14" ry="10" fill="#ffc107"/>
  <ellipse cx="108" cy="52" rx="14" ry="10" fill="#ffc107"/>
  <circle cx="100" cy="54" r="5" fill="#ffab00"/>
  <ellipse cx="92" cy="52" rx="10" ry="7" fill="#ffca28"/>
  <ellipse cx="108" cy="52" rx="10" ry="7" fill="#ffca28"/>
  <!-- Excitement lines from box -->
  <line x1="100" y1="30" x2="100" y2="18" stroke="#ff9800" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <line x1="120" y1="35" x2="130" y2="25" stroke="#ff9800" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="80" y1="35" x2="70" y2="25" stroke="#ff9800" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="135" y1="48" x2="148" y2="42" stroke="#ff9800" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
  <line x1="65" y1="48" x2="52" y2="42" stroke="#ff9800" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
  <!-- Small star bursts -->
  <polygon points="155,105 157,110 162,110 158,113 160,118 155,115 150,118 152,113 148,110 153,110" fill="#ffd54f" opacity="0.6"/>
  <polygon points="38,110 40,114 44,114 41,116 42,120 38,118 34,120 36,116 33,114 37,114" fill="#ffab40" opacity="0.5"/>
  <!-- Bouncy motion lines -->
  <path d="M55 140 Q60 136 65 140" fill="none" stroke="#ff9800" stroke-width="1.5" opacity="0.4"/>
  <path d="M135 140 Q140 136 145 140" fill="none" stroke="#ff9800" stroke-width="1.5" opacity="0.4"/>
  <!-- Gradients -->
  <defs>
    <linearGradient id="giftGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="white" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="black" stop-opacity="0.05"/>
    </linearGradient>
    <linearGradient id="lidGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="white" stop-opacity="0.2"/>
      <stop offset="100%" stop-color="black" stop-opacity="0.05"/>
    </linearGradient>
  </defs>
</svg>

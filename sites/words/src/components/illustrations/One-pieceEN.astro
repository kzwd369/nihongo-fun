<!-- English one-piece = one-piece swimsuit -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Sun -->
  <circle cx="35" cy="28" r="11" fill="#ffd54f" opacity="0.85"/>
  <line x1="35" y1="10" x2="35" y2="14" stroke="#ffb300" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="35" y1="42" x2="35" y2="46" stroke="#ffb300" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="17" y1="28" x2="21" y2="28" stroke="#ffb300" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="49" y1="28" x2="53" y2="28" stroke="#ffb300" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Beach water at bottom -->
  <rect x="0" y="138" width="200" height="22" fill="#4fc3f7"/>
  <path d="M0 138 Q15 134 30 138 T60 138 T90 138 T120 138 T150 138 T180 138 T200 138" fill="none" stroke="white" stroke-width="1" opacity="0.6"/>
  <!-- Sand strip -->
  <rect x="0" y="135" width="200" height="3" fill="#fff59d"/>
  <!-- One-piece swimsuit shape (centered) -->
  <!-- Straps -->
  <path d="M85 35 L78 60" fill="none" stroke="#0277bd" stroke-width="3.5" stroke-linecap="round"/>
  <path d="M115 35 L122 60" fill="none" stroke="#0277bd" stroke-width="3.5" stroke-linecap="round"/>
  <!-- Top (bra cups) -->
  <path d="M75 55 Q85 50 95 55 Q100 60 100 65 Q100 60 105 55 Q115 50 125 55 L125 75 L75 75 Z" fill="#0288d1" stroke="#01579b" stroke-width="1.2"/>
  <!-- Cleavage notch -->
  <path d="M95 55 Q100 65 105 55 L100 70 Z" fill="#01579b"/>
  <!-- Body (one-piece torso) -->
  <path d="M75 75 L125 75 L130 110 Q120 122 100 122 Q80 122 70 110 Z" fill="#0288d1" stroke="#01579b" stroke-width="1.2"/>
  <!-- Side cutout / contour -->
  <path d="M75 88 Q70 100 75 110" fill="none" stroke="#01579b" stroke-width="0.8"/>
  <path d="M125 88 Q130 100 125 110" fill="none" stroke="#01579b" stroke-width="0.8"/>
  <!-- Highlight (shiny lycra) -->
  <ellipse cx="88" cy="85" rx="3" ry="12" fill="#4fc3f7" opacity="0.7"/>
  <ellipse cx="115" cy="85" rx="3" ry="12" fill="#4fc3f7" opacity="0.7"/>
  <!-- White stripe accent -->
  <path d="M100 75 L100 122" stroke="white" stroke-width="1.5" stroke-dasharray="0"/>
  <!-- Decorative buckle -->
  <rect x="95" y="78" width="10" height="5" fill="#ffd54f" stroke="#f9a825" stroke-width="0.5" rx="1"/>
  <!-- Pool / wave splash drops -->
  <circle cx="50" cy="130" r="2" fill="#81d4fa" opacity="0.7"/>
  <circle cx="160" cy="128" r="2" fill="#81d4fa" opacity="0.7"/>
  <circle cx="170" cy="125" r="1.5" fill="#81d4fa" opacity="0.7"/>
  <!-- Beach ball -->
  <circle cx="170" cy="60" r="11" fill="white" stroke="#37474f" stroke-width="0.6"/>
  <path d="M170 49 Q175 60 170 71" fill="#ef5350"/>
  <path d="M170 49 Q165 60 170 71" fill="#42a5f5"/>
  <path d="M159 60 Q170 55 181 60" fill="#fdd835" opacity="0.8"/>
</svg>

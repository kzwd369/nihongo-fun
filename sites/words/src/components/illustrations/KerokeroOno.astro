<!-- Cute green frog on lily pad — ケロケロ (frog ribbit) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f2f1" rx="8"/>
  <!-- Water surface ripples -->
  <g fill="none" stroke="#4db6ac" stroke-width="1.5" stroke-linecap="round" opacity="0.55">
    <path d="M20 140 Q40 135 60 140"/>
    <path d="M140 145 Q160 140 180 145"/>
    <path d="M30 125 Q55 120 80 125"/>
  </g>
  <!-- Lily pad -->
  <path d="M55 130 Q50 105 95 100 Q145 103 145 130 Q145 140 100 140 Q50 138 55 130Z" fill="#66bb6a" stroke="#2e7d32" stroke-width="1.5"/>
  <path d="M100 105 L100 130" stroke="#2e7d32" stroke-width="1"/>
  <!-- Pink flower on pad -->
  <g transform="translate(55 112)">
    <circle cx="0" cy="0" r="3" fill="#f48fb1"/>
    <circle cx="-4" cy="-2" r="2.5" fill="#f48fb1"/>
    <circle cx="4" cy="-2" r="2.5" fill="#f48fb1"/>
    <circle cx="0" cy="-5" r="2.5" fill="#f48fb1"/>
    <circle cx="0" cy="-1" r="1.5" fill="#fff59d"/>
  </g>

  <!-- Frog body -->
  <ellipse cx="110" cy="100" rx="32" ry="22" fill="#81c784" stroke="#2e7d32" stroke-width="1.5"/>
  <!-- Belly -->
  <ellipse cx="110" cy="108" rx="20" ry="10" fill="#c5e1a5"/>
  <!-- Eyes (bulging on top) -->
  <circle cx="95" cy="75" r="10" fill="#81c784" stroke="#2e7d32" stroke-width="1.5"/>
  <circle cx="125" cy="75" r="10" fill="#81c784" stroke="#2e7d32" stroke-width="1.5"/>
  <circle cx="95" cy="75" r="6" fill="white"/>
  <circle cx="125" cy="75" r="6" fill="white"/>
  <circle cx="96" cy="76" r="3" fill="#1b5e20"/>
  <circle cx="126" cy="76" r="3" fill="#1b5e20"/>
  <circle cx="97" cy="75" r="1" fill="white"/>
  <circle cx="127" cy="75" r="1" fill="white"/>

  <!-- Smiling wide frog mouth -->
  <path d="M85 100 Q110 115 135 100" fill="none" stroke="#1b5e20" stroke-width="2" stroke-linecap="round"/>

  <!-- Cheeks blush -->
  <circle cx="82" cy="100" r="3" fill="#f8bbd0" opacity="0.7"/>
  <circle cx="138" cy="100" r="3" fill="#f8bbd0" opacity="0.7"/>

  <!-- Legs hint -->
  <ellipse cx="78" cy="115" rx="6" ry="4" fill="#66bb6a" stroke="#2e7d32" stroke-width="1"/>
  <ellipse cx="142" cy="115" rx="6" ry="4" fill="#66bb6a" stroke="#2e7d32" stroke-width="1"/>

  <!-- Speech bubble -->
  <ellipse cx="160" cy="35" rx="30" ry="14" fill="white" stroke="#388e3c" stroke-width="1.5"/>
  <text x="160" y="40" text-anchor="middle" font-family="sans-serif" font-size="11" font-weight="800" fill="#2e7d32">ケロッ!</text>
  <path d="M143 43 L135 52 L148 47" fill="white" stroke="#388e3c" stroke-width="1.5" stroke-linejoin="round"/>

  <!-- ケロケロ text -->
  <text x="15" y="30" font-family="sans-serif" font-size="14" font-weight="800" fill="#2e7d32">ケロケロ♪</text>
</svg>

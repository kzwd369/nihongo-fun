<!-- English: "salary man" is not a real word — confused concept -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- "salary" label -->
  <rect x="10" y="55" width="65" height="28" fill="#c8e6c9" rx="6" stroke="#66bb6a" stroke-width="1"/>
  <text x="42" y="74" text-anchor="middle" font-size="12" font-family="sans-serif" font-weight="bold" fill="#2e7d32">salary</text>
  <!-- plus sign -->
  <text x="85" y="76" text-anchor="middle" font-size="20" font-family="sans-serif" font-weight="bold" fill="#757575">+</text>
  <!-- stick figure "man" -->
  <rect x="100" y="55" width="65" height="28" fill="#bbdefb" rx="6" stroke="#64b5f6" stroke-width="1"/>
  <!-- simple stick figure inside the box -->
  <circle cx="125" cy="62" r="4" fill="none" stroke="#1565c0" stroke-width="1.5"/>
  <line x1="125" y1="66" x2="125" y2="76" stroke="#1565c0" stroke-width="1.5"/>
  <line x1="125" y1="69" x2="118" y2="74" stroke="#1565c0" stroke-width="1.5"/>
  <line x1="125" y1="69" x2="132" y2="74" stroke="#1565c0" stroke-width="1.5"/>
  <text x="145" y="74" text-anchor="middle" font-size="12" font-family="sans-serif" font-weight="bold" fill="#1565c0">man</text>
  <!-- equals sign -->
  <text x="100" y="105" text-anchor="middle" font-size="20" font-family="sans-serif" font-weight="bold" fill="#757575">=</text>
  <!-- confused result -->
  <rect x="50" y="110" width="100" height="32" fill="#fff3e0" rx="8" stroke="#ff9800" stroke-width="1.5" stroke-dasharray="4,3"/>
  <!-- confused face -->
  <circle cx="75" cy="126" r="10" fill="#ffe082"/>
  <!-- confused eyes -->
  <circle cx="72" cy="124" r="1.5" fill="#5d4037"/>
  <circle cx="78" cy="124" r="1.5" fill="#5d4037"/>
  <!-- raised eyebrow -->
  <line x1="76" y1="120" x2="80" y2="118" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- wavy confused mouth -->
  <path d="M70 130 Q73 128 75 130 Q77 132 80 130" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- question marks -->
  <text x="100" y="131" text-anchor="middle" font-size="16" font-family="sans-serif" font-weight="bold" fill="#e65100">???</text>
  <!-- top label -->
  <text x="100" y="30" text-anchor="middle" font-size="11" font-family="sans-serif" fill="#78909c">In English, this means...</text>
  <text x="100" y="45" text-anchor="middle" font-size="11" font-family="sans-serif" font-weight="bold" fill="#d84315">nothing!</text>
</svg>

<!-- Japanese ワンルーム = compact studio apartment, single combined room + small bath -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f3e5f5" rx="8"/>
  <!-- Apartment floor plan (top-down view) -->
  <!-- Outer walls -->
  <rect x="30" y="25" width="140" height="100" fill="#fafafa" stroke="#5d4037" stroke-width="2.5"/>
  <!-- Main room divider for tiny bathroom -->
  <line x1="30" y1="55" x2="65" y2="55" stroke="#5d4037" stroke-width="2"/>
  <line x1="65" y1="25" x2="65" y2="55" stroke="#5d4037" stroke-width="2"/>
  <!-- Entrance (bottom) -->
  <rect x="85" y="123" width="30" height="4" fill="#bcaaa4"/>
  <path d="M85,127 Q100,132 115,127" fill="none" stroke="#8d6e63" stroke-width="1" stroke-dasharray="2,2"/>
  <!-- Tiny bathroom (top-left) -->
  <text x="47" y="35" font-size="7" fill="#757575" text-anchor="middle">バス</text>
  <!-- Toilet -->
  <ellipse cx="40" cy="45" rx="4" ry="3" fill="white" stroke="#90a4ae" stroke-width="0.8"/>
  <!-- Tub -->
  <rect x="48" y="32" width="14" height="20" fill="#e1f5fe" stroke="#4fc3f7" stroke-width="0.8" rx="1"/>
  <!-- Kitchen (top-right corner) -->
  <rect x="68" y="28" width="45" height="12" fill="#d7ccc8" stroke="#8d6e63" stroke-width="1"/>
  <!-- Sink -->
  <rect x="72" y="30" width="10" height="8" fill="#cfd8dc" stroke="#78909c" stroke-width="0.5"/>
  <!-- Stove -->
  <rect x="86" y="30" width="10" height="8" fill="#424242" stroke="#212121" stroke-width="0.5"/>
  <circle cx="89" cy="34" r="1.5" fill="#e53935"/>
  <circle cx="93" cy="34" r="1.5" fill="#e53935"/>
  <!-- Fridge -->
  <rect x="100" y="28" width="10" height="14" fill="#e0e0e0" stroke="#9e9e9e" stroke-width="0.5"/>
  <line x1="100" y1="35" x2="110" y2="35" stroke="#9e9e9e" stroke-width="0.3"/>
  <!-- Bed -->
  <rect x="130" y="35" width="30" height="18" fill="#a5d6a7" stroke="#43a047" stroke-width="1" rx="1"/>
  <rect x="132" y="37" width="10" height="8" fill="white" stroke="#b0bec5" stroke-width="0.5"/>
  <!-- Desk -->
  <rect x="130" y="62" width="30" height="10" fill="#8d6e63" stroke="#5d4037" stroke-width="1"/>
  <!-- Chair -->
  <rect x="138" y="75" width="10" height="8" fill="#3e2723" rx="1"/>
  <!-- PC/laptop -->
  <rect x="136" y="64" width="10" height="6" fill="#424242"/>
  <rect x="136" y="69" width="10" height="1" fill="#212121"/>
  <!-- TV -->
  <rect x="75" y="55" width="16" height="10" fill="#263238" stroke="#000" stroke-width="0.5"/>
  <!-- Small table -->
  <rect x="75" y="75" width="25" height="14" fill="#d7ccc8" stroke="#8d6e63" stroke-width="0.8" rx="1"/>
  <!-- Closet -->
  <rect x="35" y="95" width="30" height="20" fill="#bcaaa4" stroke="#6d4c41" stroke-width="1"/>
  <line x1="50" y1="95" x2="50" y2="115" stroke="#6d4c41" stroke-width="0.8"/>
  <!-- Label on each area -->
  <text x="100" y="145" font-size="10" font-weight="bold" fill="#4a148c" text-anchor="middle">ワンルーム = 1部屋＋小さなバス</text>
  <!-- Size indicator -->
  <text x="155" y="100" font-size="8" fill="#6a1b9a">20㎡</text>
  <text x="38" y="155" font-size="7" fill="#6a1b9a">一人暮らし向け</text>
  <!-- Title -->
  <text x="100" y="18" font-size="11" font-weight="bold" fill="#6a1b9a" text-anchor="middle">日本のワンルーム</text>
</svg>

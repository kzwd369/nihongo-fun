<!-- Peaceful sleeping face with Z's — スヤスヤ (peaceful sleep) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8eaf6" rx="8"/>
  <!-- Soft moon glow -->
  <circle cx="160" cy="40" r="22" fill="#fff9c4" opacity="0.7"/>
  <circle cx="160" cy="40" r="15" fill="#fff59d"/>
  <!-- Tiny stars -->
  <circle cx="40" cy="30" r="1.5" fill="#fff59d"/>
  <circle cx="55" cy="50" r="1" fill="#fff59d"/>
  <circle cx="30" cy="60" r="1" fill="#fff59d"/>
  <!-- Pillow -->
  <ellipse cx="100" cy="115" rx="80" ry="18" fill="#c5cae9"/>
  <ellipse cx="100" cy="112" rx="70" ry="12" fill="#e8eaf6"/>
  <!-- Sleeping head -->
  <circle cx="100" cy="92" r="34" fill="#ffe0b2"/>
  <!-- Closed eyes - peaceful arcs -->
  <path d="M82,90 Q88,95 94,90" fill="none" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <path d="M106,90 Q112,95 118,90" fill="none" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Tiny content mouth -->
  <path d="M95,105 Q100,107 105,105" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Cheeks -->
  <ellipse cx="78" cy="100" rx="6" ry="3" fill="#ffab91" opacity="0.5"/>
  <ellipse cx="122" cy="100" rx="6" ry="3" fill="#ffab91" opacity="0.5"/>
  <!-- Z Z Z floating up -->
  <text x="135" y="60" font-family="Georgia, serif" font-size="14" font-weight="700" fill="#7986cb" opacity="0.9">z</text>
  <text x="145" y="48" font-family="Georgia, serif" font-size="18" font-weight="700" fill="#7986cb" opacity="0.7">z</text>
  <text x="158" y="32" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#7986cb" opacity="0.5">Z</text>
  <!-- Blanket edge hint -->
  <path d="M40 130 Q100 142 160 130" fill="#9fa8da" opacity="0.6"/>
</svg>

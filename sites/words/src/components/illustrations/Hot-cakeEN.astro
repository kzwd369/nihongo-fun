<!-- English "pancake" + idiom "selling like hotcakes" -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Shop sign -->
  <rect x="15" y="12" width="170" height="22" fill="#c2185b" rx="3"/>
  <text x="100" y="27" font-size="11" font-weight="bold" fill="#fff8e1" text-anchor="middle">SOLD OUT — SELLING LIKE HOTCAKES!</text>
  <!-- Counter/plate -->
  <rect x="10" y="110" width="180" height="8" fill="#8d6e63"/>
  <ellipse cx="100" cy="108" rx="48" ry="5" fill="#eceff1" stroke="#90a4ae" stroke-width="1"/>
  <!-- Thinner American-style pancake stack (shorter layers) -->
  <ellipse cx="100" cy="105" rx="42" ry="5" fill="#c68642"/>
  <ellipse cx="100" cy="102" rx="42" ry="4" fill="#dcae7c"/>
  <ellipse cx="100" cy="98" rx="40" ry="4" fill="#c68642"/>
  <ellipse cx="100" cy="95" rx="40" ry="3" fill="#dcae7c"/>
  <ellipse cx="100" cy="91" rx="38" ry="4" fill="#c68642"/>
  <ellipse cx="100" cy="88" rx="38" ry="3" fill="#dcae7c"/>
  <!-- Motion lines - pancakes flying off -->
  <!-- Flying pancake 1 -->
  <ellipse cx="35" cy="55" rx="14" ry="4" fill="#dcae7c" stroke="#c68642" stroke-width="1"/>
  <line x1="55" y1="50" x2="62" y2="48" stroke="#ff7043" stroke-width="2" stroke-linecap="round"/>
  <line x1="55" y1="58" x2="62" y2="60" stroke="#ff7043" stroke-width="2" stroke-linecap="round"/>
  <!-- Flying pancake 2 -->
  <ellipse cx="165" cy="60" rx="14" ry="4" fill="#dcae7c" stroke="#c68642" stroke-width="1"/>
  <line x1="145" y1="55" x2="138" y2="53" stroke="#ff7043" stroke-width="2" stroke-linecap="round"/>
  <line x1="145" y1="63" x2="138" y2="65" stroke="#ff7043" stroke-width="2" stroke-linecap="round"/>
  <!-- Dollar signs (strong sales) -->
  <text x="35" y="85" font-size="18" font-weight="bold" fill="#43a047">$</text>
  <text x="160" y="90" font-size="16" font-weight="bold" fill="#43a047">$</text>
  <text x="55" y="75" font-size="13" font-weight="bold" fill="#43a047" opacity="0.7">$</text>
  <text x="148" y="78" font-size="12" font-weight="bold" fill="#43a047" opacity="0.7">$</text>
  <!-- Happy chef face peeking -->
  <circle cx="100" cy="75" r="10" fill="#ffe0b2"/>
  <!-- Chef hat -->
  <path d="M90,70 Q90,55 100,55 Q110,55 110,70 Z" fill="white"/>
  <ellipse cx="100" cy="55" rx="10" ry="4" fill="white"/>
  <!-- Eyes -->
  <circle cx="96" cy="75" r="1.5" fill="#3e2723"/>
  <circle cx="104" cy="75" r="1.5" fill="#3e2723"/>
  <!-- Big smile -->
  <path d="M95,79 Q100,83 105,79" fill="none" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Label -->
  <text x="100" y="135" font-size="10" font-weight="bold" fill="#880e4f" text-anchor="middle">"selling like hotcakes" (idiom)</text>
  <!-- Floor -->
  <rect x="0" y="140" width="200" height="20" fill="#f8bbd0" rx="0"/>
  <text x="100" y="154" font-size="9" fill="#880e4f" text-anchor="middle">= pancakes (the food)</text>
</svg>

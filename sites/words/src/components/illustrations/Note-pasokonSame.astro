<!-- Pattern A: Same object (laptop) — called ノートパソコン in JP, laptop in EN -->
<svg viewBox="0 0 180 140" width="180" height="140" xmlns="http://www.w3.org/2000/svg" style="margin: 0 auto; display: block;">
  <rect width="180" height="140" fill="#f0f7ff" rx="8"/>
  <!-- Screen -->
  <rect x="30" y="15" width="120" height="80" fill="#37474f" rx="4"/>
  <rect x="35" y="20" width="110" height="70" fill="#bbdefb" rx="2"/>
  <!-- Screen content: code lines -->
  <rect x="42" y="30" width="50" height="4" fill="#1565c0" rx="1" opacity="0.6"/>
  <rect x="42" y="40" width="70" height="4" fill="#2e7d32" rx="1" opacity="0.6"/>
  <rect x="42" y="50" width="40" height="4" fill="#e65100" rx="1" opacity="0.6"/>
  <rect x="42" y="60" width="60" height="4" fill="#1565c0" rx="1" opacity="0.6"/>
  <rect x="42" y="70" width="35" height="4" fill="#6a1b9a" rx="1" opacity="0.6"/>
  <!-- Hinge -->
  <rect x="25" y="95" width="130" height="5" fill="#546e7a" rx="2"/>
  <!-- Keyboard base -->
  <path d="M15,100 L25,95 L155,95 L165,100 L165,115 Q165,120 160,120 L20,120 Q15,120 15,115 Z" fill="#78909c"/>
  <!-- Keyboard keys -->
  <rect x="30" y="102" width="120" height="4" fill="#90a4ae" rx="1"/>
  <rect x="30" y="109" width="120" height="4" fill="#90a4ae" rx="1"/>
  <!-- Trackpad -->
  <rect x="70" y="116" width="40" height="2" fill="#90a4ae" rx="0.5"/>
</svg>

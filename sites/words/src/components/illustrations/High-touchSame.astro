<!-- High five / ハイタッチ = two hands meeting in a celebratory high five -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Celebration burst background -->
  <circle cx="100" cy="65" r="45" fill="#fff8e1" opacity="0.6"/>
  <!-- Impact lines -->
  <line x1="100" y1="15" x2="100" y2="28" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="130" y1="25" x2="122" y2="36" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="70" y1="25" x2="78" y2="36" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="145" y1="50" x2="135" y2="52" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <line x1="55" y1="50" x2="65" y2="52" stroke="#ffca28" stroke-width="2" stroke-linecap="round"/>
  <!-- Small stars -->
  <polygon points="60,20 62,26 68,26 63,30 65,36 60,32 55,36 57,30 52,26 58,26" fill="#ffd54f" transform="scale(0.5) translate(70,10)"/>
  <polygon points="60,20 62,26 68,26 63,30 65,36 60,32 55,36 57,30 52,26 58,26" fill="#ffd54f" transform="scale(0.5) translate(210,20)"/>
  <!-- Left hand (palm facing right) -->
  <g transform="translate(30, 40)">
    <!-- Arm -->
    <rect x="-15" y="45" width="30" height="50" fill="#ffe0b2" rx="8" transform="rotate(25 0 70)"/>
    <!-- Palm -->
    <rect x="15" y="15" width="30" height="38" fill="#ffe0b2" rx="5"/>
    <!-- Thumb -->
    <rect x="10" y="38" width="10" height="18" fill="#ffe0b2" rx="4" transform="rotate(-20 15 47)"/>
    <!-- Fingers -->
    <rect x="17" y="-2" width="7" height="22" fill="#ffe0b2" rx="3"/>
    <rect x="25" y="-6" width="7" height="24" fill="#ffe0b2" rx="3"/>
    <rect x="33" y="-4" width="7" height="22" fill="#ffe0b2" rx="3"/>
    <rect x="40" y="0" width="7" height="19" fill="#ffe0b2" rx="3"/>
  </g>
  <!-- Right hand (palm facing left) -->
  <g transform="translate(105, 40)">
    <!-- Arm -->
    <rect x="20" y="45" width="30" height="50" fill="#d7ccc8" rx="8" transform="rotate(-25 35 70)"/>
    <!-- Palm -->
    <rect x="18" y="15" width="30" height="38" fill="#d7ccc8" rx="5"/>
    <!-- Thumb -->
    <rect x="43" y="38" width="10" height="18" fill="#d7ccc8" rx="4" transform="rotate(20 48 47)"/>
    <!-- Fingers -->
    <rect x="18" y="-2" width="7" height="22" fill="#d7ccc8" rx="3"/>
    <rect x="26" y="-6" width="7" height="24" fill="#d7ccc8" rx="3"/>
    <rect x="34" y="-4" width="7" height="22" fill="#d7ccc8" rx="3"/>
    <rect x="41" y="0" width="7" height="19" fill="#d7ccc8" rx="3"/>
  </g>
  <!-- Impact flash at contact point -->
  <circle cx="100" cy="55" r="6" fill="#fff176" opacity="0.8"/>
  <circle cx="100" cy="55" r="3" fill="white" opacity="0.9"/>
  <!-- Label -->
  <text x="100" y="148" font-size="10" fill="#5d4037" text-anchor="middle" font-family="sans-serif" font-weight="bold">🖐 High Five / ハイタッチ</text>
</svg>

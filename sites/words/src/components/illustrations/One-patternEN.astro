<!-- English: "one pattern" doesn't mean anything — natives say "predictable", "formulaic", etc. -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Word cloud / list of correct English equivalents -->
  <!-- Big strikethrough heading -->
  <rect x="40" y="15" width="120" height="22" fill="#ffebee" stroke="#c62828" stroke-width="1.5" rx="3"/>
  <text x="100" y="30" font-size="13" font-weight="bold" fill="#c62828" text-anchor="middle">"one pattern" ✗</text>
  <line x1="48" y1="22" x2="155" y2="34" stroke="#c62828" stroke-width="1.5" opacity="0.7"/>
  <!-- Subtitle -->
  <text x="100" y="46" font-size="7" fill="#5d4037" text-anchor="middle">Use these instead:</text>
  <!-- Native equivalents arranged like word cloud -->
  <rect x="20" y="55" width="62" height="16" fill="#fff" stroke="#1565c0" stroke-width="1" rx="3"/>
  <text x="51" y="66" font-size="9" font-weight="bold" fill="#1565c0" text-anchor="middle">predictable</text>
  <rect x="90" y="55" width="58" height="16" fill="#fff" stroke="#6a1b9a" stroke-width="1" rx="3"/>
  <text x="119" y="66" font-size="9" font-weight="bold" fill="#6a1b9a" text-anchor="middle">formulaic</text>
  <rect x="156" y="55" width="36" height="16" fill="#fff" stroke="#e65100" stroke-width="1" rx="3"/>
  <text x="174" y="66" font-size="8" font-weight="bold" fill="#e65100" text-anchor="middle">trite</text>
  <rect x="14" y="76" width="68" height="16" fill="#fff" stroke="#2e7d32" stroke-width="1" rx="3"/>
  <text x="48" y="87" font-size="9" font-weight="bold" fill="#2e7d32" text-anchor="middle">cookie-cutter</text>
  <rect x="90" y="76" width="100" height="16" fill="#fff" stroke="#c62828" stroke-width="1" rx="3"/>
  <text x="140" y="87" font-size="9" font-weight="bold" fill="#c62828" text-anchor="middle">a one-trick pony</text>
  <rect x="14" y="97" width="80" height="16" fill="#fff" stroke="#0277bd" stroke-width="1" rx="3"/>
  <text x="54" y="108" font-size="9" font-weight="bold" fill="#0277bd" text-anchor="middle">the same old</text>
  <rect x="100" y="97" width="80" height="16" fill="#fff" stroke="#558b2f" stroke-width="1" rx="3"/>
  <text x="140" y="108" font-size="9" font-weight="bold" fill="#558b2f" text-anchor="middle">repetitive</text>
  <!-- Confused English speaker -->
  <circle cx="35" cy="135" r="9" fill="#ffcc80"/>
  <path d="M27 130 Q35 122 43 130" fill="#5d4037"/>
  <line x1="31" y1="135" x2="34" y2="137" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="39" y1="135" x2="36" y2="137" stroke="#5d4037" stroke-width="1.5"/>
  <path d="M31 142 Q35 140 39 142" fill="none" stroke="#5d4037" stroke-width="1"/>
  <!-- Speech bubble -->
  <path d="M50 130 L60 124 Q90 124 90 132 Q90 140 60 140 L55 145 Z" fill="#fff" stroke="#5d4037" stroke-width="1"/>
  <text x="73" y="135" font-size="6" fill="#5d4037" text-anchor="middle">"One...what?"</text>
  <!-- Right side: example sentence comparison -->
  <rect x="100" y="120" width="92" height="30" fill="#fff8e1" stroke="#5d4037" stroke-width="1" rx="2"/>
  <text x="146" y="129" font-size="6" font-style="italic" fill="#5d4037" text-anchor="middle">"His jokes are predictable."</text>
  <text x="146" y="137" font-size="6" font-style="italic" fill="#5d4037" text-anchor="middle">"Same old dad joke."</text>
  <text x="146" y="145" font-size="6" font-weight="bold" fill="#2e7d32" text-anchor="middle">≠ "His jokes are one-pattern"</text>
  <!-- Label -->
  <text x="100" y="158" font-size="6" fill="#1b5e20" text-anchor="middle">"One pattern" is meaningless on its own in English</text>
</svg>

<!-- Japanese トランプ = playing cards (a deck of cards) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Table surface -->
  <ellipse cx="100" cy="130" rx="90" ry="25" fill="#d7ccc8"/>
  <!-- Back card (fanned) -->
  <g transform="translate(55, 30) rotate(-15, 40, 55)">
    <rect width="55" height="80" fill="#1565c0" rx="4" stroke="#0d47a1" stroke-width="1"/>
    <rect x="5" y="5" width="45" height="70" fill="none" stroke="#42a5f5" stroke-width="0.5" rx="2"/>
    <line x1="15" y1="15" x2="40" y2="65" stroke="#42a5f5" stroke-width="0.3" opacity="0.5"/>
    <line x1="40" y1="15" x2="15" y2="65" stroke="#42a5f5" stroke-width="0.3" opacity="0.5"/>
  </g>
  <!-- Middle card -->
  <g transform="translate(65, 28) rotate(-5, 40, 55)">
    <rect width="55" height="80" fill="#e3f2fd" rx="4" stroke="#90caf9" stroke-width="1"/>
    <text x="8" y="18" font-size="12" fill="#e53935" font-family="serif">&#9829;</text>
    <text x="8" y="30" font-size="10" fill="#e53935" font-family="serif">K</text>
    <text x="27" y="52" font-size="20" fill="#e53935" font-family="serif">&#9829;</text>
  </g>
  <!-- Front card -->
  <g transform="translate(78, 25) rotate(8, 40, 55)">
    <rect width="55" height="80" fill="#fff" rx="4" stroke="#bdbdbd" stroke-width="1"/>
    <text x="8" y="18" font-size="12" fill="#212121" font-family="serif">&#9824;</text>
    <text x="8" y="30" font-size="10" fill="#212121" font-family="serif">A</text>
    <text x="27" y="55" font-size="22" fill="#212121" font-family="serif">&#9824;</text>
  </g>
  <!-- Extra scattered card -->
  <g transform="translate(30, 60) rotate(-25, 25, 35)">
    <rect width="40" height="58" fill="#fff" rx="3" stroke="#bdbdbd" stroke-width="0.8"/>
    <text x="5" y="14" font-size="9" fill="#e53935" font-family="serif">&#9830;</text>
    <text x="5" y="23" font-size="8" fill="#e53935" font-family="serif">7</text>
  </g>
  <!-- Label -->
  <text x="100" y="152" text-anchor="middle" font-size="11" fill="#546e7a" font-family="sans-serif">トランプ = playing cards</text>
</svg>

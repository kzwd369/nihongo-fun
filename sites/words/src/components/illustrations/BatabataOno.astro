<!-- Person rushing frantically — バタバタ (batabata) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f4ff" rx="8"/>
  <!-- Floor -->
  <line x1="0" y1="145" x2="200" y2="145" stroke="#c5cae9" stroke-width="1.5"/>
  <!-- Running person — leaning forward -->
  <!-- Head -->
  <circle cx="115" cy="42" r="14" fill="#ffe0b2"/>
  <!-- Hair -->
  <ellipse cx="115" cy="34" rx="14" ry="8" fill="#5d4037"/>
  <!-- Sweat drops -->
  <ellipse cx="134" cy="38" rx="2" ry="3.5" fill="#90caf9"/>
  <ellipse cx="138" cy="48" rx="1.5" ry="2.5" fill="#90caf9"/>
  <!-- Eyes — stressed -->
  <circle cx="110" cy="42" r="1.5" fill="#333"/>
  <circle cx="120" cy="42" r="1.5" fill="#333"/>
  <!-- Mouth — open and panting -->
  <ellipse cx="115" cy="49" rx="3" ry="2" fill="#e57373"/>
  <!-- Body — shirt -->
  <polygon points="105,55 125,55 130,100 100,100" fill="#7986cb"/>
  <!-- Tie flying back -->
  <polygon points="115,58 113,75 118,75 116,58" fill="#ef5350"/>
  <polygon points="113,75 105,82 118,75" fill="#ef5350"/>
  <!-- Left arm — reaching forward with briefcase -->
  <line x1="108" y1="62" x2="82" y2="75" stroke="#ffe0b2" stroke-width="6" stroke-linecap="round"/>
  <!-- Briefcase -->
  <rect x="68" y="72" width="18" height="14" fill="#8d6e63" rx="2"/>
  <line x1="72" y1="72" x2="72" y2="70" stroke="#6d4c41" stroke-width="1.5"/>
  <line x1="82" y1="72" x2="82" y2="70" stroke="#6d4c41" stroke-width="1.5"/>
  <line x1="72" y1="70" x2="82" y2="70" stroke="#6d4c41" stroke-width="2"/>
  <!-- Right arm — swinging back -->
  <line x1="122" y1="62" x2="148" y2="80" stroke="#ffe0b2" stroke-width="6" stroke-linecap="round"/>
  <!-- Left leg — front stride -->
  <line x1="108" y1="100" x2="90" y2="143" stroke="#37474f" stroke-width="7" stroke-linecap="round"/>
  <!-- Right leg — back stride -->
  <line x1="120" y1="100" x2="140" y2="143" stroke="#37474f" stroke-width="7" stroke-linecap="round"/>
  <!-- Shoes -->
  <ellipse cx="86" cy="144" rx="8" ry="3" fill="#5d4037"/>
  <ellipse cx="144" cy="144" rx="8" ry="3" fill="#5d4037"/>
  <!-- Flying papers -->
  <rect x="140" y="25" width="14" height="18" fill="white" stroke="#bbb" stroke-width="0.5" transform="rotate(15, 147, 34)"/>
  <line x1="143" y1="30" x2="151" y2="30" stroke="#ccc" stroke-width="0.5" transform="rotate(15, 147, 34)"/>
  <line x1="143" y1="33" x2="151" y2="33" stroke="#ccc" stroke-width="0.5" transform="rotate(15, 147, 34)"/>
  <rect x="152" y="50" width="12" height="16" fill="white" stroke="#bbb" stroke-width="0.5" transform="rotate(-10, 158, 58)"/>
  <rect x="30" y="18" width="13" height="17" fill="white" stroke="#bbb" stroke-width="0.5" transform="rotate(-20, 36, 26)"/>
  <!-- Motion lines -->
  <line x1="155" y1="65" x2="175" y2="65" stroke="#9e9e9e" stroke-width="1.5" stroke-linecap="round"/>
  <line x1="158" y1="75" x2="180" y2="75" stroke="#9e9e9e" stroke-width="1" stroke-linecap="round"/>
  <line x1="155" y1="85" x2="172" y2="85" stroke="#9e9e9e" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Dust clouds at feet -->
  <circle cx="145" cy="140" r="5" fill="#e0e0e0" opacity="0.6"/>
  <circle cx="152" cy="136" r="3.5" fill="#e0e0e0" opacity="0.4"/>
</svg>

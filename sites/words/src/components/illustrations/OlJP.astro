<!-- Japanese OL (オーエル) = female office worker -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Office background -->
  <rect x="15" y="15" width="170" height="130" fill="#fafafa" rx="4"/>
  <!-- Window -->
  <rect x="130" y="22" width="45" height="40" fill="#bbdefb" rx="2" stroke="#e0e0e0" stroke-width="1"/>
  <line x1="152.5" y1="22" x2="152.5" y2="62" stroke="#e0e0e0" stroke-width="1"/>
  <line x1="130" y1="42" x2="175" y2="42" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Desk -->
  <rect x="20" y="100" width="160" height="8" fill="#bcaaa4" rx="2"/>
  <rect x="25" y="108" width="8" height="30" fill="#a1887f" rx="1"/>
  <rect x="167" y="108" width="8" height="30" fill="#a1887f" rx="1"/>
  <!-- Computer on desk -->
  <rect x="120" y="72" width="40" height="28" fill="#546e7a" rx="2"/>
  <rect x="123" y="75" width="34" height="22" fill="#e3f2fd" rx="1"/>
  <rect x="135" y="100" width="16" height="3" fill="#78909c" rx="1"/>
  <!-- Keyboard -->
  <rect x="118" y="94" width="30" height="6" fill="#e0e0e0" rx="1"/>
  <!-- Coffee cup -->
  <rect x="155" y="90" width="10" height="10" fill="white" rx="1" stroke="#bdbdbd" stroke-width="0.5"/>
  <ellipse cx="160" cy="90" rx="5" ry="1.5" fill="white" stroke="#bdbdbd" stroke-width="0.5"/>
  <path d="M165 93 Q169 95 165 97" fill="none" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Steam -->
  <path d="M158 86 Q159 83 158 80" fill="none" stroke="#bdbdbd" stroke-width="0.5"/>
  <path d="M162 86 Q163 83 162 80" fill="none" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Person - head -->
  <circle cx="70" cy="45" r="14" fill="#ffe0b2"/>
  <!-- Hair - bob cut -->
  <path d="M56 42 Q56 28 70 26 Q84 28 84 42" fill="#37474f"/>
  <rect x="56" y="40" width="6" height="16" fill="#37474f" rx="2"/>
  <rect x="78" y="40" width="6" height="16" fill="#37474f" rx="2"/>
  <!-- Eyes -->
  <circle cx="64" cy="46" r="1.5" fill="#37474f"/>
  <circle cx="76" cy="46" r="1.5" fill="#37474f"/>
  <!-- Eyelashes -->
  <line x1="62" y1="44" x2="63" y2="45" stroke="#37474f" stroke-width="0.5"/>
  <line x1="78" y1="45" x2="77" y2="44" stroke="#37474f" stroke-width="0.5"/>
  <!-- Smile -->
  <path d="M65 52 Q70 56 75 52" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Body - blouse -->
  <rect x="57" y="59" width="26" height="28" fill="white" rx="3"/>
  <!-- Collar -->
  <path d="M63 59 L70 67 L77 59" fill="none" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Blazer/jacket -->
  <path d="M55 62 L57 59 L57 87 L55 87 Z" fill="#5c6bc0" rx="1"/>
  <path d="M85 62 L83 59 L83 87 L85 87 Z" fill="#5c6bc0" rx="1"/>
  <rect x="55" y="62" width="6" height="25" fill="#5c6bc0" rx="1"/>
  <rect x="79" y="62" width="6" height="25" fill="#5c6bc0" rx="1"/>
  <!-- Skirt -->
  <path d="M57 87 L54 110 L86 110 L83 87 Z" fill="#5c6bc0"/>
  <!-- Arms -->
  <line x1="55" y1="66" x2="40" y2="85" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <line x1="85" y1="66" x2="100" y2="85" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <!-- Documents in left hand -->
  <rect x="30" y="78" width="16" height="22" fill="white" rx="1" stroke="#e0e0e0" stroke-width="0.5"/>
  <line x1="33" y1="83" x2="43" y2="83" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="33" y1="86" x2="43" y2="86" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="33" y1="89" x2="43" y2="89" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="33" y1="92" x2="40" y2="92" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Second document behind -->
  <rect x="32" y="80" width="16" height="22" fill="white" rx="1" stroke="#e0e0e0" stroke-width="0.5" opacity="0.5" transform="translate(-3,-1)"/>
  <!-- Legs -->
  <line x1="64" y1="110" x2="62" y2="138" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <line x1="76" y1="110" x2="78" y2="138" stroke="#ffe0b2" stroke-width="4" stroke-linecap="round"/>
  <!-- Shoes -->
  <ellipse cx="60" cy="140" rx="6" ry="3" fill="#37474f"/>
  <ellipse cx="80" cy="140" rx="6" ry="3" fill="#37474f"/>
</svg>

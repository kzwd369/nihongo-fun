<!-- English Smart = intelligent, clever, brainy -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Lightbulb glow background -->
  <circle cx="100" cy="30" r="35" fill="#fff9c4" opacity="0.3"/>
  <!-- Person (brainy/studious) -->
  <!-- Head -->
  <circle cx="100" cy="55" r="16" fill="#ffcc80"/>
  <!-- Graduation cap -->
  <rect x="82" y="38" width="36" height="5" fill="#37474f"/>
  <polygon points="100,28 82,40 118,40" fill="#37474f"/>
  <line x1="118" y1="40" x2="125" y2="50" stroke="#37474f" stroke-width="1.5"/>
  <circle cx="125" cy="52" r="2" fill="#ffd54f"/>
  <!-- Glasses -->
  <circle cx="93" cy="55" r="5" fill="none" stroke="#5d4037" stroke-width="1.5"/>
  <circle cx="107" cy="55" r="5" fill="none" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="98" y1="55" x2="102" y2="55" stroke="#5d4037" stroke-width="1.5"/>
  <line x1="88" y1="55" x2="85" y2="53" stroke="#5d4037" stroke-width="1"/>
  <line x1="112" y1="55" x2="115" y2="53" stroke="#5d4037" stroke-width="1"/>
  <!-- Eyes behind glasses -->
  <circle cx="93" cy="55" r="1.5" fill="#5d4037"/>
  <circle cx="107" cy="55" r="1.5" fill="#5d4037"/>
  <!-- Confident smile -->
  <path d="M95,63 Q100,67 105,63" fill="none" stroke="#5d4037" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Body -->
  <rect x="90" y="71" width="20" height="24" fill="#1565c0" rx="3"/>
  <!-- Arms holding book -->
  <line x1="90" y1="76" x2="72" y2="88" stroke="#1565c0" stroke-width="5" stroke-linecap="round"/>
  <line x1="110" y1="76" x2="128" y2="88" stroke="#1565c0" stroke-width="5" stroke-linecap="round"/>
  <!-- Book in left hand -->
  <rect x="58" y="82" width="18" height="14" fill="#4caf50" rx="1"/>
  <line x1="67" y1="82" x2="67" y2="96" stroke="#388e3c" stroke-width="1.5"/>
  <line x1="60" y1="86" x2="65" y2="86" stroke="white" stroke-width="0.5" opacity="0.5"/>
  <line x1="60" y1="89" x2="64" y2="89" stroke="white" stroke-width="0.5" opacity="0.5"/>
  <!-- Light bulb above head (idea!) -->
  <path d="M95,18 Q93,10 100,8 Q107,10 105,18" fill="#fff9c4" stroke="#ffd54f" stroke-width="1"/>
  <rect x="96" y="18" width="8" height="3" fill="#ffd54f" rx="0.5"/>
  <rect x="97" y="21" width="6" height="1.5" fill="#ffc107" rx="0.5"/>
  <!-- Light rays -->
  <line x1="100" y1="3" x2="100" y2="0" stroke="#ffd54f" stroke-width="1.5"/>
  <line x1="88" y1="8" x2="85" y2="5" stroke="#ffd54f" stroke-width="1.5"/>
  <line x1="112" y1="8" x2="115" y2="5" stroke="#ffd54f" stroke-width="1.5"/>
  <!-- Mathematical/science symbols floating -->
  <text x="35" y="55" font-size="11" fill="#1565c0" opacity="0.5" font-family="serif">E=mc²</text>
  <text x="145" y="50" font-size="14" fill="#1565c0" opacity="0.4" font-family="serif">π</text>
  <text x="155" y="75" font-size="10" fill="#1565c0" opacity="0.4" font-family="serif">∑</text>
  <text x="30" y="80" font-size="12" fill="#1565c0" opacity="0.4" font-family="serif">∞</text>
  <!-- Stack of books on floor -->
  <rect x="135" y="110" width="25" height="6" fill="#e53935" rx="1"/>
  <rect x="133" y="104" width="25" height="6" fill="#42a5f5" rx="1"/>
  <rect x="136" y="98" width="25" height="6" fill="#66bb6a" rx="1"/>
  <!-- Legs -->
  <rect x="93" y="95" width="6" height="22" fill="#455a64" rx="1"/>
  <rect x="101" y="95" width="6" height="22" fill="#455a64" rx="1"/>
  <!-- Shoes -->
  <ellipse cx="96" cy="118" rx="6" ry="3" fill="#5d4037"/>
  <ellipse cx="104" cy="118" rx="6" ry="3" fill="#5d4037"/>
  <!-- Floor -->
  <rect x="0" y="125" width="200" height="35" fill="#bbdefb" rx="0" opacity="0.4"/>
</svg>

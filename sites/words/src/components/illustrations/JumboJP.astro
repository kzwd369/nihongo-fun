<!-- Japanese ジャンボ = prefix for extra-large, works on abstract nouns too (lottery, names) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fffde7" rx="8"/>
  <!-- Sparkle effects -->
  <text x="20" y="25" font-size="14" fill="#fbc02d">✦</text>
  <text x="175" y="30" font-size="12" fill="#fbc02d">✦</text>
  <text x="20" y="120" font-size="10" fill="#fbc02d">✦</text>
  <text x="175" y="125" font-size="12" fill="#fbc02d">✦</text>
  <!-- Giant lottery ticket (center) -->
  <rect x="55" y="40" width="90" height="60" fill="#ffeb3b" stroke="#f57f17" stroke-width="2" rx="4"/>
  <!-- Ticket perforation border -->
  <rect x="58" y="43" width="84" height="54" fill="none" stroke="#f57f17" stroke-width="1" stroke-dasharray="2,2" rx="3"/>
  <!-- Ticket title -->
  <text x="100" y="58" font-size="11" font-weight="bold" fill="#c62828" text-anchor="middle">ジャンボ宝くじ</text>
  <!-- Prize amount -->
  <text x="100" y="78" font-size="16" font-weight="bold" fill="#b71c1c" text-anchor="middle">7億円</text>
  <!-- Small text -->
  <text x="100" y="92" font-size="7" fill="#6d4c41" text-anchor="middle">一等前後賞合わせて</text>
  <!-- Three icons illustrating other uses -->
  <!-- 1. Jumbo jet (physical size) -->
  <g transform="translate(15,108)">
    <ellipse cx="20" cy="10" rx="18" ry="4" fill="#90caf9" stroke="#1976d2" stroke-width="0.8"/>
    <polygon points="2,10 -5,6 -5,14" fill="#90caf9" stroke="#1976d2" stroke-width="0.8"/>
    <polygon points="10,6 15,-2 20,6" fill="#90caf9" stroke="#1976d2" stroke-width="0.8"/>
    <circle cx="12" cy="10" r="1" fill="#1976d2"/>
    <circle cx="20" cy="10" r="1" fill="#1976d2"/>
    <circle cx="28" cy="10" r="1" fill="#1976d2"/>
    <text x="20" y="30" font-size="7" font-weight="bold" fill="#1565c0" text-anchor="middle">ジャンボ機</text>
  </g>
  <!-- 2. Jumbo parfait -->
  <g transform="translate(80,110)">
    <path d="M10,5 L8,25 L22,25 L20,5 Z" fill="#fff3e0" stroke="#6d4c41" stroke-width="0.8"/>
    <circle cx="15" cy="4" r="3" fill="#ffcdd2"/>
    <circle cx="11" cy="2" r="2" fill="#fff9c4"/>
    <circle cx="19" cy="2" r="2" fill="#c8e6c9"/>
    <text x="15" y="35" font-size="7" font-weight="bold" fill="#6d4c41" text-anchor="middle">ジャンボパフェ</text>
  </g>
  <!-- 3. Jumbo (nickname) -->
  <g transform="translate(140,108)">
    <!-- Stout character -->
    <circle cx="20" cy="10" r="7" fill="#ffcc80"/>
    <circle cx="18" cy="9" r="0.8" fill="#3e2723"/>
    <circle cx="22" cy="9" r="0.8" fill="#3e2723"/>
    <path d="M17,12 Q20,14 23,12" fill="none" stroke="#3e2723" stroke-width="0.8" stroke-linecap="round"/>
    <ellipse cx="20" cy="23" rx="12" ry="6" fill="#8d6e63"/>
    <text x="20" y="38" font-size="7" font-weight="bold" fill="#5d4037" text-anchor="middle">ジャンボ〇〇</text>
  </g>
  <!-- Title -->
  <text x="100" y="20" font-size="11" font-weight="bold" fill="#f57f17" text-anchor="middle">「ジャンボ」何にでもつく</text>
  <text x="100" y="35" font-size="7" fill="#827717" text-anchor="middle">(物理的にも抽象的にもOK)</text>
</svg>

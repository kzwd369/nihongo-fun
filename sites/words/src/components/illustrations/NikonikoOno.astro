  <path d="M75,72 Q82,62 89,72" fill="none" stroke="#5d4037" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M111,72 Q118,62 125,72" fill="none" stroke="#5d4037" stroke-width="2.5" stroke-linecap="round"/>

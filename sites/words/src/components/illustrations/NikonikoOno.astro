  <circle cx="155" cy="128" r="2.5" fill="#ffcc02" opacity="0.5"/>
  <circle cx="45" cy="125" r="2.5" fill="#ffcc02" opacity="0.5"/>
  <!-- Tiny hearts -->
  <path d="M165,70 C165,66 170,66 170,70 C170,66 175,66 175,70 C175,76 170,80 170,80 C170,80 165,76 165,70Z" fill="#ef9a9a" opacity="0.5"/>
  <path d="M25,65 C25,62 28,62 28,65 C28,62 31,62 31,65 C31,69 28,72 28,72 C28,72 25,69 25,65Z" fill="#ef9a9a" opacity="0.5"/>

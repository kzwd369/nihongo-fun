<!-- Dog face barking — ワンワン (dog bark) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Sound burst lines -->
  <g stroke="#ff8a65" stroke-width="2.5" stroke-linecap="round" opacity="0.7">
    <line x1="155" y1="55" x2="170" y2="48"/>
    <line x1="160" y1="75" x2="178" y2="75"/>
    <line x1="155" y1="95" x2="170" y2="102"/>
  </g>
  <!-- Dog head -->
  <ellipse cx="90" cy="85" rx="50" ry="42" fill="#a1887f"/>
  <!-- Floppy ears -->
  <ellipse cx="55" cy="65" rx="14" ry="22" fill="#795548" transform="rotate(-15 55 65)"/>
  <ellipse cx="125" cy="65" rx="14" ry="22" fill="#795548" transform="rotate(15 125 65)"/>
  <!-- Snout -->
  <ellipse cx="90" cy="100" rx="22" ry="18" fill="#d7ccc8"/>
  <!-- Open barking mouth -->
  <ellipse cx="90" cy="108" rx="14" ry="11" fill="#5d4037"/>
  <ellipse cx="90" cy="113" rx="9" ry="5" fill="#ef5350"/>
  <!-- Tongue tip -->
  <path d="M85 116 Q90 120 95 116" fill="#ff8a80"/>
  <!-- Eyes - alert -->
  <circle cx="72" cy="78" r="4" fill="#3e2723"/>
  <circle cx="108" cy="78" r="4" fill="#3e2723"/>
  <circle cx="73" cy="77" r="1.5" fill="white"/>
  <circle cx="109" cy="77" r="1.5" fill="white"/>
  <!-- Nose -->
  <ellipse cx="90" cy="90" rx="5" ry="4" fill="#3e2723"/>
  <!-- Bark text bubbles -->
  <ellipse cx="160" cy="35" rx="28" ry="14" fill="white" stroke="#ff8a65" stroke-width="1.5"/>
  <text x="160" y="40" text-anchor="middle" font-family="sans-serif" font-size="11" font-weight="800" fill="#d84315">ワン!</text>
  <ellipse cx="170" cy="125" rx="24" ry="12" fill="white" stroke="#ff8a65" stroke-width="1.5"/>
  <text x="170" y="129" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="800" fill="#d84315">ワン!</text>
</svg>

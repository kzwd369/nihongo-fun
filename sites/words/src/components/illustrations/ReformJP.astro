<!-- Japanese リフォーム = home renovation/remodeling -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- House outline -->
  <polygon points="100,15 35,55 165,55" fill="#8d6e63" stroke="#6d4c41" stroke-width="1"/>
  <rect x="45" y="55" width="110" height="80" fill="#fff8e1" stroke="#bcaaa4" stroke-width="1"/>
  <!-- Window being renovated (half painted) -->
  <rect x="58" y="65" width="28" height="24" fill="#bbdefb" rx="1" stroke="#78909c" stroke-width="1"/>
  <rect x="58" y="65" width="14" height="24" fill="#81d4fa" rx="1"/>
  <line x1="72" y1="65" x2="72" y2="89" stroke="#78909c" stroke-width="0.5"/>
  <line x1="58" y1="77" x2="86" y2="77" stroke="#78909c" stroke-width="0.5"/>
  <!-- New window -->
  <rect x="114" y="65" width="28" height="24" fill="#81d4fa" rx="1" stroke="#78909c" stroke-width="1"/>
  <line x1="128" y1="65" x2="128" y2="89" stroke="#78909c" stroke-width="0.5"/>
  <line x1="114" y1="77" x2="142" y2="77" stroke="#78909c" stroke-width="0.5"/>
  <!-- Door -->
  <rect x="88" y="100" width="24" height="35" fill="#a1887f" rx="2"/>
  <circle cx="107" cy="118" r="2" fill="#ffd54f"/>
  <!-- Paint bucket -->
  <rect x="15" y="105" width="22" height="20" fill="#78909c" rx="2"/>
  <rect x="13" y="102" width="26" height="5" fill="#90a4ae" rx="1"/>
  <ellipse cx="26" cy="107" rx="8" ry="3" fill="#42a5f5"/>
  <!-- Paint roller -->
  <line x1="170" y1="70" x2="170" y2="110" stroke="#795548" stroke-width="2"/>
  <rect x="163" y="65" width="14" height="10" fill="#42a5f5" rx="2"/>
  <!-- Paint drip on wall -->
  <path d="M150 55 L150 62" stroke="#42a5f5" stroke-width="2" stroke-linecap="round"/>
  <circle cx="150" cy="64" r="2" fill="#42a5f5"/>
  <!-- Hammer -->
  <line x1="25" y1="80" x2="35" y2="95" stroke="#795548" stroke-width="2"/>
  <rect x="17" y="74" width="12" height="8" fill="#bdbdbd" rx="1" transform="rotate(-30, 23, 78)"/>
  <!-- Label -->
  <text x="100" y="152" text-anchor="middle" font-size="11" fill="#2e7d32" font-family="sans-serif">リフォーム = home renovation</text>
</svg>

<!-- Love confession moment: a heart with a letter/envelope and sparkles around it -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#fce4ec"/>

  <!-- Envelope body -->
  <rect x="65" y="70" width="70" height="45" rx="4" fill="#fff" stroke="#f48fb1" stroke-width="1.5"/>
  <!-- Envelope flap -->
  <polygon points="65,70 100,95 135,70" fill="#f8bbd0" stroke="#f48fb1" stroke-width="1.5"/>

  <!-- Heart coming out of envelope -->
  <path d="M100,40 C100,40 88,28 78,32 C68,36 68,48 78,56 L100,72 L122,56 C132,48 132,36 122,32 C112,28 100,40 100,40Z" fill="#e91e63" opacity="0.85"/>
  <!-- Heart shine -->
  <ellipse cx="90" cy="42" rx="5" ry="3" fill="#fff" opacity="0.4" transform="rotate(-20 90 42)"/>

  <!-- Sparkles -->
  <circle cx="50" cy="45" r="2" fill="#f48fb1"/>
  <circle cx="48" cy="43" r="1" fill="#e91e63" opacity="0.6"/>

  <circle cx="150" cy="50" r="2.5" fill="#f48fb1"/>
  <circle cx="153" cy="47" r="1" fill="#e91e63" opacity="0.6"/>

  <circle cx="145" cy="90" r="1.5" fill="#f48fb1" opacity="0.7"/>

  <circle cx="55" cy="100" r="1.5" fill="#f48fb1" opacity="0.7"/>

  <!-- Four-point star sparkle left -->
  <path d="M40,70 L42,66 L44,70 L42,74Z" fill="#e91e63" opacity="0.5"/>

  <!-- Four-point star sparkle right -->
  <path d="M160,75 L162,71 L164,75 L162,79Z" fill="#e91e63" opacity="0.5"/>

  <!-- Small hearts floating -->
  <path d="M55,55 C55,55 52,52 50,53 C48,54 48,57 50,59 L55,63 L60,59 C62,57 62,54 60,53 C58,52 55,55 55,55Z" fill="#f48fb1" opacity="0.6"/>
  <path d="M148,110 C148,110 146,108 144,109 C142,110 142,112 144,113 L148,116 L152,113 C154,112 154,110 152,109 C150,108 148,110 148,110Z" fill="#f48fb1" opacity="0.5"/>
</svg>

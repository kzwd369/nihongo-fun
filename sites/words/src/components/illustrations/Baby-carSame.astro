<!-- ベビーカー = baby stroller / pushchair -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Ground -->
  <rect x="0" y="135" width="200" height="25" fill="#e8f5e9" rx="0"/>
  <!-- Path -->
  <rect x="10" y="135" width="180" height="10" fill="#f5f5f5" rx="2"/>
  <!-- Stroller frame -->
  <!-- Back legs -->
  <line x1="70" y1="75" x2="60" y2="130" stroke="#78909c" stroke-width="3" stroke-linecap="round"/>
  <!-- Front legs -->
  <line x1="120" y1="100" x2="135" y2="130" stroke="#78909c" stroke-width="3" stroke-linecap="round"/>
  <!-- Axle connector -->
  <line x1="65" y1="115" x2="132" y2="125" stroke="#78909c" stroke-width="2" stroke-linecap="round"/>
  <!-- Handle -->
  <line x1="70" y1="75" x2="55" y2="45" stroke="#78909c" stroke-width="3" stroke-linecap="round"/>
  <line x1="55" y1="45" x2="48" y2="45" stroke="#37474f" stroke-width="4" stroke-linecap="round"/>
  <!-- Seat/canopy -->
  <path d="M68 70 L125 70 L130 100 L63 100 Z" fill="#ff8a80" rx="2"/>
  <!-- Canopy top -->
  <path d="M65 70 Q75 35 120 40 L125 70 Z" fill="#ef5350" opacity="0.8"/>
  <!-- Canopy support -->
  <line x1="68" y1="70" x2="78" y2="42" stroke="#78909c" stroke-width="1.5"/>
  <!-- Baby peeking out -->
  <!-- Baby head -->
  <circle cx="100" cy="58" r="10" fill="#ffe0b2"/>
  <!-- Baby eyes -->
  <circle cx="96" cy="57" r="1.5" fill="#37474f"/>
  <circle cx="104" cy="57" r="1.5" fill="#37474f"/>
  <!-- Baby smile -->
  <path d="M96 62 Q100 65 104 62" fill="none" stroke="#37474f" stroke-width="1" stroke-linecap="round"/>
  <!-- Baby hat -->
  <path d="M90 53 Q92 45 100 43 Q108 45 110 53" fill="#fff9c4"/>
  <rect x="88" y="52" width="24" height="3" fill="#ffd54f" rx="1"/>
  <!-- Baby body in seat -->
  <rect x="88" y="68" width="24" height="25" fill="#bbdefb" rx="3"/>
  <!-- Baby blanket -->
  <rect x="80" y="85" width="40" height="15" fill="#c8e6c9" rx="2"/>
  <!-- Back wheel -->
  <circle cx="58" cy="132" r="9" fill="#546e7a"/>
  <circle cx="58" cy="132" r="5" fill="#78909c"/>
  <circle cx="58" cy="132" r="2" fill="#b0bec5"/>
  <!-- Front wheel -->
  <circle cx="137" cy="132" r="7" fill="#546e7a"/>
  <circle cx="137" cy="132" r="4" fill="#78909c"/>
  <circle cx="137" cy="132" r="1.5" fill="#b0bec5"/>
  <!-- Storage basket underneath -->
  <path d="M70 118 L125 122 L128 128 L67 124 Z" fill="#e0e0e0" opacity="0.6"/>
  <!-- Small bag in basket -->
  <rect x="85" y="118" width="14" height="8" fill="#ce93d8" rx="2"/>
  <!-- Small decorative elements -->
  <!-- Stars/sparkles -->
  <text x="155" y="50" font-size="12" fill="#ffd54f" opacity="0.6">✦</text>
  <text x="165" y="80" font-size="8" fill="#ffd54f" opacity="0.4">✦</text>
  <!-- Tree in background -->
  <rect x="170" y="90" width="6" height="45" fill="#a1887f" rx="1"/>
  <circle cx="173" cy="80" r="18" fill="#a5d6a7" opacity="0.5"/>
  <circle cx="165" cy="88" r="12" fill="#81c784" opacity="0.4"/>
</svg>

<!-- A surprised face with exclamation and question marks and speed lines, representing anime reaction words -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#fce4ec" />
  <!-- Speed lines radiating outward -->
  <line x1="100" y1="10" x2="100" y2="25" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="145" y1="22" x2="138" y2="35" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="55" y1="22" x2="62" y2="35" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="168" y1="55" x2="155" y2="60" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="32" y1="55" x2="45" y2="60" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="170" y1="90" x2="157" y2="88" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <line x1="30" y1="90" x2="43" y2="88" stroke="#f8bbd0" stroke-width="1.5" stroke-linecap="round" />
  <!-- Face circle -->
  <circle cx="100" cy="82" r="34" fill="#f48fb1" />
  <!-- Wide shocked eyes -->
  <ellipse cx="88" cy="78" rx="7" ry="9" fill="white" />
  <ellipse cx="112" cy="78" rx="7" ry="9" fill="white" />
  <circle cx="88" cy="80" r="3.5" fill="#880e4f" />
  <circle cx="112" cy="80" r="3.5" fill="#880e4f" />
  <!-- Tiny highlight dots in eyes -->
  <circle cx="90" cy="77" r="1.5" fill="white" />
  <circle cx="114" cy="77" r="1.5" fill="white" />
  <!-- Open shocked mouth -->
  <ellipse cx="100" cy="99" rx="8" ry="6" fill="#880e4f" />
  <!-- "!" mark top-right -->
  <line x1="152" y1="28" x2="152" y2="48" stroke="#e91e63" stroke-width="3.5" stroke-linecap="round" />
  <circle cx="152" cy="55" r="2.5" fill="#e91e63" />
  <!-- "?!" mark top-left -->
  <path d="M 42 30 Q 42 22 50 22 Q 58 22 58 30 Q 58 36 50 38" fill="none" stroke="#e91e63" stroke-width="2.5" stroke-linecap="round" />
  <circle cx="50" cy="44" r="2" fill="#e91e63" />
  <!-- Sweat drop -->
  <path d="M 130 58 Q 133 50 136 58 Q 133 62 130 58" fill="#f8bbd0" />
</svg>

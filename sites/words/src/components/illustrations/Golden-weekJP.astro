<!-- Japanese ゴールデンウィーク = cluster of holidays from late April to early May -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Sky gradient feel -->
  <rect x="10" y="8" width="180" height="144" fill="#e8f5e9" rx="6"/>
  <!-- Calendar -->
  <rect x="30" y="20" width="100" height="90" fill="white" rx="4" stroke="#e0e0e0" stroke-width="1"/>
  <!-- Calendar header -->
  <rect x="30" y="20" width="100" height="18" fill="#ef5350" rx="4"/>
  <rect x="30" y="32" width="100" height="6" fill="#ef5350"/>
  <text x="80" y="34" font-size="10" fill="white" text-anchor="middle" font-family="sans-serif" font-weight="bold">4月-5月</text>
  <!-- Day headers -->
  <text x="39" y="48" font-size="5" fill="#ef5350" font-family="sans-serif">日</text>
  <text x="49" y="48" font-size="5" fill="#37474f" font-family="sans-serif">月</text>
  <text x="59" y="48" font-size="5" fill="#37474f" font-family="sans-serif">火</text>
  <text x="69" y="48" font-size="5" fill="#37474f" font-family="sans-serif">水</text>
  <text x="79" y="48" font-size="5" fill="#37474f" font-family="sans-serif">木</text>
  <text x="89" y="48" font-size="5" fill="#37474f" font-family="sans-serif">金</text>
  <text x="99" y="48" font-size="5" fill="#42a5f5" font-family="sans-serif">土</text>
  <!-- Week with GW holidays highlighted -->
  <text x="39" y="58" font-size="5" fill="#bdbdbd" font-family="sans-serif">27</text>
  <text x="49" y="58" font-size="5" fill="#bdbdbd" font-family="sans-serif">28</text>
  <!-- Apr 29 - Showa Day -->
  <circle cx="61" cy="56" r="5" fill="#ffcdd2"/>
  <text x="59" y="58" font-size="5" fill="#ef5350" font-family="sans-serif">29</text>
  <text x="69" y="58" font-size="5" fill="#37474f" font-family="sans-serif">30</text>
  <text x="79" y="58" font-size="5" fill="#37474f" font-family="sans-serif">1</text>
  <text x="89" y="58" font-size="5" fill="#37474f" font-family="sans-serif">2</text>
  <!-- May 3 - Constitution Day -->
  <circle cx="41" cy="66" r="5" fill="#ffcdd2"/>
  <text x="39" y="68" font-size="5" fill="#ef5350" font-family="sans-serif">3</text>
  <!-- May 4 - Greenery Day -->
  <circle cx="51" cy="66" r="5" fill="#c8e6c9"/>
  <text x="49" y="68" font-size="5" fill="#43a047" font-family="sans-serif">4</text>
  <!-- May 5 - Children's Day -->
  <circle cx="61" cy="66" r="5" fill="#bbdefb"/>
  <text x="59" y="68" font-size="5" fill="#1e88e5" font-family="sans-serif">5</text>
  <text x="69" y="68" font-size="5" fill="#37474f" font-family="sans-serif">6</text>
  <text x="79" y="68" font-size="5" fill="#37474f" font-family="sans-serif">7</text>
  <text x="89" y="68" font-size="5" fill="#37474f" font-family="sans-serif">8</text>
  <text x="99" y="68" font-size="5" fill="#42a5f5" font-family="sans-serif">9</text>
  <!-- GW bracket -->
  <rect x="33" y="72" width="62" height="8" fill="#fff9c4" rx="2" opacity="0.7"/>
  <text x="64" y="78" font-size="5" fill="#f9a825" text-anchor="middle" font-family="sans-serif" font-weight="bold">GW ✦</text>
  <!-- Koinobori (carp streamers) -->
  <!-- Pole -->
  <line x1="155" y1="20" x2="155" y2="120" stroke="#8d6e63" stroke-width="2"/>
  <circle cx="155" cy="18" r="3" fill="#ffd54f"/>
  <!-- Arrow/spinner -->
  <line x1="150" y1="24" x2="160" y2="24" stroke="#78909c" stroke-width="1"/>
  <!-- Black carp (father) -->
  <ellipse cx="168" cy="38" rx="16" ry="6" fill="#37474f"/>
  <circle cx="178" cy="37" r="2" fill="white"/>
  <circle cx="179" cy="37" r="1" fill="#37474f"/>
  <path d="M152 32 L155 38 L152 44" fill="#37474f"/>
  <!-- Scales -->
  <path d="M160 34 Q163 38 160 42" fill="none" stroke="#546e7a" stroke-width="0.5"/>
  <path d="M165 34 Q168 38 165 42" fill="none" stroke="#546e7a" stroke-width="0.5"/>
  <!-- Red carp (mother) -->
  <ellipse cx="170" cy="54" rx="14" ry="5" fill="#ef5350"/>
  <circle cx="179" cy="53" r="1.8" fill="white"/>
  <circle cx="179.8" cy="53" r="0.9" fill="#ef5350"/>
  <path d="M156 49 L158 54 L156 59" fill="#ef5350"/>
  <!-- Blue carp (child) -->
  <ellipse cx="172" cy="68" rx="12" ry="4" fill="#42a5f5"/>
  <circle cx="180" cy="67.5" r="1.5" fill="white"/>
  <circle cx="180.7" cy="67.5" r="0.7" fill="#42a5f5"/>
  <path d="M160 64 L162 68 L160 72" fill="#42a5f5"/>
  <!-- Cherry blossom petals scattered -->
  <circle cx="20" cy="30" r="3" fill="#f8bbd0" opacity="0.7"/>
  <circle cx="22" cy="28" r="3" fill="#f8bbd0" opacity="0.7"/>
  <circle cx="18" cy="28" r="3" fill="#f8bbd0" opacity="0.7"/>
  <circle cx="20" cy="26" r="3" fill="#f8bbd0" opacity="0.7"/>
  <circle cx="20" cy="29" r="1.5" fill="#fce4ec"/>
  <circle cx="140" cy="100" r="3" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="142" cy="98" r="3" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="138" cy="98" r="3" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="140" cy="96" r="3" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="140" cy="99" r="1.5" fill="#fce4ec"/>
  <!-- Small blossoms -->
  <circle cx="15" cy="100" r="2" fill="#f8bbd0" opacity="0.5"/>
  <circle cx="50" cy="130" r="2" fill="#f8bbd0" opacity="0.4"/>
  <circle cx="110" cy="135" r="2" fill="#f8bbd0" opacity="0.5"/>
</svg>

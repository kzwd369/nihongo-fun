<!-- English "Fight!" = literal physical combat / boxing -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#212121" rx="8"/>
  <!-- Boxing ring floor -->
  <rect x="0" y="110" width="200" height="50" fill="#546e7a"/>
  <!-- Ring ropes -->
  <line x1="10" y1="118" x2="190" y2="118" stroke="#e0e0e0" stroke-width="2"/>
  <line x1="10" y1="125" x2="190" y2="125" stroke="#bdbdbd" stroke-width="2"/>
  <!-- Corner posts -->
  <rect x="5" y="108" width="6" height="52" fill="#c62828"/>
  <rect x="189" y="108" width="6" height="52" fill="#1565c0"/>
  <!-- Spotlight effect -->
  <ellipse cx="100" cy="80" rx="70" ry="30" fill="#fff9c4" opacity="0.15"/>
  <!-- Boxer 1 (left - red gloves) -->
  <circle cx="70" cy="55" r="11" fill="#ffcc80"/>
  <!-- Headgear -->
  <path d="M60 50 Q70 42 80 50 L80 58 L60 58 Z" fill="#c62828"/>
  <!-- Angry eyes -->
  <line x1="64" y1="54" x2="68" y2="56" stroke="#000" stroke-width="2"/>
  <line x1="76" y1="54" x2="72" y2="56" stroke="#000" stroke-width="2"/>
  <!-- Gritted teeth -->
  <rect x="66" y="59" width="8" height="3" fill="white" stroke="#000" stroke-width="0.5"/>
  <line x1="68" y1="59" x2="68" y2="62" stroke="#000" stroke-width="0.3"/>
  <line x1="70" y1="59" x2="70" y2="62" stroke="#000" stroke-width="0.3"/>
  <line x1="72" y1="59" x2="72" y2="62" stroke="#000" stroke-width="0.3"/>
  <!-- Body -->
  <rect x="60" y="66" width="20" height="25" fill="#c62828" rx="2"/>
  <!-- Arm punching forward with glove -->
  <line x1="78" y1="72" x2="100" y2="80" stroke="#ffcc80" stroke-width="5" stroke-linecap="round"/>
  <circle cx="105" cy="80" r="9" fill="#d32f2f" stroke="#7f0000" stroke-width="1.5"/>
  <text x="105" y="84" font-size="7" fill="white" text-anchor="middle" font-weight="bold">🥊</text>
  <!-- Other arm defending -->
  <circle cx="58" cy="75" r="7" fill="#d32f2f" stroke="#7f0000" stroke-width="1.5"/>
  <!-- Legs -->
  <line x1="65" y1="91" x2="62" y2="108" stroke="#1a237e" stroke-width="5" stroke-linecap="round"/>
  <line x1="75" y1="91" x2="78" y2="108" stroke="#1a237e" stroke-width="5" stroke-linecap="round"/>
  <!-- Boxer 2 (right - blue gloves) -->
  <circle cx="140" cy="55" r="11" fill="#ffcc80"/>
  <path d="M130 50 Q140 42 150 50 L150 58 L130 58 Z" fill="#1565c0"/>
  <line x1="134" y1="54" x2="138" y2="56" stroke="#000" stroke-width="2"/>
  <line x1="146" y1="54" x2="142" y2="56" stroke="#000" stroke-width="2"/>
  <rect x="136" y="59" width="8" height="3" fill="white" stroke="#000" stroke-width="0.5"/>
  <!-- Body -->
  <rect x="130" y="66" width="20" height="25" fill="#1565c0" rx="2"/>
  <!-- Arm defending -->
  <circle cx="122" cy="78" r="8" fill="#1976d2" stroke="#0d47a1" stroke-width="1.5"/>
  <!-- Arm pulled back -->
  <line x1="150" y1="72" x2="162" y2="68" stroke="#ffcc80" stroke-width="5" stroke-linecap="round"/>
  <circle cx="165" cy="66" r="8" fill="#1976d2" stroke="#0d47a1" stroke-width="1.5"/>
  <!-- Legs -->
  <line x1="135" y1="91" x2="132" y2="108" stroke="#263238" stroke-width="5" stroke-linecap="round"/>
  <line x1="145" y1="91" x2="148" y2="108" stroke="#263238" stroke-width="5" stroke-linecap="round"/>
  <!-- Impact/POW effect between them -->
  <polygon points="100,75 112,72 108,82 115,88 105,90 100,98 95,88 85,85 93,78" fill="#ffeb3b" stroke="#f57f17" stroke-width="1"/>
  <text x="100" y="87" font-size="9" font-weight="bold" fill="#c62828" text-anchor="middle">POW!</text>
  <!-- "FIGHT!" big text -->
  <rect x="60" y="15" width="80" height="22" fill="#c62828" stroke="#fff" stroke-width="2" rx="3"/>
  <text x="100" y="31" font-size="15" font-weight="bold" fill="white" text-anchor="middle" font-family="Arial Black">FIGHT!</text>
  <!-- Label -->
  <text x="100" y="152" font-size="9" font-weight="bold" fill="#ffeb3b" text-anchor="middle">"Fight!" = Literal physical combat</text>
</svg>

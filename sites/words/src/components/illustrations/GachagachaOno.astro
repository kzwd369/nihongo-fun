<!-- Capsule toy vending machine — ガチャガチャ (gachagacha) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f3e5f5" rx="8"/>
  <!-- Machine body -->
  <rect x="55" y="20" width="90" height="130" fill="#e0e0e0" rx="6"/>
  <rect x="58" y="23" width="84" height="124" fill="#eeeeee" rx="4"/>
  <!-- Globe dome (transparent capsule container) -->
  <ellipse cx="100" cy="58" rx="35" ry="32" fill="#e3f2fd" opacity="0.7"/>
  <ellipse cx="100" cy="58" rx="35" ry="32" fill="none" stroke="#90caf9" stroke-width="1.5"/>
  <!-- Shine on dome -->
  <ellipse cx="82" cy="42" rx="8" ry="12" fill="white" opacity="0.4" transform="rotate(-15, 82, 42)"/>
  <!-- Colorful capsules inside -->
  <circle cx="85" cy="50" r="7" fill="#ef5350" opacity="0.85"/>
  <circle cx="100" cy="45" r="7" fill="#42a5f5" opacity="0.85"/>
  <circle cx="115" cy="50" r="7" fill="#66bb6a" opacity="0.85"/>
  <circle cx="92" cy="62" r="7" fill="#ffa726" opacity="0.85"/>
  <circle cx="108" cy="62" r="7" fill="#ab47bc" opacity="0.85"/>
  <circle cx="100" cy="73" r="7" fill="#ffee58" opacity="0.85"/>
  <circle cx="85" cy="72" r="6" fill="#ec407a" opacity="0.85"/>
  <circle cx="115" cy="72" r="6" fill="#26c6da" opacity="0.85"/>
  <!-- Capsule highlights -->
  <circle cx="83" cy="48" r="2" fill="white" opacity="0.5"/>
  <circle cx="98" cy="43" r="2" fill="white" opacity="0.5"/>
  <circle cx="113" cy="48" r="2" fill="white" opacity="0.5"/>
  <!-- Machine middle section -->
  <rect x="60" y="88" width="80" height="25" fill="#bdbdbd" rx="2"/>
  <!-- Coin slot -->
  <rect x="110" y="94" width="14" height="3" fill="#757575" rx="1"/>
  <!-- Crank/dial -->
  <circle cx="82" cy="100" r="9" fill="#ff7043" stroke="#e64a19" stroke-width="1.5"/>
  <circle cx="82" cy="100" r="4" fill="#e64a19"/>
  <line x1="82" y1="100" x2="73" y2="96" stroke="#e64a19" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Dispensing area -->
  <rect x="70" y="118" width="60" height="22" fill="#9e9e9e" rx="3"/>
  <rect x="75" y="120" width="50" height="18" fill="#212121" rx="2"/>
  <!-- Capsule coming out -->
  <circle cx="100" cy="129" r="7" fill="#ef5350"/>
  <circle cx="98" cy="127" r="2" fill="white" opacity="0.4"/>
  <!-- Label -->
  <rect x="68" y="8" width="64" height="14" fill="#ff7043" rx="3"/>
  <text x="100" y="18" font-size="7" fill="white" text-anchor="middle" font-weight="bold" font-family="sans-serif">GACHA GACHA</text>
</svg>

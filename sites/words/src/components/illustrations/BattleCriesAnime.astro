<!-- Battle energy / power-up: a raised fist with energy lines and star bursts -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#fff3e0"/>

  <!-- Speed / energy lines radiating outward -->
  <line x1="100" y1="20" x2="100" y2="8" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <line x1="130" y1="28" x2="140" y2="16" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="70" y1="28" x2="60" y2="16" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="148" y1="55" x2="162" y2="48" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
  <line x1="52" y1="55" x2="38" y2="48" stroke="#e64a19" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
  <line x1="155" y1="80" x2="168" y2="80" stroke="#e64a19" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
  <line x1="45" y1="80" x2="32" y2="80" stroke="#e64a19" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>

  <!-- Fist - wrist/arm -->
  <rect x="90" y="100" width="20" height="30" rx="4" fill="#ffcc80"/>

  <!-- Fist - main block -->
  <rect x="82" y="60" width="36" height="42" rx="8" fill="#ffcc80"/>
  <!-- Fist - thumb -->
  <rect x="76" y="82" width="12" height="18" rx="5" fill="#ffb74d"/>
  <!-- Finger lines -->
  <line x1="88" y1="68" x2="112" y2="68" stroke="#e64a19" stroke-width="0.8" opacity="0.4"/>
  <line x1="88" y1="78" x2="112" y2="78" stroke="#e64a19" stroke-width="0.8" opacity="0.4"/>
  <line x1="88" y1="88" x2="112" y2="88" stroke="#e64a19" stroke-width="0.8" opacity="0.4"/>

  <!-- Star burst top-left -->
  <path d="M55,35 L57,29 L59,35 L65,33 L61,37 L65,41 L59,39 L57,45 L55,39 L49,41 L53,37 L49,33Z" fill="#ff8f00" opacity="0.7"/>

  <!-- Star burst top-right -->
  <path d="M148,38 L150,33 L152,38 L156,36 L154,40 L156,44 L152,42 L150,47 L148,42 L144,44 L146,40 L144,36Z" fill="#ff8f00" opacity="0.6"/>

  <!-- Small star bottom-left -->
  <path d="M38,105 L39,101 L40,105 L44,104 L41,106 L44,108 L40,107 L39,111 L38,107 L34,108 L37,106 L34,104Z" fill="#e64a19" opacity="0.5"/>

  <!-- Energy circle glow -->
  <circle cx="100" cy="80" r="32" fill="none" stroke="#ffab40" stroke-width="1.5" opacity="0.3"/>
  <circle cx="100" cy="80" r="42" fill="none" stroke="#ffab40" stroke-width="1" opacity="0.15"/>
</svg>

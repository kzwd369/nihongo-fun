<!-- Three face silhouettes with different expressions representing ore/boku/watashi character personalities -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#ede7f6" />
  <!-- Face 1: Tough (ore) - left -->
  <circle cx="40" cy="72" r="22" fill="#b39ddb" />
  <!-- Angry/tough brows -->
  <line x1="30" y1="65" x2="38" y2="68" stroke="#4a148c" stroke-width="2" stroke-linecap="round" />
  <line x1="50" y1="65" x2="42" y2="68" stroke="#4a148c" stroke-width="2" stroke-linecap="round" />
  <!-- Eyes -->
  <circle cx="34" cy="72" r="2" fill="#4a148c" />
  <circle cx="46" cy="72" r="2" fill="#4a148c" />
  <!-- Confident mouth -->
  <path d="M 34 80 L 40 83 L 46 80" fill="none" stroke="#4a148c" stroke-width="1.5" stroke-linecap="round" />
  <!-- Spiky hair hint -->
  <path d="M 22 58 L 28 42 L 34 56" fill="#7e57c2" />
  <path d="M 32 54 L 40 38 L 46 54" fill="#7e57c2" />
  <path d="M 44 56 L 52 42 L 58 58" fill="#7e57c2" />
  <!-- Face 2: Gentle (boku) - center -->
  <circle cx="100" cy="72" r="22" fill="#ce93d8" />
  <!-- Soft eyes -->
  <ellipse cx="93" cy="71" rx="2.5" ry="3" fill="#4a148c" />
  <ellipse cx="107" cy="71" rx="2.5" ry="3" fill="#4a148c" />
  <!-- Gentle smile -->
  <path d="M 93 80 Q 100 86 107 80" fill="none" stroke="#4a148c" stroke-width="1.5" stroke-linecap="round" />
  <!-- Soft hair -->
  <ellipse cx="100" cy="54" rx="24" ry="10" fill="#7e57c2" />
  <!-- Face 3: Neutral (watashi) - right -->
  <circle cx="160" cy="72" r="22" fill="#b39ddb" />
  <!-- Neutral eyes -->
  <circle cx="153" cy="71" r="2" fill="#4a148c" />
  <circle cx="167" cy="71" r="2" fill="#4a148c" />
  <!-- Neutral mouth -->
  <line x1="154" y1="81" x2="166" y2="81" stroke="#4a148c" stroke-width="1.5" stroke-linecap="round" />
  <!-- Neat hair -->
  <path d="M 138 64 Q 142 44 160 42 Q 178 44 182 64" fill="#7e57c2" />
  <!-- Decorative dots -->
  <circle cx="40" cy="115" r="3" fill="#d1c4e9" />
  <circle cx="100" cy="115" r="3" fill="#d1c4e9" />
  <circle cx="160" cy="115" r="3" fill="#d1c4e9" />
</svg>

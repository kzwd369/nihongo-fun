<!-- English "pierce" = verb to puncture -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e0f2f1" rx="8"/>
  <!-- Dictionary page look -->
  <rect x="15" y="15" width="170" height="130" fill="#fff8e1" stroke="#8d6e63" stroke-width="1.5" rx="2"/>
  <line x1="25" y1="30" x2="175" y2="30" stroke="#d7ccc8" stroke-width="0.3"/>
  <!-- Headword -->
  <text x="30" y="40" font-size="16" font-weight="bold" fill="#3e2723">pierce</text>
  <text x="100" y="40" font-size="9" font-style="italic" fill="#5d4037">/pɪərs/</text>
  <text x="150" y="40" font-size="8" fill="#795548">verb</text>
  <!-- Definition -->
  <text x="30" y="55" font-size="7" fill="#3e2723">1. to make a hole through</text>
  <text x="30" y="64" font-size="7" fill="#3e2723">   something with a sharp object</text>
  <!-- Illustration panel inside -->
  <rect x="30" y="72" width="140" height="50" fill="#b2dfdb" rx="3"/>
  <!-- Needle piercing through -->
  <!-- Fabric/ear piece -->
  <ellipse cx="100" cy="97" rx="20" ry="10" fill="#ffcc80" stroke="#8d6e63" stroke-width="1"/>
  <!-- Needle coming through -->
  <line x1="50" y1="97" x2="150" y2="97" stroke="#b0bec5" stroke-width="2"/>
  <polygon points="150,94 158,97 150,100" fill="#78909c"/>
  <!-- Needle base (eye) -->
  <ellipse cx="48" cy="97" rx="4" ry="3" fill="#90a4ae" stroke="#546e7a" stroke-width="0.5"/>
  <circle cx="48" cy="97" r="1.5" fill="#263238"/>
  <!-- Hole in material -->
  <ellipse cx="100" cy="97" rx="1.5" ry="0.8" fill="#5d4037"/>
  <!-- Action dots -->
  <circle cx="130" cy="92" r="0.8" fill="#ef5350"/>
  <circle cx="135" cy="95" r="0.6" fill="#ef5350"/>
  <!-- Example sentences -->
  <text x="30" y="132" font-size="6" fill="#5d4037" font-style="italic">"The arrow pierced the target."</text>
  <text x="30" y="140" font-size="6" fill="#5d4037" font-style="italic">"She pierced her ears."</text>
  <!-- Red X over wrong usage box -->
  <rect x="115" y="125" width="60" height="18" fill="#ffebee" stroke="#c62828" stroke-width="1" rx="2"/>
  <text x="145" y="133" font-size="6" fill="#c62828" text-anchor="middle">"I bought a pierce"</text>
  <line x1="117" y1="127" x2="173" y2="141" stroke="#c62828" stroke-width="2"/>
  <line x1="173" y1="127" x2="117" y2="141" stroke="#c62828" stroke-width="2"/>
  <!-- Label -->
  <text x="100" y="155" font-size="8" font-weight="bold" fill="#004d40" text-anchor="middle">English: "pierce" = VERB, not a noun for earrings</text>
</svg>

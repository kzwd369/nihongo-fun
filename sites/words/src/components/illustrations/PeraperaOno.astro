<!-- Person with speech bubbles flowing smoothly — ペラペラ (fluent speech) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Person head -->
  <circle cx="65" cy="75" r="22" fill="#ffccbc"/>
  <!-- Hair -->
  <path d="M43 68 C43 50 55 48 65 48 C75 48 87 50 87 68 C87 62 80 55 65 55 C50 55 43 62 43 68Z" fill="#5d4037"/>
  <!-- Eyes -->
  <circle cx="57" cy="73" r="2.5" fill="#37474f"/>
  <circle cx="73" cy="73" r="2.5" fill="#37474f"/>
  <circle cx="58" cy="72" r="0.8" fill="white"/>
  <circle cx="74" cy="72" r="0.8" fill="white"/>
  <!-- Happy mouth (speaking) -->
  <ellipse cx="65" cy="83" rx="6" ry="4" fill="#e57373"/>
  <ellipse cx="65" cy="81" rx="5" ry="2" fill="#ffccbc"/>
  <!-- Body -->
  <rect x="50" y="97" width="30" height="35" fill="#42a5f5" rx="4"/>
  <!-- Neck -->
  <rect x="59" y="93" width="12" height="8" fill="#ffccbc"/>
  <!-- Speech bubbles flowing right -->
  <rect x="100" y="25" width="50" height="22" fill="white" rx="10" stroke="#81c784" stroke-width="1.5"/>
  <polygon points="98,36 106,33 106,40" fill="white" stroke="#81c784" stroke-width="1.5" stroke-linejoin="round"/>
  <polygon points="100,36 106,34 106,39" fill="white"/>
  <!-- Text lines in bubble 1 -->
  <line x1="110" y1="33" x2="125" y2="33" stroke="#81c784" stroke-width="2" stroke-linecap="round"/>
  <line x1="128" y1="33" x2="140" y2="33" stroke="#a5d6a7" stroke-width="2" stroke-linecap="round"/>
  <line x1="112" y1="39" x2="138" y2="39" stroke="#c8e6c9" stroke-width="2" stroke-linecap="round"/>
  <!-- Second speech bubble -->
  <rect x="115" y="55" width="55" height="22" fill="white" rx="10" stroke="#66bb6a" stroke-width="1.5"/>
  <polygon points="113,66 120,63 120,70" fill="white" stroke="#66bb6a" stroke-width="1.5" stroke-linejoin="round"/>
  <polygon points="115,66 120,64 120,69" fill="white"/>
  <!-- Text lines in bubble 2 -->
  <line x1="125" y1="63" x2="148" y2="63" stroke="#66bb6a" stroke-width="2" stroke-linecap="round"/>
  <line x1="150" y1="63" x2="160" y2="63" stroke="#a5d6a7" stroke-width="2" stroke-linecap="round"/>
  <line x1="127" y1="69" x2="158" y2="69" stroke="#c8e6c9" stroke-width="2" stroke-linecap="round"/>
  <!-- Third speech bubble -->
  <rect x="108" y="85" width="60" height="22" fill="white" rx="10" stroke="#4caf50" stroke-width="1.5"/>
  <polygon points="106,96 113,93 113,100" fill="white" stroke="#4caf50" stroke-width="1.5" stroke-linejoin="round"/>
  <polygon points="108,96 113,94 113,99" fill="white"/>
  <!-- Text lines in bubble 3 -->
  <line x1="118" y1="93" x2="140" y2="93" stroke="#4caf50" stroke-width="2" stroke-linecap="round"/>
  <line x1="143" y1="93" x2="158" y2="93" stroke="#81c784" stroke-width="2" stroke-linecap="round"/>
  <line x1="120" y1="99" x2="155" y2="99" stroke="#c8e6c9" stroke-width="2" stroke-linecap="round"/>
  <!-- Flow arrows / motion lines -->
  <path d="M90 45 Q95 42 100 45" fill="none" stroke="#81c784" stroke-width="1" opacity="0.5"/>
  <path d="M92 65 Q97 62 102 65" fill="none" stroke="#66bb6a" stroke-width="1" opacity="0.5"/>
  <path d="M90 90 Q95 87 100 90" fill="none" stroke="#4caf50" stroke-width="1" opacity="0.5"/>
  <!-- Small decorative elements -->
  <circle cx="175" cy="115" r="3" fill="#a5d6a7" opacity="0.5"/>
  <circle cx="180" cy="130" r="2" fill="#c8e6c9" opacity="0.4"/>
  <circle cx="22" cy="30" r="2.5" fill="#a5d6a7" opacity="0.4"/>
</svg>

<!-- Aloof face turned away with pout — ツンツン (aloof/prickly) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e1f5fe" rx="8"/>
  <!-- Spiky "tsun" spikes in background -->
  <polygon points="25,30 30,20 35,30" fill="#4fc3f7" opacity="0.6"/>
  <polygon points="165,25 170,15 175,25" fill="#4fc3f7" opacity="0.6"/>
  <polygon points="30,130 35,120 40,130" fill="#4fc3f7" opacity="0.5"/>
  <polygon points="170,135 175,125 180,135" fill="#4fc3f7" opacity="0.5"/>
  <!-- Head (slightly turned sideways) -->
  <ellipse cx="100" cy="82" rx="38" ry="42" fill="#ffe0b2"/>
  <!-- Spiky hair (ツンツン — spikes up) -->
  <path d="M62 72 L68 42 L75 60 L82 38 L90 58 L100 36 L110 58 L118 38 L125 60 L132 42 L138 72 Q125 55 100 53 Q75 55 62 72 Z" fill="#5d4037"/>
  <!-- Side glance eye (looking away to the side) -->
  <ellipse cx="82" cy="84" rx="5" ry="6" fill="white" stroke="#3e2723" stroke-width="1.5"/>
  <ellipse cx="110" cy="84" rx="5" ry="6" fill="white" stroke="#3e2723" stroke-width="1.5"/>
  <!-- Pupils looking left (away) -->
  <circle cx="79" cy="84" r="2.5" fill="#3e2723"/>
  <circle cx="107" cy="84" r="2.5" fill="#3e2723"/>
  <!-- Angled eyebrows (annoyed) -->
  <path d="M74 72 L92 76" stroke="#3e2723" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M108 76 L126 72" stroke="#3e2723" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Pouty small mouth (angled) -->
  <path d="M92 104 Q100 100 108 104" fill="none" stroke="#5d4037" stroke-width="2" stroke-linecap="round"/>
  <!-- Slight blush (tsundere hint) -->
  <ellipse cx="72" cy="98" rx="6" ry="3" fill="#f8bbd0" opacity="0.8"/>
  <ellipse cx="128" cy="98" rx="6" ry="3" fill="#f8bbd0" opacity="0.8"/>
  <!-- "Hmph" puff lines at mouth -->
  <path d="M130 100 Q138 96 140 92" fill="none" stroke="#81d4fa" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
  <path d="M135 106 Q143 106 148 104" fill="none" stroke="#81d4fa" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
  <!-- Crossed-arms hint below -->
  <path d="M55 135 Q100 128 145 135" fill="none" stroke="#5d4037" stroke-width="3" stroke-linecap="round" opacity="0.4"/>
  <!-- ツン text -->
  <text x="155" y="55" font-family="sans-serif" font-size="14" font-weight="800" fill="#0277bd" opacity="0.85">ツン</text>
  <text x="25" y="108" font-family="sans-serif" font-size="11" font-weight="700" fill="#0277bd" opacity="0.7">ツン</text>
</svg>

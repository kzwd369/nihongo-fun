<!-- Squishy mochi blob with cute face — もちもち (soft & chewy) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Background soft dots -->
  <circle cx="30" cy="30" r="4" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="170" cy="25" r="3" fill="#f48fb1" opacity="0.6"/>
  <circle cx="25" cy="130" r="3.5" fill="#f8bbd0" opacity="0.6"/>
  <circle cx="175" cy="125" r="4" fill="#f48fb1" opacity="0.5"/>
  <!-- Plate shadow -->
  <ellipse cx="100" cy="130" rx="60" ry="8" fill="#ad1457" opacity="0.15"/>
  <!-- Mochi body (soft rounded squishy shape) -->
  <path d="M55 95 Q50 65 80 55 Q100 48 120 55 Q150 65 145 95 Q150 120 120 125 Q100 128 80 125 Q50 120 55 95 Z" fill="#ffffff"/>
  <path d="M55 95 Q50 65 80 55 Q100 48 120 55 Q150 65 145 95 Q150 120 120 125 Q100 128 80 125 Q50 120 55 95 Z" fill="url(#mochiGrad)"/>
  <!-- Highlight for shine -->
  <ellipse cx="80" cy="70" rx="16" ry="6" fill="white" opacity="0.7"/>
  <!-- Eyes (dots, slight smile) -->
  <circle cx="85" cy="90" r="3" fill="#5d4037"/>
  <circle cx="115" cy="90" r="3" fill="#5d4037"/>
  <!-- Tiny mouth -->
  <path d="M94 102 Q100 106 106 102" fill="none" stroke="#5d4037" stroke-width="1.8" stroke-linecap="round"/>
  <!-- Cheek blush -->
  <ellipse cx="75" cy="100" rx="5" ry="3" fill="#f8bbd0" opacity="0.8"/>
  <ellipse cx="125" cy="100" rx="5" ry="3" fill="#f8bbd0" opacity="0.8"/>
  <!-- Squish motion lines -->
  <path d="M40 80 Q48 82 45 88" fill="none" stroke="#f48fb1" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
  <path d="M160 80 Q152 82 155 88" fill="none" stroke="#f48fb1" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
  <path d="M40 105 Q48 103 45 98" fill="none" stroke="#f48fb1" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <path d="M160 105 Q152 103 155 98" fill="none" stroke="#f48fb1" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <!-- Tiny heart above -->
  <path d="M100 28 C100 24 94 24 94 30 C94 34 100 38 102 40 C104 38 110 34 110 30 C110 24 104 24 102 28 Z" fill="#ec407a" opacity="0.8"/>
  <defs>
    <radialGradient id="mochiGrad" cx="0.5" cy="0.4">
      <stop offset="0%" stop-color="white" stop-opacity="0"/>
      <stop offset="100%" stop-color="#f8bbd0" stop-opacity="0.5"/>
    </radialGradient>
  </defs>
</svg>

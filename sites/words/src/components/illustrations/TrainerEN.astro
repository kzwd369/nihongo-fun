<!-- English (British) trainer = sneaker / athletic shoe -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Ground shadow -->
  <ellipse cx="100" cy="135" rx="80" ry="6" fill="#cfd8dc" opacity="0.5"/>
  <!-- Sole base (flat thick rubber) -->
  <path d="M25 110 Q22 130 40 132 L165 132 Q175 130 175 118 L170 110 Z" fill="white" stroke="#37474f" stroke-width="1.2"/>
  <!-- Midsole (colored rubber stripe) -->
  <path d="M25 115 L175 115 L173 122 L27 122 Z" fill="#ef5350"/>
  <!-- Tread pattern -->
  <line x1="35" y1="128" x2="35" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="50" y1="128" x2="50" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="65" y1="128" x2="65" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="80" y1="128" x2="80" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="95" y1="128" x2="95" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="110" y1="128" x2="110" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="125" y1="128" x2="125" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="140" y1="128" x2="140" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <line x1="155" y1="128" x2="155" y2="132" stroke="#37474f" stroke-width="0.6"/>
  <!-- Upper / body of shoe -->
  <path d="M30 110 Q35 70 80 60 Q110 55 140 70 Q170 85 170 110 Z" fill="#42a5f5" stroke="#0d47a1" stroke-width="1.2"/>
  <!-- Toe cap -->
  <path d="M155 100 Q170 90 170 110 L155 110 Z" fill="#1976d2"/>
  <!-- Heel cap -->
  <path d="M30 110 Q32 90 50 88 L52 110 Z" fill="#1976d2"/>
  <!-- Side swoosh / accent -->
  <path d="M55 105 Q90 80 145 95" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
  <!-- Tongue -->
  <path d="M75 75 L100 60 L105 75 L100 95 L80 95 Z" fill="#bbdefb" stroke="#0d47a1" stroke-width="0.8"/>
  <!-- Laces -->
  <path d="M82 80 L98 78" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M83 86 L97 84" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M84 92 L96 90" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Eyelets -->
  <circle cx="82" cy="80" r="1.2" fill="#37474f"/>
  <circle cx="98" cy="78" r="1.2" fill="#37474f"/>
  <circle cx="83" cy="86" r="1.2" fill="#37474f"/>
  <circle cx="97" cy="84" r="1.2" fill="#37474f"/>
  <circle cx="84" cy="92" r="1.2" fill="#37474f"/>
  <circle cx="96" cy="90" r="1.2" fill="#37474f"/>
  <!-- Heel pull tab -->
  <rect x="34" y="80" width="6" height="8" fill="#ef5350" rx="1"/>
  <!-- Brand stripe on side -->
  <rect x="115" y="100" width="20" height="3" fill="white"/>
  <rect x="115" y="105" width="20" height="2" fill="white"/>
  <!-- Sparkle/motion lines -->
  <path d="M180 80 L188 80" stroke="#90a4ae" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
  <path d="M180 88 L186 88" stroke="#90a4ae" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  <text x="20" y="55" font-size="9" fill="#bdbdbd" opacity="0.7">✦</text>
</svg>

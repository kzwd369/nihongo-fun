<!-- Japanese テンション = high energy, excitement -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Energy burst background -->
  <polygon points="100,10 108,40 140,20 115,48 150,55 115,62 140,85 108,70 100,100 92,70 60,85 85,62 50,55 85,48 60,20 92,40" fill="#fff9c4" opacity="0.5"/>
  <!-- Excited person jumping -->
  <!-- Head -->
  <circle cx="100" cy="45" r="16" fill="#ffcc80"/>
  <!-- Hair (spiky from excitement) -->
  <path d="M84,40 L80,25 L88,35" fill="#5d4037"/>
  <path d="M92,35 L90,18 L98,30" fill="#5d4037"/>
  <path d="M100,33 L100,15 L105,28" fill="#5d4037"/>
  <path d="M108,35 L112,20 L110,33" fill="#5d4037"/>
  <path d="M114,40 L120,28 L115,38" fill="#5d4037"/>
  <!-- Big happy eyes (sparkly) -->
  <circle cx="93" cy="43" r="4" fill="white"/>
  <circle cx="93" cy="43" r="2.5" fill="#5d4037"/>
  <circle cx="91.5" cy="41.5" r="1" fill="white"/>
  <circle cx="107" cy="43" r="4" fill="white"/>
  <circle cx="107" cy="43" r="2.5" fill="#5d4037"/>
  <circle cx="105.5" cy="41.5" r="1" fill="white"/>
  <!-- Big excited smile -->
  <path d="M90,52 Q100,62 110,52" fill="#e53935" stroke="#c62828" stroke-width="0.5"/>
  <path d="M93,52 Q100,56 107,52" fill="white"/>
  <!-- Blush -->
  <ellipse cx="86" cy="50" rx="4" ry="2" fill="#ffab91" opacity="0.6"/>
  <ellipse cx="114" cy="50" rx="4" ry="2" fill="#ffab91" opacity="0.6"/>
  <!-- Body (jumping pose) -->
  <rect x="90" y="62" width="20" height="22" fill="#ff7043" rx="4"/>
  <!-- Arms raised up -->
  <line x1="90" y1="66" x2="68" y2="48" stroke="#ff7043" stroke-width="5" stroke-linecap="round"/>
  <line x1="110" y1="66" x2="132" y2="48" stroke="#ff7043" stroke-width="5" stroke-linecap="round"/>
  <!-- Hands (fists up) -->
  <circle cx="66" cy="46" r="4" fill="#ffcc80"/>
  <circle cx="134" cy="46" r="4" fill="#ffcc80"/>
  <!-- Legs (jumping) -->
  <line x1="95" y1="84" x2="82" y2="105" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <line x1="105" y1="84" x2="118" y2="105" stroke="#42a5f5" stroke-width="5" stroke-linecap="round"/>
  <!-- Shoes -->
  <ellipse cx="80" cy="107" rx="6" ry="3" fill="#e53935"/>
  <ellipse cx="120" cy="107" rx="6" ry="3" fill="#e53935"/>
  <!-- Action lines -->
  <line x1="55" y1="35" x2="45" y2="30" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <line x1="145" y1="35" x2="155" y2="30" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <line x1="50" y1="55" x2="38" y2="55" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <line x1="150" y1="55" x2="162" y2="55" stroke="#ffd54f" stroke-width="2" stroke-linecap="round"/>
  <!-- Musical notes floating -->
  <text x="42" y="70" font-size="14" fill="#ff7043" opacity="0.7">♪</text>
  <text x="155" y="65" font-size="12" fill="#ff7043" opacity="0.7">♫</text>
  <!-- Ground shadow -->
  <ellipse cx="100" cy="120" rx="30" ry="5" fill="#e0e0e0" opacity="0.4"/>
  <!-- Floor -->
  <rect x="0" y="130" width="200" height="30" fill="#ffccbc" rx="0"/>
</svg>

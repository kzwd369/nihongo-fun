<!-- Restless figure with motion lines and clock — そわそわ (restless) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fce4ec" rx="8"/>
  <!-- Clock (anticipation) -->
  <circle cx="160" cy="35" r="18" fill="white" stroke="#ad1457" stroke-width="2"/>
  <line x1="160" y1="35" x2="160" y2="22" stroke="#ad1457" stroke-width="2" stroke-linecap="round"/>
  <line x1="160" y1="35" x2="170" y2="40" stroke="#ad1457" stroke-width="2" stroke-linecap="round"/>
  <circle cx="160" cy="35" r="1.5" fill="#ad1457"/>
  <!-- Motion wiggle lines on clock -->
  <path d="M180 28 Q186 30 184 35" fill="none" stroke="#d81b60" stroke-width="1.5" opacity="0.6"/>
  <path d="M183 22 Q190 22 188 28" fill="none" stroke="#d81b60" stroke-width="1.5" opacity="0.5"/>
  <!-- Head -->
  <circle cx="80" cy="55" r="25" fill="#fce4d6"/>
  <!-- Hair -->
  <path d="M58 50 Q60 30 80 28 Q100 30 102 50 Q98 38 80 36 Q62 38 58 50Z" fill="#5d4037"/>
  <!-- Worried eyes (dots looking sideways) -->
  <ellipse cx="74" cy="58" rx="2.5" ry="3" fill="#3e2723"/>
  <ellipse cx="89" cy="58" rx="2.5" ry="3" fill="#3e2723"/>
  <!-- Wavy nervous mouth -->
  <path d="M73 70 Q77 67 81 70 T89 70" fill="none" stroke="#5d4037" stroke-width="1.8" stroke-linecap="round"/>
  <!-- Sweat drop -->
  <path d="M105 45 Q108 40 110 45 Q110 50 107 50 Q104 50 105 45Z" fill="#4fc3f7"/>
  <!-- Body (sitting fidgeting) -->
  <path d="M60 80 Q60 75 70 73 L90 73 Q100 75 100 80 L100 130 L60 130 Z" fill="#f48fb1"/>
  <!-- Arms (fidgeting) -->
  <ellipse cx="48" cy="100" rx="6" ry="14" fill="#fce4d6" transform="rotate(-20, 48, 100)"/>
  <ellipse cx="112" cy="100" rx="6" ry="14" fill="#fce4d6" transform="rotate(20, 112, 100)"/>
  <!-- Motion lines around figure (jittering) -->
  <g stroke="#ad1457" stroke-width="2" stroke-linecap="round" opacity="0.5">
    <line x1="30" y1="90" x2="42" y2="90"/>
    <line x1="32" y1="100" x2="40" y2="100"/>
    <line x1="118" y1="90" x2="130" y2="90"/>
    <line x1="120" y1="100" x2="128" y2="100"/>
  </g>
  <!-- Wiggle motion at sides -->
  <path d="M20 120 Q25 115 30 120 T40 120" fill="none" stroke="#ad1457" stroke-width="1.5" opacity="0.5"/>
  <path d="M120 130 Q125 125 130 130 T140 130" fill="none" stroke="#ad1457" stroke-width="1.5" opacity="0.5"/>
  <!-- Tapping foot dots -->
  <circle cx="70" cy="148" r="2" fill="#ad1457" opacity="0.6"/>
  <circle cx="76" cy="148" r="2" fill="#ad1457" opacity="0.5"/>
  <circle cx="82" cy="148" r="2" fill="#ad1457" opacity="0.4"/>
</svg>

<!-- Two simple human figures, one bowing to the other, representing social hierarchy and Japanese honorifics -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 160" width="200" height="160" style="margin: 8px auto; display: block;">
  <!-- Background -->
  <rect width="200" height="160" rx="8" fill="#e8eaf6" />
  <!-- Floor line -->
  <line x1="20" y1="130" x2="180" y2="130" stroke="#c5cae9" stroke-width="1.5" />
  <!-- Standing figure (right) -->
  <circle cx="140" cy="60" r="12" fill="#5c6bc0" />
  <line x1="140" y1="72" x2="140" y2="110" stroke="#5c6bc0" stroke-width="3" stroke-linecap="round" />
  <line x1="140" y1="85" x2="125" y2="95" stroke="#5c6bc0" stroke-width="2.5" stroke-linecap="round" />
  <line x1="140" y1="85" x2="155" y2="95" stroke="#5c6bc0" stroke-width="2.5" stroke-linecap="round" />
  <line x1="140" y1="110" x2="130" y2="130" stroke="#5c6bc0" stroke-width="2.5" stroke-linecap="round" />
  <line x1="140" y1="110" x2="150" y2="130" stroke="#5c6bc0" stroke-width="2.5" stroke-linecap="round" />
  <!-- Bowing figure (left) - tilted forward -->
  <circle cx="68" cy="62" r="12" fill="#7986cb" />
  <line x1="65" y1="73" x2="58" y2="108" stroke="#7986cb" stroke-width="3" stroke-linecap="round" />
  <line x1="62" y1="88" x2="78" y2="82" stroke="#7986cb" stroke-width="2.5" stroke-linecap="round" />
  <line x1="62" y1="88" x2="48" y2="82" stroke="#7986cb" stroke-width="2.5" stroke-linecap="round" />
  <line x1="58" y1="108" x2="48" y2="130" stroke="#7986cb" stroke-width="2.5" stroke-linecap="round" />
  <line x1="58" y1="108" x2="68" y2="130" stroke="#7986cb" stroke-width="2.5" stroke-linecap="round" />
  <!-- Motion arc for bowing -->
  <path d="M 75 50 Q 82 42 88 50" fill="none" stroke="#9fa8da" stroke-width="1.5" stroke-linecap="round" />
  <path d="M 78 44 Q 86 35 92 44" fill="none" stroke="#9fa8da" stroke-width="1" stroke-linecap="round" />
</svg>

<!-- English pudding = broad dessert category (British Christmas pudding / American chocolate pudding) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#efebe9" rx="8"/>
  <!-- LEFT: British Christmas pudding -->
  <!-- Plate -->
  <ellipse cx="60" cy="120" rx="35" ry="6" fill="#eceff1" stroke="#cfd8dc" stroke-width="0.8"/>
  <!-- Pudding dome -->
  <path d="M30 120 Q30 70 60 60 Q90 70 90 120 Z" fill="#4e342e"/>
  <!-- White icing/brandy butter dripping -->
  <path d="M35 80 Q38 85 35 90" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
  <path d="M60 72 Q60 80 58 85" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
  <path d="M80 78 Q82 84 80 88" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
  <ellipse cx="60" cy="68" rx="20" ry="6" fill="#fff"/>
  <!-- Holly decoration -->
  <ellipse cx="55" cy="62" rx="5" ry="3" fill="#2e7d32" transform="rotate(-20, 55, 62)"/>
  <ellipse cx="65" cy="62" rx="5" ry="3" fill="#2e7d32" transform="rotate(20, 65, 62)"/>
  <circle cx="58" cy="58" r="2.5" fill="#c62828"/>
  <circle cx="63" cy="59" r="2.5" fill="#c62828"/>
  <!-- Fruit bits -->
  <circle cx="45" cy="95" r="1.5" fill="#ff8f00" opacity="0.7"/>
  <circle cx="70" cy="100" r="1.5" fill="#ff8f00" opacity="0.7"/>
  <circle cx="55" cy="108" r="1" fill="#d84315" opacity="0.7"/>
  <!-- RIGHT: American chocolate pudding cup -->
  <!-- Cup -->
  <path d="M120 125 L125 75 L165 75 L170 125 Z" fill="#e0e0e0" stroke="#bdbdbd" stroke-width="0.8"/>
  <ellipse cx="145" cy="75" rx="20" ry="5" fill="#eeeeee" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Chocolate pudding -->
  <ellipse cx="145" cy="78" rx="18" ry="4" fill="#5d4037"/>
  <!-- Whipped cream on top -->
  <ellipse cx="145" cy="72" rx="14" ry="5" fill="#fff"/>
  <ellipse cx="140" cy="70" rx="8" ry="4" fill="#fff"/>
  <ellipse cx="150" cy="70" rx="8" ry="4" fill="#fff"/>
  <ellipse cx="145" cy="67" rx="6" ry="3" fill="#fff"/>
  <!-- Chocolate shavings -->
  <rect x="142" y="64" width="4" height="2" fill="#6d4c41" rx="0.5" transform="rotate(15, 144, 65)"/>
  <rect x="147" y="66" width="3" height="1.5" fill="#6d4c41" rx="0.5" transform="rotate(-10, 148, 67)"/>
  <!-- "OR" divider -->
  <text x="100" y="98" text-anchor="middle" font-size="10" fill="#9e9e9e" font-family="sans-serif">or</text>
  <line x1="100" y1="70" x2="100" y2="88" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="100" y1="103" x2="100" y2="120" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Label -->
  <text x="100" y="148" text-anchor="middle" font-size="11" fill="#5d4037" font-family="sans-serif">pudding = many types of dessert</text>
</svg>

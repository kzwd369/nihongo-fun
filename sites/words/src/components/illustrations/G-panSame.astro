<!-- ジーパン = blue denim jeans -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hanger top (suggestion) removed; jeans laid flat -->
  <!-- Waistband -->
  <rect x="60" y="22" width="80" height="14" fill="#5c6bc0" rx="2" stroke="#3949ab" stroke-width="1"/>
  <!-- Belt loops -->
  <rect x="68" y="20" width="3" height="6" fill="#3949ab"/>
  <rect x="98" y="18" width="3" height="6" fill="#3949ab"/>
  <rect x="128" y="20" width="3" height="6" fill="#3949ab"/>
  <!-- Button -->
  <circle cx="100" cy="29" r="2.5" fill="#ffd54f" stroke="#f9a825" stroke-width="0.6"/>
  <!-- Jeans body (hip area) -->
  <path d="M60 36 L140 36 L142 70 L100 78 L58 70 Z" fill="#5c6bc0" stroke="#3949ab" stroke-width="1.2"/>
  <!-- Left leg -->
  <path d="M58 70 L100 78 L96 145 L70 145 Z" fill="#5c6bc0" stroke="#3949ab" stroke-width="1.2"/>
  <!-- Right leg -->
  <path d="M100 78 L142 70 L130 145 L104 145 Z" fill="#5c6bc0" stroke="#3949ab" stroke-width="1.2"/>
  <!-- Seam center -->
  <line x1="100" y1="36" x2="100" y2="78" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <line x1="83" y1="80" x2="83" y2="145" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <line x1="117" y1="80" x2="117" y2="145" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <!-- Pockets -->
  <path d="M65 38 L80 38 L78 50 L65 46 Z" fill="none" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <path d="M135 38 L120 38 L122 50 L135 46 Z" fill="none" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <!-- Zipper hint -->
  <line x1="100" y1="36" x2="100" y2="60" stroke="#3949ab" stroke-width="1.5"/>
  <!-- Hem stitching -->
  <line x1="70" y1="142" x2="96" y2="142" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <line x1="104" y1="142" x2="130" y2="142" stroke="#fff59d" stroke-width="0.8" stroke-dasharray="2 2"/>
  <!-- Highlight (slight fade) -->
  <path d="M75 80 L78 140 L82 140 L79 80 Z" fill="#7986cb" opacity="0.5"/>
  <path d="M118 80 L121 140 L125 140 L122 80 Z" fill="#7986cb" opacity="0.5"/>
  <!-- Brand patch -->
  <rect x="125" y="42" width="14" height="9" fill="#8d6e63" rx="1"/>
</svg>

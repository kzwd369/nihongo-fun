<!-- English reform = political/social reform -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Podium -->
  <rect x="70" y="85" width="60" height="50" fill="#5d4037" rx="2"/>
  <rect x="75" y="90" width="50" height="20" fill="#6d4c41" rx="1"/>
  <!-- REFORM banner -->
  <rect x="30" y="10" width="140" height="28" fill="#1565c0" rx="3"/>
  <text x="100" y="30" text-anchor="middle" font-size="14" fill="#fff" font-weight="bold" font-family="sans-serif">REFORM</text>
  <!-- Banner strings -->
  <line x1="30" y1="10" x2="20" y2="5" stroke="#90a4ae" stroke-width="0.8"/>
  <line x1="170" y1="10" x2="180" y2="5" stroke="#90a4ae" stroke-width="0.8"/>
  <!-- Person at podium -->
  <circle cx="100" cy="58" r="14" fill="#ffccbc"/>
  <!-- Eyes -->
  <circle cx="95" cy="56" r="1.8" fill="#5d4037"/>
  <circle cx="105" cy="56" r="1.8" fill="#5d4037"/>
  <!-- Determined mouth -->
  <path d="M95 63 L100 65 L105 63" fill="none" stroke="#5d4037" stroke-width="1" stroke-linecap="round"/>
  <!-- Hair -->
  <path d="M86 52 Q88 40 100 38 Q112 40 114 52" fill="#37474f"/>
  <!-- Suit -->
  <path d="M88 70 Q100 75 112 70 L114 88 H86 Z" fill="#1a237e"/>
  <!-- Tie -->
  <polygon points="100,70 97,78 100,85 103,78" fill="#c62828"/>
  <!-- Raised fist -->
  <circle cx="125" cy="62" r="5" fill="#ffccbc"/>
  <line x1="120" y1="68" x2="125" y2="62" stroke="#ffccbc" stroke-width="3"/>
  <!-- Microphone -->
  <circle cx="90" cy="88" r="3" fill="#616161"/>
  <line x1="90" y1="91" x2="90" y2="100" stroke="#757575" stroke-width="1.5"/>
  <!-- Audience silhouettes -->
  <circle cx="30" cy="130" r="8" fill="#b0bec5" opacity="0.5"/>
  <circle cx="55" cy="135" r="8" fill="#b0bec5" opacity="0.4"/>
  <circle cx="80" cy="138" r="7" fill="#b0bec5" opacity="0.3"/>
  <circle cx="120" cy="138" r="7" fill="#b0bec5" opacity="0.3"/>
  <circle cx="145" cy="135" r="8" fill="#b0bec5" opacity="0.4"/>
  <circle cx="170" cy="130" r="8" fill="#b0bec5" opacity="0.5"/>
  <!-- Label -->
  <text x="100" y="155" text-anchor="middle" font-size="11" fill="#1565c0" font-family="sans-serif">reform = political change</text>
</svg>

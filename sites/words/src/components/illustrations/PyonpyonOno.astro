<!-- Hopping rabbit with motion arcs — ぴょんぴょん (hopping) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Ground line -->
  <line x1="10" y1="135" x2="190" y2="135" stroke="#a5d6a7" stroke-width="2" stroke-dasharray="3,3" opacity="0.6"/>
  <!-- Motion arcs (hops) -->
  <path d="M30 135 Q55 90 80 135" fill="none" stroke="#81c784" stroke-width="2" stroke-dasharray="4,4" opacity="0.6"/>
  <path d="M80 135 Q110 80 140 135" fill="none" stroke="#66bb6a" stroke-width="2" stroke-dasharray="4,4" opacity="0.7"/>
  <!-- Tiny leaves -->
  <path d="M25 125 Q30 120 35 125 Q30 130 25 125Z" fill="#81c784" opacity="0.7"/>
  <path d="M165 125 Q170 120 175 125 Q170 130 165 125Z" fill="#81c784" opacity="0.7"/>
  <!-- Rabbit (mid-hop) -->
  <g transform="translate(115,60)">
    <!-- Body -->
    <ellipse cx="20" cy="30" rx="22" ry="18" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <!-- Head -->
    <circle cx="30" cy="18" r="14" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <!-- Ears (raised, long) -->
    <ellipse cx="26" cy="-2" rx="3.5" ry="12" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <ellipse cx="34" cy="-2" rx="3.5" ry="12" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <ellipse cx="26" cy="-2" rx="1.5" ry="8" fill="#f8bbd0"/>
    <ellipse cx="34" cy="-2" rx="1.5" ry="8" fill="#f8bbd0"/>
    <!-- Eye -->
    <circle cx="32" cy="16" r="2" fill="#3e2723"/>
    <!-- Nose -->
    <circle cx="38" cy="20" r="1.5" fill="#ec407a"/>
    <!-- Tail -->
    <circle cx="-2" cy="28" r="5" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <!-- Legs (tucked from hop) -->
    <ellipse cx="10" cy="44" rx="5" ry="3" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
    <ellipse cx="28" cy="46" rx="5" ry="3" fill="#ffffff" stroke="#bdbdbd" stroke-width="1"/>
  </g>
  <!-- Speed lines behind rabbit -->
  <line x1="70" y1="95" x2="85" y2="95" stroke="#81c784" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
  <line x1="62" y1="105" x2="80" y2="105" stroke="#81c784" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
  <line x1="72" y1="115" x2="85" y2="115" stroke="#81c784" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
  <!-- Dust puffs from ground -->
  <circle cx="45" cy="132" r="3" fill="#c8e6c9" opacity="0.7"/>
  <circle cx="52" cy="135" r="2" fill="#c8e6c9" opacity="0.6"/>
</svg>

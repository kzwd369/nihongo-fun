<!-- Japanese ワンピース = a women's dress (top + skirt as one piece) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hanger -->
  <path d="M100 18 Q100 10 105 10 Q110 10 110 16" fill="none" stroke="#90a4ae" stroke-width="2" stroke-linecap="round"/>
  <path d="M65 35 L100 18 L135 35" fill="none" stroke="#90a4ae" stroke-width="2.5" stroke-linejoin="round"/>
  <line x1="65" y1="35" x2="135" y2="35" stroke="#90a4ae" stroke-width="2"/>
  <!-- Dress top (fitted bodice with short sleeves) -->
  <!-- Sleeves -->
  <path d="M65 38 L55 50 L60 60 L72 55 Z" fill="#ba68c8" stroke="#7b1fa2" stroke-width="0.8"/>
  <path d="M135 38 L145 50 L140 60 L128 55 Z" fill="#ba68c8" stroke="#7b1fa2" stroke-width="0.8"/>
  <!-- Bodice -->
  <path d="M70 38 L130 38 L132 75 L68 75 Z" fill="#ba68c8" stroke="#7b1fa2" stroke-width="1.2"/>
  <!-- Round neckline -->
  <path d="M85 38 Q100 50 115 38" fill="#f0f7ff" stroke="#7b1fa2" stroke-width="0.8"/>
  <!-- Waist belt -->
  <rect x="68" y="73" width="64" height="6" fill="#4a148c"/>
  <circle cx="100" cy="76" r="2.5" fill="#ffd54f" stroke="#f9a825" stroke-width="0.5"/>
  <!-- Skirt (A-line, flared) -->
  <path d="M68 79 L132 79 L155 145 L45 145 Z" fill="#ce93d8" stroke="#7b1fa2" stroke-width="1.2"/>
  <!-- Pleats / fabric folds on skirt -->
  <line x1="80" y1="82" x2="68" y2="143" stroke="#ab47bc" stroke-width="0.8" opacity="0.7"/>
  <line x1="92" y1="82" x2="86" y2="144" stroke="#ab47bc" stroke-width="0.8" opacity="0.7"/>
  <line x1="100" y1="82" x2="100" y2="144" stroke="#ab47bc" stroke-width="0.8" opacity="0.7"/>
  <line x1="108" y1="82" x2="114" y2="144" stroke="#ab47bc" stroke-width="0.8" opacity="0.7"/>
  <line x1="120" y1="82" x2="132" y2="143" stroke="#ab47bc" stroke-width="0.8" opacity="0.7"/>
  <!-- Hem trim -->
  <path d="M45 145 L155 145" stroke="#7b1fa2" stroke-width="1.2"/>
  <!-- Floral pattern on skirt -->
  <circle cx="75" cy="100" r="2.5" fill="#fff59d"/>
  <circle cx="95" cy="115" r="2.5" fill="#fff59d"/>
  <circle cx="115" cy="105" r="2.5" fill="#fff59d"/>
  <circle cx="125" cy="125" r="2.5" fill="#fff59d"/>
  <circle cx="80" cy="130" r="2.5" fill="#fff59d"/>
  <circle cx="105" cy="135" r="2.5" fill="#fff59d"/>
  <!-- Sparkles -->
  <text x="40" y="55" font-size="9" fill="#ce93d8" opacity="0.7">✦</text>
  <text x="160" y="80" font-size="8" fill="#ce93d8" opacity="0.6">✦</text>
</svg>

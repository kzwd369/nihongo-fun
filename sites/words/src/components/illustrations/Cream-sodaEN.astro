<!-- English "cream soda" = sweet amber/vanilla carbonated drink, no ice cream, no green -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff3e0" rx="8"/>
  <!-- Shelf line -->
  <rect x="0" y="125" width="200" height="3" fill="#8d6e63"/>
  <!-- Bottle -->
  <!-- Bottle neck -->
  <rect x="72" y="28" width="16" height="15" fill="#6d4c41" rx="2"/>
  <!-- Cap -->
  <rect x="70" y="22" width="20" height="8" fill="#c62828" rx="1"/>
  <path d="M70,24 L90,24" stroke="#b71c1c" stroke-width="0.5"/>
  <path d="M70,27 L90,27" stroke="#b71c1c" stroke-width="0.5"/>
  <!-- Bottle body (amber glass) -->
  <path d="M62,43 L58,55 L58,115 Q58,120 63,120 L97,120 Q102,120 102,115 L102,55 L98,43 Z" fill="#c68642" stroke="#6d4c41" stroke-width="1.2"/>
  <!-- Liquid shine -->
  <path d="M65,48 L62,55 L62,110" fill="none" stroke="#ffecb3" stroke-width="2" opacity="0.5"/>
  <!-- Label -->
  <rect x="62" y="65" width="38" height="35" fill="#fff8e1" stroke="#6d4c41" stroke-width="1"/>
  <text x="81" y="76" font-size="7" font-weight="bold" fill="#6d4c41" text-anchor="middle">VINTAGE</text>
  <text x="81" y="86" font-size="8" font-weight="bold" fill="#c62828" text-anchor="middle">CREAM</text>
  <text x="81" y="95" font-size="8" font-weight="bold" fill="#c62828" text-anchor="middle">SODA</text>
  <!-- Can on the right -->
  <rect x="125" y="55" width="40" height="65" fill="#8d6e63" rx="1"/>
  <rect x="125" y="55" width="40" height="8" fill="#6d4c41" rx="1"/>
  <rect x="125" y="115" width="40" height="5" fill="#6d4c41"/>
  <rect x="128" y="68" width="34" height="45" fill="#ffca28"/>
  <text x="145" y="82" font-size="7" font-weight="bold" fill="#6d4c41" text-anchor="middle">A&amp;W</text>
  <text x="145" y="95" font-size="6" font-weight="bold" fill="#6d4c41" text-anchor="middle">CREAM</text>
  <text x="145" y="104" font-size="6" font-weight="bold" fill="#6d4c41" text-anchor="middle">SODA</text>
  <!-- Pull tab -->
  <ellipse cx="145" cy="55" rx="4" ry="1.5" fill="#bdbdbd"/>
  <!-- "No green, no ice cream" notices -->
  <!-- X over green -->
  <rect x="8" y="45" width="35" height="18" fill="#ffebee" stroke="#e53935" stroke-width="1" rx="2"/>
  <circle cx="18" cy="54" r="4" fill="#66bb6a"/>
  <text x="32" y="58" font-size="7" fill="#424242">green</text>
  <line x1="10" y1="47" x2="41" y2="61" stroke="#e53935" stroke-width="2"/>
  <line x1="41" y1="47" x2="10" y2="61" stroke="#e53935" stroke-width="2"/>
  <!-- X over ice cream -->
  <rect x="8" y="75" width="35" height="18" fill="#ffebee" stroke="#e53935" stroke-width="1" rx="2"/>
  <circle cx="18" cy="84" r="4" fill="#fff9c4" stroke="#f9a825" stroke-width="0.5"/>
  <text x="32" y="88" font-size="7" fill="#424242">cream</text>
  <line x1="10" y1="77" x2="41" y2="91" stroke="#e53935" stroke-width="2"/>
  <line x1="41" y1="77" x2="10" y2="91" stroke="#e53935" stroke-width="2"/>
  <!-- Label -->
  <text x="100" y="140" font-size="10" font-weight="bold" fill="#6d4c41" text-anchor="middle">Cream Soda (US)</text>
  <text x="100" y="153" font-size="8" fill="#8d6e63" text-anchor="middle">= amber vanilla-flavored fizzy drink in a bottle</text>
</svg>

<!-- English correct terms: custom-made, made-to-order, bespoke, tailor-made -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fff8e1" rx="8"/>
  <!-- Luxury tailor shop sign -->
  <rect x="15" y="15" width="170" height="28" fill="#1a237e" stroke="#ffd54f" stroke-width="1.5" rx="3"/>
  <text x="100" y="28" font-size="10" font-weight="bold" fill="#ffd54f" text-anchor="middle" font-family="serif">— SAVILE ROW —</text>
  <text x="100" y="40" font-size="9" font-style="italic" fill="#fff59d" text-anchor="middle" font-family="serif">Bespoke Tailors Since 1920</text>
  <!-- "order-made" crossed out -->
  <rect x="12" y="52" width="50" height="16" fill="#ffebee" stroke="#e53935" stroke-width="1" rx="2"/>
  <text x="37" y="63" font-size="9" fill="#424242" text-anchor="middle">"order-made"</text>
  <line x1="14" y1="54" x2="60" y2="66" stroke="#e53935" stroke-width="2.5"/>
  <line x1="60" y1="54" x2="14" y2="66" stroke="#e53935" stroke-width="2.5"/>
  <!-- Correct terms box -->
  <rect x="75" y="52" width="115" height="75" fill="white" stroke="#1a237e" stroke-width="1.5" rx="3"/>
  <text x="132" y="65" font-size="9" font-weight="bold" fill="#1a237e" text-anchor="middle">✓ Correct English:</text>
  <!-- Term 1 -->
  <circle cx="85" cy="75" r="1.5" fill="#43a047"/>
  <text x="90" y="78" font-size="9" font-weight="bold" fill="#2e7d32">bespoke</text>
  <text x="135" y="78" font-size="7" fill="#757575" font-style="italic">(high-end UK)</text>
  <!-- Term 2 -->
  <circle cx="85" cy="88" r="1.5" fill="#43a047"/>
  <text x="90" y="91" font-size="9" font-weight="bold" fill="#2e7d32">custom-made</text>
  <text x="152" y="91" font-size="7" fill="#757575" font-style="italic">(common)</text>
  <!-- Term 3 -->
  <circle cx="85" cy="101" r="1.5" fill="#43a047"/>
  <text x="90" y="104" font-size="9" font-weight="bold" fill="#2e7d32">made-to-order</text>
  <!-- Term 4 -->
  <circle cx="85" cy="114" r="1.5" fill="#43a047"/>
  <text x="90" y="117" font-size="9" font-weight="bold" fill="#2e7d32">tailor-made</text>
  <!-- Tailor figure on left -->
  <!-- Head -->
  <circle cx="30" cy="88" r="9" fill="#ffe0b2"/>
  <!-- Hair -->
  <path d="M22,86 Q22,77 30,77 Q38,77 38,86 L36,83 Q30,80 24,83 Z" fill="#3e2723"/>
  <!-- Glasses -->
  <circle cx="27" cy="88" r="2.5" fill="none" stroke="#3e2723" stroke-width="1"/>
  <circle cx="33" cy="88" r="2.5" fill="none" stroke="#3e2723" stroke-width="1"/>
  <line x1="29.5" y1="88" x2="30.5" y2="88" stroke="#3e2723" stroke-width="0.5"/>
  <!-- Mustache -->
  <path d="M26,92 Q30,94 34,92" fill="none" stroke="#5d4037" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Body (vest) -->
  <rect x="22" y="97" width="16" height="20" fill="#5d4037" rx="2"/>
  <rect x="26" y="97" width="8" height="20" fill="white"/>
  <line x1="30" y1="97" x2="30" y2="117" stroke="#3e2723" stroke-width="0.5"/>
  <!-- Bow tie -->
  <polygon points="26,100 30,97 30,103" fill="#b71c1c"/>
  <polygon points="34,100 30,97 30,103" fill="#b71c1c"/>
  <circle cx="30" cy="100" r="1" fill="#880e4f"/>
  <!-- Measuring tape over shoulder -->
  <path d="M22,100 Q15,110 18,125" fill="none" stroke="#ffca28" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Legs -->
  <rect x="24" y="117" width="5" height="14" fill="#263238"/>
  <rect x="31" y="117" width="5" height="14" fill="#263238"/>
  <!-- Floor -->
  <rect x="0" y="131" width="200" height="29" fill="#ffecb3" rx="0"/>
  <text x="100" y="147" font-size="10" font-weight="bold" fill="#bf360c" text-anchor="middle">"Order-made" is not English</text>
  <text x="100" y="157" font-size="8" fill="#6d4c41" text-anchor="middle">Use bespoke / custom-made / tailor-made</text>
</svg>

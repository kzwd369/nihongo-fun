<!-- Stars and sparkles pattern — キラキラ (sparkling/glittering) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#fffde7" rx="8"/>
  <!-- Large central 4-point star -->
  <polygon points="100,20 106,60 145,75 106,90 100,130 94,90 55,75 94,60" fill="#ffd54f"/>
  <polygon points="100,35 104,60 130,75 104,90 100,115 96,90 70,75 96,60" fill="#ffea00" opacity="0.7"/>
  <!-- Central highlight -->
  <circle cx="100" cy="75" r="6" fill="white" opacity="0.8"/>
  <!-- Top-left sparkle -->
  <polygon points="35,22 37,32 47,35 37,38 35,48 33,38 23,35 33,32" fill="#ffab00" opacity="0.7"/>
  <circle cx="35" cy="35" r="2" fill="white" opacity="0.7"/>
  <!-- Top-right sparkle -->
  <polygon points="165,18 167,28 177,30 167,32 165,42 163,32 153,30 163,28" fill="#ffc107" opacity="0.8"/>
  <circle cx="165" cy="30" r="2" fill="white" opacity="0.7"/>
  <!-- Bottom-left sparkle -->
  <polygon points="30,105 32,113 40,115 32,117 30,125 28,117 20,115 28,113" fill="#ffc107" opacity="0.6"/>
  <circle cx="30" cy="115" r="1.5" fill="white" opacity="0.6"/>
  <!-- Bottom-right sparkle -->
  <polygon points="170,100 172,108 180,110 172,112 170,120 168,112 160,110 168,108" fill="#ffab00" opacity="0.65"/>
  <circle cx="170" cy="110" r="1.5" fill="white" opacity="0.6"/>
  <!-- Small diamond sparkles scattered -->
  <polygon points="60,15 62,20 67,22 62,24 60,29 58,24 53,22 58,20" fill="#ffe082" opacity="0.5"/>
  <polygon points="145,50 146,54 150,55 146,56 145,60 144,56 140,55 144,54" fill="#ffe082" opacity="0.5"/>
  <polygon points="55,60 56,64 60,65 56,66 55,70 54,66 50,65 54,64" fill="#ffe082" opacity="0.45"/>
  <polygon points="150,120 151,123 154,124 151,125 150,128 149,125 146,124 149,123" fill="#ffe082" opacity="0.5"/>
  <polygon points="50,135 51,138 54,139 51,140 50,143 49,140 46,139 49,138" fill="#ffe082" opacity="0.4"/>
  <!-- Tiny dots -->
  <circle cx="80" cy="30" r="1.5" fill="#ffd54f" opacity="0.6"/>
  <circle cx="120" cy="25" r="1" fill="#ffc107" opacity="0.5"/>
  <circle cx="75" cy="120" r="1.5" fill="#ffd54f" opacity="0.5"/>
  <circle cx="130" cy="125" r="1" fill="#ffc107" opacity="0.4"/>
  <circle cx="88" cy="140" r="1.5" fill="#ffe082" opacity="0.5"/>
  <circle cx="115" cy="145" r="1" fill="#ffd54f" opacity="0.4"/>
  <!-- Light rays from center -->
  <line x1="100" y1="75" x2="100" y2="5" stroke="#ffd54f" stroke-width="0.8" opacity="0.2"/>
  <line x1="100" y1="75" x2="185" y2="75" stroke="#ffd54f" stroke-width="0.8" opacity="0.2"/>
  <line x1="100" y1="75" x2="100" y2="150" stroke="#ffd54f" stroke-width="0.8" opacity="0.2"/>
  <line x1="100" y1="75" x2="15" y2="75" stroke="#ffd54f" stroke-width="0.8" opacity="0.2"/>
  <line x1="100" y1="75" x2="165" y2="20" stroke="#ffd54f" stroke-width="0.6" opacity="0.15"/>
  <line x1="100" y1="75" x2="35" y2="130" stroke="#ffd54f" stroke-width="0.6" opacity="0.15"/>
  <line x1="100" y1="75" x2="35" y2="20" stroke="#ffd54f" stroke-width="0.6" opacity="0.15"/>
  <line x1="100" y1="75" x2="165" y2="130" stroke="#ffd54f" stroke-width="0.6" opacity="0.15"/>
</svg>

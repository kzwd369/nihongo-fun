<!-- Japanese トレーナー = crewneck sweatshirt -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#f0f7ff" rx="8"/>
  <!-- Hanger -->
  <path d="M100 18 Q100 10 105 10 Q110 10 110 16" fill="none" stroke="#90a4ae" stroke-width="2" stroke-linecap="round"/>
  <path d="M55 38 L100 18 L145 38" fill="none" stroke="#90a4ae" stroke-width="2.5" stroke-linejoin="round"/>
  <line x1="55" y1="38" x2="145" y2="38" stroke="#90a4ae" stroke-width="2"/>
  <!-- Sweatshirt body -->
  <!-- Sleeves (long) -->
  <path d="M55 40 L30 75 L25 130 L48 132 L62 80 Z" fill="#7e57c2" stroke="#4527a0" stroke-width="1.2"/>
  <path d="M145 40 L170 75 L175 130 L152 132 L138 80 Z" fill="#7e57c2" stroke="#4527a0" stroke-width="1.2"/>
  <!-- Body -->
  <path d="M62 40 L138 40 L142 135 L58 135 Z" fill="#7e57c2" stroke="#4527a0" stroke-width="1.2"/>
  <!-- Crew neck collar (round, ribbed) -->
  <ellipse cx="100" cy="42" rx="20" ry="7" fill="#5e35b2" stroke="#4527a0" stroke-width="1"/>
  <ellipse cx="100" cy="42" rx="20" ry="7" fill="none" stroke="#4527a0" stroke-width="0.5" stroke-dasharray="2 1.5"/>
  <ellipse cx="100" cy="44" rx="16" ry="4.5" fill="#f0f7ff"/>
  <!-- Cuff ribbing -->
  <rect x="22" y="125" width="28" height="9" fill="#5e35b2" rx="1"/>
  <line x1="24" y1="127" x2="48" y2="127" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="24" y1="130" x2="48" y2="130" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="24" y1="133" x2="48" y2="133" stroke="#4527a0" stroke-width="0.4"/>
  <rect x="150" y="125" width="28" height="9" fill="#5e35b2" rx="1"/>
  <line x1="152" y1="127" x2="176" y2="127" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="152" y1="130" x2="176" y2="130" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="152" y1="133" x2="176" y2="133" stroke="#4527a0" stroke-width="0.4"/>
  <!-- Bottom hem ribbing -->
  <rect x="58" y="130" width="84" height="8" fill="#5e35b2"/>
  <line x1="60" y1="132" x2="140" y2="132" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="60" y1="134" x2="140" y2="134" stroke="#4527a0" stroke-width="0.4"/>
  <line x1="60" y1="136" x2="140" y2="136" stroke="#4527a0" stroke-width="0.4"/>
  <!-- Front graphic / college-style logo -->
  <text x="100" y="85" font-size="14" fill="#fff59d" text-anchor="middle" font-family="serif" font-weight="bold">TOKYO</text>
  <text x="100" y="100" font-size="8" fill="white" text-anchor="middle" font-family="serif">UNIVERSITY</text>
  <line x1="78" y1="105" x2="122" y2="105" stroke="#fff59d" stroke-width="0.8"/>
  <text x="100" y="116" font-size="6" fill="white" text-anchor="middle" font-family="serif" font-style="italic">Est. 1877</text>
</svg>

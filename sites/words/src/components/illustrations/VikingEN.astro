<!-- English Viking = Norse warrior/seafarer -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Sky and sea -->
  <rect x="0" y="100" width="200" height="60" fill="#90caf9" rx="0 0 8 8"/>
  <!-- Waves -->
  <path d="M0,115 Q25,108 50,115 Q75,122 100,115 Q125,108 150,115 Q175,122 200,115" fill="none" stroke="#64b5f6" stroke-width="2"/>
  <path d="M0,125 Q25,118 50,125 Q75,132 100,125 Q125,118 150,125 Q175,132 200,125" fill="none" stroke="#64b5f6" stroke-width="1.5"/>
  <!-- Viking longship -->
  <path d="M40,105 Q100,130 160,105" fill="#8d6e63" stroke="#6d4c41" stroke-width="1.5"/>
  <path d="M35,105 Q38,102 42,105" fill="#6d4c41"/>
  <path d="M158,105 Q162,100 167,103 L160,105" fill="#6d4c41"/>
  <!-- Dragon head -->
  <path d="M160,105 Q170,95 165,85 Q168,88 172,85 Q170,92 175,97" fill="#8d6e63" stroke="#6d4c41" stroke-width="1"/>
  <circle cx="168" cy="89" r="1" fill="#5d4037"/>
  <!-- Mast and sail -->
  <line x1="100" y1="105" x2="100" y2="35" stroke="#6d4c41" stroke-width="2.5"/>
  <polygon points="100,40 100,90 140,65" fill="#eceff1" stroke="#bdbdbd" stroke-width="1"/>
  <line x1="100" y1="55" x2="135" y2="55" stroke="#bdbdbd" stroke-width="0.5"/>
  <line x1="100" y1="70" x2="128" y2="70" stroke="#bdbdbd" stroke-width="0.5"/>
  <!-- Viking warrior on ship -->
  <!-- Helmet with horns -->
  <ellipse cx="80" cy="72" rx="9" ry="7" fill="#bdbdbd"/>
  <path d="M71,72 Q67,62 63,58" fill="none" stroke="#9e9e9e" stroke-width="2.5" stroke-linecap="round"/>
  <path d="M89,72 Q93,62 97,58" fill="none" stroke="#9e9e9e" stroke-width="2.5" stroke-linecap="round"/>
  <!-- Face -->
  <circle cx="80" cy="78" r="7" fill="#ffcc80"/>
  <!-- Beard -->
  <path d="M74,80 Q80,90 86,80" fill="#8d6e63"/>
  <!-- Eyes -->
  <circle cx="77" cy="77" r="1.2" fill="#5d4037"/>
  <circle cx="83" cy="77" r="1.2" fill="#5d4037"/>
  <!-- Body with armor -->
  <rect x="73" y="85" width="14" height="16" fill="#78909c" rx="2"/>
  <line x1="80" y1="86" x2="80" y2="100" stroke="#90a4ae" stroke-width="1"/>
  <!-- Shield -->
  <circle cx="68" cy="93" r="8" fill="#ffd54f" stroke="#f9a825" stroke-width="1.5"/>
  <circle cx="68" cy="93" r="3" fill="#f9a825"/>
  <!-- Sword -->
  <line x1="92" y1="88" x2="98" y2="72" stroke="#bdbdbd" stroke-width="2"/>
  <rect x="90" y="87" width="4" height="3" fill="#8d6e63" rx="0.5"/>
  <!-- Sun -->
  <circle cx="30" cy="25" r="12" fill="#fff9c4"/>
  <circle cx="30" cy="25" r="8" fill="#ffee58"/>
  <!-- Clouds -->
  <ellipse cx="140" cy="20" rx="20" ry="8" fill="white" opacity="0.8"/>
  <ellipse cx="155" cy="18" rx="12" ry="6" fill="white" opacity="0.8"/>
</svg>

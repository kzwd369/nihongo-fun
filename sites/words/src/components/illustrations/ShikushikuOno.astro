<!-- Child figure crying softly — シクシク (quiet sobbing) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e3f2fd" rx="8"/>
  <!-- Gentle rain-ish drops for sad mood -->
  <g fill="#90caf9" opacity="0.5">
    <circle cx="25" cy="30" r="1.5"/>
    <circle cx="45" cy="45" r="1.2"/>
    <circle cx="170" cy="35" r="1.5"/>
    <circle cx="180" cy="55" r="1.2"/>
  </g>
  <!-- Head -->
  <circle cx="100" cy="80" r="42" fill="#ffe0b2"/>
  <!-- Hair tuft -->
  <path d="M65 70 Q75 38 100 36 Q125 38 135 70 Q125 50 100 50 Q75 50 65 70Z" fill="#6d4c41"/>
  <!-- Downturned eyes (sad, closed) -->
  <path d="M78 80 Q84 88 90 80" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <path d="M110 80 Q116 88 122 80" fill="none" stroke="#3e2723" stroke-width="2" stroke-linecap="round"/>
  <!-- Tear drops -->
  <path d="M82 90 Q82 100 86 105 Q90 100 90 90 Q86 95 82 90Z" fill="#64b5f6"/>
  <path d="M114 90 Q114 100 118 105 Q122 100 122 90 Q118 95 114 90Z" fill="#64b5f6"/>
  <!-- Second tear trailing -->
  <circle cx="86" cy="112" r="2" fill="#64b5f6" opacity="0.8"/>
  <circle cx="118" cy="112" r="2" fill="#64b5f6" opacity="0.8"/>
  <!-- Sad mouth -->
  <path d="M92 105 Q100 100 108 105" fill="none" stroke="#5d4037" stroke-width="1.8" stroke-linecap="round"/>
  <!-- Pale blush (flushed from crying) -->
  <ellipse cx="70" cy="95" rx="6" ry="3" fill="#ef9a9a" opacity="0.5"/>
  <ellipse cx="130" cy="95" rx="6" ry="3" fill="#ef9a9a" opacity="0.5"/>
  <!-- Hand/sleeve near eye (wiping tears) -->
  <path d="M55 105 Q70 100 78 102 Q72 112 58 118 Z" fill="#90caf9" opacity="0.8"/>

  <!-- シクシク text -->
  <text x="100" y="30" text-anchor="middle" font-family="sans-serif" font-size="14" font-weight="800" fill="#1976d2" opacity="0.85">シクシク</text>
  <text x="145" y="140" font-family="sans-serif" font-size="11" font-weight="700" fill="#1976d2" opacity="0.7">…シク</text>
</svg>

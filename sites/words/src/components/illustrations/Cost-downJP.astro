<!-- Japanese コストダウン = cost reduction (used as noun, often with する) -->
<svg viewBox="0 0 200 160" width="200" height="160" xmlns="http://www.w3.org/2000/svg" style="margin: 8px auto; display: block;">
  <rect width="200" height="160" fill="#e8f5e9" rx="8"/>
  <!-- Factory silhouette in back -->
  <rect x="15" y="55" width="40" height="45" fill="#a5d6a7" opacity="0.6"/>
  <rect x="18" y="40" width="8" height="15" fill="#a5d6a7" opacity="0.6"/>
  <rect x="30" y="45" width="8" height="10" fill="#a5d6a7" opacity="0.6"/>
  <!-- Smoke (reduced) -->
  <circle cx="22" cy="36" r="3" fill="#cfd8dc" opacity="0.5"/>
  <circle cx="34" cy="41" r="2" fill="#cfd8dc" opacity="0.5"/>
  <!-- Bar chart going down -->
  <rect x="115" y="35" width="10" height="55" fill="#66bb6a"/>
  <rect x="130" y="50" width="10" height="40" fill="#66bb6a"/>
  <rect x="145" y="65" width="10" height="25" fill="#66bb6a"/>
  <rect x="160" y="78" width="10" height="12" fill="#66bb6a"/>
  <!-- Descending arrow over chart -->
  <path d="M118,32 L168,80" stroke="#e53935" stroke-width="3" stroke-linecap="round" fill="none"/>
  <polygon points="168,80 160,76 164,84" fill="#e53935"/>
  <!-- Yen symbol -->
  <text x="175" y="48" font-size="14" font-weight="bold" fill="#2e7d32">¥</text>
  <!-- Businessperson -->
  <!-- Head -->
  <circle cx="75" cy="70" r="13" fill="#ffcc80"/>
  <!-- Hair -->
  <path d="M63,68 Q62,55 75,53 Q88,55 87,68 L84,64 Q75,60 66,64 Z" fill="#3e2723"/>
  <!-- Eyes (confident) -->
  <path d="M68,70 Q70,67 72,70" fill="none" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <path d="M78,70 Q80,67 82,70" fill="none" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Confident smile -->
  <path d="M70,76 Q75,79 80,76" fill="none" stroke="#3e2723" stroke-width="1.5" stroke-linecap="round"/>
  <!-- Body (suit) -->
  <rect x="63" y="83" width="24" height="25" fill="#37474f" rx="3"/>
  <!-- White shirt triangle -->
  <polygon points="75,83 70,95 80,95" fill="white"/>
  <!-- Tie -->
  <polygon points="73,83 77,83 76,95 74,95" fill="#e53935"/>
  <!-- Left arm pointing at chart -->
  <line x1="87" y1="88" x2="108" y2="78" stroke="#37474f" stroke-width="5" stroke-linecap="round"/>
  <circle cx="110" cy="78" r="3.5" fill="#ffcc80"/>
  <!-- Right arm -->
  <line x1="63" y1="88" x2="55" y2="100" stroke="#37474f" stroke-width="5" stroke-linecap="round"/>
  <!-- Legs -->
  <rect x="66" y="108" width="7" height="20" fill="#263238"/>
  <rect x="77" y="108" width="7" height="20" fill="#263238"/>
  <!-- Floor -->
  <rect x="0" y="128" width="200" height="32" fill="#c8e6c9" rx="0"/>
  <!-- Label -->
  <text x="100" y="148" font-size="11" font-weight="bold" fill="#2e7d32" text-anchor="middle">コストダウン成功</text>
</svg>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';

const illustrations = import.meta.glob('../../../components/illustrations/*.astro', { eager: true });

function getIllustration(slug: string, vsPattern: string) {
  const capitalize = slug.charAt(0).toUpperCase() + slug.slice(1);
  const suffix = vsPattern === 'same' ? 'Same' : 'JP';
  const key = `../../../components/illustrations/${capitalize}${suffix}.astro`;
  const mod = illustrations[key] as { default: any } | undefined;
  return mod?.default;
}

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'es' } },
    { params: { locale: 'zh-tw' } },
  ];
}

const { locale } = Astro.params;
const isNoindex = locale === 'en';

const allEntries = await getCollection('wasei-eigo');
const entries = allEntries
  .filter(e => e.data.locale === locale && !e.data.draft)
  .sort((a, b) => a.data.slug.localeCompare(b.data.slug));

const labels: Record<string, Record<string, string>> = {
  en: { title: 'Wasei-Eigo — Japanese-Made English', subtitle: 'Words that look English but mean something completely different in Japanese.', home: 'Home' },
  es: { title: 'Wasei-Eigo — Inglés hecho en Japón', subtitle: 'Palabras que parecen inglés pero significan algo completamente diferente en japonés.', home: 'Inicio' },
  'zh-tw': { title: '和製英語 — 日本人自創的英語', subtitle: '看起來像英文，但在日語中意思完全不同的詞彙。', home: '首頁' },
};
const t = labels[locale!] || labels.en;

// Category → color map
const catColors: Record<string, { bg: string; badge: string }> = {
  housing:       { bg: 'linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%)', badge: '#2e7d32' },
  work:          { bg: 'linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%)', badge: '#1565c0' },
  'daily-life':  { bg: 'linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%)', badge: '#e65100' },
  technology:    { bg: 'linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%)', badge: '#283593' },
  food:          { bg: 'linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%)', badge: '#c2185b' },
  education:     { bg: 'linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%)', badge: '#f57f17' },
  business:      { bg: 'linear-gradient(135deg, #eceff1 0%, #cfd8dc 100%)', badge: '#37474f' },
  fashion:       { bg: 'linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%)', badge: '#7b1fa2' },
  entertainment: { bg: 'linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%)', badge: '#00838f' },
  personality:   { bg: 'linear-gradient(135deg, #fce4ec 0%, #f3e5f5 100%)', badge: '#ad1457' },
  culture:       { bg: 'linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%)', badge: '#e65100' },
};
const defaultColor = { bg: 'linear-gradient(135deg, #f5f5f5 0%, #eeeeee 100%)', badge: '#616161' };
---

<BaseLayout
  title={`${t.title} | Nihongo Fun`}
  description={t.subtitle}
  locale={locale!}
  noindex={isNoindex}
  pagePath="/wasei-eigo/"
>
  <Nav locale={locale!} />

  <main class="pillar">
    <div class="pillar-hero">
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </div>

    <div class="word-grid">
      {entries.map(entry => {
        const Illust = getIllustration(entry.data.slug, entry.data.vsPattern);
        const colors = catColors[entry.data.category] || defaultColor;
        return (
          <a href={`/${locale}/wasei-eigo/${entry.data.slug}/`} class="word-card" style={`--card-bg: ${colors.bg}; --cat-color: ${colors.badge};`}>
            <div class="card-layout">
              {Illust && (
                <div class="card-icon">
                  <Illust />
                </div>
              )}
              <div class="card-text">
                <div class="word-jp">{entry.data.japanese}</div>
                <div class="word-romaji">{entry.data.romaji}</div>
                <div class="word-vs">
                  <span class="vs-jp">{entry.data.japaneseMeaning}</span>
                  <span class="vs-arrow">≠</span>
                  <span class="vs-en">{entry.data.originalEnglish}</span>
                </div>
                <span class="word-cat">{entry.data.category}</span>
              </div>
            </div>
            {entry.data.jlpt && <span class="word-jlpt">{entry.data.jlpt}</span>}
          </a>
        );
      })}
    </div>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .pillar {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .pillar-hero {
    text-align: center;
    padding: 48px 0 32px;
  }
  .pillar-hero h1 {
    font-size: 28px;
    font-weight: 800;
  }
  .pillar-hero p {
    color: var(--text-light);
    margin-top: 8px;
    font-size: 16px;
  }
  .word-grid {
    display: grid;
    gap: 16px;
    padding-bottom: 60px;
  }
  .word-card {
    background: var(--card-bg);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 24px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .word-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    text-decoration: none;
  }
  .card-layout {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .card-icon {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 16px;
    background: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-icon :global(svg) {
    width: 72px;
    height: 58px;
    border-radius: 8px;
  }
  .card-text {
    flex: 1;
    min-width: 0;
  }
  .word-jp {
    font-family: var(--jp-font);
    font-size: 26px;
    font-weight: 700;
  }
  .word-romaji {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 2px;
  }
  .word-vs {
    margin-top: 8px;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .vs-jp {
    background: rgba(255,255,255,0.7);
    padding: 2px 10px;
    border-radius: 6px;
    font-weight: 500;
    color: var(--text);
    backdrop-filter: blur(4px);
  }
  .vs-arrow {
    color: var(--text-light);
    font-weight: 700;
  }
  .vs-en {
    background: rgba(255,255,255,0.5);
    padding: 2px 10px;
    border-radius: 6px;
    color: var(--text-light);
    backdrop-filter: blur(4px);
  }
  .word-cat {
    display: inline-block;
    margin-top: 8px;
    background: var(--cat-color);
    color: #fff;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: capitalize;
  }
  .word-jlpt {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(255,255,255,0.7);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    color: var(--text-light);
    font-weight: 600;
    backdrop-filter: blur(4px);
  }
  @media (max-width: 600px) {
    .card-icon {
      width: 64px;
      height: 64px;
    }
    .card-icon :global(svg) {
      width: 56px;
      height: 45px;
    }
    .word-jp { font-size: 22px; }
    .word-vs { font-size: 12px; }
  }
</style>

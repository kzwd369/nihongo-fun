---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'es' } },
    { params: { locale: 'zh-tw' } },
    { params: { locale: 'th' } },
  ];
}

const { locale } = Astro.params;
const isNoindex = locale === 'en';
const lastUpdated = '2026-04-14';

type Section = { heading: string; body: string[] };
type Copy = {
  title: string; desc: string; pageTitle: string;
  lead: string; lastUpdatedLabel: string;
  sections: Section[];
  contactLink: { label: string; href: string };
};

const t: Record<string, Copy> = {
  en: {
    title: 'Privacy Policy — Nihongo Fun',
    desc: 'How Nihongo Fun handles cookies, analytics, and third-party advertising.',
    pageTitle: 'Privacy Policy',
    lead: 'This page explains what information Nihongo Fun collects, why, and the third-party services involved.',
    lastUpdatedLabel: 'Last updated',
    sections: [
      {
        heading: 'Information we collect',
        body: [
          'Nihongo Fun does not ask for or store personal information such as names, email addresses, or payment details on its own servers.',
          'When you visit the site, your browser automatically transmits standard technical data (IP address, browser type, referrer, pages viewed) to the services listed below. We use this data in aggregate to understand how the site is used and to improve it.',
        ],
      },
      {
        heading: 'Google Analytics',
        body: [
          'We use Google Analytics to understand site traffic and visitor behavior. Google Analytics uses cookies to collect anonymous usage data. This data is processed by Google under its own privacy policy.',
          'You can opt out of Google Analytics tracking by installing the Google Analytics Opt-out Browser Add-on (https://tools.google.com/dlpage/gaoptout).',
        ],
      },
      {
        heading: 'Google AdSense',
        body: [
          'This site uses Google AdSense, a third-party advertising service provided by Google. Google may use cookies or device identifiers to serve ads based on your prior visits to this and other websites.',
          'You can disable personalized advertising by visiting Google\'s Ads Settings (https://www.google.com/settings/ads). For more information about how Google uses data, see Google\'s Privacy & Terms (https://policies.google.com/technologies/partner-sites).',
        ],
      },
      {
        heading: 'Contact form',
        body: [
          'Our contact form is hosted on Google Forms. Messages you send through the form are delivered to the site operator. Please do not include sensitive personal information. Google\'s own privacy terms apply to form submissions.',
        ],
      },
      {
        heading: 'Cookies',
        body: [
          'Cookies are small text files stored on your device by the services described above. You can disable or delete cookies in your browser settings; some features of third-party services may not work correctly without them.',
        ],
      },
      {
        heading: 'Changes to this policy',
        body: [
          'We may update this policy from time to time. Significant changes will be reflected here with an updated date at the top of the page.',
        ],
      },
    ],
    contactLink: { label: 'Questions about this policy? Contact us', href: `/${locale}/about/#contact` },
  },
  es: {
    title: 'Política de privacidad — Nihongo Fun',
    desc: 'Cómo Nihongo Fun maneja cookies, análisis y publicidad de terceros.',
    pageTitle: 'Política de privacidad',
    lead: 'Esta página explica qué información recopila Nihongo Fun, por qué lo hace, y qué servicios de terceros están involucrados.',
    lastUpdatedLabel: 'Última actualización',
    sections: [
      {
        heading: 'Información que recopilamos',
        body: [
          'Nihongo Fun no solicita ni almacena información personal como nombres, direcciones de correo o datos de pago en sus propios servidores.',
          'Cuando visitas el sitio, tu navegador transmite automáticamente datos técnicos estándar (dirección IP, tipo de navegador, referente, páginas vistas) a los servicios enumerados más abajo. Utilizamos estos datos de forma agregada para entender cómo se usa el sitio y mejorarlo.',
        ],
      },
      {
        heading: 'Google Analytics',
        body: [
          'Usamos Google Analytics para analizar el tráfico del sitio y el comportamiento de los visitantes. Google Analytics utiliza cookies para recopilar datos de uso de forma anónima. Estos datos son procesados por Google según su propia política de privacidad.',
          'Puedes desactivar el seguimiento de Google Analytics instalando el complemento de inhabilitación (https://tools.google.com/dlpage/gaoptout).',
        ],
      },
      {
        heading: 'Google AdSense',
        body: [
          'Este sitio utiliza Google AdSense, un servicio publicitario de terceros proporcionado por Google. Google puede usar cookies o identificadores de dispositivo para mostrar anuncios basados en tus visitas anteriores a este y otros sitios web.',
          'Puedes desactivar la publicidad personalizada en la configuración de anuncios de Google (https://www.google.com/settings/ads). Para más información sobre cómo Google usa los datos, consulta su Privacidad y Condiciones (https://policies.google.com/technologies/partner-sites).',
        ],
      },
      {
        heading: 'Formulario de contacto',
        body: [
          'Nuestro formulario de contacto está alojado en Google Forms. Los mensajes enviados a través del formulario llegan al responsable del sitio. Por favor, no incluyas información personal sensible. Las condiciones de privacidad de Google se aplican a los envíos del formulario.',
        ],
      },
      {
        heading: 'Cookies',
        body: [
          'Las cookies son pequeños archivos de texto que los servicios descritos almacenan en tu dispositivo. Puedes desactivarlas o eliminarlas desde la configuración de tu navegador; algunas funciones de terceros pueden no funcionar correctamente sin ellas.',
        ],
      },
      {

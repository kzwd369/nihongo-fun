        ],
      },
      {
        heading: '政策修訂',
        body: [
          '本政策可能隨時更新。重大變更將反映在本頁，並同步更新頁首的最後更新日期。',
        ],
      },
    ],
    contactLink: { label: '對本政策有疑問？請聯絡我們', href: `/${locale}/about/#contact` },
  },
  th: {
    title: 'นโยบายความเป็นส่วนตัว — Nihongo Fun',
    desc: 'วิธีที่ Nihongo Fun จัดการคุกกี้ เครื่องมือวิเคราะห์ และโฆษณาจากบุคคลที่สาม',
    pageTitle: 'นโยบายความเป็นส่วนตัว',
    lead: 'หน้านี้อธิบายข้อมูลที่ Nihongo Fun เก็บ เหตุผลที่เก็บ และบริการของบุคคลที่สามที่เกี่ยวข้อง',
    lastUpdatedLabel: 'ปรับปรุงล่าสุด',
    sections: [
      {
        heading: 'ข้อมูลที่เราเก็บ',
        body: [
          'Nihongo Fun ไม่ขอหรือเก็บข้อมูลส่วนบุคคล เช่น ชื่อ อีเมล หรือข้อมูลการชำระเงินไว้บนเซิร์ฟเวอร์ของเราเอง',
          'เมื่อคุณเยี่ยมชมเว็บไซต์ เบราว์เซอร์ของคุณจะส่งข้อมูลเชิงเทคนิคมาตรฐาน (IP, ชนิดเบราว์เซอร์, ที่มา, หน้าที่เปิด) ให้กับบริการที่ระบุไว้ด้านล่างโดยอัตโนมัติ เราใช้ข้อมูลเหล่านี้ในรูปแบบรวมเพื่อทำความเข้าใจการใช้งานเว็บและปรับปรุงเว็บให้ดีขึ้น',
        ],
      },
      {
        heading: 'Google Analytics',
        body: [
          'เราใช้ Google Analytics เพื่อวิเคราะห์การเข้าชมและพฤติกรรมของผู้เยี่ยมชม Google Analytics ใช้คุกกี้เก็บข้อมูลการใช้งานแบบไม่ระบุตัวตน และประมวลผลโดย Google ตามนโยบายความเป็นส่วนตัวของ Google เอง',
          'หากต้องการหยุดการติดตามของ Google Analytics คุณสามารถติดตั้งส่วนขยายเบราว์เซอร์ที่ Google จัดเตรียมไว้ให้ (https://tools.google.com/dlpage/gaoptout)',
        ],
      },
      {
        heading: 'Google AdSense',
        body: [
          'เว็บไซต์นี้ใช้ Google AdSense ซึ่งเป็นบริการโฆษณาของบุคคลที่สามจาก Google โดย Google อาจใช้คุกกี้หรือรหัสอุปกรณ์เพื่อแสดงโฆษณาตามประวัติการเข้าชมของคุณที่เว็บนี้และเว็บอื่น ๆ',
          'คุณสามารถปิดโฆษณาแบบเฉพาะบุคคลได้ที่หน้าตั้งค่าโฆษณาของ Google (https://www.google.com/settings/ads) และอ่านรายละเอียดเพิ่มเติมได้ที่นโยบายความเป็นส่วนตัวของ Google (https://policies.google.com/technologies/partner-sites)',
        ],
      },
      {
        heading: 'ฟอร์มติดต่อ',
        body: [
          'ฟอร์มติดต่อของเราใช้บริการ Google Forms ข้อความที่ส่งผ่านฟอร์มจะไปถึงผู้ดูแลเว็บไซต์ กรุณาอย่ากรอกข้อมูลส่วนบุคคลที่ละเอียดอ่อน เงื่อนไขความเป็นส่วนตัวของ Google จะถูกนำมาใช้กับข้อมูลที่ส่งผ่านฟอร์มด้วย',
        ],
      },
      {
        heading: 'คุกกี้',
        body: [
          'คุกกี้คือไฟล์ข้อความขนาดเล็กที่บริการข้างต้นบันทึกไว้บนอุปกรณ์ของคุณ คุณสามารถปิดหรือลบคุกกี้ได้จากการตั้งค่าเบราว์เซอร์ แต่บางฟังก์ชันของบริการบุคคลที่สามอาจทำงานไม่สมบูรณ์',
        ],
      },
      {
        heading: 'การแก้ไขนโยบาย',
        body: [
          'นโยบายนี้อาจมีการปรับปรุงเป็นครั้งคราว การเปลี่ยนแปลงที่สำคัญจะสะท้อนอยู่ในหน้านี้ พร้อมอัปเดตวันที่ด้านบน',
        ],
      },
    ],
    contactLink: { label: 'มีคำถามเกี่ยวกับนโยบายนี้? ติดต่อเรา', href: `/${locale}/about/#contact` },
  },
};

const i = t[locale!] || t.en;
---

<BaseLayout
  title={i.title}
  description={i.desc}
  locale={locale!}
  noindex={isNoindex}
  pagePath="/privacy/"
>
  <Nav locale={locale!} />

  <article class="legal">
    <header>
      <h1>{i.pageTitle}</h1>
      <p class="meta">{i.lastUpdatedLabel}: {lastUpdated}</p>
      <p class="lead">{i.lead}</p>
    </header>

    {i.sections.map((section) => (
      <section>
        <h2>{section.heading}</h2>
        {section.body.map((p) => <p>{p}</p>)}
      </section>
    ))}

    <p class="contact-link">
      <a href={i.contactLink.href}>{i.contactLink.label} &rarr;</a>
    </p>
  </article>

  <Footer locale={locale!} />
</BaseLayout>

<style>
  .legal {
    max-width: 680px;
    margin: 0 auto;
    padding: 40px 24px 20px;
  }
  .legal header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .legal h1 {
    font-size: 32px;
    font-weight: 900;
    margin-bottom: 8px;
    letter-spacing: -0.3px;
  }
  .meta {
    font-size: 13px;
    color: var(--text-light);
    margin-bottom: 16px;
  }
  .lead {
    font-size: 16px;
    color: var(--text-light);
    line-height: 1.65;
  }
  .legal section {
    margin-bottom: 32px;
  }
  .legal h2 {
    font-size: 19px;
    font-weight: 800;
    margin-bottom: 12px;
    color: var(--text);
  }
  .legal p {
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 10px;
    color: var(--text);
  }
  .contact-link {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 15px;
    text-align: center;
  }
  .contact-link a {
    font-weight: 600;
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .legal h1 { font-size: 26px; }
    .legal h2 { font-size: 17px; }
  }
</style>

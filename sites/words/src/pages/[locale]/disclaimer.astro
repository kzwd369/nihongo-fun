        body: [
          'We may update this notice from time to time. The date at the top reflects the most recent revision.',
        ],
      },
    ],
    contactLink: { label: 'Questions or a correction? Contact us', href: `/${locale}/about/#contact` },
  },
  es: {
    title: 'Aviso legal — Nihongo Fun',
    desc: 'Notas sobre exactitud, enlaces externos y derechos de autor del contenido de Nihongo Fun.',
    pageTitle: 'Aviso legal',
    lead: 'Unas notas honestas sobre cómo escribimos, qué podemos y qué no podemos garantizar, y cómo manejamos el contenido ajeno.',
    lastUpdatedLabel: 'Última actualización',
    sections: [

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';

const illustrations = import.meta.glob('../../../components/illustrations/*.astro', { eager: true });

function getIllustration(slug: string) {
  const capitalize = slug.charAt(0).toUpperCase() + slug.slice(1);
  const key = `../../../components/illustrations/${capitalize}Ono.astro`;
  const mod = illustrations[key] as { default: any } | undefined;
  return mod?.default;
}

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'es' } },
    { params: { locale: 'zh-tw' } },
  ];
}

const { locale } = Astro.params;
const isNoindex = locale === 'en';

const allEntries = await getCollection('onomatopoeia');
const entries = allEntries
  .filter(e => e.data.locale === locale && !e.data.draft)
  .sort((a, b) => a.data.slug.localeCompare(b.data.slug));

const labels: Record<string, Record<string, string>> = {
  en: { title: 'Onomatopoeia — Japanese Sound Words', subtitle: 'Expressive words that mimic sounds, feelings, and textures — a uniquely rich part of Japanese.', home: 'Home' },
  es: { title: 'Onomatopeyas — Palabras de sonido japonesas', subtitle: 'Palabras expresivas que imitan sonidos, sentimientos y texturas — una parte única del japonés.', home: 'Inicio' },
  'zh-tw': { title: '擬聲擬態詞 — 日語的聲音詞彙', subtitle: '模仿聲音、感覺和質感的表達詞彙 — 日語中獨特而豐富的一部分。', home: '首頁' },
};
const t = labels[locale!] || labels.en;

const typeLabels: Record<string, Record<string, string>> = {
  en: { giongo: 'Sound', giseigo: 'Voice', gitaigo: 'State', giyougo: 'Action', gijougo: 'Emotion' },
  es: { giongo: 'Sonido', giseigo: 'Voz', gitaigo: 'Estado', giyougo: 'Acción', gijougo: 'Emoción' },
  'zh-tw': { giongo: '聲音', giseigo: '聲響', gitaigo: '狀態', giyougo: '動作', gijougo: '情感' },
};
const tType = typeLabels[locale!] || typeLabels.en;

// Type → gradient color map
const typeColors: Record<string, { bg: string; badge: string; text: string }> = {
  giongo:  { bg: 'linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%)', badge: 'linear-gradient(135deg, #ff9800, #f57c00)', text: '#e65100' },
  giseigo: { bg: 'linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%)', badge: 'linear-gradient(135deg, #e91e63, #c2185b)', text: '#880e4f' },
  gitaigo: { bg: 'linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%)', badge: 'linear-gradient(135deg, #5c6bc0, #3949ab)', text: '#1a237e' },
  giyougo: { bg: 'linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%)', badge: 'linear-gradient(135deg, #00bcd4, #0097a7)', text: '#006064' },
  gijougo: { bg: 'linear-gradient(135deg, #fce4ec 0%, #f3e5f5 100%)', badge: 'linear-gradient(135deg, #e91e63, #9c27b0)', text: '#880e4f' },
};
---

<BaseLayout
  title={`${t.title} | Nihongo Fun`}
  description={t.subtitle}
  locale={locale!}
  noindex={isNoindex}
  pagePath="/onomatopoeia/"
>
  <Nav locale={locale!} />

  <main class="pillar">
    <div class="pillar-hero">
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </div>

    <div class="word-grid">
      {entries.map(entry => {
        const Illust = getIllustration(entry.data.slug);
        const colors = typeColors[entry.data.type] || typeColors.giongo;
        return (
          <a href={`/${locale}/onomatopoeia/${entry.data.slug}/`} class="word-card" style={`--card-bg: ${colors.bg}; --type-badge: ${colors.badge}; --type-text: ${colors.text};`}>
            <div class="card-layout">
              {Illust && (
                <div class="card-icon">
                  <Illust />
                </div>
              )}
              <div class="card-text">
                <div class="word-jp">{entry.data.japanese}</div>
                <div class="word-romaji">{entry.data.romaji}</div>
                <div class="word-meaning">{entry.data.meaning}</div>
                <span class="word-type">{tType[entry.data.type]}</span>
              </div>
            </div>
            {entry.data.jlpt && <span class="word-jlpt">{entry.data.jlpt}</span>}
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style>
  .pillar {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .pillar-hero {
    text-align: center;
    padding: 48px 0 32px;
  }
  .pillar-hero h1 {
    font-size: 28px;
    font-weight: 800;
  }
  .pillar-hero p {
    color: var(--text-light);
    margin-top: 8px;
    font-size: 16px;
  }
  .word-grid {
    display: grid;
    gap: 16px;
    padding-bottom: 60px;
  }
  .word-card {
    background: var(--card-bg);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 24px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .word-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    text-decoration: none;
  }
  .card-layout {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .card-icon {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 16px;
    background: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .card-icon :global(svg) {
    width: 72px;
    height: 58px;
    border-radius: 8px;
  }
  .card-text {
    flex: 1;
    min-width: 0;
  }
  .word-jp {
    font-family: var(--jp-font);
    font-size: 26px;
    font-weight: 700;
  }
  .word-romaji {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 2px;
  }
  .word-meaning {
    margin-top: 8px;
    font-size: 14px;
    color: var(--text);
    line-height: 1.4;
  }
  .word-type {
    display: inline-block;
    margin-top: 8px;
    background: var(--type-badge);
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.5px;
  }
  .word-jlpt {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(255,255,255,0.7);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    color: var(--text-light);
    font-weight: 600;
    backdrop-filter: blur(4px);
  }
  @media (max-width: 600px) {
    .card-icon {
      width: 64px;
      height: 64px;
    }
    .card-icon :global(svg) {
      width: 56px;
      height: 45px;
    }
    .word-jp { font-size: 22px; }
  }
</style>

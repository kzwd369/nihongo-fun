---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroCard from '../../../components/HeroCard.astro';
import ExampleSentence from '../../../components/ExampleSentence.astro';
import AnimeCallout from '../../../components/AnimeCallout.astro';
import RelatedWords from '../../../components/RelatedWords.astro';

// Illustration components
const illustrations = import.meta.glob('../../../components/illustrations/*.astro', { eager: true });

function getIllustration(slug: string) {
  const capitalize = slug.charAt(0).toUpperCase() + slug.slice(1);
  const key = `../../../components/illustrations/${capitalize}Ono.astro`;
  const mod = illustrations[key] as { default: any } | undefined;
  return mod?.default;
}

export async function getStaticPaths() {
  const entries = await getCollection('onomatopoeia');
  return entries.map(entry => ({
    params: { locale: entry.data.locale, slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const locale = data.locale;

// Resolve related words to real data
const allEntries = await getCollection('onomatopoeia');
const localeEntries = allEntries.filter(e => e.data.locale === locale);
const resolvedRelated = data.relatedWords
  .map(slug => localeEntries.find(e => e.data.slug === slug))
  .filter(Boolean)
  .map(e => ({
    slug: e!.data.slug,
    japanese: e!.data.japanese,
    label: e!.data.meaning,
  }));

const HeroSVG = getIllustration(data.slug);
const isNoindex = locale === 'en';

// i18n labels
const labels: Record<string, Record<string, string>> = {
  en: { home: 'Home', onomatopoeia: 'Onomatopoeia', examples: 'Examples', anime: 'In Anime', related: 'Related Onomatopoeia', meaning: 'Meaning', type: 'Type', listenPron: 'Listen' },
  es: { home: 'Inicio', onomatopoeia: 'Onomatopeyas', examples: 'Ejemplos', anime: 'En el Anime', related: 'Onomatopeyas Relacionadas', meaning: 'Significado', type: 'Tipo', listenPron: 'Escuchar' },
  'zh-tw': { home: '首頁', onomatopoeia: '擬聲擬態詞', examples: '例句', anime: '動漫裡的用法', related: '相關擬聲擬態詞', meaning: '意思', type: '類型', listenPron: '聆聽' },
};
const t = labels[locale] || labels.en;

const typeLabels: Record<string, Record<string, string>> = {
  en: { giongo: 'Giongo — Actual sounds', giseigo: 'Giseigo — Voiced sounds', gitaigo: 'Gitaigo — States & textures', giyougo: 'Giyougo — Manner of action', gijougo: 'Gijougo — Emotions & feelings' },
  es: { giongo: 'Giongo — Sonidos reales', giseigo: 'Giseigo — Sonidos de voz', gitaigo: 'Gitaigo — Estados y texturas', giyougo: 'Giyougo — Manera de actuar', gijougo: 'Gijougo — Emociones y sentimientos' },
  'zh-tw': { giongo: '擬音語 — 實際聲音', giseigo: '擬聲語 — 模仿聲響', gitaigo: '擬態語 — 狀態與質感', giyougo: '擬容語 — 動作方式', gijougo: '擬情語 — 情緒與感受' },
};
const tTypeLabel = typeLabels[locale] || typeLabels.en;

// Type → color theme
const typeThemes: Record<string, { accent: string; light: string; gradient: string }> = {
  giongo:  { accent: '#f57c00', light: '#fff3e0', gradient: 'linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%)' },
  giseigo: { accent: '#e91e63', light: '#fce4ec', gradient: 'linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%)' },
  gitaigo: { accent: '#5c6bc0', light: '#e8eaf6', gradient: 'linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%)' },
  giyougo: { accent: '#00897b', light: '#e0f2f1', gradient: 'linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%)' },
  gijougo: { accent: '#d81b60', light: '#fce4ec', gradient: 'linear-gradient(135deg, #fce4ec 0%, #f3e5f5 100%)' },
};
const theme = typeThemes[data.type] || typeThemes.giongo;

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      name: data.japanese,
      alternateName: data.romaji,
      description: data.metaDescription,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'Japanese Onomatopoeia (オノマトペ)',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t.home, item: `https://nihongo-fun.com/${locale}/` },
        { '@type': 'ListItem', position: 2, name: t.onomatopoeia, item: `https://nihongo-fun.com/${locale}/onomatopoeia/` },
        { '@type': 'ListItem', position: 3, name: data.japanese },
      ],
    },
  ],
};

const breadcrumbs = [
  { label: t.home, href: `/${locale}/` },
  { label: t.onomatopoeia, href: `/${locale}/onomatopoeia/` },
  { label: data.category },
  { label: data.japanese },
];
---

<BaseLayout
  title={`${data.japanese} (${data.romaji}) — ${t.onomatopoeia} | Nihongo Fun`}
  description={data.metaDescription}
  locale={locale}
  noindex={isNoindex}
  jsonLd={jsonLd}
  pagePath={`/onomatopoeia/${data.slug}/`}
>
  <Nav locale={locale} />
  <Breadcrumb items={breadcrumbs} />

  <HeroCard
    japanese={data.japanese}
    romaji={data.romaji}
    category={data.category}
    collectionLabel={t.onomatopoeia}
    jlpt={data.jlpt}
  >
    {HeroSVG && <HeroSVG slot="hero-svg" />}

    <!-- Meta -->
    <div class="meta-panel" style={`--theme-gradient: ${theme.gradient}; --theme-accent: ${theme.accent}; --theme-light: ${theme.light};`}>
      <div class="meta-grid">
        <div class="meta-item">
          <div class="meta-label">{t.meaning}</div>
          <div class="meta-value">{data.meaning}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">{t.type}</div>
          <div class="type-badge">{tTypeLabel[data.type]}</div>
        </div>
      </div>
    </div>

    <!-- Audio button -->
    <div class="ono-audio-row">
      <button class="ono-audio-btn" data-word={data.japanese}>
        <div class="play-icon">
          <svg width="14" height="16" viewBox="0 0 14 16" fill="none">
            <path d="M1 1.5L13 8L1 14.5V1.5Z" fill="white" class="play-path"/>
          </svg>
        </div>
        <div class="ono-audio-info">
          <div class="ono-audio-lang">🇯🇵 {t.listenPron}</div>
          <div class="ono-audio-word">{data.japanese}</div>
          <div class="ono-audio-phonetic">{data.romaji}</div>
        </div>
        <div class="wave-bars">
          <div class="wave-bar" style="height:6px"></div>
          <div class="wave-bar" style="height:12px"></div>
          <div class="wave-bar" style="height:8px"></div>
          <div class="wave-bar" style="height:14px"></div>
          <div class="wave-bar" style="height:5px"></div>
        </div>
      </button>
    </div>
  </HeroCard>

  <!-- Main content from markdown -->
  <div class="content" style={`--theme-accent: ${theme.accent}; --theme-light: ${theme.light};`}>
    <div class="content-card content-card--prose prose">
      <Content />
    </div>

    <!-- Examples -->
    {data.examples.length > 0 && (
      <div class="content-card">
        <h2>{t.examples}</h2>
        {data.examples.map(ex => (
          <ExampleSentence
            japanese={ex.japanese}
            reading={ex.reading}
            translation={ex.translation}
          />
        ))}
      </div>
    )}

    <!-- Anime appearances -->
    {data.animeAppearances.length > 0 && (
      <div class="content-card">
        <h2>{t.anime}</h2>
        {data.animeAppearances.map(a => (
          <AnimeCallout title={a.title} description={a.description} />
        ))}
      </div>
    )}

    <!-- Related words -->
    {data.relatedWords.length > 0 && (
      <div class="content-card">
        <h2>{t.related}</h2>
        <RelatedWords
          words={resolvedRelated}
          locale={locale}
          collection="onomatopoeia"
        />
      </div>
    )}
  </div>

  <footer>
    <p>Nihongo Fun — <a href={`/${locale}/`}>{t.home}</a></p>
  </footer>
</BaseLayout>

<script>
  function initOnoAudio() {
    document.querySelectorAll<HTMLButtonElement>('.ono-audio-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const word = btn.dataset.word || '';
        const wasPlaying = btn.classList.contains('playing');

        document.querySelectorAll('.ono-audio-btn').forEach(b => {
          b.classList.remove('playing');
          const path = b.querySelector('.play-path');
          if (path) path.setAttribute('d', 'M1 1.5L13 8L1 14.5V1.5Z');
        });

        if (!wasPlaying && 'speechSynthesis' in window) {
          const utterance = new SpeechSynthesisUtterance(word);
          utterance.lang = 'ja-JP';
          utterance.rate = 0.85;

          btn.classList.add('playing');
          const path = btn.querySelector('.play-path');
          if (path) path.setAttribute('d', 'M2 1H5V15H2V1ZM9 1H12V15H9V1Z');

          utterance.onend = () => {
            btn.classList.remove('playing');
            if (path) path.setAttribute('d', 'M1 1.5L13 8L1 14.5V1.5Z');
          };

          window.speechSynthesis.cancel();
          window.speechSynthesis.speak(utterance);
        }
      });
    });
  }
  initOnoAudio();
</script>

<style>
  .meta-panel {
    background: var(--theme-gradient);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .meta-item { font-size: 14px; }
  .meta-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-light);
    margin-bottom: 4px;
  }
  .meta-value {
    font-weight: 600;
  }
  .type-badge {
    display: inline-block;
    background: var(--theme-accent);
    color: #fff;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
  }
  .ono-audio-row {
    margin-bottom: 16px;
  }
  .ono-audio-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    color: var(--text);
  }
  .ono-audio-btn:hover { border-color: var(--accent); background: var(--accent-light); }
  .ono-audio-btn.playing { border-color: var(--accent); background: var(--accent-light); }
  .ono-audio-btn .play-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: transform 0.15s;
  }
  .ono-audio-btn:hover .play-icon { transform: scale(1.08); }
  .ono-audio-btn.playing .play-icon { background: #c62828; }
  .ono-audio-info { flex: 1; text-align: left; }
  .ono-audio-lang { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-light); }
  .ono-audio-word { font-size: 16px; font-weight: 700; margin-top: 1px; }
  .ono-audio-phonetic { font-size: 12px; color: var(--text-light); margin-top: 1px; }
  .ono-audio-btn .wave-bars { display: flex; align-items: center; gap: 2px; height: 20px; }
  .ono-audio-btn .wave-bar { width: 3px; background: var(--accent); border-radius: 2px; opacity: 0.3; }
  .ono-audio-btn.playing .wave-bar { opacity: 1; animation: wave 0.6s ease-in-out infinite alternate; }
  .ono-audio-btn.playing .wave-bar:nth-child(1) { animation-delay: 0s; }
  .ono-audio-btn.playing .wave-bar:nth-child(2) { animation-delay: 0.1s; }
  .ono-audio-btn.playing .wave-bar:nth-child(3) { animation-delay: 0.2s; }
  .ono-audio-btn.playing .wave-bar:nth-child(4) { animation-delay: 0.15s; }
  .ono-audio-btn.playing .wave-bar:nth-child(5) { animation-delay: 0.05s; }
  @keyframes wave { from { height: 4px; } to { height: 18px; } }
  .content {
    max-width: 720px;
    margin: 24px auto;
    padding: 0 24px;
  }
  .content-card {
    background: var(--card);
    border-radius: 16px;
    border: 1px solid var(--border);
    padding: 32px;
    margin-bottom: 20px;
  }
  .content-card--prose {
    border-top: 3px solid var(--theme-accent);
  }
  .content-card h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--theme-accent, var(--accent));
    display: inline-block;
  }
  .prose :global(h2) {
    font-size: 20px;
    font-weight: 700;
    margin: 24px 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--theme-accent, var(--accent));
    display: inline-block;
    color: var(--theme-accent, var(--text));
  }
  .prose :global(p) {
    margin-bottom: 16px;
    font-size: 16px;
  }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .prose :global(li) {
    margin-bottom: 8px;
  }
  .prose :global(strong) {
    font-weight: 700;
  }
  footer {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 24px;
    text-align: center;
    font-size: 13px;
    color: var(--text-light);
  }
  @media (max-width: 600px) {
    .meta-grid { grid-template-columns: 1fr; }
    .content-card { padding: 20px; }
  }
</style>
